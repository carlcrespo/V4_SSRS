    <DataSet Name="Accounting_Treatment_TypeDS">
      <Query>
        <DataSourceName>Insight</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CultureID">
            <Value>en-US</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        AccountingTreatmentTypeID, AccountingTreatmentTypeName
FROM            (SELECT        NULL AS AccountingTreatmentTypeID, NULL AS AccountingTreatmentTypeName
                          UNION ALL
                          SELECT        Lease_AccountingTreatmentType_Cnfg.AccountingTreatmentTypeID, Lease_AccountingTreatmentType_CnfgLocale.AccountingTreatmentTypeName
                          FROM            Lease_AccountingTreatmentType_Cnfg INNER JOIN
                                                   Lease_AccountingTreatmentType_CnfgLocale ON 
                                                   Lease_AccountingTreatmentType_Cnfg.AccountingTreatmentTypeID = Lease_AccountingTreatmentType_CnfgLocale.AccountingTreatmentTypeID AND 
                                                   Lease_AccountingTreatmentType_Cnfg.IsActive = 1
                          WHERE        (Lease_AccountingTreatmentType_CnfgLocale.CultureID = @CultureID)) AS RS1
ORDER BY AccountingTreatmentTypeName</CommandText>
      </Query>
      <Fields>
        <Field Name="AccountingTreatmentTypeID">
          <DataField>AccountingTreatmentTypeID</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
        <Field Name="AccountingTreatmentTypeName">
          <DataField>AccountingTreatmentTypeName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
