  <DataSets>
    <DataSet Name="Future_Minimum_Lease_Payment_Report_DS">
      <Query>
        <DataSourceName>Insight</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AsofDate">
            <Value>=Parameters!AsofDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CSLAccountingTreatmentTypeId">
            <Value>=Join(Parameters!CSLAccountingTreatmentTypeId.Value, ",")</Value>
          </QueryParameter>
          <QueryParameter Name="@CultureID">
            <Value>=Parameters!CultureID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>EXEC IIC_FutureMinimumLeasePaymentReport @AsofDate, @CSLAccountingTreatmentTypeId, @CultureID </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="LeaseSequenceNumber">
          <DataField>LeaseSequenceNumber</DataField>
