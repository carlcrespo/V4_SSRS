  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AccountNumber">
            <Value>=Parameters!AccountNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PONumber">
            <Value>=Parameters!PONumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ConvertedtoReal">
            <Value>=Parameters!ConvertedtoReal.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--------------------------------------------------------------------------------------------------
-- CHANGE LOG:
--	#0001 - 2021-07-15 - Update Currency field
--------------------------------------------------------------------------------------------------     

-- 20191022
-- Build 20180501 (report logic)

/*
Paramenters:
1. Account Number or Null
2. PONumber or Null
3. Convert to Real status = 'NeedToVerify' or 'Yes' or 'Null'. 
*/
-----------------------------------------------------
-- Test code
--DECLARE @AccountNumber varchar(20) = 'PNC010' 
--              ,@PONumber varchar(50) = '' -- '4500279726'
--              ,@ConvertedtoReal VARCHAR(20) = ''
-----------------------------------------------------

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SET NOCOUNT ON

;
WITH
cte_rpt
AS
(
       SELECT	E.AccountNumber
				,E.CustomerName
				,F.SequenceNumber
				,C.PayOffQuoteID
				,IsNull(G.InvoiceNumber,'') PayoffInvoiceNumber
				,IsNull(H.PONumber,'') PONumber
				,IIF (g.InvoiceNumber is null,'NeedToVerify','Yes') ConvertedtoReal
				,CONVERT(Date,a.[DueDate])DueDate
				,L.Symbol																			-- #00001						
				,L.ISO		
				,fs.FundingSourceId
				,fs.FundingSourceNumber
				,fs.Company
				,fs.Alias														-- #00001
				,[QuoteAmount]
				,[TaxAmount]
				,D.Description PayoffType
                ,I.InternalComment
          FROM [dbo].[Payoff_QuoteInvoiceHeader] A    ---This table has all PO invoices irrespective of convert to real status and/or payoff status. 
         INNER JOIN [dbo].[Payoff_QuoteInvoiceLeaseDetail] B  --- Join A with B in order to get the PayoffQuoteID to join with C
			ON A.PayOffQuoteInvoiceID=B.PayOffQuoteInvoiceID
         INNER JOIN [dbo].[Payoff_Quote] C      
			ON B.PayOffQuoteID = C.PayOffQuoteID
		   AND C.QuoteStatusID = 4 --activated
         INNER JOIN [dbo].[Payoff_TransactionType_Cnfg] D
			ON C.PayoffTransactionTypeID = D.PayoffTransactionTypeID
         INNER JOIN [dbo].[Customer_Profile] E
			ON A.CustomerID=E.CustomerID
         INNER JOIN [dbo].[Lease_Profile] F
			ON C.leaseid=F.leaseid
          LEFT JOIN
			   (
				   SELECT [InvoiceID]
						  ,[InvoiceBatchID]
						  ,IH.[InvoiceNumberID]
						  ,INV.InvoiceNumber
						  ,[DueDate]
						  ,[OriginalMemoBalance]
						  ,[OriginalNonMemoBalance]
						  ,[OutstandingMemoBalance]
						  ,[OutstandingNonMemoBalance]
				     FROM [dbo].[Invoice_Header] IH
				    INNER JOIN [dbo].[Invoice_Number] INV
					   ON ih.InvoiceNumberID=inv.InvoiceNumberID
			   ) G
			ON G.invoicenumberid = A.invoicenumberid
		 INNER JOIN [dbo].[Payoff_FinancialDetail] H
            ON B.PayOffQuoteID=H.PayOffQuoteID
		 INNER JOIN [dbo].[Payoff_BillingDetail] I
            ON B.PayOffQuoteID=I.PayOffQuoteID
		  LEFT JOIN LLC_Profile J														-- #00001
		    ON F.LLCID = J.LLCID 
		  LEFT JOIN Currency_Index K													-- #00001
		    ON K.CurrencyIndexID = J.CurrencyIndexID  
		  LEFT JOIN Currency_Symbol_Cnfg L												-- #00001	
		    ON K.CurrencySymbolID = L.SymbolId 
		  LEFT JOIN FundingSource_Profile fs
			ON F.LabellingLessorID = fs.FundingSourceID
			AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label

         WHERE A.InvoiceStatusID=1 --active
           AND A.QuoteAmount &gt;0
)
,

cte_filter
AS
       (
       SELECT DISTINCT 
              AccountNumber,PONumber,ConvertedtoReal
         FROM cte_rpt
        WHERE AccountNumber LIKE IIF(@AccountNumber is NULL OR @AccountNumber ='','%',@AccountNumber)
       INTERSECT 
       SELECT DISTINCT 
              AccountNumber,PONumber,ConvertedtoReal
         FROM cte_rpt
        WHERE PONumber LIKE IIF(@PONumber IS NULL OR @PONumber ='','%',@PONumber)
       INTERSECT 
       SELECT DISTINCT 
              AccountNumber,PONumber,ConvertedtoReal
         FROM cte_rpt
        WHERE ConvertedtoReal LIKE IIF(@ConvertedtoReal IS NULL OR @ConvertedtoReal ='','%',@ConvertedtoReal)

       )



SELECT 
        cte_rpt.AccountNumber
        ,cte_rpt.CustomerName
        ,cte_rpt.SequenceNumber
        ,cte_rpt.PayOffQuoteID
        ,cte_rpt.PayoffInvoiceNumber
        ,cte_rpt.PONumber
        ,cte_rpt.ConvertedtoReal
        ,FORMAT(cte_rpt.DueDate,'yyy-MM-dd') DueDate
		,cte_rpt.Symbol																	-- #00001
		,cte_rpt.ISO
		,cte_rpt.FundingSourceId
        ,cte_rpt.FundingSourceNumber
        ,cte_rpt.Company	
		,cte_rpt.Alias													-- #00001
        ,cte_rpt.QuoteAmount
        ,cte_rpt.TaxAmount
        ,cte_rpt.PayoffType
        ,cte_rpt.InternalComment
  FROM cte_rpt
 INNER JOIN cte_filter
    ON cte_rpt.AccountNumber = cte_filter.AccountNumber
   AND cte_rpt.ConvertedtoReal = cte_filter.ConvertedtoReal
   AND cte_rpt.PONumber = cte_filter.PONumber

    

 WHERE NOT(@AccountNumber = '' AND @PONumber = '' AND @ConvertedtoReal = '')
		OR (@AccountNumber IS NULL AND @PONumber IS NULL AND @ConvertedtoReal IS NULL)
 UNION
SELECT 'Enter Account Number or select NULL' AccountNumber
        ,'' CustomerName
        ,'' SequenceNumber
        ,0 PayOffQuoteID
        ,'' PayoffInvoiceNumber
        ,'Enter PO Number or select NULL' PONumber
        ,'Enter "YES" or "NEEDTOVERIFY" or select NULL' ConvertedtoReal
        ,'' DueDate
		,'' Symbol																			-- #00001
		,'' ISO	
		,'' FundingSourceId
        ,'' FundingSourceNumber
        ,'' Company		
		,'' Alias													-- #00001
        ,0 QuoteAmount
        ,0 TaxAmount
        ,'' PayoffType
        ,'' InternalComment
 FROM cte_rpt


WHERE @AccountNumber = '' AND @PONumber = '' AND @ConvertedtoReal = ''
ORDER BY 
      cte_rpt.AccountNumber
     ,FORMAT(cte_rpt.DueDate,'yyy-MM-dd')    
   
SET NOCOUNT OFF;
    </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
