        <CommandText>--USE [LW_PROD]
--GO
--/****** Object:  UserDefinedFunction [dbo].[f_PropertyTaxBillNumber_20160426]    Script Date: 2/27/2019 9:17:13 AM ******/
--SET ANSI_NULLS ON
--GO
--SET QUOTED_IDENTIFIER ON
--GO
---- =============================================
---- Author:		Carl Crespo
---- Create date: 2016-04-20
---- Description:	Property Tax Bill Number Report
---- =============================================
--ALTER FUNCTION [dbo].[f_PropertyTaxBillNumber_20160426]
--(	
--@Date1 Date, @Date2 Date
--)
--RETURNS TABLE 
--AS
--RETURN 
--(
-----------------------------------------------------
---- Test Code
--Declare @Date1 Date, @Date2 Date
--Set @Date1 = '1/1/2019'
--Set @Date2 = '1/31/2019'
-----------------------------------------------------
 --Select * From f_PropertyTaxBillNumber_20160420('1/1/2013','4/1/2016')
-------------------------------------------------------
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED 

;
WITH
cte_LabelingLessor
AS
(
SELECT lp.LeaseID
      ,lp.CustomerID
      ,lp.SequenceNumber
	  ,fp.FundingSourceNumber --LabellingLessor
	  ,fp.Company AS LabellingLessor
  FROM Lease_Profile lp
  INNER JOIN FundingSource_Profile fp
	ON fp.FundingSourceId = lp.LabellingLessorID
)
Select Top 100 Percent  
		 r.LeaseID
		,r.JournalID 
		,r.SequenceNumber
		,r.AccountNumber
		,r.CustomerName
		,r.PropertyTaxAmount 
		,r.[Property Tax Bill Number]
		,r.ReportingYear
		,r.LabellingLessor LabelingLessor
		,r.PostDate
		,r.Reversed
		,r.ReversalJournalID
From
(
		Select   tax.LeaseID
				,tax.JournalID 
				--,e.LeaseSequenceNumber SequenceNumber
				,lp.SequenceNumber
				--,e.CustomerAccountNumber AccountNumber
				,cp.AccountNumber
				--,e.CustomerName
				,cp.CustomerName
				,tax.PropertyTaxAmount * (-1) AS PropertyTaxAmount
				,tax.[Property Tax Bill Number]
				,tax.ReportingYear
				--,e.LabellingLessorName LabelingLessor
				,ll.LabellingLessor 
				--,Coalesce(Format(e.PostDate,'yyyy-MM-dd'),'') PostDate
				,FORMAT(gl.SysPostDateAndTime,'yyyy-MM-dd') PostDate
				,tax.Reversed
				,tax.ReversalJournalID
		From
		(
			SELECT   t.[LeaseID]
					,t.JournalID
					,Sum(t.Amount) PropertyTaxAmount 
					,t.BillNumber [Property Tax Bill Number]
					,t.ReportingYear
					,'No' Reversed
					,t.ReversalJournalID
			  FROM PropertyTax_Assessment t 
			  Where t.ReversalJournalID is NULL  
		Group By	t.LeaseID
				  ,t.BillNumber
				  ,t.ReportingYear
				  ,t.JournalID
				  ,t.ReversalJournalID
		) tax
			INNER JOIN [GeneralLedger_Journal] gl
				On tax.JournalID = gl.JournalID
				AND Cast(gl.SysPostDateAndTime AS DATE) Between @Date1 And @Date2
			INNER JOIN Lease_Profile lp
				ON tax.LeaseID = lp.LeaseID
			INNER JOIN dbo.Customer_Profile cp
				ON cp.CustomerID = lp.CustomerID
			INNER JOIN cte_LabelingLessor ll
				ON tax.LeaseID = ll.LeaseID
			---------------------------------------------------------------
			--Left Join GeneralLedger_Entries e
			--	On tax.JournalID = e.JournalID and tax.LeaseID = e.LeaseID
			--WHERE CONVERT(DATE,e.PostDate) BETWEEN @Date1 AND @Date2
		UNION
		Select   tax.LeaseID
				,tax.JournalID 
				--,e.LeaseSequenceNumber SequenceNumber
				,lp.SequenceNumber
				--,e.CustomerAccountNumber AccountNumber
				,cp.AccountNumber
				--,e.CustomerName
				,cp.CustomerName
				,tax.PropertyTaxAmount  AS PropertyTaxAmount
				,tax.[Property Tax Bill Number]
				,tax.ReportingYear
				--,e.LabellingLessorName LabelingLessor
				,ll.LabellingLessor 
				--,Coalesce(Format(tax.PostDate,'yyyy-MM-dd'),'') PostDate
				,FORMAT(gl.SysPostDateAndTime,'yyyy-MM-dd') PostDate
				,tax.Reversed
				,tax.ReversalJournalID
		From
		(
			SELECT   t.[LeaseID]
					,t.ReversalJournalID JournalID
					,Sum(t.Amount) PropertyTaxAmount 
					,t.BillNumber [Property Tax Bill Number]
					,t.ReportingYear
					,t.ReversalPostDate PostDate
					, 'Yes' Reversed
					,t.ReversalJournalID
			  FROM PropertyTax_Assessment t 
			  Where t.ReversalJournalID is NOT NULL  
			Group By   t.LeaseID
					  ,t.BillNumber
					  ,t.ReportingYear
					  ,t.JournalID
					  ,t.ReversalJournalID
					  ,t.ReversalPostDate 
		) tax
			-------------------------------------------------------------------------------------------------------
			INNER JOIN [GeneralLedger_Journal] gl
				On tax.JournalID = gl.JournalID
				AND Cast(gl.SysPostDateAndTime AS DATE) Between @Date1 And @Date2
			INNER JOIN Lease_Profile lp
				ON tax.LeaseID = lp.LeaseID
			INNER JOIN dbo.Customer_Profile cp
				ON cp.CustomerID = lp.CustomerID
			INNER JOIN cte_LabelingLessor ll
				ON tax.LeaseID = ll.LeaseID
			-------------------------------------------------------------------------------------------------------
			--Left Join  GeneralLedger_Entries e
			--	On tax.JournalID = e.JournalID and tax.LeaseID = e.LeaseID
			--WHERE CONVERT(DATE,tax.PostDate) BETWEEN @Date1 AND @Date2
) r
--Where	Cast(r.PostDate AS DATE) Between @Date1 And @Date2
WHERE r.PropertyTaxAmount != 0.00
Order By r.PostDate
		,r.[Property Tax Bill Number]
		,r.AccountNumber
		,r.SequenceNumber
--)</CommandText>
      </Query>
      <Fields>
        <Field Name="LeaseID">
          <DataField>LeaseID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="JournalID">
          <DataField>JournalID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PropertyTaxAmount">
          <DataField>PropertyTaxAmount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Property_Tax_Bill_Number">
          <DataField>Property Tax Bill Number</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReportingYear">
          <DataField>ReportingYear</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="LabelingLessor">
          <DataField>LabelingLessor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PostDate">
          <DataField>PostDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Reversed">
          <DataField>Reversed</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReversalJournalID">
          <DataField>ReversalJournalID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Date1">
            <Value>=Parameters!Date1.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Date2">
            <Value>=Parameters!Date2.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 201903189
-- Property Tax Bill Number Report
-- Work Order #31892

-----------------------------------------------------
---- Test Code
--Declare @Date1 Date, @Date2 Date
--Set @Date1 = '2/1/2019'
--Set @Date2 = '2/28/2019'
-----------------------------------------------------
 --Select * From f_PropertyTaxBillNumber_20160420('1/1/2013','4/1/2016')
-------------------------------------------------------
-- test code
--SELECT leaseID,Collector,* FROM dbo.PropertyTax_Assessment where leaseid=2011 AND  ReversalJournalID is NULL
--SELECT sequencenumber FROM lease_profile WHERE leaseid=2011
-------------------------------------------------------
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED 

;
WITH
cte_LabelingLessor
AS
(
SELECT lp.LeaseID
      ,lp.CustomerID
      ,lp.SequenceNumber
	  ,fp.FundingSourceNumber --LabellingLessor
	  ,fp.Company AS LabellingLessor
  FROM Lease_Profile lp
  INNER JOIN FundingSource_Profile fp
	ON fp.FundingSourceId = lp.LabellingLessorID
)
Select Top 100 Percent  
		 r.LeaseID
		,r.JournalID 
		,r.SequenceNumber
		,r.AccountNumber
		,r.CustomerName
		,r.PropertyTaxAmount 
		,r.[Property Tax Bill Number]
		,r.ReportingYear
		,r.LabellingLessor LabelingLessor
		,r.PostDate
		,r.Reversed
		,r.ReversalJournalID
		,r.TaxDistrict

From
(
		Select   tax.LeaseID
				,tax.JournalID 
				--,e.LeaseSequenceNumber SequenceNumber
				,lp.SequenceNumber
				--,e.CustomerAccountNumber AccountNumber
				,cp.AccountNumber
				--,e.CustomerName
				,cp.CustomerName
				,tax.PropertyTaxAmount * (-1) AS PropertyTaxAmount
				,tax.[Property Tax Bill Number]
				,tax.ReportingYear
				--,e.LabellingLessorName LabelingLessor
				,ll.LabellingLessor 
				--,Coalesce(Format(e.PostDate,'yyyy-MM-dd'),'') PostDate
				,FORMAT(gl.SysPostDateAndTime,'yyyy-MM-dd') PostDate
				,tax.Reversed
				,tax.ReversalJournalID
				, tax.TaxDistrict
		From
		(
			SELECT   t.[LeaseID]
					,t.JournalID
					,Sum(t.Amount) PropertyTaxAmount 
					,t.BillNumber [Property Tax Bill Number]
					,t.ReportingYear
					,'No' Reversed
					,t.ReversalJournalID
					--------------------
					-- 20190315
					,t.TaxDistrict
					--------------------
			  FROM PropertyTax_Assessment t 
			  Where t.ReversalJournalID is NULL  
		Group By	t.LeaseID
				  ,t.BillNumber
				  ,t.ReportingYear
				  ,t.JournalID
				  ,t.ReversalJournalID
				  --------------------
					-- 20190315
					,t.TaxDistrict
					--------------------
		) tax
			INNER JOIN [GeneralLedger_Journal] gl
				On tax.JournalID = gl.JournalID
				AND Cast(gl.SysPostDateAndTime AS DATE) Between @Date1 And @Date2
			INNER JOIN Lease_Profile lp
				ON tax.LeaseID = lp.LeaseID
			INNER JOIN dbo.Customer_Profile cp
				ON cp.CustomerID = lp.CustomerID
			INNER JOIN cte_LabelingLessor ll
				ON tax.LeaseID = ll.LeaseID
			---------------------------------------------------------------
			--Left Join GeneralLedger_Entries e
			--	On tax.JournalID = e.JournalID and tax.LeaseID = e.LeaseID
			--WHERE CONVERT(DATE,e.PostDate) BETWEEN @Date1 AND @Date2
		UNION
		Select   tax.LeaseID
				,tax.JournalID 
				--,e.LeaseSequenceNumber SequenceNumber
				,lp.SequenceNumber
				--,e.CustomerAccountNumber AccountNumber
				,cp.AccountNumber
				--,e.CustomerName
				,cp.CustomerName
				,tax.PropertyTaxAmount  AS PropertyTaxAmount
				,tax.[Property Tax Bill Number]
				,tax.ReportingYear
				--,e.LabellingLessorName LabelingLessor
				,ll.LabellingLessor 
				--,Coalesce(Format(tax.PostDate,'yyyy-MM-dd'),'') PostDate
				,FORMAT(gl.SysPostDateAndTime,'yyyy-MM-dd') PostDate
				,tax.Reversed
				,tax.ReversalJournalID
					--------------------
					-- 20190315
					,tax.TaxDistrict
					--------------------
		From
		(
			SELECT   t.[LeaseID]
					,t.ReversalJournalID JournalID
					,Sum(t.Amount) PropertyTaxAmount 
					,t.BillNumber [Property Tax Bill Number]
					,t.ReportingYear
					,t.ReversalPostDate PostDate
					, 'Yes' Reversed
					,t.ReversalJournalID
				  --------------------
					-- 20190315
					,t.TaxDistrict
					--------------------
			  FROM PropertyTax_Assessment t 
			  Where t.ReversalJournalID is NOT NULL  
			Group By   t.LeaseID
					  ,t.BillNumber
					  ,t.ReportingYear
					  ,t.JournalID
					  ,t.ReversalJournalID
					  ,t.ReversalPostDate 
				  --------------------
					-- 20190315
					,t.TaxDistrict
					--------------------
		) tax
			-------------------------------------------------------------------------------------------------------
			INNER JOIN [GeneralLedger_Journal] gl
				On tax.JournalID = gl.JournalID
				AND Cast(gl.SysPostDateAndTime AS DATE) Between @Date1 And @Date2
			INNER JOIN Lease_Profile lp
				ON tax.LeaseID = lp.LeaseID
			INNER JOIN dbo.Customer_Profile cp
				ON cp.CustomerID = lp.CustomerID
			INNER JOIN cte_LabelingLessor ll
				ON tax.LeaseID = ll.LeaseID
			-------------------------------------------------------------------------------------------------------
			--Left Join  GeneralLedger_Entries e
			--	On tax.JournalID = e.JournalID and tax.LeaseID = e.LeaseID
			--WHERE CONVERT(DATE,tax.PostDate) BETWEEN @Date1 AND @Date2
) r
--Where	Cast(r.PostDate AS DATE) Between @Date1 And @Date2
WHERE r.PropertyTaxAmount != 0.00 
AND r.Reversed='No'
--AND leaseID=2011
Order By r.PostDate
		,r.[Property Tax Bill Number]
		,r.AccountNumber
		,r.SequenceNumber
--)</CommandText>
      </Query>
      <Fields>
        <Field Name="LeaseID">
          <DataField>LeaseID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="JournalID">
          <DataField>JournalID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PropertyTaxAmount">
          <DataField>PropertyTaxAmount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Property_Tax_Bill_Number">
          <DataField>Property Tax Bill Number</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReportingYear">
          <DataField>ReportingYear</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="LabelingLessor">
          <DataField>LabelingLessor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PostDate">
          <DataField>PostDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Reversed">
          <DataField>Reversed</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReversalJournalID">
          <DataField>ReversalJournalID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="TaxDistrict">
          <DataField>TaxDistrict</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
