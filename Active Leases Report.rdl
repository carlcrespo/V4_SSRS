  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DATE1">
            <Value>=Parameters!DATE1.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DATE2">
            <Value>=Parameters!DATE2.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- Build 20191008
-- Work Order #28956
-- Active Leases Report

/*
Sheryn Murray has requested a report displaying All Active Leases with a commencement date parameter filter, 
which will be used to help determine files that should move from the 7th floor fileroom to new secure storage area in the 611 Anton Basement.

Report Should Include at minimum, the following columns:
Lessee Name
Schedule Number
Commencement Date
*/

--Declare @DATE1 Date , @DATE2 DATE 
--SET @DATE1 = '1/1/17' 
--SET @DATE2 = '11/1/17'

SELECT 
      B.[CustomerName] 
      ,A.[SequenceNumber]
      ,CONVERT (DATE,A.[ExpectedInceptionDate]) InceptionDate
	  ,CONVERT (DATE,A.[ExpectedMaturityDate]) ExpectedMaturityDate
	  --,A.[StatusId]
	  --,A.[BookingStatusId]
	  --,B.[AccountNumber]
      --,C.[Term]
	  --,CONVERT (DATE,C.[PostDate])PostDate 
	  --,CONVERT (DATE,C.[MaturityDate])MaturityDate	 
	  --,A.[LeaseID]	  
      --,A.[LeaseNumber]
	  --,A.[PortfolioID]
	  --,A.[CustomerID]

  FROM [Lease_Profile] A
  INNER Join [Customer_Profile] B
  ON A.[CustomerID] = B.[CustomerID]

  INNER Join [Lease_Contract]C
  ON A.[LeaseID] = C.[LeaseID]
  
  WHERE C.[IsActive]=1
  AND A.[StatusId]=2
  AND A.[BookingStatusId]=2
  AND CONVERT (DATE,A.[ExpectedInceptionDate]) BETWEEN @DATE1 AND @DATE2</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="InceptionDate">
          <DataField>InceptionDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="ExpectedMaturityDate">
          <DataField>ExpectedMaturityDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
