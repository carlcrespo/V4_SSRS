    <DataSet Name="AccountingTreatmentType">
      <Query>
        <DataSourceName>LeaseWave</DataSourceName>
        <CommandText>SELECT 
	AccountingTreatmentTypeID
  ,[Description] AccountingTreatmentType
  FROM Lease_AccountingTreatmentType_Cnfg
  WHERE IsActive=1
  ORDER BY [Description]</CommandText>
      </Query>
      <Fields>
        <Field Name="AccountingTreatmentTypeID">
          <DataField>AccountingTreatmentTypeID</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
        <Field Name="AccountingTreatmentType">
          <DataField>AccountingTreatmentType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
