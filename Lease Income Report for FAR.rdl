    <DataSource Name="LeaseWave">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>c0987638-582a-4acc-bf97-80d9a396241c</rd:DataSourceID>
