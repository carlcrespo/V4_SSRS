  <DataSets>
    <DataSet Name="LeaseIncome">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@IncomeDate">
            <Value>=Parameters!IncomeDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AccountingTreatmentType">
            <Value>=Parameters!AccountingTreatmentType.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--20210823
/*
Here is the sql query for Lease Income Report for FAR. They have validated my extract and would like this flipped to an SSRS. The main parameter is IncomeDate. 
They would like to add another parameter for AccountingTreatmentType to filter by one or multi or all. The default should be all are checked. 
*/
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED 
--DECLARE @IncomeDate DATE = '2021-06-30',@AccountingTreatmentType VARCHAR(30)=NULL

SELECT 
	  --A.IncomeID
     --,A.LeaseID
	   CC.AccountNumber
	  ,CC.CompanyName
	  ,CC.SequenceNumber
	  ,CC.Term
	  ,CC.Structure
	  ,D.LeaseType AccountingTreatmentType
	  ,CONVERT(DECIMAL(18,6),CC.LevelPrimaryYield) Yield
	  ,CC.LessorInvestment
	  ,D.ResidualBookedAmount
	  ,CC.MarginAmount
	  ,CC.UnearnedIncome
	  ,CC.InitialInvestmentBalanceAmount
	  ,CC.TotalLeaseReceivable
      ,A.IncomeTerm
      ,StepNumber
      ,CONVERT(DATE,A.IncomeDate)IncomeDate
	  ,IIF (B.JournalID is null,'',B.JournalID) JournalID
	  ,LeasePaymentAmount
      ,A.LessorBeginNetBookValue
      ,A.LessorEndNetBookValue
      ,A.CustomerBeginNetBookValue
      ,A.CustomerEndNetBookValue
      ,A.PrimaryIncome
      ,A.PrimaryIncomeBalance
	  ,IIF (BB.DeprAmt is null,0,BB.DeprAmt) DeprAmt
      ,A.IDCExpense
      ,A.IDCExpenseBalance
      ,A.ResidualIncome
      ,A.ResidualIncomeBalance
      ,A.CustomerPrimaryIncome
      ,A.RentalIncome
      ,A.DeferredRentalIncome
	  ,ci.ISO
	  ,csc.Symbol
      ,fs.FundingSourceId
      ,fs.FundingSourceNumber
      ,fs.Company
	  ,fs.Alias

FROM Lease_IncomeSchedule A
INNER JOIN  Lease_IncomeScheduleDetail B
	  ON A.IncomeID=B.IncomeID
	  AND B.JournalID is not null
LEFT JOIN 
  (
  SELECT 
      IncomeDetailID
      ,SUM (DepreciationAmount)DeprAmt
  FROM LeaseDepreciation_Inventory
  GROUP BY 
	IncomeDetailID
  ) BB
  ON B.IncomeDetailID=BB.IncomeDetailID
INNER JOIN 
  (
  SELECT 
	   A.LeaseID
	  ,B.SequenceNumber
	  ,C.AccountNumber
	  ,C.CompanyName
      ,Term
      ,IIF (A.ContractStructureId=1,'Regular','Irregular') Structure
	  ,D.LevelPrimaryYield
	  ,D.LessorInvestment
	  ,D.MarginAmount
	  ,D.TotalAmortizableIncome UnearnedIncome
	  ,D.InitialInvestmentBalanceAmount
	  ,D.TotalLeaseReceivable
  FROM Lease_Contract A
  INNER JOIN  Lease_Profile B
	ON A.LeaseID=B.LeaseID
	AND A.IsActive=1
  INNER JOIN Customer_Profile C
	ON B.CustomerID=C.CustomerID
  INNER JOIN Lease_Accrual D
	ON A.LeaseID=D.LeaseID
	AND D.IsActive=1
  ) CC
  ON A.LeaseID=CC.LeaseID
INNER JOIN 
  (
  SELECT 
	 A.LeaseID
	,A.ResidualBookedAmount
    ,B.[Description] LeaseType
  FROM Lease_Investment A
  INNER JOIN Lease_AccountingTreatmentType_Cnfg B
	  ON A.AccountingTreatmentTypeId=B.AccountingTreatmentTypeID
	  AND B.IsActive=1
	  AND A.IsActive=1
  ) D
  ON A.LeaseID=D.LeaseId
INNER JOIN Lease_Profile lp
	ON cc.SequenceNumber = lp.SequenceNumber
INNER JOIN dbo.LLC_Profile llc
	ON lp.LLCID = llc.LLCID
INNER JOIN Currency_Index ci
	ON llc.CurrencyIndexID = ci.CurrencyIndexID
INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
	ON ci.ISO = csc.ISO  
LEFT JOIN FundingSource_Profile fs
    ON lp.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label

WHERE 
  A.IncomeDate = @IncomeDate
  AND A.IsActive=1
  AND D.LeaseType IN (@AccountingTreatmentType)
Order By 
  cc.AccountNumber
 ,cc.SequenceNumber
 ,A.IncomeTerm</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
