    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>
-- 20220920 rev6

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED

;
WITH  
---------------------------------------------------------
-- 20220922
cte_GLview
AS
(
	SELECT DISTINCT 
		  GLJournalView.JournalID
		, Security_UserProfile.FirstName + SPACE(1) + Security_UserProfile.LastName as UserName
	FROM 
		GLJournalView 

		INNER JOIN GeneralLedger_Journal 
			ON GeneralLedger_Journal.JournalID = GLJournalView.JournalID

		LEFT JOIN Lease_Profile
			ON Lease_Profile.LeaseID = GLJournalView.EntityID
			AND GLJournalView.EntityTypeID = 5 --Lease			

		LEFT JOIN APInvoice_Profile 
			ON APInvoice_Profile.VendorInvoiceID = GLJournalView.EntityID
			AND GLJournalView.EntityTypeID = 24 --VendorInvoice

		LEFT JOIN Security_UserProfile
			ON Security_UserProfile.UserID = GeneralLedger_Journal.CreatedByUserID

		LEFT JOIN Receipt_UnallocatedCash
			ON Receipt_UnallocatedCash.UnallocatedCashReceiptID = GLJournalView.EntityID			
			AND GLJournalView.EntityTypeID IN (19)  --UnallocatedCash

		LEFT JOIN Customer_Profile UnallocatedCash_Customer_Profile
			ON UnallocatedCash_Customer_Profile.CustomerID = Receipt_UnallocatedCash.EntityID
			AND Receipt_UnallocatedCash.EntityTypeID = 1 --Customer

		LEFT JOIN Inventory_Profile
			ON Inventory_Profile.InventoryID = GLJournalView.EntityID
			AND GLJournalView.EntityTypeID = 4 --Inventory
			AND GLJournalView.SubTransactionTypeID = 4 --InventoryValueAdjustment

	WHERE
		GLJournalView.IsActiveTransactionType = 1 --Choose active transaction types only
		AND GLJournalView.EntityType = 'Unallocated Cash'
)
,
---------------------------------------------------------
cte_rep
AS
(
	SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID,
	(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
	,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
	,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
	,(SELECT FirstName FROM Security_UserProfile WHERE UserID = e.UserID) FirstName
	,(SELECT LastName FROM Security_UserProfile WHERE UserID = e.UserID) LastName
	,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
	,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
		,(SELECT RoleFunctionID FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionID
	,e.EntityID
	FROM EmployeeAssignment_Entity e
	WHERE e.EntityTypeID  = 1 And 
	 e.EmployeeAssignmentID IN 
		(
		SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
		FROM EmployeeAssignment_Entity 
		WHERE EntityTypeID = 1  /*@EntityTypeID --BillingAdmin*/
			AND IsActive = 1 
			AND RoleFunctionID = 40  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=40, RoleFunctionName = 'Billing'
		GROUP BY EntityID --,UserID 
		)
)
,
 CTE_UnallocatedCashReceiptDetail  
 AS        
 (        
  SELECT   
     Receipt_UnallocatedCash.UnallocatedCashReceiptID  
   , Receipt_UnallocatedCash.PostDate [PostDate]  
   , Receipt_UnallocatedCash.CheckDate [ReceivedDate]  
   , Receipt_UnallocatedCash.Amount  
   , IsNull(Sum(-Receipt_UnallocatedCashClearingDetail.BalanceClearedAmount),0) Balance  
   , Receipt_BatchHeader.BatchName  
   , Receipt_Type_CnfgLocale.ReceiptTypeName [ReceiptType]  
   , Receipt_UnallocatedCash.CheckNumber  
   , Department_CnfgLocale.DepartmentName  [ResponsibleParty]  
   , GenericEntityList.LessorDefinedUniqueID [AccountNumber]  
   , Receipt_UnallocatedCash.Comment [Notes]  
   , Receipt_UnallocatedCash.NameOnCheck [Payee]   
   ------------------------------
   -- 20220824
   ,Receipt_UnallocatedCash.LLCID
   ,Receipt_UnallocatedCash.EntityTypeID
   ,ci.ISO
   ------------------------------
   -- 20220914
   ,Receipt_UnallocatedCash.LastModifiedUserID
   ,sup.UserCode
   ------------------------------
  FROM  
   Receipt_UnallocatedCash  
  LEFT JOIN Receipt_UnallocatedCashClearingDetail  
   ON Receipt_UnallocatedCashClearingDetail.UnallocatedCashReceiptID = Receipt_UnallocatedCash.UnallocatedCashReceiptID  
  LEFT JOIN  GenericEntityList  
   ON GenericEntityList.EntityID = Receipt_UnallocatedCash.EntityId  
   AND GenericEntityList.EntityTypeId  = Receipt_UnallocatedCash.EntityTypeId -- Buyer/Customer/Unidentified  
  LEFT JOIN Receipt_BatchHeader  
   ON Receipt_BatchHeader.BatchID = Receipt_UnallocatedCash.BatchID  
   AND Receipt_BatchHeader.LLCID &lt;&gt; 0
  LEFT JOIN Department_Cnfg  
   ON Department_Cnfg.DepartmentID = Receipt_UnallocatedCash.DepartmentID  
   AND Department_Cnfg.IsActive = 1 -- Active  
  LEFT JOIN Department_CnfgLocale   
   ON Department_CnfgLocale.DepartmentID = Department_Cnfg.DepartmentID  
  LEFT JOIN Receipt_Type_Cnfg ON  
   Receipt_Type_Cnfg.ReceiptTypeId = Receipt_UnallocatedCash.PaymentTypeID  
   AND Receipt_Type_Cnfg.IsActive = 1 -- Active  
  LEFT JOIN Receipt_Type_CnfgLocale   
   ON Receipt_Type_Cnfg.ReceiptTypeID = Receipt_Type_CnfgLocale.ReceiptTypeID 
------------------------------------------------
-- 20220824
  INNER JOIN dbo.Currency_Index ci
    ON Receipt_UnallocatedCash.LLCID = ci.CurrencyIndexID
------------------------------------------------
---- 20220914
--LEFT JOIN Security_UserProfile SUP1
--	ON Receipt_UnallocatedCash.LastModifiedUserID = SUP.UserID
--------------------------------------------------
-- 20220920
--FROM [LWDW].[dbo].[Receipt_UnallocatedCash] RUC
LEFT JOIN GeneralLedger_JournalEntryEntity GLJEE
	ON Receipt_UnallocatedCash.UnallocatedCashReceiptID = GLJEE.EntityID
LEFT JOIN GeneralLedger_Journal GLJ
	ON GLJEE.JournalID = GLJ.JournalID
LEFT JOIN Security_UserProfile SUP
	ON GLJ.CreatedByUserID = SUP.UserID
--------------------------------------------------
-- 20220922
INNER JOIN cte_GLview v
	ON GLJ.JournalID = v.JournalID
--------------------------------------------------
WHERE Receipt_UnallocatedCash.LLCID &lt;&gt; 0  
  GROUP BY   
     Receipt_UnallocatedCash.UnallocatedCashReceiptID  
   , Receipt_UnallocatedCash.PostDate    
   , Receipt_UnallocatedCash.CheckDate    
   , Receipt_UnallocatedCash.Amount  
   , Receipt_BatchHeader.BatchName  
   , Receipt_Type_CnfgLocale.ReceiptTypeName   
   , Receipt_UnallocatedCash.CheckNumber  
   , Department_CnfgLocale.DepartmentName     
   , GenericEntityList.LessorDefinedUniqueID    
   , Receipt_UnallocatedCash.Comment    
   , Receipt_UnallocatedCash.NameOnCheck  
   ------------------------------
   -- 20220824
   ,Receipt_UnallocatedCash.LLCID
   ,Receipt_UnallocatedCash.EntityTypeID
   ,ci.ISO
   ------------------------------
   -- 20220914
   ,Receipt_UnallocatedCash.LastModifiedUserID
   ,sup.UserCode
   ------------------------------
 ) 
 ,
 cte_rpt
 AS
 (
 SELECT --DISTINCT  
    CTE_UnallocatedCashReceiptDetail.UnallocatedCashReceiptID  
  , CTE_UnallocatedCashReceiptDetail.PostDate  
  , CTE_UnallocatedCashReceiptDetail.ReceivedDate  
  , CTE_UnallocatedCashReceiptDetail.Amount  
  , CTE_UnallocatedCashReceiptDetail.Amount + CTE_UnallocatedCashReceiptDetail.Balance [Balance]  
  , CTE_UnallocatedCashReceiptDetail.BatchName  
  , CTE_UnallocatedCashReceiptDetail.ReceiptType  
  , CTE_UnallocatedCashReceiptDetail.CheckNumber  
  , CTE_UnallocatedCashReceiptDetail.ResponsibleParty  
  , CTE_UnallocatedCashReceiptDetail.AccountNumber  
  , CTE_UnallocatedCashReceiptDetail.Notes  
  , CTE_UnallocatedCashReceiptDetail.Payee
  -------------------------------------
  -- 20220824
  ,CTE_UnallocatedCashReceiptDetail.ISO
  -------------------------------------
  -- 120220914
  ,CTE_UnallocatedCashReceiptDetail.UserCode
  -------------------------------------
 FROM  
  CTE_UnallocatedCashReceiptDetail  
 WHERE 
	CTE_UnallocatedCashReceiptDetail.Amount + CTE_UnallocatedCashReceiptDetail.Balance &gt; 0
	--AND AccountNumber = 'HNA01'
	AND UnallocatedCashReceiptID &gt; 132
	AND CTE_UnallocatedCashReceiptDetail.UnallocatedCashReceiptID IN
	(
	SELECT 
		Receipt_UnallocatedCash.UnallocatedCashReceiptID
	FROM 
		GLJournalView 
		INNER JOIN Receipt_UnallocatedCash
				ON Receipt_UnallocatedCash.UnallocatedCashReceiptID = GLJournalView.EntityID
				AND Receipt_UnallocatedCash.LLCID &lt;&gt; 0
				AND GLJournalView.EntityType = 'Unallocated Cash'
		LEFT JOIN Receipt_UnallocatedCashClearingDetail
				ON Receipt_UnallocatedCashClearingDetail.UnallocatedCashReceiptID = Receipt_UnallocatedCash.UnallocatedCashReceiptID 
		LEFT JOIN Receipt_UnallocatedCashClearingHeader
				ON Receipt_UnallocatedCashClearingHeader.UnallocatedCashPostID = Receipt_UnallocatedCashClearingDetail.UnAllocatedCashPostID
		LEFT JOIN Receipt_Header
				ON Receipt_Header.UnallocatedCashPostID = Receipt_UnallocatedCashClearingDetail.UnAllocatedCashPostID
				AND Receipt_Header.LLCID &lt;&gt; 0
		LEFT JOIN Receipt_UnAllocatedCashClearingMethod_Cnfg
				ON Receipt_UnallocatedCashClearingHeader.UnallocatedCashPostTypeID = Receipt_UnAllocatedCashClearingMethod_Cnfg.UnallocatedCashPostTypeID
		LEFT JOIN Customer_Profile
				ON Receipt_UnallocatedCash.EntityID  = Customer_Profile.CustomerID
				AND Receipt_UnallocatedCash.EntityTypeID = 1
		LEFT JOIN GeneralLedger_Template UnallocatedCash_GeneralLedger_Template
				ON UnallocatedCash_GeneralLedger_Template.TemplateId = Receipt_UnallocatedCash.GLTemplateID
		LEFT JOIN GeneralLedger_Template UnallocatedCashClearingHeader_GeneralLedger_Template
				ON UnallocatedCashClearingHeader_GeneralLedger_Template.TemplateId = Receipt_UnallocatedCashClearingHeader.GLTemplateID 
	WHERE 
		SubTransactionType IN ('Clear Unallocated Cash','Unallocated Cash')
		  AND Receipt_UnallocatedCash.Balance &gt; 0
	GROUP BY 
		Receipt_UnallocatedCash.UnallocatedCashReceiptID
	)
GROUP BY
    CTE_UnallocatedCashReceiptDetail.UnallocatedCashReceiptID  
  , CTE_UnallocatedCashReceiptDetail.PostDate  
  , CTE_UnallocatedCashReceiptDetail.ReceivedDate  
  , CTE_UnallocatedCashReceiptDetail.Amount  
  , CTE_UnallocatedCashReceiptDetail.Amount + CTE_UnallocatedCashReceiptDetail.Balance 
  , CTE_UnallocatedCashReceiptDetail.BatchName  
  , CTE_UnallocatedCashReceiptDetail.ReceiptType  
  , CTE_UnallocatedCashReceiptDetail.CheckNumber  
  , CTE_UnallocatedCashReceiptDetail.ResponsibleParty  
  , CTE_UnallocatedCashReceiptDetail.AccountNumber  
  , CTE_UnallocatedCashReceiptDetail.Notes  
  , CTE_UnallocatedCashReceiptDetail.Payee  
  -------------------------------------
  -- 202208245
  ,CTE_UnallocatedCashReceiptDetail.ISO
  -------------------------------------
  -- 120220914
  ,CTE_UnallocatedCashReceiptDetail.UserCode
  -------------------------------------
)
,
cte_GL_Cash_Template
AS
(
SELECT a.UnallocatedCashReceiptID
	  ,[Cash GL Template]=b.[Name] 
  FROM Receipt_UnallocatedCash a
 INNER join GeneralLedger_Template b
	ON a.GLTemplateID = b.TemplateId
)
 SELECT distinct
    r.UnallocatedCashReceiptID  
  , r.PostDate  
  , r.ReceivedDate  
  , r.Amount  
  , r.Balance  
  , r.BatchName  
  , r.ReceiptType  
  , r.CheckNumber  
  , r.ResponsibleParty  
  , r.AccountNumber  
  , r.Notes  
  , r.Payee 
  , cp.CustomerName
  ,c.FirstName +' '+ c.LastName Billing_Rep
  ,g.[Cash GL Template]
  -----------
  -- 20220824
  ,r.ISO
  -----------
  -- 20220914
  ,r.UserCode PostedToUnallocatedBy
FROM cte_rpt r
LEFT JOIN customer_profile cp
	ON r.AccountNumber = cp.AccountNumber
LEFT JOIN cte_rep c
	ON r.AccountNumber = c.AccountNumber
LEFT JOIN cte_GL_Cash_Template g
	ON r.UnallocatedCashReceiptID = g.UnallocatedCashReceiptID
--WHERE r.UnallocatedCashReceiptID=32351
ORDER BY 
	UnallocatedCashReceiptID ASC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
