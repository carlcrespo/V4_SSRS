    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT mp.MLAID
      ,mp.CustomerID
      ,mp.MLATypeID	  
	  ,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = mp.CustomerID) [Account Number]
	  ,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID=mp.CustomerID) [Customer Name]
      ,mp.MLAName [Client MLA Name]     
	  ,mp.ClientMLANumber [Client MLA Number]
	  ,(SELECT [Description]   FROM Template_MLAType_Cnfg WHERE MLATypeID=mp.MLATypeID) [MLA Type]      
	  ,CAST(mp.MLADate AS DATE) [MLA Date]
	  ,(IIF(mp.isActive=1,'Yes','No')) Active    
	  FROM MLA_Profile mp
	Order By mp.MLAName</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MLAID">
          <DataField>MLAID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CustomerID">
          <DataField>CustomerID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MLATypeID">
          <DataField>MLATypeID</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
        <Field Name="Account_Number">
          <DataField>Account Number</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Customer_Name">
          <DataField>Customer Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Client_MLA_Name">
