  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>-- 20191021
SELECT
	 r.LabellingLessor
,r.Alias
,r.FundingSourceId
	,r.AccountNumber
	,r.CustomerName
	,r.SequenceNumber
	,r.CommencementDate
	,r.MaturityDate
	,r.StopBilling
	,r.CommentDate StopBillDate
	,r.ARSpecialist
	,r.StopBillComment Comment
FROM
	(
	SELECT 
	FP.Company LabellingLessor
,FP.Alias
,FP.FundingSourceId
	,CP.AccountNumber
	,CP.CustomerName
	,[SequenceNumber]
	,Convert(Date,[ExpectedInceptionDate]) CommencementDate
	,Convert (Date,[ExpectedMaturityDate]) MaturityDate
	,IIF ([IsStopBilling]=1, 'Yes','No') StopBilling
	,CONVERT(Date,LBC.LastModifiedDate) CommentDate
	,CONCAT (UP.FirstName,UP.LastName) ARSpecialist
	,lbc.Comment StopBillComment

	FROM [dbo].[Lease_Profile] LP

	inner join [dbo].[Customer_Profile] CP
	on LP.CustomerID = CP.CustomerID

	inner join [dbo].[FundingSource_Profile] FP
	on LP.LabellingLessorID=FP.FundingSourceId

	inner join [dbo].[EmployeeAssignment_Entity] EA
	on CP.CustomerID=EA.EntityID

	inner join [dbo].[Security_UserProfile] UP
	on EA.UserID=UP.UserID

	inner join [dbo].[Lease_BillingComment] LBC
	on lp.leaseid =lbc.LeaseID



	where IsStopBilling=1 and EA.RoleFunctionID=40 and EA.IsActive=1 and LP.statusid in (2,6) and EA. EntityTypeID=1

	--order by 

	-- CP.AccountNumber
	--,lp.SequenceNumber
	--,CommentDate
	) r

		order by 

	 r.AccountNumber
	,r.SequenceNumber
	,r.CommentDate</CommandText>
      </Query>
