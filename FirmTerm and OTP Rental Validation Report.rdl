  <DataSources>
    <DataSource Name="LW_PROD">
      <DataSourceReference>/Data Sources/LW_ISO</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>925355b0-7e91-44da-a1f3-253b48c024d6</rd:DataSourceID>
    </DataSource>
    <DataSource Name="DataSource1">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>165abbc9-0c2e-4ea5-bcd3-3718cef73047</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ExpectedMaturityDate">
            <Value>=Parameters!ExpectedMaturityDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20191008
-- Build 20180720
 --Declare @ExpectedMaturityDate Date = '8/31/2021'
--This report will be used by EOL Dept to compare FT Rent and the designated OTP Rent. In the event the FT Rent is changing from QTR to MO, this will ensure the OTP rent is correct.

SELECT cp.AccountNumber 
			, cp.CustomerName 
			, lp.SequenceNumber
			,ci.ISO 
			,csc.Symbol
			,fs.FundingSourceId
			,fs.FundingSourceNumber
			,fs.Company 
,fs.Alias
			, po.Description AS PurchaseOptionType 
			, lc2.Description AS RegularORIrregular 
			, lc.Term -- ,Convert(Date,lc.PostDate) as LeaseBookingPostDate
 ,
       CONVERT (DATE,[ExpectedInceptionDate]) CommenceDate ,
               CONVERT(DATE,[ExpectedMaturityDate]) MaturityDate ,
               fr.Description AS FirmTermFrequency ,
               fr2.Description AS PractOTPFrequency ,
               sum(iil.LeaseRentalAmount) AS Rental ,
               sum(iil.OverTermPaymentRentalAmount) AS OTPRent ,
               SUM(iil.[FullAmortizationAmount]) [FullAmortizationAmount]
FROM [dbo].[Lease_Profile] AS LP
INNER JOIN [dbo].[Customer_Profile] AS CP ON lp.CustomerID=CP.CustomerID
INNER JOIN [dbo].[Lease_Investment] AS LI ON lp.leaseid=li.leaseid
AND li.IsActive=1
INNER JOIN [dbo].[Lease_ContractPurchaseOption_Cnfg] AS PO ON li.PurchaseOptionID=po.PurchaseOptionID
AND po.PurchaseOptionID=1 -- FMV
INNER JOIN [dbo].[Lease_Contract] AS LC ON lp.leaseid=lc.leaseid
AND lc.IsActive=1
INNER JOIN [dbo].[Lease_ContractStructure_Cnfg]LC2 ON lc.ContractStructureId=lc2.ContractStructureId
INNER JOIN [dbo].[MaturityManagement_Lease] AS MM ON lp.leaseid=mm.leaseid
INNER JOIN [dbo].[Lease_RentalFrequency_Cnfg] AS FR ON lc.IrregularRentalFrequencyID=FR.RentalFrequencyID
LEFT JOIN [dbo].[Lease_RentalFrequency_Cnfg] AS FR2 ON mm.PractOTPFrequencyID=FR2.RentalFrequencyID
INNER JOIN [dbo].[Lease_InventoryInLease] AS IIL ON lp.leaseid=iil.leaseid
AND iil.IsInLease=1
INNER JOIN dbo.LLC_Profile llc
       ON lp.LLCID = llc.LLCID
INNER JOIN Currency_Index ci
       ON llc.CurrencyIndexID = ci.CurrencyIndexID
INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
       ON ci.ISO = csc.ISO  
LEFT JOIN FundingSource_Profile fs
       ON lp.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label

WHERE lp.statusid in (2,
                      6)
  AND MaturityDate &gt;= @ExpectedMaturityDate
GROUP BY lp.LeaseID ,
         lp.CustomerID ,
         cp.AccountNumber ,
         cp.CustomerName ,
         lp.SequenceNumber ,
         lc2.Description ,
         lc.Term ,
         lc.PostDate ,
         fr.Description ,
         fr2.Description ,
         li.IsActive ,
         [ExpectedInceptionDate] ,
         [ExpectedMaturityDate] ,
         po.Description ,
         mm.PractOTPFrequencyID ,
         lp.DefaultInvoiceGroupID
		 ,ci.ISO 
		 ,csc.Symbol
		 ,fs.FundingSourceId
		 ,fs.FundingSourceNumber
		 ,fs.Company 
,fs.Alias
ORDER BY MaturityDate ,
         AccountNumber</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
