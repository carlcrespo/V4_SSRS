  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <CommandText>-- 20191008
DECLARE @AccountNumber VARCHAR(20) = 'HON13' -- test
DECLARE @CustomerID INT

SELECT @CustomerID = customerid
FROM   customer_profile
WHERE  accountnumber = @AccountNumber

PRINT @CustomerID

SELECT Z.sequencenumber
		,Z.ISO 
		,Z.Symbol
        ,Z.FundingSourceId
        ,Z.FundingSourceNumber
		,Z.Company,
Z.Alias,
       Z.leasestatus,
       Z.chargetype,
       Z.amount  Rent_Amount,
       Z.balance Rent_Balance,
       Z.taxamt  Tax_Amount,
       Z.taxbal  Tax_Balance,
       Z.duedate,
       Z.invoiced
FROM   (SELECT C.sequencenumber
				,ci.ISO 
			   ,csc.Symbol
        	   ,fs.FundingSourceId
        	   ,fs.FundingSourceNumber
			   ,fs.Company,
fs.Alias,
               F.description                           LeaseStatus,
               D.description                           ChargeType,
               B.amount
               --This is the remaining OTP rent post payoff adjustments applied or not
               ,
               Sum([balance])                          Balance,
               E.taxamt,
               E.taxbal,
               CONVERT(DATE, B.duedate)                DueDate,
               Iif(A.[invoiceid] IS NULL, 'No', 'Yes') Invoiced
        FROM   [dbo].[receivable_otherpaymentdetail] A
               INNER JOIN [dbo].[receivable_otherpaymentheader] B
                       ON A.receivableheaderid = B.receivableheaderid
               INNER JOIN [dbo].[lease_profile] C
                       ON A.leaseid = C.leaseid
                          AND C.customerid = @CustomerID
				INNER JOIN dbo.LLC_Profile llc
      				   ON C.LLCID = llc.LLCID
				INNER JOIN Currency_Index ci
      				   ON llc.CurrencyIndexID = ci.CurrencyIndexID
				INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
      				   ON ci.ISO = csc.ISO  
				LEFT JOIN FundingSource_Profile fs
      				   ON C.LabellingLessorID = fs.FundingSourceID
      				   AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label
               INNER JOIN [dbo].[receivable_type_cnfg] D
                       ON A.receivabletypeid = D.receivabletypeid
               INNER JOIN (SELECT A.[invoicedealdetailid],
                                  [invoiceid],
                                  [entityid],
                                  [delinquencylastrundate],
                                  [isdelinquencyfullyassessed],
                                  bb.amt,
                                  bb.taxamt,
                                  bb.taxbal,
                                  [pastduebalance],
                                  [pastduetaxbalance],
                                  [entitytypeid]
                           FROM   [dbo].[invoice_dealdetail] A
                                  INNER JOIN
                                  (SELECT [invoicedealdetailid],
                                          Sum([amount])    Amt,
                                          Sum([taxamount]) TaxAmt,
                                          Sum([taxbalance])TaxBal
                                   FROM   [dbo].[invoice_receivabledetail]
                                   GROUP  BY invoicedealdetailid) BB
                                          ON
                                  A.invoicedealdetailid = BB.invoicedealdetailid
                          ) E
                       ON A.invoiceid = E.invoiceid
               INNER JOIN [dbo].[lease_status_cnfg] F
                       ON C.statusid = F.statusid
        WHERE  balance &lt;&gt; 0
               AND B.receivabletypeid = 3
               AND isdummy = 0
        GROUP  BY B.amount,
                  B.duedate,
                  C.sequencenumber,
				  ci.ISO 
			   ,csc.Symbol
        	   ,fs.FundingSourceId
        	   ,fs.FundingSourceNumber
			   ,fs.Company,
fs.Alias,
                  D.description,
                  E.taxamt,
                  E.taxbal,
                  F.description,
                  Iif(A.[invoiceid] IS NULL, 'No', 'Yes')
        --Order by 
        --  SequenceNumber
        -- ,DueDate
        UNION
        --INTERSECT
       /****** Script for SelectTopNRows command from SSMS  ******/
        --For Steve Lease Rental
        SELECT B.sequencenumber
			   ,ci.ISO 
			   ,csc.Symbol
        	   ,fs.FundingSourceId
        	   ,fs.FundingSourceNumber
			   ,fs.Company,
fs.Alias,
               F.description                           LeaseStatus,
               D.description                           ChargeType,
               C.amount,
               Sum([balance])                          Balance,
               E.taxamt,
               E.taxbal,
               CONVERT(DATE, C.duedate)                DueDate,
               Iif(A.[invoiceid] IS NULL, 'No', 'Yes') Invoiced
        FROM   [dbo].[receivable_leasepaymentdetail] A
               INNER JOIN [dbo].[lease_profile] B
                       ON A.leaseid = B.leaseid
                          AND B.customerid = @CustomerID
				INNER JOIN dbo.LLC_Profile llc
      				   ON B.LLCID = llc.LLCID
				INNER JOIN Currency_Index ci
      				   ON llc.CurrencyIndexID = ci.CurrencyIndexID
				INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
      				   ON ci.ISO = csc.ISO  
				LEFT JOIN FundingSource_Profile fs
      				   ON B.LabellingLessorID = fs.FundingSourceID
      				   AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label
               INNER JOIN [dbo].[receivable_leasepaymentheader] C
                       ON A.receivableheaderid = C.receivableheaderid
               INNER JOIN [dbo].[receivable_type_cnfg] D
                       ON A.receivabletypeid = D.receivabletypeid
               LEFT JOIN (SELECT AA.[invoicedealdetailid],
                                 [invoiceid],
                                 [entityid],
                                 [delinquencylastrundate],
                                 [isdelinquencyfullyassessed],
                                 BB.amt,
                                 BB.taxamt,
                                 BB.taxbal,
                                 [pastduebalance],
                                 [pastduetaxbalance],
                                 [entitytypeid]
                          FROM   [dbo].[invoice_dealdetail] AA
                                 INNER JOIN
                                 (SELECT [invoicedealdetailid],
                                         Sum([amount])    Amt,
                                         Sum([taxamount]) TaxAmt,
                                         Sum([taxbalance])TaxBal
                                  FROM   [dbo].[invoice_receivabledetail]
                                  GROUP  BY invoicedealdetailid) BB
                                         ON
                                 AA.invoicedealdetailid = BB.invoicedealdetailid
                         ) E
                      ON A.invoiceid = E.invoiceid
               INNER JOIN [dbo].[lease_status_cnfg] F
                       ON B.statusid = F.statusid
        WHERE  A.balance &lt;&gt; 0
               AND A.isdummy = 0
        GROUP  BY C.duedate,
                  C.amount,
                  B.sequencenumber
				  ,ci.ISO 
			   ,csc.Symbol
        	   ,fs.FundingSourceId
        	   ,fs.FundingSourceNumber
			   ,fs.Company,
fs.Alias,
                  CONVERT(DATE, B.expectedmaturitydate),
                  D.description,
                  Iif(A.[invoiceid] IS NULL, 'No', 'Yes'),
                  E.taxamt,
                  E.taxbal,
                  F.description
       --Order By 
       --  SequenceNumber
       -- ,DueDate
       ) Z
ORDER  BY Z.sequencenumber,
          Z.duedate </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SequenceNumber">
          <DataField>sequencenumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ISO">
