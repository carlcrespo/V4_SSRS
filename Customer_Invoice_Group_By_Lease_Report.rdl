  <DataSets>
    <DataSet Name="DataSet3">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AccountNumber">
            <Value>=Parameters!AccountNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20191008
-- Build 20180720
-------------------------------------------------
-- test code
---- DECLARE @AccountNumber AS VARCHAR(30) = 'HON010'
-------------------------------------------------
Declare @CustomerID int

SELECT @CustomerID = CustomerID
FROM Customer_Profile
WHERE AccountNumber = @AccountNumber

PRINT @CustomerID

(
SELECT 
	 fs.Company LabellingLessor
    ,fs.Alias CoAlias
    ,fs.FundingSourceId
	,cp.AccountNumber
    ,cp.CustomerName
    ,lp.SequenceNumber
    ,CONVERT(Date,lp.ExpectedMaturityDate) MaturityDate
	,IIF(lp.IsStopBilling=0,'No','Yes') StopBilled
	,lp.PurchaseOrderNumber
	,ig.InvoiceGroupName
	,IIF(ig.IsEmailNotificationAllowed=0,'No','Yes') IsEmailAllowed
	,IIF(ig.IsPrintInvoiceNotRequired=0,'No','Yes') NoPrint
	,IIF (ig.[IsEmailWithAttachment]=0, 'No','Yes') EmailWithAttachment
    ,ig.ToEmailAddresses
    ,ig.BCCEmailAddresses
	,ig.CCEmailAddresses
	,IIF (ig.[IsRentalInvoiceSplitByDeal]=0, 'Yes','No') CombinedBill
    ,IIF(ig.IsLeaseRentalInvoiceSplitByLocation=0,'No','Yes') SplitBillByLocation
	,IIF (igf.FirstInvoiceFormatID=32, 'Detail - Subtotal By Location','Summary') FirstRentalFormat
	,IIF (igf.InvoiceFormatID=32, 'Detail - Subtotal By Location','Summary') RentalFormat
	
  FROM [dbo].[Lease_Profile] as LP

  inner join [dbo].[Customer_Profile] as CP
  on lp.CustomerID=CP.CustomerID
  AND CP.CustomerID=@CustomerID

  inner join [dbo].[InvoiceGroup_Profile] as IG
  on lp.DefaultInvoiceGroupID=ig.InvoiceGroupID

  inner join [dbo].[FundingSource_Profile] as FS
  on lp.LabellingLessorID=fs.FundingSourceId

  inner join [dbo].[InvoiceGroup_InvoiceFormat] as IGF
  on ig.InvoiceGroupID=igf.InvoiceGroupID

  inner join [dbo].[InvoiceGroup_InvoiceFormat_Cnfg] IFC
  on igf.InvoiceFormatID=ifc.FormatID
  AND ifc.InvoiceTypeID=1
  AND ifc.IsActive=1

  where lp.statusid in (2,6) 
  AND @AccountNumber != ''
  )
  UNION
  (
SELECT 
	 fs.Company LabellingLessor
    ,fs.Alias CoAlias
    ,fs.FundingSourceId
	,cp.AccountNumber
    ,cp.CustomerName
    ,lp.SequenceNumber
    ,CONVERT(Date,lp.ExpectedMaturityDate) MaturityDate
	,IIF(lp.IsStopBilling=0,'No','Yes') StopBilled
	,lp.PurchaseOrderNumber
	,ig.InvoiceGroupName
	,IIF(ig.IsEmailNotificationAllowed=0,'No','Yes') IsEmailAllowed
	,IIF(ig.IsPrintInvoiceNotRequired=0,'No','Yes') NoPrint
	,IIF (ig.[IsEmailWithAttachment]=0, 'No','Yes') EmailWithAttachment
    ,ig.ToEmailAddresses
    ,ig.BCCEmailAddresses
	,ig.CCEmailAddresses
	,IIF (ig.[IsRentalInvoiceSplitByDeal]=0, 'Yes','No') CombinedBill
    ,IIF(ig.IsLeaseRentalInvoiceSplitByLocation=0,'No','Yes') SplitBillByLocation
	,IIF (igf.FirstInvoiceFormatID=32, 'Detail - Subtotal By Location','Summary') FirstRentalFormat
	,IIF (igf.InvoiceFormatID=32, 'Detail - Subtotal By Location','Summary') RentalFormat
	
  FROM [dbo].[Lease_Profile] as LP

  inner join [dbo].[Customer_Profile] as CP
  on lp.CustomerID=CP.CustomerID
  --AND CP.CustomerID=@CustomerID

  inner join [dbo].[InvoiceGroup_Profile] as IG
  on lp.DefaultInvoiceGroupID=ig.InvoiceGroupID

  inner join [dbo].[FundingSource_Profile] as FS
  on lp.LabellingLessorID=fs.FundingSourceId

  inner join [dbo].[InvoiceGroup_InvoiceFormat] as IGF
  on ig.InvoiceGroupID=igf.InvoiceGroupID

  inner join [dbo].[InvoiceGroup_InvoiceFormat_Cnfg] IFC
  on igf.InvoiceFormatID=ifc.FormatID
  AND ifc.InvoiceTypeID=1
  AND ifc.IsActive=1

  where lp.statusid in (2,6) 
  AND @AccountNumber = ''
  )


  order by 
  
  AccountNumber
  ,SequenceNumber</CommandText>
        <Timeout>69</Timeout>
      </Query>
