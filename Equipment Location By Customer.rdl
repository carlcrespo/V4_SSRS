  <DataSets>
    <DataSet Name="ds_inter_assets">
      <Query>
        <DataSourceName>LW</DataSourceName>
        <CommandText>-- 20191008


SELECT 
	
         cp.AccountNumber
	  ,cp.CustomerName
	  ,lp.[SequenceNumber]
	  ,lp.ExpectedInceptionDate as CommenceDate
	  ,lp.ExpectedMaturityDate as MaturityDate
	  ,count (iil.[InventoryID]) as AssetCount
	  ,tc.[Description] as Country
	  
     
FROM [dbo].[Lease_InventoryInLease] as IIL

	  inner join [dbo].[Lease_Profile] LP
	  on iil.leaseid=lp.leaseid

	  inner join [dbo].[Inventory_Location] as IL
	  on iil.InventoryID=il.InventoryID

	  inner join [dbo].[Inventory_LocationTemplate] as LT
	  on il.LocationTemplateID=lt.LocationTemplateID

	  inner join [dbo].[Template_State_Cnfg] as T
	  on lt.stateid=t.stateid

	  inner join [dbo].[Template_Country_Cnfg] as TC
	  on t.countryid=tc.countryid

	  inner join [dbo].[Customer_Profile] as CP
	  on lp.CustomerID=cp.CustomerID


where iil.isinlease=1 and lp.StatusId in (2,6)
  
  Group By

      
          cp.accountnumber
	  ,cp.CustomerName
	  ,lp.[SequenceNumber]
	  ,lp.ExpectedInceptionDate
	  ,lp.ExpectedMaturityDate
	  ,tc.[Description] 


  order by AccountNumber,SequenceNumber, Country</CommandText>
      </Query>
      <Fields>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CommenceDate">
          <DataField>CommenceDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="MaturityDate">
          <DataField>MaturityDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="AssetCount">
          <DataField>AssetCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Country">
          <DataField>Country</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_20210315">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>-- 20210315


SELECT 
	
       cp.AccountNumber
	  ,cp.CustomerName
	  ,lp.[SequenceNumber]
	  --,lp.ExpectedInceptionDate as CommenceDate
	  ,lc.InceptionDate CommenceDate
--	  ,lp.ExpectedMaturityDate as MaturityDate
	  ,lc.MaturityDate
	  ,count (iil.[InventoryID]) as AssetCount
	  ,tc.[Description] as Country
	  ,fs.Company -- Labelling Lessor
,fs.FundingSourceID
,fs.Alias
	  
     
FROM [dbo].[Lease_InventoryInLease] as IIL

	  inner join [dbo].[Lease_Profile] LP
	  on iil.leaseid=lp.leaseid

	  inner join [dbo].[Inventory_Location] as IL
	  on iil.InventoryID=il.InventoryID

	  inner join [dbo].[Inventory_LocationTemplate] as LT
	  on il.LocationTemplateID=lt.LocationTemplateID

	  inner join [dbo].[Template_State_Cnfg] as T
	  on lt.stateid=t.stateid

	  inner join [dbo].[Template_Country_Cnfg] as TC
	  on t.countryid=tc.countryid

	  inner join [dbo].[Customer_Profile] as CP
	  on lp.CustomerID=cp.CustomerID

	  INNER JOIN Lease_Contract lc
		ON lp.LeaseID = lc.LeaseID
		AND lc.IsActive = 1

	  LEFT JOIN FundingSource_Profile fs
       ON lp.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)


where iil.isinlease=1 and lp.StatusId in (2,6) --AND lp.StatusId IN (SELECT StatusID FROM Lease_Status_Cnfg WHERE Description IN ('Commenced','Assumed'))

  Group By

      
       cp.accountnumber
	  ,cp.CustomerName
	  ,lp.[SequenceNumber]
	  --,lp.ExpectedInceptionDate
	  --,lp.ExpectedMaturityDate
	  ,tc.[Description] 
	  ,lc.InceptionDate
	  ,lc.MaturityDate
,fs.Company 
,fs.FundingSourceID
,fs.Alias

  order by AccountNumber,SequenceNumber, Country</CommandText>
      </Query>
      <Fields>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CommenceDate">
          <DataField>CommenceDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="MaturityDate">
          <DataField>MaturityDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="AssetCount">
          <DataField>AssetCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Country">
          <DataField>Country</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Company">
          <DataField>Company</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FundingSourceID">
          <DataField>FundingSourceID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Alias">
          <DataField>Alias</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
