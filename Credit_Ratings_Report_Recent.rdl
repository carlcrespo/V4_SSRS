      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>-- revised 20201027 -- Recent Credit Ratings
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED 
----------------------------------------------------
---- Test
--Declare @AsOfDate DATE = getdate() -- '4/1/2016' 
--, @LesseeName varchar(100) = NULL  --'Federal Way/ School District No. 210- Planning Rate Profile' /
--, @All varchar(21) = 'All Credit Ratings' -- 'Recent Credit Ratings' -- 'All Credit Ratings' -- 
----------------------------------------------------
;
With
cte_prep_Customer_CreditRating
AS
(
--SELECT -- *
-- [CreditRatingID]
--      ,[CustomerID] 
--      ,[AsOfDate]
--      ,[SPRatings]
--      ,[MoodysRatings]
--      ,[InternalRating]
--      ,[FitchRating]
--      ,[JapaneseRating]
--      ,[RatingOutlook]
--      ,[Comments]
--      ,[ParentCustomerID]
--      ,[ParentAsOfDate]
--      ,[ParentSPRatings]
--      ,[ParentMoodysRatings]
--      ,[ParentInternalRating]
--      ,[ParentFitchRating]
--      ,[ParentJapaneseRating]
--      ,[ParentRatingOutlook]
--      ,[ParentComments]
--      ,[IsActive]
--      ,[LastModifiedUserID]
--      ,[LastModifiedDate]
--FROM [dbo].[Customer_CreditRating] 
--Where 
--[AsOfDate]&lt;=Cast(Getdate() as Date)
---------------------------------
-- --20160602
--	And IsActive = 1 
----and CustomerID IN (11,1012)
----order by CustomerID,creditratingid
----Where CustomerID IN (38/*,63,74, 123,541*/)
----Where [CreditRatingID] in
----	(
----	SELECT MAX(CreditRatingID) CreditRatingID
----	  FROM [dbo].[Customer_CreditRating]
----	  Where [AsOfDate]&lt;=@AsOfDate
----	  Group by CustomerID
----	)
-----------------------------------
---- 20170419
--	And @All = 'All Credit Ratings'
--Union 
SELECT 
 [CreditRatingID]
      ,[CustomerID] 
      ,[AsOfDate]
      ,[SPRatings]
      ,[MoodysRatings]
      ,[InternalRating]
      ,[FitchRating]
      ,[JapaneseRating]
      ,[RatingOutlook]
      ,[Comments]
      ,[ParentCustomerID]
      ,[ParentAsOfDate]
      ,[ParentSPRatings]
      ,[ParentMoodysRatings]
      ,[ParentInternalRating]
      ,[ParentFitchRating]
      ,[ParentJapaneseRating]
      ,[ParentRatingOutlook]
      ,[ParentComments]
      ,[IsActive]
      ,[LastModifiedUserID]
      ,[LastModifiedDate]
FROM [dbo].[Customer_CreditRating] 
Where 
	[AsOfDate]&lt;=Cast(Getdate() as Date) 
	--And IsActive = 1 
	--And @All = 'Recent Credit Ratings'
	And CreditRatingID in
		(
		SELECT 
			   MAX(CreditRatingID) CreditRatingID
		FROM [dbo].[Customer_CreditRating] 
		Group By [CustomerID]
		)
)
,
cte_Customer_CreditRating
AS
(
-------------------------------------------------------------------------
SELECT Case y.Flag
			When 0 Then 'CR CustomerID'
			When 1 Then 'CR CustomerID + CR ParentCustomerID'
			When 2 Then 'CR CustomerID + Separate CR ParentCustomerID'
			When 3 Then 'CR CustomerID + CP ParentCustomerID'
			Else ''
		End CustomerID_Status
	  ,y.[CreditRatingID]
      ,y.[CustomerID]
      ,Cast(y.AsOfDate As Date) AsOfDate
      ,y.[SPRatings]
      ,y.[MoodysRatings]
      ,y.[InternalRating]
      ,IsNull(y.FitchRating,'') FitchRating
      ,IsNull(y.JapaneseRating,'') JapaneseRating
      ,IsNull(y.RatingOutlook,'') RatingOutlook
      ,IsNull(y.Comments,'') Comments
      ,IsNull(Convert(char(10),y.ParentCustomerID),'') ParentCustomerID
      ,Cast(y.[ParentAsOfDate] As Date) [ParentAsOfDate]
      ,IsNull(y.ParentSPRatings,'') ParentSPRatings
      ,IsNull(y.ParentMoodysRatings,'') ParentMoodysRatings
      ,IsNull(y.ParentInternalRating,'') ParentInternalRating
      ,IsNull(y.ParentFitchRating,'') ParentFitchRating
      ,IsNull(y.ParentJapaneseRating,'') ParentJapaneseRating
      ,IsNull(y.ParentRatingOutlook,'') ParentRatingOutlook
      ,IsNull(y.ParentComments,'') ParentComments
      ,y.[IsActive]
      ,y.[LastModifiedUserID]
      ,y.[LastModifiedDate]
FROM 
(
	--------------------------------------------------------------------
	-- ParentCustomerID not in Customer_CreditRating or Customer_Profile
--1-----------------------------------------------------------------------------
	SELECT 0 Flag
		   ,'' PCID 
		   ,[CreditRatingID]
		  ,[CustomerID]
		  ,[AsOfDate]
		  ,[SPRatings]
		  ,[MoodysRatings]
		  ,[InternalRating]
		  ,[FitchRating]
		  ,[JapaneseRating]
		  ,[RatingOutlook]
		  ,[Comments]
		  ,[ParentCustomerID]
		  ,[ParentAsOfDate]
		  ,[ParentSPRatings]
		  ,[ParentMoodysRatings]
		  ,[ParentInternalRating]
		  ,[ParentFitchRating]
		  ,[ParentJapaneseRating]
		  ,[ParentRatingOutlook]
		  ,[ParentComments]
		  ,[IsActive]
		  ,[LastModifiedUserID]
		  ,[LastModifiedDate]
	  FROM cte_prep_Customer_CreditRating
	  Where CustomerID in 
			(
				Select CustomerID
				From Customer_Profile
				Where ParentCustomerID is Null
			)
			AND ParentCustomerID is NUll
--2---------------------------------------------------------------------------
	Union All
	-- ParentCustomerID and CustomerID in Customer_CreditRating as one record
	SELECT 1 Flag
		  ,ParentCustomerID PCID
		  ,[CreditRatingID]
		  ,[CustomerID]
		  ,[AsOfDate]
		  ,[SPRatings]
		  ,[MoodysRatings]
		  ,[InternalRating]
		  ,[FitchRating]
		  ,[JapaneseRating]
		  ,[RatingOutlook]
		  ,[Comments]
		  ,[ParentCustomerID]
		  ,[ParentAsOfDate]
		  ,[ParentSPRatings]
		  ,[ParentMoodysRatings]
		  ,[ParentInternalRating]
		  ,[ParentFitchRating]
		  ,[ParentJapaneseRating]
		  ,[ParentRatingOutlook]
		  ,[ParentComments]
		  ,[IsActive]
		  ,[LastModifiedUserID]
		  ,[LastModifiedDate]
	  FROM cte_prep_Customer_CreditRating
	  Where ParentCustomerID is not Null
--3----------------------------------------------------------------------------------
	Union All
	-- ParentCustomerID in Customer_Profile and in Customer_CreditRating as 2 records
	SELECT Distinct 2 Flag
		   ,x.PCID
		   ,x.[CreditRatingID]
		  ,x.[CustomerID]
		  ,x.[AsOfDate]
		  ,x.[SPRatings]
		  ,x.[MoodysRatings]
		  ,x.[InternalRating]
		  ,x.[FitchRating]
		  ,x.[JapaneseRating]
		  ,x.[RatingOutlook]
		  ,x.[Comments]
		  ,x.PCID ParentCustomerID
		  ,cr2.AsOfDate ParentAsOfDate
		  ,cr2.SPRatings ParentSPRatings
		  ,cr2.MoodysRatings ParentMoodysRatings
		  ,cr2.InternalRating ParentInternalRating
		  ,cr2.FitchRating ParentFitchRating
		  ,cr2.JapaneseRating ParentJapaneseRating
		  ,cr2.RatingOutlook ParentRatingOutlook
		  ,cr2.Comments ParentComments
		  ,x.[IsActive]
		  ,x.[LastModifiedUserID]
		  ,x.[LastModifiedDate]
	From
		(
			Select 
				cp.ParentCustomerID PCID
			   ,cr.[CreditRatingID]
			  ,cr.[CustomerID]
			  ,cr.[AsOfDate]
			  ,cr.[SPRatings]
			  ,cr.[MoodysRatings]
			  ,cr.[InternalRating]
			  ,cr.[FitchRating]
			  ,cr.[JapaneseRating]
			  ,cr.[RatingOutlook]
			  ,cr.[Comments]
			  ,cr.ParentCustomerID
			  ,cr.ParentAsOfDate
			  ,cr.ParentSPRatings
			  ,cr.ParentMoodysRatings
			  ,cr.ParentInternalRating
			  ,cr.ParentFitchRating
			  ,cr.ParentJapaneseRating
			  ,cr.ParentRatingOutlook
			  ,cr.ParentComments
			  ,cr.[IsActive]
			  ,cr.[LastModifiedUserID]
			  ,cr.[LastModifiedDate]
		  FROM cte_prep_Customer_CreditRating cr
		  Inner Join Customer_Profile cp
---------------------------------------------------------------------------------
-- change NULL from AND to WHERE
			ON cr.CustomerID = cp.CustomerID and cp.ParentCustomerID is not Null
  				And cr.ParentCustomerID is Null
				And cp.ParentCustomerID in (Select CustomerID From cte_prep_Customer_CreditRating) 
-------------------------------------
-- 20160602
		Where cp.CustomerStatusID = 1 -- Active  
-------------------------------------
		) x
	Inner Join cte_prep_Customer_CreditRating cr2
		On x.PCID = cr2.CustomerID
	Where cr2.CreditRatingID IN
		(
		Select c.CreditRatingID
		From 
			(
				Select CustomerID,CreditRatingID,AsOfDate 
				From cte_prep_Customer_CreditRating
				--Intersect 
				--Select CustomerID,Max(CreditRatingID) CreditRatingID, Max(AsOfDate) AsOfDate 
				--From cte_prep_Customer_CreditRating
				--Group By CustomerID
			) c
		)
--4----------------------------------------------------------------------------------
	Union All
	-- ParentCustomerID in Customer_Profile and not in cte_prep_Customer_CreditRating 
	SELECT 3 Flag
			,cp.ParentCustomerID PCID
		   ,cr.[CreditRatingID]
		  ,cr.[CustomerID]
		  ,cr.[AsOfDate]
		  ,cr.[SPRatings]
		  ,cr.[MoodysRatings]
		  ,cr.[InternalRating]
		  ,cr.[FitchRating]
		  ,cr.[JapaneseRating]
		  ,cr.[RatingOutlook]
		  ,cr.[Comments]
		  ,cp.[ParentCustomerID]
		  ,cr.[ParentAsOfDate]
		  ,cr.[ParentSPRatings]
		  ,cr.[ParentMoodysRatings]
		  ,cr.[ParentInternalRating]
		  ,cr.[ParentFitchRating]
		  ,cr.[ParentJapaneseRating]
		  ,cr.[ParentRatingOutlook]
		  ,cr.[ParentComments]
		  ,cr.[IsActive]
		  ,cr.[LastModifiedUserID]
		  ,cr.[LastModifiedDate]
	  FROM cte_prep_Customer_CreditRating cr
	  Inner Join Customer_Profile cp
		ON cr.CustomerID = cp.CustomerID and cp.ParentCustomerID is not Null
  			And cr.ParentCustomerID is Null
			And cp.ParentCustomerID not in (Select CustomerID From cte_prep_Customer_CreditRating)
-------------------------------------
-- 20160602
		Where cp.CustomerStatusID = 1  -- Active
-------------------------------------
) y
-----------------------------------------------------------------------------------------
) 
--Select * From cte_Customer_CreditRating
----------------------------------------------------------------------------------------------------------------------	
,
cte_rpt
AS
(
--9--
SELECT --DISTINCT
Top 100 Percent
o.CustomerID
--,(Select CustomerName From Customer_Profile Where CustomerID = o.CustomerID) LesseeName
,o.ISO
,o.Symbol
,o.FundingSourceId
,o.FundingSourceNumber
,o.Company
,o.Alias
,cp.CustomerName LesseeName
,o.AccountNumber
,v.VertDesc 
,o.AsOfDate
,o.[S&amp;P Ratings]
,o.[Moody's Ratings]
,o.[Internal Rating]
,o.[Fitch Rating]
,o.[Japanese Rating]
,o.[Rating Outlook]
,REPLACE(REPLACE(REPLACE(o.Comments, CHAR(9),''), CHAR(10),''), CHAR(13),'')  Comments
,o.ParentCustomerID
--,IsNull((Select AccountNumber From Customer_Profile Where CustomerID = o.ParentCustomerID),'') ParentAccountNumber
,Coalesce(cpp.AccountNumber,'') ParentAccountNumber
,o.CustomerName ParentName
,o.[Parent As Of Date]
,o.[Parent S&amp;P Ratings]
,o.[Parent Moody's Ratings]
,o.[Parent Internal Rating]
,o.[Parent Fitch Rating]
,o.[Parent Japanese Rating]
,o.[Parent Rating Outlook]
,REPLACE(REPLACE(REPLACE(o.[Parent Comments], CHAR(9),''), CHAR(10),''), CHAR(13),'')  [Parent Comments]
,o.TotalExposure_Customer TotalExposure
--,(SELECT dbo.f_Expo(o.CustomerID,o.asOfDate)) Total_Exposure_OTI
FROM



(
----------------------------------------------------------------------------------------------------------------------
	  --8--
	  SELECT 
		r.CustomerID
		,TE.ISO
		,TE.Symbol
		,TE.FundingSourceId
		,TE.FundingSourceNumber
		,TE.Company
		,TE.Alias
		,r.CreditRatingID
		,(SELECT AccountNumber FROM dbo.Customer_Profile WHERE CustomerID = r.CustomerID) AccountNumber
		,CONVERT(DATE,r.AsOfDate) AsOfDate
		,r.SPRatings [S&amp;P Ratings]
		,r.MoodysRatings [Moody's Ratings]
		,r.InternalRating [Internal Rating]
		,ISNULL(r.FitchRating,'') [Fitch Rating]
		,ISNULL(r.JapaneseRating,'') [Japanese Rating]
		,ISNULL(r.RatingOutlook,'') [Rating Outlook]
		,REPLACE(REPLACE(REPLACE(ISNULL(r.Comments,''),'''',''),CHAR(10),''),CHAR(13),'') Comments
		,ISNULL(r.ParentCustomerID,'') ParentCustomerID
		,ISNULL((SELECT CustomerName FROM dbo.Customer_Profile WHERE CustomerID = r.ParentCustomerID),'') CustomerName
		--,CONVERT(DATE,r.ParentAsOfDate) [Parent As Of Date]
		,Coalesce(Format(r.ParentAsOfDate,'yyyy-MM-dd'),'') [Parent As Of Date]
		,ISNULL(r.ParentSPRatings,'') [Parent S&amp;P Ratings]
		,ISNULL(r.ParentMoodysRatings,'') [Parent Moody's Ratings]
		,ISNULL(r.ParentInternalRating,'') [Parent Internal Rating]
		,ISNULL(r.ParentFitchRating,'') [Parent Fitch Rating]
		,ISNULL(r.ParentJapaneseRating,'') [Parent Japanese Rating]
		,REPLACE(ISNULL(r.ParentRatingOutlook,''),'''','') [Parent Rating Outlook]
		,REPLACE(ISNULL(r.ParentComments,''),'''','') [Parent Comments]
		,TE.TotalExposure_Customer
	  FROM cte_prep_Customer_CreditRating r 
	  Left /*Inner*/ JOIN 
		  (
----------------------------------------------------------------------------------------------------------------------
				--7a-- Odessa script captured from SQL Profiler
				SELECT Lease_Profile.CustomerID
					,(SUM(ISNULL(Receivable_LeasePaymentDetail.Balance,0)) + SUM(ISNULL(Receivable_Adjustment.Balance,0))) TotalExposure_Customer  --[CurrentRemainingRental] 
					,ci.ISO
					 ,csc.Symbol
        			 ,fs.FundingSourceId
        			 ,fs.FundingSourceNumber
					 ,fs.Company
					 ,fs.Alias
				FROM
					Receivable_LeasePaymentHeader 
					INNER JOIN Receivable_LeasePaymentDetail
						ON 	Receivable_LeasePaymentHeader.ReceivableHeaderID = Receivable_LeasePaymentDetail.ReceivableHeaderID
					INNER JOIN Lease_Profile
						ON Receivable_LeasePaymentHeader.LeaseID = Lease_Profile.LeaseID
					Inner JOIN dbo.LLC_Profile llc
      					   ON Lease_Profile.LLCID = llc.LLCID
					Inner JOIN Currency_Index ci
      					   ON llc.CurrencyIndexID = ci.CurrencyIndexID
					Inner JOIN dbo.Currency_Symbol_CnfgLocale csc
      					   ON ci.ISO = csc.ISO 
					LEFT JOIN FundingSource_Profile fs
      					   ON Lease_Profile.LabellingLessorID = fs.FundingSourceID
      					   AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label 
					LEFT JOIN Receivable_Adjustment
						ON Receivable_Adjustment.OriginalReceivableID = Receivable_LeasePaymentDetail.ReceivableID
				WHERE
					/*Lease_Profile.CustomerID = @CustomerID
					AND*/ Receivable_LeasePaymentHeader.IsActive = 1 -- Yes
					AND Receivable_LeasePaymentDetail.IsDummy = 0 -- No
					AND Receivable_LeasePaymentDetail.Balance &gt; 0
					AND Receivable_LeasePaymentDetail.ReceivableTypeID = 1 -- Lease Rental
					AND Receivable_LeasePaymentDetail.IsSuspended = 0
				Group by Lease_Profile.CustomerID
				,ci.ISO
				 ,csc.Symbol
        		 ,fs.FundingSourceId
        		 ,fs.FundingSourceNumber
				 ,fs.Company
				 ,fs.Alias
			) TE
				ON r.CustomerID = TE.CustomerID AND r.IsActive = 1 
		WHERE r.CreditRatingID IN
			(
			SELECT x.CreditRatingID--, x.CustomerID, x.AsOfDate
			  FROM cte_Customer_CreditRating x

			--Inner Join
			--(
			--SELECT CustomerID,Max(AsOfDate) AsOfDate
			--  FROM cte_Customer_CreditRating
			--  Where IsActive = 1
			--  Group By CustomerID
			--) y
			--	ON x.CustomerID = y.CustomerID and x.AsOfDate = y.AsOfDate

			--Where x.CreditRatingID IN
			--	(
			--		SELECT MAX(CreditRatingID)
			--		FROM cte_Customer_CreditRating
			--		GROUP BY CustomerID
			--	)
			)
		--8--
----------------------------------------------------------------------------------------------------------------------	
) o
Inner Join Customer_Profile cp
	On o.CustomerID = cp.CustomerID
-------------------------------------
-- 20160602
		AND cp.CustomerStatusID = 1  -- Active
-------------------------------------
left Join Customer_Profile cpp
	On o.ParentCustomerID = cpp.CustomerID
-------------------------------------
-- 20160602
		AND cpp.CustomerStatusID = 2  -- Active
-------------------------------------
--Where cp.CustomerName like '%'+ @LesseeName +'%'

LEFT JOIN 
	(
---------------------------------------------------------
-- 20201027
	SELECT   
		 ccl.CustomerCreditLineID as CustCreditLineID
		,ccl.CustomerID
		,ccl.VerticalID
		,ccv.[Description] as VertDesc
    FROM Customer_CreditLine ccl
	INNER JOIN CustomerCredit_Vertical_Cnfg ccv
		ON ccl.VerticalID = ccv.VerticalID 
	WHERE ccl.CustomerCreditLineID IN 
		(
		 SELECT
			MAX(CustomerCreditLineID) 
		  FROM Customer_CreditLine ccl
		  INNER JOIN CustomerCredit_Vertical_Cnfg ccv
			ON ccl.VerticalID = ccv.VerticalID 
		  GROUP BY CustomerID
		)
	) v
	on o.customerid = v.CustomerID
Order By o.CustomerID
---------------------------------------------------------
----9--
)
----------------------------------------------------------------------------------------------------------------------	
,
cte_out
as
(
Select * FROM cte_rpt --Where LesseeName = @LesseeName 
--Union
--Select * FROM cte_rpt Where LesseeName like '%'+ @LesseeName +'%' and (@LesseeName is not NULL or @LesseeName != '')
--Union
--Select * FROM cte_rpt Where @LesseeName is NULL or @LesseeName = ''

)
SELECT 
	 o.CustomerID [Customer ID]
	,o.ISO
	,o.Symbol
	,o.FundingSourceId
	,o.FundingSourceNumber
	,o.Company
	,o.Alias
	,o.LesseeName [Lessee Name]
	,o.AccountNumber [Lessee Account Number] 
	,o.VertDesc Vertical
	,o.ParentAccountNumber [Parent Account Number]
	,o.AsOfDate [As Of Date]
	,o.[S&amp;P Ratings] [Lessee S  &amp; P Rating]
	,o.[Moody's Ratings] [Lessee Moody's Rating]
	,o.[Internal Rating] [Lessee Internal Rating]
	,o.[Fitch Rating]
	,o.[Japanese Rating]
	,o.[Rating Outlook] [Lessee Rating Outlook]
	,o.Comments
	,o.ParentCustomerID [Parent Customer ID]
	,o.[Parent As Of Date]
	,o.ParentName [Parent Name]
	,o.[Parent S&amp;P Ratings]
	,o.[Parent Moody's Ratings]
	,o.[Parent Internal Rating]
	,o.[Parent Fitch Rating]
	,o.[Parent Japanese Rating]
	,o.[Parent Rating Outlook]
	,o.[Parent Comments]
	,o.TotalExposure [Total Remaining Rentals]
FROM cte_out o
WHERE  o.VertDesc &lt;&gt; 'Education'
--AND o.CustomerID=711
--GO</CommandText>
      </Query>
      <Fields>
        <Field Name="Customer_ID">
          <DataField>Customer ID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ISO">
          <DataField>ISO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Lessee_Name">
          <DataField>Lessee Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Symbol">
          <DataField>Symbol</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Lessee_Account_Number">
          <DataField>Lessee Account Number</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FundingSourceId">
          <DataField>FundingSourceId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
