    <DataSet Name="LabelingLessor">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LeaseNumber">
            <Value>=Parameters!LeaseNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT FundingSourceNumber AS [LabellingLessor] 
FROM FundingSource_Profile 
WHERE FundingSourceId IN (SELECT [LabellingLessorID] FROM Lease_Profile WHERE SequenceNumber =@LeaseNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="LabellingLessor">
          <DataField>LabellingLessor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="LeaseDates">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LeaseNumber">
            <Value>=Parameters!LeaseNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText> -- 20190305
-- LeaseDates
-- Work Order #31997

---------------------------------------
-- test code
--DECLARE @LeaseNumber VARCHAR(30) = 'WES020-1'
---------------------------------------

SELECT  
       lp.SequenceNumber
      ,FORMAT(lc.InceptionDate,'MM/dd/yyyy') InceptionDate
      ,FORMAT(lc.MaturityDate,'MM/dd/yyyy') MaturityDate
  FROM [dbo].[Lease_Contract] lc
 INNER JOIN dbo.Lease_Profile lp
	ON lc.LeaseID = lp.LeaseID
 WHERE lc.IsActive = 1
   AND lp.SequenceNumber = @LeaseNumber
</CommandText>
      </Query>
      <Fields>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="InceptionDate">
          <DataField>InceptionDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MaturityDate">
          <DataField>MaturityDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="OriginalEquipmentCost">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LeaseNumber">
            <Value>=Parameters!LeaseNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20220829

--DECLARE @LeaseNumber NVARCHAR(50) ='9176-6-A' -- '117-gg-77'

SELECT 
	LeaseID,
	SUM(InventoryTotalAmount) OriginalEquipmentCost
FROM 
	Lease_InventoryInLeaseHistory
WHERE InventoryInLeaseHistoryID IN
	(
	SELECT 
		MIN(InventoryInLeaseHistoryID) InventoryInLeaseHistoryID
	FROM dbo.Lease_InventoryInLeaseHistory
	WHERE LeaseID = (SELECT LeaseID FROM Lease_Profile WHERE SequenceNumber = @LeaseNumber) 
	GROUP BY 
		InventoryID,
		LeaseID
	) 
	AND LeaseID = (SELECT LeaseID FROM Lease_Profile WHERE SequenceNumber = @LeaseNumber) 
GROUP BY 
	LeaseID</CommandText>
      </Query>
      <Fields>
        <Field Name="LeaseID">
          <DataField>LeaseID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="OriginalEquipmentCost">
          <DataField>OriginalEquipmentCost</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CurrentEquipmentCost">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LeaseNumber">
            <Value>=Parameters!LeaseNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20220829

--DECLARE @LeaseNumber NVARCHAR(50) ='9176-6-A' -- '117-gg-77'

SELECT 
	LeaseID,
	SUM(InventoryTotalAmount) CurrentEquipmentCost
FROM 
	Lease_InventoryInLease
WHERE 
IsInLease=1
	AND 
	LeaseID = (SELECT LeaseID FROM Lease_Profile WHERE SequenceNumber = @LeaseNumber) 
GROUP BY LeaseID
</CommandText>
      </Query>
      <Fields>
        <Field Name="LeaseID">
          <DataField>LeaseID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CurrentEquipmentCost">
          <DataField>CurrentEquipmentCost</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
