  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="LW">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>77a8dbf1-00e0-4804-9626-effd7ad8a6a6</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LW</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@InvoiceNumber">
            <Value>=Parameters!InvoiceNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20191021
Select 
	 o.CustomerName
	,o.InvoiceNumber
	,o.[Date]
	,o.PhysicalInvoicePath
	,Left('\\'+Replace(Right(o.PhysicalInvoicePath,Len(o.PhysicalInvoicePath)-2),'\\','\'),Len('\\'+Replace(Right(o.PhysicalInvoicePath,Len(o.PhysicalInvoicePath)-2),'\\','\'))-15) [Path]
From
(
	SELECT 
		   (Select CustomerName From [dbo].Customer_Profile Where CustomerID = h.CustomerID) CustomerName
		  ,n.[InvoiceNumberID]
		  ,n.[InvoiceNumber]
		  ,n.[InvoiceTypeID]
		  ,n.[PrintCount]
		  ,n.[LastInvoicePrintedDate]
		  ,n.[LastModifiedUserID]
		  ,n.[LastModifiedDate] [Date]
		  ,n.[PhysicalInvoicePath]
		  ,n.[PDFFilePath]
	  FROM [dbo].[Invoice_Number] n
	  Inner Join .[dbo].[Invoice_Header] h
		ON n.[InvoiceNumberID] = h.[InvoiceNumberID]
	  Where n.[PDFFilePath] is not null or n.[PhysicalInvoicePath] is not null
	) o
Where o.InvoiceNumber = @InvoiceNumber</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="InvoiceNumber">
          <DataField>InvoiceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Date">
          <DataField>Date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="PhysicalInvoicePath">
          <DataField>PhysicalInvoicePath</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Path">
          <DataField>Path</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
