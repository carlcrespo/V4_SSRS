    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>Insight_DEV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CultureID">
            <Value>=Parameters!CultureID.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AccountNumber">
            <Value>=Parameters!AccountNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
	  Customer_Profile.CustomerName
	, Customer_Profile.AccountNumber
	, Inventory_LocationTemplate.LocationCode 
	, Inventory_LocationTemplate.LocationName1
	, Inventory_LocationTemplate.LocationName2
	, Inventory_LocationTemplate.LocationName3
	, Inventory_LocationTemplate.Address
	, Inventory_LocationTemplate.Address2
	, Inventory_LocationTemplate.City
	, Template_State_CnfgLocale.StateShortName AS State
	, Inventory_LocationTemplate.ZIP 
	,IIF(Inventory_LocationTemplate.isActive = 1,'Yes','No') [Is Active]
FROM 
	Customer_Profile 
	INNER JOIN Inventory_LocationTemplate 
		ON Customer_Profile.CustomerID = Inventory_LocationTemplate.EntityID 
		AND Inventory_LocationTemplate.EntityTypeID = 1 --Customer
	INNER JOIN Template_State_CnfgLocale
		ON Inventory_LocationTemplate.StateID = Template_State_CnfgLocale.StateID
		AND Template_State_CnfgLocale.CultureID = @CultureID
WHERE
	Customer_Profile.AccountNumber LIKE REPLACE(@AccountNumber, '*', '%')</CommandText>
      </Query>
      <Fields>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
