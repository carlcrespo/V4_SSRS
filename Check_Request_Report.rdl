  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ChkReqID">
            <Value>=Parameters!ChkReqID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20191021
-- Build 20180830 May Alonzo, 
-- Payee split 1
--------------------------------------
-- test code
DECLARE @CheckRequestID INT --= 1014 --9534
--------------------------------------

SET  @CheckRequestID = @ChkReqID 					

;
WITH cte_1
AS
(					
SELECT 				
	    --A.[VendorInvoiceID]	
	    --A.CustomerID		
	    --,I.VendorInvoiceID	
	    --,D.CheckRequestID	
        CAST (D.CheckRequestID AS VARCHAR(10)) CheckRequestID
		,IIF(A.[IsForeignCurrency]=1, 'Yes','No') IsForeignCurrency
		,L.ISO Currency	
	   ,CONVERT(VARCHAR,CAST(E.AmountToPay as MONEY),1) AmountToPay
	   ,F.VendorCompanyName Payee
	   ,H.VendorNumber		
	   ,H.VendorCompanyName	
      ,[VendorInvoiceNumber]	
	  ,CONVERT (Date,B.InvoiceDate) InvoiceDate
      ,CONVERT(VARCHAR,CAST([TotalOriginalAssetAmount] as MONEY),1) VendorInvoiceAcquisitionCost
	  ,CONVERT(VARCHAR,CAST(C.Amount as MONEY),1) VendorInvoiceOtherCost
	  ,CONVERT(VARCHAR,CAST(A.InvoiceTotal as MONEY),1) VendorInvoiceTotal
	  --,CONVERT(VARCHAR,CAST(I.StickerCost as MONEY),1) AssetStickerCost
	  --,CONVERT(VARCHAR,CAST(I.Markup as MONEY),1) AssetMarkUp
	  ,Sum(I.StickerCost + I.Markup) AmountOnLease 
	  ,IsNull(C.OtherCostType,'NA') OtherCostType
	  ,IsNull(C.OtherCostAllocation,'NA')OtherCostAllocation
	  ,G.AccountNumber		
	  ,G.CustomerName		
	  ,I.SequenceNumber	
	  ,J.EmployeeAssignment	
	  				
   					
  FROM [dbo].[APInvoice_Profile] A
					
  INNER JOIN [dbo].[APInvoice_BillofSale] B -- To get the invoice date
  ON A.VendorInvoiceID=B.VendorInvoiceID
					
  LEFT JOIN -- To get the other cost totals
					
  (					
  SELECT				
	  				
       [VendorInvoiceID]		
       ,A.[Description] OtherCostType
       ,SUM([Amount])Amount	
	   ,A.AllocationMethodID	
	   ,B.Description OtherCostAllocation
      					
  FROM [dbo].[APInvoice_CostOther] A
  					
  LEFT JOIN [dbo].[APInvoice_AllocationMethod_Cnfg] B
  ON A.AllocationMethodID=B.AllocationMethodID
  AND B.IsActive=1			
					
  WHERE A.IsActive=1		
  					
  GROUP BY 				
					
   [VendorInvoiceID]			
   ,A.[Description]			
   ,A.AllocationMethodID		
   ,B.Description			
					
   ) C					
					
   ON A.VendorInvoiceID=C.VendorInvoiceID
					
   INNER JOIN [dbo].[CheckRequest_Invoice] D --To get check request ID
   ON A.VendorInvoiceID=D.VendorInvoiceID
   AND D.IsActive=1			
					
					
   INNER JOIN 			
					
   (					
   SELECT 				
	   				
       [PayeeID]			
	  ,[CheckRequestInvoiceID]	
      ,SUM([AmountToPay]) AmountToPay
      ,[IsActive]				
    					
  FROM [dbo].[CheckRequest_PayeeInvoice]
					
  GROUP BY				
					
   [PayeeID]				
  ,[CheckRequestInvoiceID]		
  ,[IsActive]				
					
  ) E					
					
   ON D.CheckRequestInvoiceID=E.CheckRequestInvoiceID
   AND E.IsActive=1			
   AND AmountToPay &lt;&gt; 0		
					
   INNER JOIN [dbo].[Vendor_Profile] F
   ON E.PayeeID = F.VendorID	
					
   INNER JOIN [dbo].[Customer_Profile] G
   ON A.CustomerID=G.CustomerID
					
   INNER JOIN [dbo].[Vendor_Profile] H
   ON A.VendorID = H.VendorID	
					
   INNER JOIN -- To get SequenceNumber
   (					
   SELECT 				
	  				
       [VendorInvoiceID]		
	  ,C.LeaseAlias		
	  ,D.SequenceNumber	
      ,SUM([AssetAmount]) AssetAmount
	  ,SUM(B.StickerCost) StickerCost
	  ,SUM(B.MarkupAmount) Markup
      ,A.[IsActive]			
     					
  FROM [dbo].[APInvoice_CostHeader] A
					
  INNER JOIN [dbo].[LeaseTransaction_Inventory] B
  ON A.InventoryID=B.InventoryID	
  AND B.IsActive=1			
					
  INNER JOIN [dbo].[LeaseTransaction_Profile] C
  ON B.LeaseTransactionID=C.LeaseTransactionID
  AND C.AgreementTypeID=2 --LSLT
					
  INNER JOIN [dbo].[Lease_Profile] D
  ON C.LeaseID=D.LeaseID		
					
  Where A.IsActive=1		
					
  GROUP BY				
   					
       [VendorInvoiceID]		
	  ,C.LeaseAlias		
	  ,D.SequenceNumber	
      ,A.[IsActive]			
					
  ) I					
					
  ON A.VendorInvoiceID=I.VendorInvoiceID
  AND I.IsActive=1			
					
  INNER JOIN				
					
  (					
  SELECT 				
       [EntityID]				
      ,A.[UserID]			
      ,A.[RoleFunctionID]		
      ,A.[IsActive]			
	  ,CONCAT(C.FirstName,C.LastName) EmployeeAssignment
      					
  FROM [dbo].[EmployeeAssignment_Entity] A
  					
  INNER JOIN [dbo].[Security_RoleProfile] B
  ON A.RoleFunctionID=B.RoleFunctionID
  AND B.SecurityRoleID=18		
  AND UserID NOT IN (62,35,38,40)	
					
  INNER JOIN [dbo].[Security_UserProfile] C
  ON A.UserID=C.UserID		
					
					
  where EntityTypeID=1		
  AND A.IsActive=1			
  ) J					
  					
  ON G.CustomerID=J.EntityID	
					
  INNER JOIN [dbo].[LLC_Profile] K
  ON A.VendorLLCID=K.LLCID	
					
  INNER JOIN [dbo].[Currency_Index]L
  ON K.CurrencyIndexID=L.CurrencyIndexID
					
  where 				
					
  D.CheckRequestID=@CheckRequestID

					
  GROUP BY				
   --A.[VendorInvoiceID]		
	    --A.CustomerID		
	    --,I.VendorInvoiceID	
	    --,D.CheckRequestID	
        CAST (D.CheckRequestID AS VARCHAR(10)) 
		,IIF(A.[IsForeignCurrency]=1, 'Yes','No') 
		,L.ISO 			
	   ,CONVERT(VARCHAR,CAST(E.AmountToPay as MONEY),1) 
	   ,F.VendorCompanyName 	
	   ,H.VendorNumber		
	   ,H.VendorCompanyName	
      ,[VendorInvoiceNumber]	
	  ,CONVERT (Date,B.InvoiceDate) 
      ,CONVERT(VARCHAR,CAST([TotalOriginalAssetAmount] as MONEY),1) 
	  ,CONVERT(VARCHAR,CAST(C.Amount as MONEY),1) 
	  ,CONVERT(VARCHAR,CAST(A.InvoiceTotal as MONEY),1) 
	  ,CONVERT(VARCHAR,CAST(I.StickerCost as MONEY),1) 
	  ,CONVERT(VARCHAR,CAST(I.Markup as MONEY),1) 
	  ,IsNull(C.OtherCostType,'NA') 
	  ,IsNull(C.OtherCostAllocation,'NA')
	  ,G.AccountNumber		
	  ,G.CustomerName		
	  ,I.SequenceNumber	
	  ,J.EmployeeAssignment	
)
,
cte_payee
AS
(
SELECT
	 cte_1.CheckRequestID
	,cte_1.IsForeignCurrency
	,cte_1.Currency	
	,cte_1.AmountToPay
	,cte_1.Payee
	,cte_1.VendorNumber		
	,cte_1.VendorCompanyName	
	,cte_1.VendorInvoiceNumber	
	,cte_1.InvoiceDate
	,cte_1.VendorInvoiceAcquisitionCost
	,cte_1.VendorInvoiceOtherCost
	,cte_1.VendorInvoiceTotal
	,cte_1.AmountOnLease 
	,cte_1.OtherCostType
	,cte_1.OtherCostAllocation
	,cte_1.AccountNumber		
	,cte_1.CustomerName		
	,cte_1.SequenceNumber	
	,cte_1.EmployeeAssignment
FROM cte_1
)
,
cte_row
AS
(
SELECT 
	ROW_NUMBER() OVER(ORDER BY cte_payee.Payee) AS [Row_ID]
	,cte_payee.Payee
FROM cte_payee
GROUP BY cte_payee.Payee
)
SELECT
	 cte_1.CheckRequestID
	,cte_1.IsForeignCurrency
	,cte_1.Currency	
	,CAST(cte_1.AmountToPay AS MONEY) AmountToPay
	,cte_1.Payee
	,cte_row.Row_ID
	,cte_1.VendorNumber		
	,cte_1.VendorCompanyName	
	,cte_1.VendorInvoiceNumber	
	,cte_1.InvoiceDate
	,CAST(cte_1.VendorInvoiceAcquisitionCost AS MONEY) VendorInvoiceAcquisitionCost
	,CAST(cte_1.VendorInvoiceOtherCost AS MONEY) VendorInvoiceOtherCost
	,cte_1.VendorInvoiceTotal
	,CAST(cte_1.AmountOnLease AS MONEY) AmountOnLease
	,cte_1.OtherCostType
	,cte_1.OtherCostAllocation
	,cte_1.AccountNumber		
	,cte_1.CustomerName		
	,cte_1.SequenceNumber	
	,cte_1.EmployeeAssignment
FROM cte_1
INNER JOIN cte_row
	ON cte_1.Payee = cte_row.Payee
Where cte_row.Row_ID = 1</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CheckRequestID">
          <DataField>CheckRequestID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IsForeignCurrency">
          <DataField>IsForeignCurrency</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Currency">
          <DataField>Currency</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AmountToPay">
          <DataField>AmountToPay</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Payee">
          <DataField>Payee</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Row_ID">
          <DataField>Row_ID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="VendorNumber">
          <DataField>VendorNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VendorCompanyName">
          <DataField>VendorCompanyName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VendorInvoiceNumber">
          <DataField>VendorInvoiceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="InvoiceDate">
          <DataField>InvoiceDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="VendorInvoiceAcquisitionCost">
          <DataField>VendorInvoiceAcquisitionCost</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VendorInvoiceOtherCost">
          <DataField>VendorInvoiceOtherCost</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VendorInvoiceTotal">
          <DataField>VendorInvoiceTotal</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AmountOnLease">
          <DataField>AmountOnLease</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="OtherCostType">
          <DataField>OtherCostType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OtherCostAllocation">
          <DataField>OtherCostAllocation</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EmployeeAssignment">
          <DataField>EmployeeAssignment</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet2">
