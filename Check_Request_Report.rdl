  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>eeab912c-abc4-4ea2-9315-2d0e166de416</rd:DataSourceID>
    </DataSource>
