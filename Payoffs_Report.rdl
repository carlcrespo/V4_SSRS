          <QueryParameter Name="@PostDate2">
            <Value>=Parameters!PostDate2.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- Build 20180312
-- Payoffs Report
-- Work Order #32266 - Add Labeling Lessor
---------------------------------------------------
---- Test code   
--DECLARE 
--        @AccountNumber VARCHAR(20)
--       ,@SequenceNumber VARCHAR(30)
--       ,@PayoffTransactionType VARCHAR(30)
--       ,@PayoffStatus VARCHAR(20)
--       ,@QuoteCreateDate1 DATE -- from date
--       ,@QuoteCreateDate2 DATE -- to date
--       ,@TerminationDate1 DATE -- from date
--       ,@TerminationDate2 DATE -- to date
--       ,@PostDate1 DATE -- from date
--       ,@PostDate2 DATE -- to date

--SET @AccountNumber = '' 
--SET @SequenceNumber ='7095000009' -- '64780000713'
--SET @PayoffTransactionType = 'EOT Return' --'EOT Buyout'
--SET @PayoffStatus ='Sent'
--SET @QuoteCreateDate1 = '' 
--SET @QuoteCreateDate2 = '' 
--SET @TerminationDate1 = '' --'12/31/13' 
--SET @TerminationDate2 = '' --'12/31/13' 
--SET @PostDate1 = '' -- '1/1/2016' --'1/1/2018'
--SET @PostDate2 = '' -- '4/1/2016' -- '4/1/2018'
-----------------------------------------------------------
;WITH 
cte_payoffs
AS
(
		SELECT distinct
			 cp.AccountNumber
			,cp.CustomerName
			--------------------------
			-- 20190312
			,fp.Company LabelingLessor
,fp.FundingSourceId
,fp.Alias
			--------------------------
			,lp.SequenceNumber
			,ls.description LeaseStatus
			,ptc.Description as PayoffTransactionType
			,pqc.Description as PayoffStatus
			,[QuoteName]
			,Convert (Date,[QuoteRunDate]) as QuoteCreateDate
			,Convert (Date,pd.ComputeDate) as TerminationDate
			,ISNULL(Convert (Date,[PostDate]),'2098-01-01') as PostDate
			
		  FROM [dbo].[Payoff_Quote] PQ

		  inner join [dbo].[Payoff_TransactionType_Cnfg] PTC
		  on pq.payofftransactiontypeid=ptc.PayoffTransactionTypeID

		  inner join [dbo].[PayOff_QuoteStatus_Cnfg] PQC
		  on pq.QuoteStatusID=pqc.PayOffQuoteStatusID
		  AND PQC.PayOffQuoteStatusID &lt;&gt; 5

		  inner join [dbo].[Lease_Profile] LP

		  on pq.leaseid=lp.leaseid

		  inner join [dbo].[Customer_Profile] CP
		  on lp.customerid=cp.CustomerID

		  inner join [dbo].[Payoff_FinancialDetail] PD
		  on pq.PayOffQuoteID=pd.PayOffQuoteID

		  inner join [dbo].[Lease_Status_Cnfg] LS
		  on lp.StatusId=ls.StatusID
----------------------------------------------------------
-- 20190312			
          LEFT JOIN FundingSource_Profile fp
              ON fp.FundingSourceID = lp.LabellingLessorID
----------------------------------------------------------
		  )
SELECT
	 a.AccountNumber
	,a.CustomerName
	-------------------------
	-- 20190312
	,a.LabelingLessor
,a.FundingSourceId
,a.Alias
	-------------------------
	,a.SequenceNumber
	,a.LeaseStatus
	,a.PayoffTransactionType
	,a.PayoffStatus
	,a.[QuoteName]
	,FORMAT(a.QuoteCreateDate,'yyyy-MM-dd') QuoteCreateDate
	,FORMAT(a.TerminationDate,'yyyy-MM-dd') TerminationDate
	,REPLACE(FORMAT(a.PostDate,'yyyy-MM-dd'),'2098-01-01','') PostDate
FROM cte_payoffs a
WHERE 
		a.AccountNumber LIKE IIF(@AccountNumber='','%',@AccountNumber)
	AND a.SequenceNumber LIKE IIF(@SequenceNumber='','%',@SequenceNumber)
	AND a.QuoteCreateDate BETWEEN IIF(@QuoteCreateDate1='','1/1/1980',@QuoteCreateDate1) AND IIF(@QuoteCreateDate2='','1/1/2099',@QuoteCreateDate2)
	AND a.TerminationDate BETWEEN IIF(@TerminationDate1='','1/1/1980',@TerminationDate1) AND IIF(@TerminationDate2='','1/1/2099',@TerminationDate2)
	AND a.PostDate BETWEEN IIF(@PostDate1='','1/1/1980',@PostDate1) AND IIF(@PostDate2 ='' ,'1/1/2099',@PostDate2)
	AND a.PayoffTransactionType IN (@PayoffTransactionType)
	AND a.PayoffStatus IN (@PayoffStatus)</CommandText>
      </Query>
      <Fields>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LabelingLessor">
          <DataField>LabelingLessor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FundingSourceId">
          <DataField>FundingSourceId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Alias">
          <DataField>Alias</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LeaseStatus">
          <DataField>LeaseStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PayoffTransactionType">
          <DataField>PayoffTransactionType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PayoffStatus">
          <DataField>PayoffStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QuoteName">
          <DataField>QuoteName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="QuoteCreateDate">
          <DataField>QuoteCreateDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TerminationDate">
          <DataField>TerminationDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PostDate">
          <DataField>PostDate</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
