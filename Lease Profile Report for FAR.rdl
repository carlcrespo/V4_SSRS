  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LW_PRD</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Company">
            <Value>=Parameters!Company.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Att">
            <Value>=Parameters!Att.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20220301

--Tammy 2021 Year End Request - Leases Extract
--DECLARE @Company VARCHAR(50)='Garnier Group &amp; Associates, LLC'
--, @ATT VARCHAR(50)='Operating'
; WITH
CTE_PAYMENTCOUNT
As
(
SELECT LeaseID
	  ,COUNT(LEASEID) as CNT
      FROM Lease_PaymentSchedule
	  WHERE IsActive = 1
	  Group By LeaseID
)
,
cte_rpt
AS
(
Select 
LP.SequenceNumber
,CP.AccountNumber
,CP.CompanyName
,FORMAT(LC.InceptionDate,'MM/dd/yyyy') as CommencementDate
,FORMAT(LC.MaturityDate,'MM/dd/yyyy') as MaturityDate
,CASE WHEN LP.IsOverTermPaymentLease = 0 THEN 'No' ELSE 'Yes' END AS 'OTP Lease'
,LATTC.Description AS 'Accounting Treatment Type'
,ISNULL(GLT.Name,'') AS 'OTP AR GL Template'
,ISNULL(GLT2.Name,'') AS 'OTP Income GL Template'
,FSP.Company
,GLT3.Name AS 'Receipt Cash GL Template'
,GLT4.Name AS 'Virtual Cash GL Template'
,ISNULL(FORMAT(LU.NPCCSaleDate,'MM/dd/yyyy'),'') AS 'NPCC Sale Date'
,LCPOCL.PurchaseOption as 'Purchase Option'
,LI.ResidualBookedAmount as 'Residual Booked'
,ISNULL(LPOSTCL.PurchaseOptionSubType,'') as 'Purchase Option SubType'
,PaymentCount.CNT as 'Number of Payments'
,CASE WHEN LC.InceptionPaymentNumber = 1 THEN 'Advance' ELSE 'Arrears' END AS'FIRM TERM ADV/ARR'
,CASE WHEN MML.PractOTPAdvancePayment = 1 THEN 'Advance' ELSE 'Arrears' END AS'OTP ADV/ARR'
,LRFCL.RentalFrequencyName As 'Rental Frequency'
,'Lease Term'=CONVERT(smallint,LC.Term)
,LCSCL.LeaseStructureName As 'Lease Structure'
,LRFCL2.RentalFrequencyName As 'Irregular Rental Frequency'
,LC.RegularPaymentAmount As 'Regular Payment Amount'
,LBSCL.BookingStatusName As 'Booking Status'
,LSCL.StatusName As 'Status'
,LLCP.LLCName As 'Currency'

From Lease_Profile LP
Left Join Customer_Profile CP
ON LP.CustomerID = CP.CustomerID
Left Join Lease_Contract LC
ON LP.LeaseID = LC.LeaseID
Left Join Lease_Investment LI
ON LP.LeaseID = LI.LeaseId
Left Join Lease_AccountingTreatmentType_Cnfg LATTC
On LI.AccountingTreatmentTypeId = LATTC.AccountingTreatmentTypeID
Left Join GeneralLedger_Template GLT
ON LP.OverTermPaymentARGLTemplateID = GLT.TemplateId
Left Join GeneralLedger_Template GLT2
ON LP.OverTermPaymentIncomeGLTemplateID = GLT2.TemplateId
Left Join FundingSource_Profile FSP
ON LP.LabellingLessorID = FSP.FundingSourceId
Left Join GeneralLedger_Template GLT3
ON LP.ReceiptCashGLTemplateID = GLT3.TemplateId
Left Join GeneralLedger_Template GLT4
ON LP.PayagencyCashReceiptGLTemplateID = GLT4.TemplateId
Left Join Lease_UDF LU
ON LP.LeaseID = LU.LeaseID
Left Join Lease_ContractPurchaseOption_CnfgLocale LCPOCL
ON LI.PurchaseOptionID = LCPOCL.PurchaseOptionID
Left Join Lease_PurchaseOptionSubType_CnfgLocale LPOSTCL
ON LI.PurchaseOptionSubTypeID = LPOSTCL.PurchaseOptionSubTypeID
Inner Join CTE_PAYMENTCOUNT PaymentCount
ON LP.LeaseID = PaymentCount.LeaseID
LEFT JOIN MaturityManagement_Lease MML
ON LP.LeaseID = MML.LeaseID
LEFT JOIN Lease_RentalFrequency_CnfgLocale LRFCL
ON LC.RentalFrequencyID = LRFCL.RentalFrequencyID
LEFT JOIN Lease_ContractStructure_CnfgLocale LCSCL
ON LC.ContractStructureId = LCSCL.ContractStructureId
LEFT JOIN Lease_RentalFrequency_CnfgLocale LRFCL2
ON LC.IrregularRentalFrequencyID = LRFCL2.RentalFrequencyID
LEFT JOIN Lease_BookingStatus_CnfgLocale LBSCL
ON LP.BookingStatusId = LBSCL.BookingStatusID
LEFT JOIN Lease_Status_CnfgLocale LSCL
ON LP.StatusId=LSCL.StatusID
LEFT JOIN LLC_Profile LLCP
ON LP.LLCID = LLCP.LLCID

WHERE LC.IsActive = 1
AND LI.IsActive = 1
AND LP.BookingStatusId = 2
AND LP.StatusId in (2,3,6)  

)
SELECT *
FROM cte_rpt
WHERE Company IN (@Company) and [Accounting Treatment Type] in (@Att)
ORDER BY AccountNumber,SequenceNumber</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
