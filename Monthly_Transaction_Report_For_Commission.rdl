        <CommandText>-- 20191021
--Please review, added Payoff transaction Name for Buy Out and Payoff
--USE [LW_PROD]
--GO
--/****** Object:  StoredProcedure [dbo].[IIC_MonthlyTransactionReportForCommission_20160225]    Script Date: 3/22/2018 9:45:27 AM ******/
----SET ANSI_NULLS ON
----GO
----SET QUOTED_IDENTIFIER ON
----GO

----ALTER PROCEDURE [dbo].[IIC_MonthlyTransactionReportForCommission_20160225]  
----(  
--Declare
--          @FromDate DATETIME = '2/1/2018'
--       , @ToDate DATETIME = '2/28/2018'
--       , @CultureID VARCHAR(15)
----)  
------WITH ENCRYPTION  
----AS
----BEGIN

--IF @CultureID IS NULL OR LEN(@CultureID) = 0  
--BEGIN  
--       SET @CultureID = 'en-US'  
--END 

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;  
SET NOCOUNT ON;
--Drop Table #AllReceiptDetails
CREATE TABLE #AllReceiptDetails(ReceiptID BIGINT,LeaseID INT,TransactionAmount DECIMAL(18,2),InvoiceID BIGINT,ReceivableType NVARCHAR(50),ReceiptComment NVARCHAR(400),PostDate DATE,ReversedReceiptID BIGINT
, ReceiptTypeName VARCHAR(30)
)
;
-------------------------
-- 20180322
--;WITH 
--CTE_AllReceiptDetails
--AS
--(

SELECT 
         o.ReceiptID 
       , o.LeaseID
       , o.TransactionAmount 
       , o.InvoiceID
       , o.ReceivableType
       , o.ReceiptComment
       , o.PostDate
       , o.ReversedReceiptID
       , o.ReceiptTypeName
INTO #CTE_AllReceiptDetails -- Drop Table #CTE_AllReceiptDetails
FROM
(
       SELECT 
                Receipt_Header.ReceiptID 
              , Receipt_DealDetail.EntityID AS LeaseID
              , SUM(Receipt_ReceivableDetail.AmountPosted) AS TransactionAmount 
              , Invoice_Header.InvoiceID
              , Receivable_Type_CnfgLocale.ReceivableTypeName AS ReceivableType
              , Receipt_Header.Comment AS ReceiptComment
              , Receipt_Header.PostDate  AS PostDate
              , Receipt_Header.ReversedReceiptID
------------------------------------------------------------------------------------------------------------------------------------------------------
-- 20180322
              ,(SELECT  [ReceiptTypeName] FROM [dbo].[Receipt_Type_CnfgLocale] WHERE ReceiptTypeID = Receipt_Header.PaymentTypeID) ReceiptTypeName
------------------------------------------------------------------------------------------------------------------------------------------------------
       FROM 
              Receipt_Header

              INNER JOIN Receipt_DealDetail
                     ON Receipt_DealDetail.ReceiptID = Receipt_Header.ReceiptID
                     AND Receipt_DealDetail.EntityTypeID = 5 --Lease

              INNER JOIN Receipt_ReceivableDetail
                     ON Receipt_ReceivableDetail.ReceiptDealDetailID = Receipt_DealDetail.ReceiptDealDetailID

              INNER JOIN Receivable_Type_CnfgLocale
                     ON Receipt_ReceivableDetail.ReceivableTypeID = Receivable_Type_CnfgLocale.ReceivableTypeID
                     --AND Receivable_Type_CnfgLocale.CultureID = @CultureID

              INNER JOIN Invoice_Header
                     ON Invoice_Header.InvoiceID = Receipt_ReceivableDetail.InvoiceID
              
              LEFt JOIN Receivable_Sundry
                     ON Receivable_Sundry.ReceivableTypeID = Receipt_ReceivableDetail.ReceivableTypeID
                     AND Receivable_Sundry.ReceivableID = Receipt_ReceivableDetail.ReceivableID 
                     AND Receivable_Sundry.IsActive = 1
       WHERE 
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
-- 20180322
                --(Receipt_ReceivableDetail.ReceivableTypeID IN (3,5) -- OTP, Buyout
                (Receipt_ReceivableDetail.ReceivableTypeID IN (SELECT ReceivableTypeID FROM Receivable_Type_CnfgLocale WHERE ReceivableTypeName IN ('Over Term','Pay Off','Buy Out')) -- 3,4,5
-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
-- 20180322
              --OR (Receipt_ReceivableDetail.ReceivableTypeID IN (9) 
              OR (Receipt_ReceivableDetail.ReceivableTypeID IN (SELECT ReceivableTypeID FROM Receivable_Type_CnfgLocale WHERE ReceivableTypeName IN ('Sundry  (Deal - Based)')) -- 9
-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
              AND Receivable_Sundry.SundryCodeTemplateID IN (Select SundryCodeTemplateID FROM Sundry_Code WHERE SundryCodeTemplateName IN ('SLSEQ','SLSEQTX'))))--Sundry charges of the Sundry code “SLSEQ” and “SLSEQTX” (for migrated buyout charges).
              AND Receipt_Header.PostDate BETWEEN @FromDate AND @ToDate
              --AND Invoice_Header.DueDate &lt;= @ToDate
              AND Receipt_Header.IsBatchApplied = 1 
              
       GROUP BY
                Receipt_Header.ReceiptID 
              , Receipt_DealDetail.EntityID
              , Invoice_Header.InvoiceID
              , Receivable_Type_CnfgLocale.ReceivableTypeName
              , Receipt_Header.Comment
              , Receipt_Header.PostDate
              , Receipt_Header.ReversedReceiptID
-------------------------------------
-- 20180322
              ,Receipt_Header.PaymentTypeID
-------------------------------------
) o

--)
INSERT INTO #AllReceiptDetails
SELECT
         #CTE_AllReceiptDetails.ReceiptID 
       , #CTE_AllReceiptDetails.LeaseID
       , #CTE_AllReceiptDetails.TransactionAmount 
       , #CTE_AllReceiptDetails.InvoiceID
       , #CTE_AllReceiptDetails.ReceivableType
       , #CTE_AllReceiptDetails.ReceiptComment
       , #CTE_AllReceiptDetails.PostDate
       , #CTE_AllReceiptDetails.ReversedReceiptID
       ,#CTE_AllReceiptDetails.ReceiptTypeName
FROM
       #CTE_AllReceiptDetails

Drop Table #CTE_AllReceiptDetails
--  Drop Table #AllReceiptDetails
--SELECT * FROM #AllReceiptDetails

;WITH CTE_SalesPerson
AS
(
       SELECT 
                COALESCE(MAX(LeaseLevel.EmployeeAssignmentID), MAX(CustomerLevel.EmployeeAssignmentID)) AS SalesPerson
              , Lease_Profile.LeaseID
       FROM 
              Lease_Profile
              INNER JOIN #AllReceiptDetails
                     ON #AllReceiptDetails.LeaseID = Lease_Profile.LeaseID
              LEFT JOIN EmployeeAssignment_Entity LeaseLevel
                     ON LeaseLevel.EntityID = Lease_Profile.LeaseID
                     AND LeaseLevel.RoleFunctionID = 8  --Sales Rep
                     AND LeaseLevel.EntityTypeID = 5 --Lease
                     AND LeaseLevel.IsActive = 1 --Active
              LEFT JOIN EmployeeAssignment_Entity as CustomerLevel
                     ON CustomerLevel.EntityID = Lease_Profile.CustomerID
                     AND  CustomerLevel.RoleFunctionID = 8  --Sales Rep
                     AND CustomerLevel.EntityTypeID = 1 --Customer
                     AND CustomerLevel.IsActive = 1 --Active
       GROUP BY 
                LeaseLevel.RoleFunctionID
              , CustomerLevel.RoleFunctionID
              , Lease_Profile.LeaseID
),
CTE_InvoiceReceivableDetail
AS
(
       SELECT 
                InvoiceIDList.InvoiceID
              , Invoice_ReceivableDetail.InvoiceReceivableDetailID
              , Invoice_ReceivableDetail.ReceivableID
              , Invoice_ReceivableDetail.ReceivableTypeID
              FROM 
                     ( select distinct InvoiceID FROM  #AllReceiptDetails)  as InvoiceIDList 

                     INNER JOIN Invoice_DealDetail
                           ON Invoice_DealDetail.InvoiceID = InvoiceIDList.InvoiceID
                           AND Invoice_DealDetail.EntityTypeID = 5 --Lease

                     INNER JOIN Invoice_ReceivableDetail
                           ON Invoice_ReceivableDetail.InvoiceDealDetailID = Invoice_DealDetail.InvoiceDealDetailID
),
CTE_RentalPeriods
AS
(
       SELECT 
                CTE_InvoiceReceivableDetail.InvoiceID
              , CASE WHEN COUNT(DISTINCT Invoice_ReceivableDetail.RentalPeriodFromDate) &gt; 1 THEN '01/01/1900' ELSE MIN(Invoice_ReceivableDetail.RentalPeriodFromDate) END as RentalPeriodFromDate
              , CASE WHEN COUNT(DISTINCT Invoice_ReceivableDetail.RentalPeriodTODate) &gt; 1 THEN '01/01/1900' ELSE MAX(Invoice_ReceivableDetail.RentalPeriodTODate) END as RentalPeriodToDate
              , SUM(Amount) as OriginalInvoiceAmount
              FROM 
                     CTE_InvoiceReceivableDetail

                     INNER JOIN Invoice_ReceivableDetail
                           ON Invoice_ReceivableDetail.InvoiceReceivableDetailID = CTE_InvoiceReceivableDetail.InvoiceReceivableDetailID

       GROUP BY CTE_InvoiceReceivableDetail.InvoiceID
),
CTE_OTPReceivableDuedate
AS
(
       SELECT 
                CTE_InvoiceReceivableDetail.InvoiceID
              , CASE WHEN COUNT(DISTINCT Receivable_OtherPaymentTax.Duedate) &gt; 1 THEN '01/01/1900' ELSE MAX(Receivable_OtherPaymentTax.Duedate) END as ReceivableDuedate
              , SUM(Receivable_OtherPaymentTax.Amount) AS Amount
              FROM 
                     CTE_InvoiceReceivableDetail

                     INNER JOIN Receivable_OtherPaymentTax
                           ON Receivable_OtherPaymentTax.ReceivableID = CTE_InvoiceReceivableDetail.ReceivableID
                           AND Receivable_OtherPaymentTax.ReceivableTypeID = CTE_InvoiceReceivableDetail.ReceivableTypeID
                           AND Receivable_OtherPaymentTax.InvoiceID = CTE_InvoiceReceivableDetail.InvoiceID
                           AND Receivable_OtherPaymentTax.ReceivableTypeID = 3

       GROUP BY CTE_InvoiceReceivableDetail.InvoiceID
),
CTE_BuyoutReceivableDuedate
AS
(
       SELECT 
                CTE_InvoiceReceivableDetail.InvoiceID
              , CASE WHEN COUNT(DISTINCT Receivable_PayOffTax.Duedate) &gt; 1 THEN '01/01/1900' ELSE MAX(Receivable_PayOffTax.Duedate) END as ReceivableDuedate
              , SUM(Receivable_PayOffTax.Amount) AS Amount
       FROM 
                     CTE_InvoiceReceivableDetail

                     INNER JOIN Receivable_PayOffTax
                           ON Receivable_PayOffTax.ReceivableID = CTE_InvoiceReceivableDetail.ReceivableID
                           AND Receivable_PayOffTax.ReceivableTypeID = CTE_InvoiceReceivableDetail.ReceivableTypeID
                           AND Receivable_PayOffTax.InvoiceID = CTE_InvoiceReceivableDetail.InvoiceID

       GROUP BY CTE_InvoiceReceivableDetail.InvoiceID
),
CTE_SundryReceivableDuedate
AS
(
       SELECT 
                CTE_InvoiceReceivableDetail.InvoiceID
              , CASE WHEN COUNT(DISTINCT Receivable_SundryTax.Duedate) &gt; 1 THEN '01/01/1900' ELSE MAX(Receivable_SundryTax.Duedate) END as ReceivableDuedate
              , SUM(Receivable_SundryTax.Amount) AS Amount
       FROM 
                     CTE_InvoiceReceivableDetail

                     INNER JOIN Receivable_SundryTax
                           ON Receivable_SundryTax.ReceivableID = CTE_InvoiceReceivableDetail.ReceivableID
                           AND Receivable_SundryTax.ReceivableTypeID = CTE_InvoiceReceivableDetail.ReceivableTypeID
                           AND Receivable_SundryTax.InvoiceID = CTE_InvoiceReceivableDetail.InvoiceID
       GROUP BY CTE_InvoiceReceivableDetail.InvoiceID
)
,
------------------------------------------------------------------------
-- 20180323
cte_PayoffTransactionType
AS
(
SELECT 
          qh.PayOffQuoteInvoiceID
      ,qh.InvoiceNumberID
         ,qd.PayOffQuoteID
         ,pq.PayoffTransactionTypeID
         ,pt.PayoffTransactionTypeName
  FROM Payoff_QuoteInvoiceHeader qh
  LEFT JOIN Payoff_QuoteInvoiceLeaseDetail qd
       ON qh.PayOffQuoteInvoiceID = qd.PayOffQuoteInvoiceID
  INNER JOIN Payoff_Quote pq
       ON pq.PayOffQuoteID = qd.PayOffQuoteID
  INNER JOIN Payoff_TransactionType_Cnfglocale pt
       ON pt.PayoffTransactionTypeID = pq.PayoffTransactionTypeID
)
,
---------------------------------------------------------------------
CTE_FinalResult
AS
(
       SELECT
                 Receipt_Header.ReceiptID 
              ,  FundingSource_Profile.Company AS LabellingLessor
              , Customer_Profile.AccountNumber AS CustomerNumber
              , Customer_Profile.CustomerName
              , Lease_Profile.SequenceNumber AS LeaseNumber
              , #AllReceiptDetails.TransactionAmount AS TransactionAmount
              , Invoice_Number.InvoiceNumber
              , CTE_RentalPeriods.OriginalInvoiceAmount AS OriginalInvoiceAmount
              , #AllReceiptDetails.PostDate AS TransactionDate
              , #AllReceiptDetails.ReceivableType
              , #AllReceiptDetails.ReceiptComment
              , CASE WHEN Receipt_Header.ReversedDate IS NOT NULL --Reversal Receipt
                     THEN 'Receipt Reversal'
                     ELSE 'Receipt Posting'
                END AS TransactionType
              , COALESCE(Invoice_BatchHeader.RunDate,PayOff_QuoteInvoiceHeader.LastModifiedDate) AS InvoiceDate
              , Invoice_Header.DueDate AS InvoiceDueDate
              , CASE WHEN (Receipt_Header.ReversedDate IS NOT NULL AND ((#AllReceiptDetails.TransactionAmount * -1) = COALESCE(CTE_OTPReceivableDuedate.Amount,CTE_BuyoutReceivableDuedate.Amount,CTE_SundryReceivableDuedate.Amount))) --Complete Write-off
                     THEN 'Complete Write-off'
                     ELSE ''
                END AS TransactionComment
              , CASE WHEN Invoice_Header.OutstandingNonMemoBalance = 0 --Closed
                     THEN 'C'
                     ELSE 'O'
                END AS InvoiceStatus
              , Security_UserProfile.FirstName + ' ' + Security_UserProfile.LastName AS SalesPerson
              , CTE_RentalPeriods.RentalPeriodFromDate 
              , CTE_RentalPeriods.RentalPeriodToDate
              , COALESCE(CTE_OTPReceivableDuedate.ReceivableDuedate,CTE_BuyoutReceivableDuedate.ReceivableDuedate,CTE_SundryReceivableDuedate.ReceivableDuedate) as ReceivableDuedate
-----------------------------------------------------------
-- 20180322
              ,#AllReceiptDetails.ReceiptTypeName
              ,ISNULL(Receipt_Header.CheckNumber, '') CheckNumber
-----------------------------------------------------------
-- 20180323
                     ,PayOff_QuoteInvoiceHeader.PayOffQuoteInvoiceID
       FROM 
              #AllReceiptDetails 

              INNER JOIN Lease_Profile
                     ON #AllReceiptDetails.LeaseID = Lease_Profile.LeaseID

              INNER JOIN Customer_Profile
                     ON Lease_Profile.CustomerID = Customer_Profile.CustomerID

              INNER JOIN FundingSource_Profile
                     ON Lease_Profile.LabellingLessorID = FundingSource_Profile.FundingSourceID

              INNER JOIN Invoice_Header
                     ON #AllReceiptDetails.InvoiceID = Invoice_Header.InvoiceID
                     AND Invoice_Header.InvoiceStatusID = 1 --Active

              INNER JOIN Invoice_Number
                     ON Invoice_Header.InvoiceNumberID = Invoice_Number.InvoiceNumberID

              INNER JOIN Receipt_Header
                     ON #AllReceiptDetails.ReceiptID = Receipt_Header.ReceiptID

              LEFT JOIN Invoice_BatchHeader
                     ON Invoice_Header.InvoiceBatchID = Invoice_BatchHeader.InvoiceBatchID

              LEFT JOIN PayOff_QuoteInvoiceHeader
                     ON Invoice_Header.InvoiceID = PayOff_QuoteInvoiceHeader.InvoiceID

              LEFT JOIN CTE_SalesPerson
                     ON Lease_Profile.LeaseID = CTE_SalesPerson.LeaseID

              LEFT JOIN EmployeeAssignment_Entity
                     ON CTE_SalesPerson.SalesPerson = EmployeeAssignment_Entity.EmployeeAssignmentID

              LEFT JOIN Security_UserProfile
                     ON EmployeeAssignment_Entity.UserID = Security_UserProfile.UserID
                     AND Security_UserProfile.IsActive = 1 --Active

              LEFT JOIN CTE_RentalPeriods
                     ON CTE_RentalPeriods.InvoiceID = Invoice_Header.InvoiceID

              LEFT JOIN CTE_OTPReceivableDuedate
                     ON CTE_OTPReceivableDuedate.InvoiceID = Invoice_Header.InvoiceID
              
              LEFT JOIN CTE_BuyoutReceivableDuedate
                     ON CTE_BuyoutReceivableDuedate.InvoiceID = Invoice_Header.InvoiceID

              LEFT JOIN CTE_SundryReceivableDuedate
                     ON CTE_SundryReceivableDuedate.InvoiceID = Invoice_Header.InvoiceID

)

SELECT 
------------------------------------------------------------------------------
-- 20180322
       IIF(CTE_FinalResult.LabellingLessor LIKE '%Garnier%','03','01') Company , 
------------------------------------------------------------------------------
       CTE_FinalResult.LabellingLessor
       , CTE_FinalResult.CustomerNumber
       , CTE_FinalResult.CustomerName
       , CTE_FinalResult.LeaseNumber
       , SUM(CTE_FinalResult.TransactionAmount) AS TransactionAmount
       , CTE_FinalResult.InvoiceNumber
       , CTE_FinalResult.OriginalInvoiceAmount
       , CTE_FinalResult.TransactionDate
       , CTE_FinalResult.ReceivableType
-------------------------------------
-- 20180323
              ,ISNULL(tt.PayoffTransactionTypeName,'') PayoffTransactionTypeName
-------------------------------------
       , CTE_FinalResult.ReceiptComment
       , CTE_FinalResult.TransactionType
       , CTE_FinalResult.InvoiceDate
       , CTE_FinalResult.InvoiceDueDate
       , CTE_FinalResult.TransactionComment
       , CTE_FinalResult.InvoiceStatus
       , CTE_FinalResult.SalesPerson
       , CTE_FinalResult.RentalPeriodFromDate
       , CTE_FinalResult.RentalPeriodToDate
       , CTE_FinalResult.ReceivableDuedate
-------------------------------------
-- 20180322
       , CTE_FinalResult.ReceiptTypeName
       , CTE_FinalResult.CheckNumber
-------------------------------------
FROM 
       CTE_FinalResult
----------------------------------------------------------------------------------------
-- 20180323
              Left JOIN cte_PayoffTransactionType tt
                     ON tt.PayOffQuoteInvoiceID = CTE_FinalResult.PayOffQuoteInvoiceID
----------------------------------------------------------------------------------------
GROUP BY
         CTE_FinalResult.LabellingLessor
       , CTE_FinalResult.CustomerNumber
       , CTE_FinalResult.CustomerName
       , CTE_FinalResult.LeaseNumber
       , CTE_FinalResult.InvoiceNumber
       , CTE_FinalResult.OriginalInvoiceAmount
       , CTE_FinalResult.TransactionDate
       , CTE_FinalResult.ReceivableType
       , CTE_FinalResult.ReceiptComment
       , CTE_FinalResult.TransactionType
       , CTE_FinalResult.InvoiceDate
       , CTE_FinalResult.InvoiceDueDate
       , CTE_FinalResult.TransactionComment
       , CTE_FinalResult.InvoiceStatus
       , CTE_FinalResult.SalesPerson
       , CTE_FinalResult.RentalPeriodFromDate
       , CTE_FinalResult.RentalPeriodToDate
       , CTE_FinalResult.ReceivableDuedate
       , CTE_FinalResult.ReceiptID
------------------------------------
-- 20180322
       , CTE_FinalResult.ReceiptTypeName
       , CTE_FinalResult.CheckNumber
------------------------------------
-- 20180323
              ,CTE_FinalResult.PayOffQuoteInvoiceID
              ,tt.PayoffTransactionTypeName
-------------------------------------
ORDER BY
         CTE_FinalResult.ReceiptID
       , CTE_FinalResult.TransactionDate
       , CTE_FinalResult.CustomerName
       , CTE_FinalResult.LeaseNumber
       , CTE_FinalResult.LabellingLessor


DROP TABLE #AllReceiptDetails

--END 
</CommandText>
      </Query>
      <Fields>
        <Field Name="Company">
          <DataField>Company</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LabellingLessor">
          <DataField>LabellingLessor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerNumber">
          <DataField>CustomerNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
