          <DataField>ReceivableType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PayoffTransactionTypeName">
          <DataField>PayoffTransactionTypeName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
