    <DataSet Name="LabelingLessor">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LeaseSequenceNumber">
            <Value>=Parameters!LeaseSequenceNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT /*FundingSourceNumber*/ Company AS [LabellingLessor] 
, Company
, FundingSourceId
,FundingSourceNumber
,Alias
FROM FundingSource_Profile 
WHERE FundingSourceId IN (SELECT [LabellingLessorID] 
FROM Lease_Profile 
WHERE SequenceNumber =@LeaseSequenceNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="LabellingLessor">
          <DataField>LabellingLessor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Company">
          <DataField>Company</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FundingSourceId">
          <DataField>FundingSourceId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FundingSourceNumber">
          <DataField>FundingSourceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Alias">
          <DataField>Alias</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
