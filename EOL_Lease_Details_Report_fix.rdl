    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LeaseSequenceNumber">
            <Value>=Parameters!LeaseSequenceNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20210920   
----------------------------------------------
-- test
--DECLARE @LeaseSequenceNumber NVARCHAR(50) ='9028-1' -- '6955Q20122-36-1'   --'051603000051'
----------------------------------------------

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;  
SET NOCOUNT ON;

;WITH
CTE_AllAssetsInLease
AS
(
	SELECT DISTINCT 
			Lease_Profile.LeaseID	
			,Currency_Symbol_Cnfg.Symbol													-- #00001
			,Currency_Symbol_Cnfg.ISO														-- #00001		
			,InventoryID
			---------------------------------------------------------------------
			--Rev 20151007
			,Lease_Profile.ExpectedInceptionDate
			,Lease_Profile.ExpectedMaturityDate
			---------------------------------------------------------------------
	  FROM Lease_Profile
	 INNER JOIN Lease_InventoryInLease 
		ON Lease_InventoryInLease.LeaseID = Lease_Profile.LeaseID
	   AND Lease_InventoryInLease.IsInLease = 1
	  LEFT JOIN LLC_Profile																	-- #00001
		ON Lease_Profile.LLCID = LLC_Profile.LLCID 
	  LEFT JOIN Currency_Index																-- #00001
		ON LLC_Profile.CurrencyIndexID = Currency_Index.CurrencyIndexID		
	  LEFT JOIN Currency_Symbol_Cnfg														-- #00001
		ON Currency_Index.CurrencySymbolID = Currency_Symbol_Cnfg.SymbolId 
	 WHERE Lease_Profile.SequenceNumber = @LeaseSequenceNumber

	UNION ALL

	SELECT	Lease_Profile.LeaseID	
			,Currency_Symbol_Cnfg.Symbol													-- #00001
			,Currency_Symbol_Cnfg.ISO														-- #00001		
			,Lease_InventoryInLease.InventoryID
			---------------------------------------------------------------------
			--Rev 20151007
			,Lease_Profile.ExpectedInceptionDate
			,Lease_Profile.ExpectedMaturityDate
			---------------------------------------------------------------------
	  FROM Lease_Profile
	 INNER JOIN Lease_InventoryInLease 
		ON Lease_InventoryInLease.LeaseID = Lease_Profile.LeaseID
	   AND Lease_InventoryInLease.IsInLease = 0
	 INNER JOIN Payoff_InventoryInQuote
	 	ON Lease_InventoryInLease.InventoryID = Payoff_InventoryInQuote.InventoryID
	   AND Payoff_InventoryInQuote.InventoryPayoffStatusID &lt;&gt; 1 
	 INNER JOIN Payoff_Quote
		ON Payoff_Quote.LeaseID = Lease_Profile.LeaseID 
	   AND Payoff_InventoryInQuote.PayoffQuoteID = Payoff_Quote.PayoffQuoteID
	   AND ISNULL(Payoff_Quote.QuoteStatusID, 0) = 4 --Activated
	  LEFT JOIN LLC_Profile																	-- #00001
		ON Lease_Profile.LLCID = LLC_Profile.LLCID 
	  LEFT JOIN Currency_Index																-- #00001
		ON LLC_Profile.CurrencyIndexID = Currency_Index.CurrencyIndexID		
	  LEFT JOIN Currency_Symbol_Cnfg														-- #00001
		ON Currency_Index.CurrencySymbolID = Currency_Symbol_Cnfg.SymbolId 

	 WHERE Lease_Profile.SequenceNumber = @LeaseSequenceNumber
)
---------------------------------------
-- test code
--SELECT * FROM CTE_AllAssetsInLease
---------------------------------------
,
CTE_PayoffQuoteID
AS
(
	SELECT	CTE_AllAssetsInLease.InventoryID
			, Payoff_Quote.PayoffQuoteID
			, Payoff_TransactionTypeRelationship_CnfgLocale.EOLDetailsReport
			, Payoff_QuoteStatus_CnfgLocale.PayOffQuoteStatusName
	  FROM CTE_AllAssetsInLease
	 INNER JOIN Payoff_InventoryInQuote
	    ON Payoff_InventoryInQuote.InventoryID = CTE_AllAssetsInLease.InventoryID
	   AND Payoff_InventoryInQuote.InventoryPayoffStatusID &lt;&gt; 1 
	 INNER JOIN Payoff_Quote
		ON Payoff_Quote.LeaseID = CTE_AllAssetsInLease.LeaseID --Payoff Quote of Current Lease
	   AND Payoff_InventoryInQuote.PayoffQuoteID = Payoff_Quote.PayoffQuoteID
	   AND ISNULL(Payoff_Quote.QuoteStatusID, 0) &lt;&gt; 5 --InActive
	 INNER JOIN Payoff_TransactionTypeRelationship_Cnfg
		ON Payoff_InventoryInQuote.InventoryPayoffStatusID = Payoff_TransactionTypeRelationship_Cnfg.InventoryPayoffStatusID
	   AND Payoff_InventoryInQuote.InventoryStatusID = Payoff_TransactionTypeRelationship_Cnfg.InventoryStatusID
	   AND Payoff_InventoryInQuote.InventorySubStatusID = Payoff_TransactionTypeRelationship_Cnfg.InventorySubStatusID
	   AND Payoff_InventoryInQuote.PayOffQuoteID = Payoff_Quote.PayOffQuoteID
	 INNER JOIN Payoff_TransactionTypeRelationship_CnfgLocale
		ON Payoff_TransactionTypeRelationship_Cnfg.PayoffTransactionRelationID = Payoff_TransactionTypeRelationship_CnfgLocale.PayoffTransactionRelationID
	 --AND Payoff_TransactionTypeRelationship_CnfgLocale.CultureID = @CultureID
	  LEFT JOIN Payoff_QuoteStatus_CnfgLocale
		ON Payoff_Quote.QuoteStatusID = Payoff_QuoteStatus_CnfgLocale.PayOffQuoteStatusID
	 --AND Payoff_QuoteStatus_CnfgLocale.CultureID = @CultureID
)
----------------------------------------------------
-- test code
--SELECT * FROM CTE_PayoffQuoteID
----------------------------------------------------
,
cte_rpt
AS
(
	SELECT DISTINCT
			Inventory_Profile.InventoryID AS AssetNumber
			, Inventory_Profile.DerivedDescription AS EquipmentDescription
			, Inventory_Profile.Model
			, Inventory_Profile.SerialNumber
			, Inventory_ManufacturerTemplate.InventoryManufacturerName AS Manufacturer
			, CTE_AllAssetsInLease.Symbol																	-- #00001
			, CTE_AllAssetsInLease.ISO																		-- #00001
			, Lease_InventoryInLease.OverTermPaymentRentalAmount * (1 - (ISNULL(MaturityManagement_Lease.PractThirdReductionPercent,0) / 100)) AS [ModifiedRent#3]
			, Lease_InventoryInLease.OverTermPaymentRentalAmount * (1 - (ISNULL(MaturityManagement_Lease.PractSecondReductionPercent,0) / 100)) AS [ModifiedRent#2]
			, Lease_InventoryInLease.OverTermPaymentRentalAmount * (1 - (ISNULL(MaturityManagement_Lease.PractFirstReductionPercent,0) / 100)) AS ModifiedRent
			, Lease_InventoryInLease.OverTermPaymentRentalAmount AS OriginalRent
			, Inventory_Profile.RealOriginalCost AS EquipmentCost
			, Inventory_LocationTemplate.Address + CASE WHEN LEN(Inventory_LocationTemplate.Address2) &gt; 0 THEN ', ' + Inventory_LocationTemplate.Address2 ELSE '' END + ', ' + Inventory_LocationTemplate.City + ', ' + Inventory_LocationTemplate.County + ', ' + Template_State_CnfgLocale.StateShortName + ', ' + Template_Country_CnfgLocale.CountryName + ', ' + Inventory_LocationTemplate.ZIP AS EquipmentLocation
			, Inventory_TypeTemplate.InventoryTypeName AS EquipmentType
			-------------------------------------------------------------------
			--Rev 20151007
			--,d.InventoryCategoryName	
			-------------------------------------------------------------------
			, Payoff_FinancialInventoryDetail.ReturnedDate
			, Payoff_FinancialDetail.ComputeDate
			, Inventory_Profile.GreatPlainsIdentifier
			, CTE_PayoffQuoteID.PayoffQuoteID
			, CTE_PayoffQuoteID.PayOffQuoteStatusName
			, CTE_PayoffQuoteID.EOLDetailsReport AS InsightTransactionType
			--------------------------------------------------------------------
			--Rev 20151007, rev 20150623
			, Inventory_Profile.OrderNumber
			, Inventory_Profile.ChangeOrderNumber
			, Inventory_Profile.ContactPerson
			, Inventory_Profile.RoomNumber
			, Inventory_Profile.ReferenceNumber
			, Inventory_Profile.OtherReference
			, Inventory_Profile.CostCenter
			--------------------------------------------------------------------
			--Rev 20151007, 20150810 ID 703, WO 3585
			,Lease_InventoryInLease.[ResidualBookedAmount]
			--------------------------------------------------------------------
			--Rev 20151007, 20150810 ID 670, WO 3586
			,CAST(CTE_AllAssetsInLease.ExpectedInceptionDate AS DATE) ExpectedCommencmentDate
			,CAST(CTE_AllAssetsInLease.ExpectedMaturityDate AS DATE) ExpectedMaturityDate
			--------------------------------------------------------------------
			-- 20200102
			,CTE_AllAssetsInLease.LeaseID
			--------------------------------------------------------------------
	  FROM CTE_AllAssetsInLease 
	 INNER JOIN Lease_InventoryInLease 
		ON CTE_AllAssetsInLease.LeaseID = Lease_InventoryInLease.LeaseID
	   AND CTE_AllAssetsInLease.InventoryID = Lease_InventoryInLease.InventoryID
	  LEFT JOIN CTE_PayoffQuoteID
		ON CTE_PayoffQuoteID.InventoryID = Lease_InventoryInLease.InventoryID
	  LEFT JOIN Payoff_FinancialDetail
		ON CTE_PayoffQuoteID.PayOffQuoteID = Payoff_FinancialDetail.PayOffQuoteID
	  LEFT JOIN Payoff_FinancialInventoryDetail 
		ON Lease_InventoryInLease.InventoryID = Payoff_FinancialInventoryDetail.InventoryID
	   AND Payoff_FinancialInventoryDetail.PayoffQuoteID = CTE_PayoffQuoteID.PayoffQuoteID
	 INNER JOIN Inventory_Profile 
		ON Lease_InventoryInLease.InventoryID = Inventory_Profile.InventoryID
	 INNER JOIN Inventory_ManufacturerTemplate
		ON Inventory_Profile.InventoryManufacturerID = Inventory_ManufacturerTemplate.InventoryManufacturerID
	 INNER JOIN Inventory_TypeTemplate
		ON Inventory_Profile.InventoryTypeID = Inventory_TypeTemplate.InventoryTypeID
	 INNER JOIN Inventory_Location
		ON Inventory_Profile.InventoryID = Inventory_Location.InventoryID
	 INNER JOIN Inventory_LocationTemplate
		ON Inventory_Location.LocationTemplateID = Inventory_LocationTemplate.LocationTemplateID
	 INNER JOIN Template_State_Cnfg
		ON Inventory_LocationTemplate.StateID = Template_State_Cnfg.StateID
	   AND Template_State_Cnfg.IsActive = 1 --Active
	 INNER JOIN Template_State_CnfgLocale
		ON Template_State_Cnfg.StateID = Template_State_CnfgLocale.StateID
	 --AND Template_State_CnfgLocale.CultureID = @CultureID
	 INNER JOIN Template_Country_CnfgLocale
		ON Template_State_Cnfg.CountryID = Template_Country_CnfgLocale.CountryID
	 --AND Template_Country_CnfgLocale.CultureID = @CultureID
	  LEFT JOIN MaturityManagement_Lease 
		ON CTE_AllAssetsInLease.LeaseID = MaturityManagement_Lease.LeaseID
)
-----------------------
-- test code
--SELECT * FROM cte_rpt
-----------------------
--,
--cte_CatName
--AS
--(

--)
------------------------------
SELECT DISTINCT
		r.AssetNumber
		,r.EquipmentDescription
		,r.Model
		,r.SerialNumber
		,r.Manufacturer
		,r.Symbol																-- #00001
		,r.ISO																	-- #00001
		,r.[ModifiedRent#3]
		,r.[ModifiedRent#2]
		,r.ModifiedRent
		,r.OriginalRent
		,r.EquipmentCost
		,r.EquipmentLocation
		,r.EquipmentType
		,d.InventoryCategoryName	
		,r.ReturnedDate
		,r.ComputeDate
		,r.GreatPlainsIdentifier
		,r.PayoffQuoteID
		,r.PayOffQuoteStatusName
		,r.InsightTransactionType
		,r.OrderNumber
		,r.ChangeOrderNumber
		,r.ContactPerson
		,r.RoomNumber
		,r.ReferenceNumber
		,r.OtherReference
		,r.CostCenter
		,r.[ResidualBookedAmount]
		,r.ExpectedCommencmentDate
		,r.ExpectedMaturityDate
		,r.LeaseID
---------------------
-- 20210920
,fs.Company
,fs.FundingSourceNumber
,fs.Alias
  FROM cte_rpt r
	------------------------------------------------------------------------------------
	--Rev 20200102
  LEFT JOIN
		(
			SELECT DISTINCT 
					b.[InventoryInLeaseID]
					,b.[InventoryID],c.[InventoryCategoryName]
					,b.LeaseID
			  FROM [dbo].[Lease_InventoryInLease] b
			 INNER JOIN
  					(
						SELECT a.[InventoryID],a.[InventoryCategoryName]
						 FROM
							(
								-------------------------------------------------------------
								SELECT p.[InventoryID]
										,t.[InventoryCategoryName]
								  FROM [dbo].[Inventory_Profile] p
								 INNER JOIN [Inventory_CategoryTemplate] t
									ON p.[InventoryCategoryID]=t.[InventoryCategoryID]
								------------------------------------------------------------
							) a
					) c
				ON b.[InventoryID]=c.[InventoryID] 
		) d 
	 ON d.InventoryID=r.AssetNumber
	AND d.LeaseID = r.LeaseID
-----------------------------
-- 20210920
LEFT JOIN Lease_Profile lp
	ON r.LeaseID = lp.LeaseID 
LEFT JOIN FundingSource_Profile fs
       ON lp.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)
 -----------------------------------------------------------------------------------	
 ORDER BY
		r.AssetNumber

SET NOCOUNT ON;

----END</CommandText>
      </Query>
