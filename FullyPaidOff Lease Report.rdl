  <DataSets>
    <DataSet Name="dsPayOff">
      <Query>
        <DataSourceName>sLW_DB04</DataSourceName>
        <CommandText>-- 20200417
;
WITH
cte_rpt
AS
(
-- original logic
SELECT 
    fp.Company as Lessor
   ,CP.AccountNumber
   ,CP.CustomerName
   ,lp.SequenceNumber
   ,IIF (lp.StatusId=3,'FullyPaidOff', 'Active') LeaseStatus
   ,Convert (Date,lp.ExpectedInceptionDate) CommenceDate
   ,Convert (Date,lp.ExpectedMaturityDate) MaturityDate
   ,max (pq.payoffquoteID) PayoffQuoteID
   ,max (convert (date,pq.postdate)) PayoffPostDate
FROM Lease_Profile LP
INNER JOIN Customer_Profile CP
  ON LP.CustomerID=CP.CustomerID
INNER JOIN FundingSource_Profile FP
  ON lp.LabellingLessorID=fp.FundingSourceId
INNER JOIN Payoff_Quote PQ
  ON lp.leaseid=pq.leaseid
WHERE lp.statusid=3 and pq.isfullpayoff=1
GROUP BY
    lp.leaseid  
   ,fp.Company
   ,CP.AccountNumber
   ,CP.CustomerName
   ,SequenceNumber
   ,IIF (lp.StatusId=3,'FullyPaidOff', 'Active') 
   ,Convert (Date,ExpectedInceptionDate)
   ,Convert (Date,ExpectedMaturityDate)
--ORDER BY 
--        max(convert (date,pq.postdate)) 
--       ,cp.accountnumber
--       ,lp.sequencenumber  
)
----------------------------------
-- 20200417 WO#41423 revised logic
SELECT 
	 r.Lessor
	,r.AccountNumber
	,r.CustomerName
	,r.SequenceNumber
	,r.LeaseStatus
	,r.CommenceDate
	,r.MaturityDate
	,r.PayoffQuoteID
	,r.PayoffPostDate
	,pt.PayoffTransactionTypeName [Payoff Quote Trans Type] --&gt; new column
	--,FORMAT(pq.QuoteRunDate,'yyyy-MM-dd') [Processing Date] --&gt; new column
	,cast(pq.QuoteRunDate as date) [Processing Date]
FROM cte_rpt r
INNER JOIN Payoff_Quote pq
	ON r.PayoffQuoteID = pq.PayOffQuoteID
INNER JOIN Payoff_TransactionType_Cnfglocale pt
	ON pt.PayoffTransactionTypeID = pq.PayoffTransactionTypeID--ORDER BY 
ORDER BY 
	 r.PayoffPostDate 
	,r.accountnumber
	,r.sequencenumber </CommandText>
      </Query>
      <Fields>
        <Field Name="Lessor">
          <DataField>Lessor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LeaseStatus">
          <DataField>LeaseStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CommenceDate">
          <DataField>CommenceDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="MaturityDate">
          <DataField>MaturityDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="PayoffQuoteID">
          <DataField>PayoffQuoteID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="PayoffPostDate">
          <DataField>PayoffPostDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Payoff_Quote_Trans_Type">
          <DataField>Payoff Quote Trans Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Processing_Date">
          <DataField>Processing Date</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
