        <CommandText>-- 20210929 patch: MaturityManagement_Lease from inner to left outer

--SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED
--USE [LW_PROD]
--GO
--/****** Object:  StoredProcedure [dbo].[IIC_Leases_Added_Report_20160405]    Script Date: 8/23/2016 11:45:26 AM ******/
--SET ANSI_NULLS ON
--GO
--SET QUOTED_IDENTIFIER ON
--GO
--ALTER PROCEDURE [dbo].[IIC_Leases_Added_Report_20160405]  
--( 
--	   @FromDate DATETIME
--	 , @ToDate DATETIME
--	 --, @CultureID VARCHAR(15)
--)  
----WITH ENCRYPTION  
--AS
--------------------------------------------------
---- test code
--DECLARE
	--   @FromDate DATETIME = '6/1/2020'
	 --, @ToDate DATETIME = '7/31/2020'
	 --, @CultureID VARCHAR(15)
--------------------------------------------------
--BEGIN

----IF @CultureID IS NULL OR LEN(@CultureID) = 0  
----BEGIN  
----	SET @CultureID = 'en-US'  
----END

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;  
--SET NOCOUNT ON;

DECLARE @LeaseDetails TABLE (LeaseID INT,
							 CustomerID INT,
							 LeaseContractId INT,
							 PostDate DATETIME)

INSERT INTO @LeaseDetails
SELECT	 LeaseID
		, CustomerID
		, LeaseContractId
		, PostDate
FROM
(	SELECT
		  Lease_profile.LeaseID
		, Customer_profile.CustomerID
		, Lease_Contract.LeaseContractId
		, ROW_NUMBER() OVER(PARTITION BY Lease_Contract.LeaseID ORDER BY Lease_Contract.LeaseContractId) RowNum
		, Lease_Contract.PostDate
	FROM 
		Lease_profile

		INNER JOIN Lease_Contract
			ON Lease_Contract.LeaseID = Lease_profile.LeaseID			
			AND Lease_Contract.ReasonId = 1 --New
			AND Lease_Profile.BookingStatusID = 2 --Completed
			AND Lease_Profile.StatusID = 2 --Commenced
		INNER JOIN Customer_profile
			ON Customer_profile.CustomerID = Lease_Profile.CustomerID
) RS1
WHERE 
		RS1.RowNum = 1 --Take first lease contract 
	AND (RS1.PostDate BETWEEN @FromDate AND @ToDate)

;WITH CTE_FirstYearBookingDetails
AS
(
	SELECT
		  MIN(YEAR(Lease_Contract.PostDate)) [YearOfFirstBooking]
		, Lease_Profile.CustomerID
	FROM
		Lease_Profile
		INNER JOIN Lease_Contract
			ON Lease_Contract.LeaseID = Lease_Profile.LeaseID
	WHERE
		Lease_Profile.StatusId &lt;&gt; 5 --UnCommenced
		AND Lease_Profile.BookingStatusID = 2 --Completed

	GROUP BY Lease_Profile.CustomerID	
)
,
CTE_TotalEquipmentCost
AS
(
	SELECT
		  SUM(Inventory_Profile.netvalue) [TotalEquipmentCost]
		, CTE_LeaseDetails.LeaseID
	FROM 
		@LeaseDetails CTE_LeaseDetails
		
		INNER JOIN Lease_InventoryInLease
			ON Lease_InventoryInLease.LeaseID = CTE_LeaseDetails.LeaseID
		INNER JOIN Lease_InventoryInLeaseHistory
			ON Lease_InventoryInLeaseHistory.InventoryID = Lease_InventoryInLease.InventoryID
---------------------------------------------------------------------------------------------
-- 20170623
            And Lease_InventoryInLeaseHistory.LeaseID = Lease_InventoryInLease.LeaseID
---------------------------------------------------------------------------------------------
			AND Lease_InventoryInLeaseHistory.ReasonID = 1 --New
		INNER JOIN Inventory_Profile
			ON Inventory_Profile.InventoryID = Lease_InventoryInLease.InventoryID
			AND Inventory_Profile.PreviousLeaseID IS NULL
------------------------------------------------------
-- 20170623
Where Lease_InventoryInLease.IsInLease=1
-------------------------------------------------------			
	GROUP BY CTE_LeaseDetails.LeaseID

)
,
CTE_ProrataRent
AS
(
	SELECT 
		  SUM(Receivable_OtherPaymentDetail.Amount) + SUM(ISNULL(Receivable_Adjustment.Amount,0)) AS ProrataAmount
		, CTE_LeaseDetails.LeaseID
	FROM
		@LeaseDetails CTE_LeaseDetails
		INNER JOIN Receivable_OtherPaymentHeader
			ON CTE_LeaseDetails.LeaseID = Receivable_OtherPaymentHeader.LeaseID
			AND Receivable_OtherPaymentHeader.ReceivableTypeID = 26 --ProrataRent
			AND Receivable_OtherPaymentHeader.IsActive = 1 --Active
		INNER JOIN Receivable_OtherPaymentDetail
			ON Receivable_OtherPaymentHeader.ReceivableHeaderID = Receivable_OtherPaymentDetail.ReceivableHeaderID
		LEFT JOIN Receivable_Adjustment
			ON Receivable_OtherPaymentDetail.ReceivableID = Receivable_Adjustment.OriginalReceivableID
			AND Receivable_Adjustment.IsActive = 1 --Active
	GROUP BY 
		CTE_LeaseDetails.LeaseID
)
,
CTE_InterimRent
AS
(
	SELECT 
		  SUM(Receivable_OtherPaymentDetail.Amount) + SUM(ISNULL(Receivable_Adjustment.Amount,0)) AS InterimAmount
		, CTE_LeaseDetails.LeaseID
	FROM
		 @LeaseDetails CTE_LeaseDetails
		INNER JOIN Receivable_OtherPaymentHeader
			ON CTE_LeaseDetails.LeaseID = Receivable_OtherPaymentHeader.LeaseID
			AND Receivable_OtherPaymentHeader.ReceivableTypeID = 2 --InterimRent
			AND Receivable_OtherPaymentHeader.IsActive = 1 --Active
		INNER JOIN Receivable_OtherPaymentDetail
			ON Receivable_OtherPaymentHeader.ReceivableHeaderID = Receivable_OtherPaymentDetail.ReceivableHeaderID
		LEFT JOIN Receivable_Adjustment
			ON Receivable_OtherPaymentDetail.ReceivableID = Receivable_Adjustment.OriginalReceivableID
			AND Receivable_Adjustment.IsActive = 1 --Active
	GROUP BY 
		CTE_LeaseDetails.LeaseID
)
-----------------------------------------------------------------------------------------------------------------
-- 20160405
,
	CTE_SalesPerson_Details
			AS
			(
				SELECT 
					CASE WHEN LeaseLevel.RoleFunctionID = 8  --Sales Representative
							THEN MAX(LeaseLevel.EmployeeAssignmentID) 
						ELSE
							CASE WHEN CustomerLevel.RoleFunctionID = 8  --Sales Representative
								THEN MAX(CustomerLevel.EmployeeAssignmentID) 
-------------------------------------------
-- 20180914
							--ELSE ''''
							ELSE ''
-------------------------------------------
							END
						END [SalesPerson]
					, LeaseID
			FROM 
				Lease_Profile
				LEFT JOIN EmployeeAssignment_Entity LeaseLevel
					ON LeaseLevel.EntityID = Lease_Profile.LeaseID
					AND LeaseLevel.RoleFunctionID = 8  --Sales Representative
					AND LeaseLevel.EntityTypeID = 5 --Lease
					AND LeaseLevel.IsActive = 1 --Yes
				LEFT JOIN EmployeeAssignment_Entity as CustomerLevel
					ON CustomerLevel.EntityID = Lease_Profile.CustomerID
					AND  CustomerLevel.RoleFunctionID = 8  --Sales Representative
					AND CustomerLevel.EntityTypeID = 1 --Customer
					AND CustomerLevel.IsActive = 1 --Yes
			GROUP BY 
				  LeaseLevel.RoleFunctionID
				, CustomerLevel.RoleFunctionID
				, LeaseID
			)
			,
	cte_SalesPerson
	AS
	(
			SELECT 
			SalesPersonUserProfile.FirstName + SPACE(1)+ SalesPersonUserProfile.LastName [SalesRep]
			, Customer_Profile.AccountNumber AS [AccountNumber]
			, Customer_Profile.CustomerName AS [CustomerName]
			, Lease_Profile.SequenceNumber AS [LeaseSequenceNumber] 
			, Lease_Profile.PurchaseOrderNumber AS [LesseePO]
			, Customer_Profile.CustomerID
			, Syndication_TransactionType_CnfgLocale.SyndicationTransactionType AS [SyndicationTransactionType]
			, Lease_AccountingTreatmentType_CnfgLocale.AccountingTreatmentTypeName AS [LeaseType]
			, Lease_Profile.LeaseID
			, Lease_Profile.IsPerfectPay
			FROM
				Lease_Profile
				INNER JOIN Customer_Profile
					ON Customer_Profile.CustomerID = Lease_Profile.CustomerID
					AND Lease_Profile.BookingStatusID = 2 --Completed
					AND Lease_Profile.StatusID IN (2,3) --Commenced,FullyPaidOff
				INNER JOIN Lease_Investment
					ON Lease_Investment.LeaseId = Lease_Profile.LeaseID
					AND Lease_Investment.IsActive = 1 --Yes
				INNER JOIN Lease_AccountingTreatmentType_CnfgLocale
					ON Lease_AccountingTreatmentType_CnfgLocale.AccountingTreatmentTypeId = Lease_Investment.AccountingTreatmentTypeId
				INNER JOIN FundingSource_Profile			
					ON FundingSource_Profile.FundingSourceId = Lease_Profile.LabellingLessorID
				LEFT JOIN Syndication_Quote
					ON Syndication_Quote.EntityID = Lease_Profile.LeaseID
					AND Syndication_Quote.EntityTypeID = 5 --Lease
					AND Lease_Profile.SyndicationTypeID &lt;&gt; 1
					AND Syndication_Quote.SyndicationQuoteStatusID = 2 --Activated
				LEFT JOIN syndication_TransactionType_CnfgLocale
					ON syndication_TransactionType_CnfgLocale.SyndicationTransactionTypeID = Syndication_QUote.SyndicationTransactionTypeID
				LEFT JOIN CTE_SalesPerson_Details
					ON CTE_SalesPerson_Details.leaseID = Lease_Profile.LeaseID
				LEFT JOIN EmployeeAssignment_Entity SalesPersonEmployeeAssignment
					ON SalesPersonEmployeeAssignment.EmployeeAssignmentID = CTE_SalesPerson_Details.SalesPerson
				LEFT JOIN Security_UserProfile as SalesPersonUserProfile
					ON SalesPersonUserProfile.UserID = SalesPersonEmployeeAssignment.UserID
					AND SalesPersonUserProfile.IsActive = 1 --Yes
)
---------------------------------------------
-- 20180806
,
cte_LeaseAdmin
AS
(
		SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID
		,(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
		,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
		,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
		,(SELECT FirstName+SPACE(1)+LastName FROM Security_UserProfile WHERE UserID = e.UserID) Name
		,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
		,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
		,(SELECT RoleFunctionID FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionID
		,e.EntityID
		FROM EmployeeAssignment_Entity e
		WHERE e.EntityTypeID  = 1 
		And 
		 e.EmployeeAssignmentID IN 
			(
			SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
			FROM EmployeeAssignment_Entity 
			WHERE EntityTypeID = 1  /*@EntityTypeID --LeaseAdmin*/
				AND IsActive = 1 /*@IsActive*/
				AND RoleFunctionID = 38  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=38, RoleFunctionName = 'Lease Administrator'
			------------------------------	
				And EmployeeAssignmentID Not IN 
				(
					SELECT distinct e.EmployeeAssignmentID 
					FROM EmployeeAssignment_Entity e
					Inner Join Security_UserProfile s
					ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator'  
					Where e.EntityTypeID = 1
				And (SELECT UserAlias FROM Security_UserProfile WHERE UserID = e.UserID) = 'End of Lease Administrator' 
				)			
			------------------------------	 
			GROUP BY EntityID --,UserID 
			)
)
---------------------------------------------
,
cte_BillingAdmin
AS
(
	SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID,
	(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
	,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
	,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
	,(SELECT FirstName+SPACE(1)+LastName FROM Security_UserProfile WHERE UserID = e.UserID) Name
	,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
	,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
	,e.EntityID
	FROM EmployeeAssignment_Entity e
	WHERE e.EntityTypeID  = 1 And 
	 e.EmployeeAssignmentID IN 
		(
		SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
		FROM EmployeeAssignment_Entity 
		WHERE EntityTypeID = 1  /*@EntityTypeID --BillingAdmin*/
			AND IsActive = 1 
			AND RoleFunctionID = 40  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=40, RoleFunctionName = 'Billing'
		GROUP BY EntityID --,UserID 
		)
)
---------------------------------------------
,
cte_EOLAdmin
As
(
	SELECT Distinct e.EmployeeAssignmentID,
	 e.EntityTypeID
	,(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
	,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
	,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
	,(SELECT FirstName+SPACE(1)+LastName FROM Security_UserProfile WHERE UserID = e.UserID) Name
	,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
	,CASE WHEN (SELECT UserAlias FROM Security_UserProfile WHERE UserID = e.UserID) = 'End of Lease Administrator' THEN 'EOL_Admin'
		ELSE (SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) 
		END RoleFunctionName
		,e.EntityID
	FROM EmployeeAssignment_Entity e
	Inner Join Security_UserProfile s
	ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator' 

	Where e.EntityTypeID = 1
	And e.EmployeeAssignmentID IN
		(
			SELECT Max(e.EmployeeAssignmentID) 
			FROM EmployeeAssignment_Entity e
			Inner Join Security_UserProfile s
				ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator'  
			Where e.EntityTypeID = 1
			And 
				(
				SELECT UserAlias 
				FROM Security_UserProfile 
				WHERE UserID = e.UserID
				) = 'End of Lease Administrator' 
			Group By  e.EntityTypeID,e.EntityID
		)
)
-----------------------------------------------------------------------------------------------------------------
,
cte_rpt
AS
(
SELECT DISTINCT
	  FundingSource_Profile.Company AS LabellingLessor
	, Lease_Contract.PostDate
	, DATENAME(MONTH,Lease_Contract.PostDate) [PostMonth]
	, CASE 
			WHEN (CAST((MONTH(Lease_Contract.PostDate)) AS DECIMAL) / 3)  &lt;= 1
				THEN 'Q1'
			WHEN (CAST((MONTH(Lease_Contract.PostDate)) AS DECIMAL) / 3)  &lt;= 2
				THEN 'Q2'
			WHEN (CAST((MONTH(Lease_Contract.PostDate)) AS DECIMAL) / 3)  &lt;= 3
				THEN 'Q3'
			WHEN (CAST((MONTH(Lease_Contract.PostDate)) AS DECIMAL) / 3)  &lt;= 4
		 		THEN 'Q4'
			ELSE '' 
		END [PostQuarter]
	, CTE_FirstYearBookingDetails.YearOfFirstBooking 
	, Customer_profile.AccountNumber
	, Customer_profile.CustomerName
-----------------------------------------------
	, Lease_Profile.SequenceNumber 
	, Lease_Profile.LeaseID
	, ISNULL(CTE_TotalEquipmentCost.TotalEquipmentCost,0) [TotalEquipmentCost]
	, CASE 
			WHEN AccountingTreatmentTypeID = 1 --DirectFinance
				THEN 'DF'
			WHEN AccountingTreatmentTypeID = 2 --SalesType
				THEN 'ST'
			WHEN AccountingTreatmentTypeID = 3 --ConditionalSales
				THEN 'CS'
			WHEN AccountingTreatmentTypeID = 4 --Operating
				THEN 'OP'
		END [LeaseType]
	, Lease_ContractpurchaseOption_Cnfglocale.PurchaseOption [EOTOption]
	, CASE 
			WHEN MaturityManagement_Lease.IsTransitionLease = 1
				THEN 'Yes'
			ELSE 'No'
		END [TransitionLease]
	, CofA_Profile.AcceptedDate AS FinalAcceptanceDate
	, Lease_Contract.PostDate AS BookDate
	, Lease_Contract.InceptionDate AS CommencementDate
-----------------------------------------------
-- 20180806
,CONVERT(DATE,dbo.Lease_Contract.MaturityDate) MaturityDate
,CONVERT(INT,dbo.Lease_Contract.[Term]) Term
------------------------------------------------
	, Lease_ContractStructure_CnfgLocale.LeaseStructureName AS PaymentStructure
	, CASE 
			WHEN Lease_Contract.ContractStructureID = 1 --Regular
				THEN REGFREQ.Frequency 
			ELSE IRREGFREQ.Frequency 
		END AS LeasePayFreq
	, CASE 
			WHEN Lease_Contract.ContractStructureID = 1 --Regular
				THEN Lease_Contract.RegularPaymentAmount
			ELSE 0
		END AS LeasePeriodicRent
	, CASE 
			WHEN Lease_Profile.ProrataRentTypeID = 1 --None
				THEN 'N'
			WHEN Lease_Profile.ProrataRentTypeID = 2 --Standard
				THEN 'S'
			WHEN Lease_Profile.ProrataRentTypeID = 3 --InterestCarry
				THEN 'I'
			WHEN Lease_Profile.ProrataRentTypeID = 4 --NA
				THEN 'NA'
		END AS ProrataType
	, CASE
			WHEN Lease_Profile.ProrataRentTypeID = 3 --InterestCarry
				THEN Lease_Profile.ProrataInterestCarry
			ELSE 0
		END AS ProrataInterestRate
	, ISNULL(CTE_ProrataRent.ProrataAmount,0) AS ProrataAmount
	, CASE 
			WHEN Lease_Profile.InterimRentTypeID = 1 --Standard
				THEN 'S'
			WHEN Lease_Profile.InterimRentTypeID = 2 --InterestCarry
				THEN 'I'
			WHEN Lease_Profile.InterimRentTypeID = 3 --Fixed
				THEN 'F'
			WHEN Lease_Profile.InterimRentTypeID = 4 --None
				THEN 'N'
			WHEN Lease_Profile.InterimRentTypeID = 5 --NA
				THEN 'NA'
		END AS InterimType
	, CASE
			WHEN Lease_Profile.InterimRentTypeID = 2 --InterestCarry
				THEN Lease_Profile.InterimInterestCarry
			ELSE 0
		END AS InterimInterestRate
	, CASE
			WHEN Lease_Profile.InterimRentTypeID = 3 --Fixed
				THEN Lease_Profile.NoOfInterimDays
			ELSE 0
		END AS InterimDays
	, ISNULL(CTE_InterimRent.InterimAmount,0) AS InterimAmount
	, ISNULL(CTE_ProrataRent.ProrataAmount,0) + ISNULL(CTE_InterimRent.InterimAmount,0) AS TotalBilled
-----------------------------------------------
-- 20180806
,ISNULL(fee.IDCAmount,0) [IDC - Fees]
-----------------------------------------------
-- 20151224
	,ISNULL(i.IDCAmount,0) [IDC - Referral Fee]
-----------------------------------------------
-- 20180806
,ISNULL(fem.IDCAmount,0) [IDC - Front End Margin]
,ISNULL(idc.IDCAmount,0) [IDC - Initial Direct Cost]
,CONVERT(VARCHAR(12),
CONVERT(DECIMAL(12,6),lct.InternalRateOfReturn) 
)+'%' IRR
,Lease_Investment.ResidualBookedAmount [Gross Residual]
-----------------------------------------------
-- 20180913 20160405
,ISNULL(s.SalesRep,'') SalesRep
-----------------------------------------------
-- 20180806
,ISNULL(la.[Name],'') LeaseAdmin
,ISNULL(eol.[Name],'') EOL_Admin
,isnull (bill.[Name],'') BillingAdmin
,Lease_Profile.CustomerID
--,cp.AccountNumber
-----------------------------------------------
FROM
	@LeaseDetails LeaseDetails 
	
	INNER JOIN Lease_profile
		ON LeaseDetails.LeaseID = Lease_profile.LeaseID
	INNER JOIN Customer_profile
		ON Customer_profile.CustomerID = Lease_Profile.CustomerID
	INNER JOIN Lease_Contract
		ON Lease_Contract.LeaseID = LeaseDetails.LeaseID
		AND Lease_Contract.LeaseContractId = LeaseDetails.LeaseContractId
	INNER JOIN Lease_Investment
		ON  Lease_Investment.LeaseId = Lease_Profile.leaseID
		AND Lease_Investment.IsActive = 1 --Active
	INNER JOIN Lease_ContractpurchaseOption_Cnfglocale
		ON Lease_ContractpurchaseOption_Cnfglocale.PurchaseOptionID = Lease_Investment.PurchaseOptionID
	LEFT/*INNER*/ JOIN MaturityManagement_Lease
		ON MaturityManagement_Lease.LeaseID = Lease_Profile.leaseID
		AND MaturityManagement_Lease.IsActive = 1 --Active
	INNER JOIN CTE_FirstYearBookingDetails
		ON CTE_FirstYearBookingDetails.CustomerID = Customer_profile.CustomerID		
	LEFT JOIN LeaseTransaction_Profile
		ON Lease_Profile.LeaseID = LeaseTransaction_Profile.LeaseID
	LEFT JOIN Lease_ContractStructure_CnfgLocale
		ON Lease_Contract.ContractStructureId = Lease_ContractStructure_CnfgLocale.ContractStructureId
		--AND Lease_ContractStructure_CnfgLocale.CultureID = @CultureID
	LEFT JOIN Deal_RentalFrequency_CnfgLocale AS REGFREQ
		ON Lease_Contract.RentalFrequencyID = REGFREQ.FrequencyID
		--AND REGFREQ.CultureID = @CultureID
	LEFT JOIN Deal_RentalFrequency_CnfgLocale AS IRREGFREQ
		ON Lease_Contract.IrregularRentalFrequencyID = IRREGFREQ.FrequencyID
	LEFT JOIN CTE_TotalEquipmentCost
		ON CTE_TotalEquipmentCost.LeaseID = Lease_Profile.leaseID
	LEFT JOIN FundingSource_Profile
		ON Lease_Profile.LabellingLessorID = FundingSource_Profile.FundingSourceId
	LEFT JOIN CofA_Profile
		ON LeaseTransaction_Profile.LeaseTransactionID = CofA_Profile.VersionID
		AND CofA_Profile.IsFinalCofA = 1 --Final CofA		
	LEFT JOIN CTE_ProrataRent 
		ON Lease_Profile.LeaseID = CTE_ProrataRent.LeaseID
	LEFT JOIN CTE_InterimRent
		ON Lease_Profile.LeaseID = CTE_InterimRent.LeaseID
-------------------------------------------------------------------------------
	Left join cte_SalesPerson s
		ON Lease_Profile.LeaseID = s.LeaseID
-------------------------------------------------------------------------------
-- 20151224
	LEFT JOIN 
		(
		SELECT h.EntityID LeaseID
			,d.DealIDCID
			,d.IDCBucketName
			,d.IDCAmount
		FROM [dbo].[IDC_DealDetail] d
		INNER JOIN IDC_DealHeader h
			ON d.DealIDCID = h.DealIDCID AND d.IDCBucketName='Referral Fees'
		Where h.EntityTypeID = 5
		--h.EntityID = 5506
		) i  
		ON Lease_Profile.LeaseID = i.LeaseID
-------------------------------------------------------------------------------
-- 20180806
	LEFT JOIN 
		(
		SELECT h.EntityID LeaseID
			,d.DealIDCID
			,d.IDCBucketName IDCBucketName_fees
			,d.IDCAmount
		FROM [dbo].[IDC_DealDetail] d
		INNER JOIN IDC_DealHeader h
			ON d.DealIDCID = h.DealIDCID AND d.IDCBucketName='Fees'
		Where h.EntityTypeID = 5
		) fee  
		ON Lease_Profile.LeaseID = fee.LeaseID
-------------------------------------------------------------------------------
-- 20180806
	LEFT JOIN 
		(
		SELECT h.EntityID LeaseID
			,d.DealIDCID
			,d.IDCBucketName 
			,d.IDCAmount
		FROM [dbo].[IDC_DealDetail] d
		INNER JOIN IDC_DealHeader h
			ON d.DealIDCID = h.DealIDCID AND d.IDCBucketName='Front End Margin'
		Where h.EntityTypeID = 5
		) fem  
		ON Lease_Profile.LeaseID = fem.LeaseID
-------------------------------------------------------------------------------
-- 20180806
	LEFT JOIN 
		(
		SELECT h.EntityID LeaseID
			,d.DealIDCID
			,d.IDCBucketName 
			,d.IDCAmount
		FROM [dbo].[IDC_DealDetail] d
		INNER JOIN IDC_DealHeader h
			ON d.DealIDCID = h.DealIDCID AND d.IDCBucketName='Initial Direct Cost'
		Where h.EntityTypeID = 5
		) idc  
		ON Lease_Profile.LeaseID = idc.LeaseID
------------------------------------------------------
-- 20180806 
LEFT JOIN [dbo].[Lease_ClassificationTest] lct
	ON LeaseDetails.LeaseID = lct.EntityID AND lct.EntityTypeID = 5 
------------------------------------------------------
-- 20180814
	 AND lct.IsActive=1
------------------------------------------------------
-- 20180806
INNER JOIN Customer_Profile cp
	ON Lease_Profile.CustomerID = cp.CustomerID
LEFT JOIN cte_LeaseAdmin la
	ON cp.AccountNumber = la.AccountNumber
LEFT JOIN cte_EOLAdmin eol
	ON cp.AccountNumber = eol.AccountNumber
LEFT JOIN cte_BillingAdmin bill
	ON cp.AccountNumber = bill.AccountNumber
------------------------------------------------------
)
------------------------------------------------------
-- test code multi 20180914
--,
--cte_mult
--AS 
--(
