------------------------------------------------------
-- 20200924
,
cte_PriMan
AS
(
SELECT 
	lil.LeaseID,
	im.InventoryManufacturerName AS PrimaryManufacturer
FROM Inventory_Profile ip
INNER JOIN Lease_InventoryInLease lil
	ON ip.InventoryID = lil.InventoryID 
INNER JOIN Inventory_ManufacturerTemplate im
	ON ip.InventoryManufacturerID = im.InventoryManufacturerID
WHERE 
	im.IsActive=1
	AND lil.IsPrimaryInventory=1 
	AND lil.IsInLease=1	
GROUP BY 
	lil.LeaseID, 
	im.InventoryManufacturerName
)
,
--------------------------
-- 20201013
cte_Basic_Search
AS
(
SELECT
         LeaseTransaction_Profile.LeaseTransactionID
       , Customer_Profile.CustomerID
       , Lease_Profile.LeaseID
       , CASE WHEN Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
              THEN MLA_Profile.MLAID
              ELSE Lease_MLA.MLAID
         END AS MLAID
       , Lease_Profile.SequenceNumber
       , [CoTermLeaseDetails].SequenceNumber [CoTermSequenceNumber]
       , CASE WHEN Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
              THEN LeaseTransaction_Profile.BrokerID
              ELSE Lease_Profile.BrokerID
         END AS BrokerID
       , LeaseTransaction_Profile.DDSNotesdata
       , Customer_Profile.AccountNumber
       , Customer_Profile.CustomerName
       , CASE WHEN Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
              THEN 1
              ELSE 0
         END AS FEFlag
FROM
       Lease_Profile
       INNER JOIN Customer_Profile
              ON Customer_Profile.CustomerID = Lease_Profile.CustomerID
              AND Lease_Profile.BookingStatusID = 2 --Completed
       LEFT JOIN LeaseTransaction_Profile
              ON Lease_Profile.LeaseID = LeaseTransaction_Profile.LeaseID
              AND LeaseTransaction_Profile.AgreementTypeID = 2 --LeaseTransaction
       LEFT JOIN MLA_Profile
              ON MLA_Profile.MLAID = LeaseTransaction_Profile.MLAID
       LEFT JOIN MLA_Profile Lease_MLA
              ON Lease_MLA.MLAID = Lease_Profile.MLAID
       LEFT JOIN Lease_Profile [CoTermLeaseDetails]
              ON [CoTermLeaseDetails].LeaseID = Lease_Profile.CoTermLeaseID
)
, 
cte_VARCount
AS
(
SELECT cte_Basic_Search.SequenceNumber, COUNT (Vendor_Profile.VendorSubtypeID) VARCount
FROM
    cte_Basic_Search
    INNER JOIN LeaseTransaction_inventory
            ON LeaseTransaction_inventory.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID  
            AND LeaseTransaction_inventory.IsActive = 1 --Yes
    INNER JOIN APInvoice_CostHeader
            ON APInvoice_CostHeader.inventoryID = LeaseTransaction_inventory.InventoryID
    INNER JOIN APInvoice_profile
            ON APInvoice_profile.VendorInvoiceID = APInvoice_CostHeader.VendorInvoiceID
    INNER JOIN Vendor_Profile
            ON Vendor_Profile.VendorID = APInvoice_profile.VendorID 
            AND Vendor_Profile.VendorSubtypeID = 2 --VAR
GROUP BY cte_Basic_Search.SequenceNumber
)  
,
cte_ISECount
AS
(
SELECT cte_Basic_Search.SequenceNumber, COUNT (Vendor_Profile.VendorSubtypeID) ISECount
FROM
    cte_Basic_Search
    INNER JOIN LeaseTransaction_inventory
            ON LeaseTransaction_inventory.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID  
            AND LeaseTransaction_inventory.IsActive = 1 --Yes
    INNER JOIN APInvoice_CostHeader
            ON APInvoice_CostHeader.inventoryID = LeaseTransaction_inventory.InventoryID
    INNER JOIN APInvoice_profile
            ON APInvoice_profile.VendorInvoiceID = APInvoice_CostHeader.VendorInvoiceID
    INNER JOIN Vendor_Profile
            ON Vendor_Profile.VendorID = APInvoice_profile.VendorID 
            AND Vendor_Profile.VendorSubtypeID = 3 --ISE)
GROUP BY cte_Basic_Search.SequenceNumber
)
,
cte_Vendor
AS
(
SELECT 
	b.LeaseID,
	b.SequenceNumber,
	IIF(ISNULL(v.VARCount,0)&gt;0,'Y','N') [RED8 IS A Vendor Y/N],
	IIF(ISNULL(i.ISECount,0)&gt;0,'Y','N') [2NDGEAR is a Vendor Y/N]
FROM cte_Basic_Search b
LEFT JOIN cte_VARCount v
	ON b.SequenceNumber = v.SequenceNumber
LEFT JOIN cte_ISECount i
	ON b.SequenceNumber = i.SequenceNumber
)
--------------------------------
SELECT 
	 r.LabellingLessor
	,r.PostDate
	,r.PostMonth
	,r.PostQuarter
	,r.YearOfFirstBooking 
	,r.AccountNumber
	,r.CustomerName
	,r.SequenceNumber 
	,r.LeaseID
	,r.TotalEquipmentCost
	,r.LeaseType
	,r.EOTOption
	,r.TransitionLease
	,r.FinalAcceptanceDate
	,r.BookDate
	,r.CommencementDate
	,r.MaturityDate
	,r.Term
	,r.PaymentStructure
	,r.LeasePayFreq
	,r.LeasePeriodicRent
	,r.ProrataType
    ,r.ProrataInterestRate
	,r.ProrataAmount
	,r.InterimType
	,r.InterimInterestRate
	,r.InterimDays
	,r.InterimAmount
	,r.TotalBilled
	,r.[IDC - Fees]
	,r.[IDC - Referral Fee]
	,r.[IDC - Front End Margin]
	,r.[IDC - Initial Direct Cost]
	,r.IRR
	,r.[Gross Residual]
	,r.SalesRep
	,r.LeaseAdmin
	,r.EOL_Admin
	,r.BillingAdmin
	,r.CustomerID
    ,la.MarginAmount
    ,la.InitialInvestmentBalanceAmount
	,ISNULL(m.PrimaryManufacturer,'') PrimaryManufacturer
	,v.[RED8 IS A Vendor Y/N]
	,v.[2NDGEAR is a Vendor Y/N]
FROM cte_rpt r
INNER JOIN Lease_Accrual la
	ON la.LeaseID = r.LeaseID
LEFT JOIN cte_PriMan m
	ON r.LeaseID = m.LeaseID
LEFT JOIN cte_Vendor v
	ON r.SequenceNumber = v.SequenceNumber
WHERE la.ISactive = 1
ORDER BY 
	 r.LeaseID,
	 r.PostDate,
	 r.AccountNumber


--END</CommandText>
