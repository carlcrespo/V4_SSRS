  <DataSources>
    <DataSource Name="LW_PROD">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>dfcfd522-b343-45f5-b348-df038ab3cf19</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@AccountNumber">
            <Value>=Parameters!AccountNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@LeaseAlias">
            <Value>=Parameters!LeaseAlias.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- Build 20180705

--USE [LW_PROD]
--GO
------------------------------------------------
---- test code
--Declare
--       @LeaseAlias NVARCHAR(50) = '2'
--       ,@AccountNumber NVARCHAR(80) = 'GOR020'
-----------------------------------------------

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SET NOCOUNT ON;

SELECT 
		r.Logic
       ,r.LocationCode
       ,r.[Address]
       ,r.Address2
       ,r.City
       ,r.StateShortName
       ,r.Zip
       ,r.UpfrontTaxAmount
	   ,r.LeaseTransactionID
	   ,r.AccountNumber
	   ,r.LeaseAlias
	   ,r.[Illinois Upfront Tax on Leases]
FROM 
	(
	SELECT 'IIC_UpfrontTaxSummaryReport' Logic,
			 Inventory_LocationTemplate.LocationCode
		   , Inventory_LocationTemplate.Address
		   , Inventory_LocationTemplate.Address2
		   , Inventory_LocationTemplate.City
		   , Template_State_CnfgLocale.StateShortName
		   , Inventory_LocationTemplate.Zip
		   ,SUM(LeaseTransaction_InventoryDetail_Tax.Amount) [UpfrontTaxAmount]
	------------------------------------------------------------------------
	-- 20180326
		   ,LeaseTransaction_Tax.LeaseTransactionID
		   ,Customer_Profile.AccountNumber
		   ,LeaseTransaction_Profile.LeaseAlias
		   ,'Yes' [Illinois Upfront Tax on Leases]
	------------------------------------------------------------------------          
	FROM
		   LeaseTransaction_Profile

		   INNER JOIN Customer_Profile
				  ON LeaseTransaction_Profile.CustomerID = Customer_Profile.CustomerID
				  AND Customer_Profile.AccountNumber = @AccountNumber

		   INNER JOIN LeaseTransaction_Tax
				  ON LeaseTransaction_Tax.LeaseTransactionID = LeaseTransaction_Profile.LeaseTransactionID
				  AND LeaseTransaction_Tax.IsActive = 1

		   INNER JOIN LeaseTransaction_InventoryHeader_Tax
				  ON LeaseTransaction_InventoryHeader_Tax.LeaseTransactionTaxID = LeaseTransaction_Tax.LeaseTransactionTaxID
				  AND LeaseTransaction_InventoryHeader_Tax.InventoryID = LeaseTransaction_Tax.InventoryID
				  AND LeaseTransaction_InventoryHeader_Tax.TaxReceiptTypeID IN (2,3) -- Consider upfront tax only

		   INNER JOIN LeaseTransaction_InventoryDetail_Tax
				  ON LeaseTransaction_InventoryDetail_Tax.LeaseTransactionInventoryHeaderTaxID = LeaseTransaction_InventoryHeader_Tax.LeaseTransactionInventoryHeaderTaxID
				  --------------------------------------------------------------------------------------------------------------------------------------------------------
				  -- 20180423
				  AND LeaseTransaction_InventoryDetail_Tax.ImpositionType = 'Illinois Upfront Tax on Leases'
				  ----------------------------------------------------------------------------------------------------------------------------------------------------------                    
		   INNER JOIN Inventory_LocationTemplate
				  ON Inventory_LocationTemplate.LocationTemplateID = LeaseTransaction_InventoryHeader_Tax.LocationTemplateID              
                           
		   LEFT OUTER JOIN Template_State_CnfgLocale 
				  ON Template_State_CnfgLocale.StateID = Inventory_LocationTemplate.StateID
	WHERE 
		   --LeaseTransaction_Profile.LeaseAlias LIKE @LeaseAlias
		   LeaseTransaction_Profile.LeaseAlias = @LeaseAlias
	GROUP BY
		   Inventory_LocationTemplate.LocationCode
		   , Inventory_LocationTemplate.Address
		   , Inventory_LocationTemplate.Address2
		   , Inventory_LocationTemplate.City
		   , Template_State_CnfgLocale.StateShortName
		   , Inventory_LocationTemplate.Zip
	------------------------------------------------------------------------
	-- 20180326
		   ,LeaseTransaction_Tax.LeaseTransactionID
		   ,Customer_Profile.AccountNumber
		   ,LeaseTransaction_Profile.LeaseAlias
	UNION 
	SELECT 'IIC_UpfrontTaxSummaryReport' Logic,
			 Inventory_LocationTemplate.LocationCode
		   , Inventory_LocationTemplate.Address
		   , Inventory_LocationTemplate.Address2
		   , Inventory_LocationTemplate.City
		   , Template_State_CnfgLocale.StateShortName
		   , Inventory_LocationTemplate.Zip
		   ,SUM(LeaseTransaction_InventoryDetail_Tax.Amount) [UpfrontTaxAmount]
	------------------------------------------------------------------------
	-- 20180326
		   ,LeaseTransaction_Tax.LeaseTransactionID
		   ,Customer_Profile.AccountNumber
		   ,LeaseTransaction_Profile.LeaseAlias
		   ,'No' [Illinois Upfront Tax on Leases]
	------------------------------------------------------------------------          
	FROM
		   LeaseTransaction_Profile

		   INNER JOIN Customer_Profile
				  ON LeaseTransaction_Profile.CustomerID = Customer_Profile.CustomerID
				  AND Customer_Profile.AccountNumber = @AccountNumber

		   INNER JOIN LeaseTransaction_Tax
				  ON LeaseTransaction_Tax.LeaseTransactionID = LeaseTransaction_Profile.LeaseTransactionID
				  AND LeaseTransaction_Tax.IsActive = 1

		   INNER JOIN LeaseTransaction_InventoryHeader_Tax
				  ON LeaseTransaction_InventoryHeader_Tax.LeaseTransactionTaxID = LeaseTransaction_Tax.LeaseTransactionTaxID
				  AND LeaseTransaction_InventoryHeader_Tax.InventoryID = LeaseTransaction_Tax.InventoryID
				  AND LeaseTransaction_InventoryHeader_Tax.TaxReceiptTypeID IN (2,3) -- Consider upfront tax only

		   INNER JOIN LeaseTransaction_InventoryDetail_Tax
				  ON LeaseTransaction_InventoryDetail_Tax.LeaseTransactionInventoryHeaderTaxID = LeaseTransaction_InventoryHeader_Tax.LeaseTransactionInventoryHeaderTaxID
				  --------------------------------------------------------------------------------------------------------------------------------------------------------
				  -- 20180423
				  AND LeaseTransaction_InventoryDetail_Tax.ImpositionType != 'Illinois Upfront Tax on Leases' 
				  ----------------------------------------------------------------------------------------------------------------------------------------------------------                    
		   INNER JOIN Inventory_LocationTemplate
				  ON Inventory_LocationTemplate.LocationTemplateID = LeaseTransaction_InventoryHeader_Tax.LocationTemplateID              
                           
		   LEFT OUTER JOIN Template_State_CnfgLocale 
				  ON Template_State_CnfgLocale.StateID = Inventory_LocationTemplate.StateID
				  AND Inventory_LocationTemplate.StateID != ''
	WHERE 
		   --LeaseTransaction_Profile.LeaseAlias LIKE @LeaseAlias
		   LeaseTransaction_Profile.LeaseAlias = @LeaseAlias
	GROUP BY
		   Inventory_LocationTemplate.LocationCode
		   , Inventory_LocationTemplate.Address
		   , Inventory_LocationTemplate.Address2
		   , Inventory_LocationTemplate.City
		   , Template_State_CnfgLocale.StateShortName
		   , Inventory_LocationTemplate.Zip
	------------------------------------------------------------------------
	-- 20180326
		   ,LeaseTransaction_Tax.LeaseTransactionID
		   ,Customer_Profile.AccountNumber
		   ,LeaseTransaction_Profile.LeaseAlias
) r
---------------------------------------------------------------------
---- 20180427
----WHERE r.City + r.[Illinois Upfront Tax on Leases]&lt;&gt;'ChicagoNo' 
WHERE r.StateShortName + r.[Illinois Upfront Tax on Leases]&lt;&gt;'ILNo'
---------------------------------------------------------------------
ORDER BY r.LocationCode</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
