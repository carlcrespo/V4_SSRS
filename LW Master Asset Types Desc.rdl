  <DataSources>
    <DataSource Name="LW_PROD">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>bea73567-d2a9-4ea9-ab6c-f8c43d475857</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <CommandText>-- 20191009
SELECT  e.AssetTypeID,e.AssetTypeName,e.[Description],e.Manufacturer,e.FactorCategoryName,e.AssetCategoryName,e.AssetSubCategoryName,e.AssetFormName,e.IsTier1,e.IsActive
FROM
(
	SELECT DISTINCT d.AssetTypeID, d.AssetTypeName,d.[Description]
	,CASE WHEN IsTier1 = 0 THEN 'Other' ELSE d.ManufacturerID END Manufacturer
	,d.FactorCategoryName,d.AssetCategoryName,d.AssetSubCategoryName,d.AssetFormName,d.IsTier1,d.IsActive
	FROM
	(
		   SELECT a.[InventoryTypeID] AssetTypeId
		  ,a.[InventoryTypeName] AssetTypeName
		  ,a.[Description]
		  ,CASE 
		  WHEN COALESCE(c.[InventoryManufacturerID],'') = '-' 
		  THEN '' 
		  ELSE COALESCE(c.[InventoryManufacturerID],'') 
		  END ManufacturerID
		  ,(
			SELECT f.[FactorCategoryName] 
			FROM [dbo].[Inventory_FactorCategoryTemplate] f 
			WHERE  f.[FactorCategoryID] = a.[FactorCategoryID]
			) [FactorCategoryName]
		  ,(
			SELECT [InventoryCategoryName]
			FROM [dbo].[Inventory_CategoryTemplate]
			WHERE InventoryCategoryID = a.[InventoryCategoryID]
			) AssetCategoryName 
			,(
			SELECT [InventorySubcategoryName]
			FROM [dbo].[Inventory_SubcategoryTemplate]
			WHERE [InventorySubcategoryID] = a.[InventorySubcategoryID]
			) AssetSubCategoryName
		  ,(
			SELECT [InventoryFormName]
			FROM [dbo].[Inventory_FormTemplate]
			WHERE [InventoryFormID] = a.[InventoryFormID] 
			) AssetFormName
		  ,a.[IsTier1]
		  ,a.[IsActive]
	  FROM [dbo].[Inventory_TypeTemplate] a
	  LEFT JOIN 
	  (
		SELECT b.[InventoryFormID]
		  ,(
			  SELECT [InventoryManufacturerName] 
			  FROM [dbo].[Inventory_ManufacturerTemplate] 
			  WHERE [InventoryManufacturerID] = b.[InventoryManufacturerID]
		  ) [InventoryManufacturerID]
		  FROM [dbo].[Inventory_TierAssignment] b
		  ) c ON c.[InventoryFormID] = a.[InventoryFormID]
	  ) d
) e
ORDER BY AssetTypeID,e.Manufacturer</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="AssetTypeID">
          <DataField>AssetTypeID</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="AssetTypeName">
