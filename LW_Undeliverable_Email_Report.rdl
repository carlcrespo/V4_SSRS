  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource2</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@RunDate">
            <Value>=Parameters!RunDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@RunDate2">
            <Value>=Parameters!RunDate2.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@email">
            <Value>=Parameters!email.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20191004
-- Include LW Invoice Number in Subject Line of LW Email - Invoice Job Report W/ Email Address
-- Work Order #33893 Add AR Rep

--DECLARE @RunDate Date = '5/1/19', @Rundate2 DATE = '5/30/19' --@JobId Int=116838, @Duedate Date='4/1/2018', @CustId Int=2206
--DECLARE @email NVARCHAR(MAX)= '' --'Latoya.Hadley@wmchealth.org'  
; 
WITH 
cte_email
AS
(
SELECT 
	 InvoiceGroupID
	,CASE 
	 WHEN ToEmailAddresses = '' AND CCEmailAddresses = '' AND BCCEmailAddresses = '' THEN ''
  	 WHEN ToEmailAddresses = '' AND CCEmailAddresses = '' AND BCCEmailAddresses !='' THEN BCCEmailAddresses
	 WHEN ToEmailAddresses = '' AND CCEmailAddresses != '' AND BCCEmailAddresses = ''THEN CCEmailAddresses
	 WHEN ToEmailAddresses = '' AND CCEmailAddresses != '' AND BCCEmailAddresses != '' THEN CCEmailAddresses+','+BCCEmailAddresses
	 WHEN ToEmailAddresses != '' AND CCEmailAddresses = '' AND BCCEmailAddresses = '' THEN ToEmailAddresses
	 WHEN ToEmailAddresses != '' AND CCEmailAddresses = '' AND BCCEmailAddresses != '' THEN ToEmailAddresses+','+BCCEmailAddresses
	 WHEN ToEmailAddresses != '' AND CCEmailAddresses != '' AND BCCEmailAddresses = '' THEN ToEmailAddresses+','+CCEmailAddresses
	 WHEN ToEmailAddresses != '' AND CCEmailAddresses != '' AND BCCEmailAddresses != '' THEN ToEmailAddresses+','+CCEmailAddresses+','+BCCEmailAddresses
	 ELSE LTRIM(RTRIM(ISNULL(ToEmailAddresses,'')+' '+ISNULL(CCEmailAddresses,' ')+' '+ISNULL(BCCEmailAddresses,' ')))
	 END ToEmailAddresses
  FROM [dbo].[InvoiceGroup_Profile]
)
-------------------------------------
-- 20190520
,
cte_reps 
AS 
(
select 
	 cp.CustomerID
	,cp.AccountNumber as AcctNumber
	,ISNULL(ar.[AR Rep],'') AR_Rep
from dbo.Customer_Profile cp
LEFT JOIN 
	(
	SELECT 
		eeu.EmpAssignmentID 
		,eeu.Entityid 
		,ee.UserID 
		,sp.LastName + ' ' + sp.FirstName as 'AR Rep'
	FROM 
		(
		SELECT  
			max(ee.EmployeeAssignmentID) as EmpAssignmentID
			,ee.EntityID
		FROM dbo.EmployeeAssignment_Entity ee
		WHERE ee.RoleFunctionID = 40
				and ee.EntityTypeID = 1
				and ee.IsActive = 1
		GROUP BY ee.EntityID
		)  eeu
		INNER JOIN dbo.EmployeeAssignment_Entity ee
			ON eeu.EmpAssignmentID = ee.EmployeeAssignmentID 
		INNER JOIN dbo.[Security_UserProfile] sp
			ON ee.UserID = sp.UserID
	) ar
	ON cp.CustomerID = ar.EntityID 
) 
-------------------------------------
,
cte_rpt
AS
(
SELECT 
           bh.JobID
          ,CONVERT(date,bh.RunDate)JobRunDate
          --,CONVERT(DATE,bh.UpdateThroughDate) UpdateThroughDate
          --,ig.ToEmailAddresses
		  ,cte_email.ToEmailAddresses
		  ,inv.[InvoiceNumber]
          ,ig.InvoiceGroupName
		  ,cp.AccountNumber
		  ,ig.CustomerName
		  ,lp.SequenceNumber
          ,CONVERT(DATE,[DueDate]) DueDate
          --,ZZ.Amount PaymentScheduleRent
          ,IRD.RentAmountInvoiced
          ,IRD.TaxAmountInvoiced
          ,IIF (ig.[IsPrintInvoiceNotRequired]=1,'Yes','No') NoPrint
          ,IIF(ig.IsRentalInvoiceSplitByDeal=1,'No','Yes') CombinedBill
          --,IIF (ih.[IsEmailSent]=1,'Yes','No') IsEmailSent
          ,IIF(IG.IsEmailNotificationAllowed=1,'Yes','No') EmailAllowed
          ,IIF(IG.IsEmailWithAttachment=1,'Yes','No') EmailWithAttachment
		  ---------------------------------------------------------------
		  -- 20190520
		  ,cte_reps.AR_Rep
		  ---------------------------------------------------------------
		  ,lp.LeaseID
          ,fs.Company -- Labelling Lessor
		  ,fs.Alias
		  ,fs.FundingSourceId

FROM [dbo].[Invoice_Header] as IH

INNER JOIN [dbo].[Invoice_Number] as INV
  on ih.[InvoiceNumberID] = inv.[InvoiceNumberID]

INNER JOIN [dbo].[InvoiceGroup_Profile] as IG 
  on ih.[InvoiceGroupID] = ig.InvoiceGroupID

INNER JOIN [dbo].[Customer_Profile] as CP
  on ih.customerid=cp.customerid

INNER JOIN [dbo].[Invoice_BatchHeader] as BH
  on ih.invoicebatchid = bh.invoicebatchid 
  AND bh.RunDate between @RunDate and @RunDate2

INNER JOIN [dbo].[Invoice_DealDetail] IDD
  on ih.InvoiceID=idd.InvoiceID

INNER JOIN [dbo].[Lease_Profile] as LP
  on idd.entityid=lp.leaseid

INNER JOIN dbo.LLC_Profile llc
  ON lp.LLCID = llc.LLCID

LEFT JOIN FundingSource_Profile fs
  ON lp.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)


INNER JOIN 
	  (
	  SELECT 
		   [InvoiceDealDetailID]
		  ,SUM([Amount])RentAmountInvoiced
		  ,SUM([Balance])RentBalance
		  ,SUM([TaxAmount]) TaxAmountInvoiced
		  ,SUM([TaxBalance]) TaxBalance
		  ,ReceivableTypeID
	  FROM [dbo].[Invoice_ReceivableDetail]
	  GROUP BY
 		   [InvoiceDealDetailID]
			   ,ReceivableTypeID
	   ) IRD
	   ON IDD.InvoiceDealDetailID=IRD.InvoiceDealDetailID
	   AND ReceivableTypeID in (1,3)
LEFT JOIN 
	  (
		SELECT 
				A.[ReceivableHeaderID]
			  ,[LeaseID]
			  ,A.[Amount]
				 ,B.InvoiceID
		  FROM [dbo].[Receivable_LeasePaymentHeader] A
		INNER JOIN 
			  (
			  SELECT
				  [ReceivableHeaderID]
				  ,SUM([Amount]) Amount
				  ,SUM([Balance]) Balance
				  ,[InvoiceID]
				  ,[IsDummy]
      
			  FROM [dbo].[Receivable_LeasePaymentDetail] A
			  WHERE
				IsDummy=0
			  GROUP BY
       
				  [ReceivableHeaderID]
				  ,[InvoiceID]
				  ,[IsDummy]

			  ) B

			  ON A.ReceivableHeaderID=B.ReceivableHeaderID
			  WHERE
			  IsActive=1
	  ) ZZ 
  ON IH.InvoiceID=ZZ.InvoiceID
  AND LP.LeaseID=ZZ.LeaseID

INNER JOIN cte_email
	ON ig.InvoiceGroupID = cte_email.InvoiceGroupID	
---------------------------------------------------
-- 20190520
LEFT JOIN cte_reps
	ON cp.AccountNumber = cte_reps.AcctNumber
---------------------------------------------------		  
WHERE 
  --bh.JobID=@JobID
  --AND CP.CustomerID=@CustId
 cte_email.ToEmailAddresses != ''
 AND 
 IRD.RentAmountInvoiced &lt;&gt; 0
)
SELECT 
     JobID
    ,JobRunDate
	,ToEmailAddresses
	,InvoiceNumber
    ,InvoiceGroupName
	,AccountNumber
	,CustomerName
	,SequenceNumber
    ,DueDate
    ,RentAmountInvoiced
    ,TaxAmountInvoiced
    ,NoPrint
    ,CombinedBill
    ,EmailAllowed
    ,EmailWithAttachment
	,cte_rpt.AR_Rep
	,LeaseID
	,Company
	,Alias
	,FundingSourceId
FROM cte_rpt WHERE @email = ''
UNION 
SELECT 
     JobID
    ,JobRunDate
	,ToEmailAddresses
	,InvoiceNumber
    ,InvoiceGroupName
	,AccountNumber
	,CustomerName
	,SequenceNumber
    ,DueDate
    ,RentAmountInvoiced
    ,TaxAmountInvoiced
    ,NoPrint
    ,CombinedBill
    ,EmailAllowed
    ,EmailWithAttachment
	,cte_rpt.AR_Rep
	,LeaseID
	,Company
	,Alias
	,FundingSourceId
FROM cte_rpt WHERE @email &lt;&gt; '' AND cte_rpt.ToEmailAddresses LIKE '%'+@email+'%'
ORDER BY
cte_rpt.[InvoiceNumber]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
