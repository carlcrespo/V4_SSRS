  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@pMaturityDate">
            <Value>=Parameters!pMaturityDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@pSeq">
            <Value>=Parameters!pSeq.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@pCustomerName">
            <Value>=Parameters!pCustomerName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@pCustomerNum">
            <Value>=Parameters!pCustomerNum.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@pLessor">
            <Value>=Parameters!pLessor.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 202203122
--Declare @pMaturityDate as date = GETDATE() -- '8/31/2021'
--Declare @pseq as NVarchar = null
--Declare @pCustomerName as NVarchar = null
--Declare @pCustomerNum as NVarchar = null
--Declare @pLessor as NVarchar = 'Garnier Group &amp; Associates, LLC' -- null
SELECT
     r.AccountNumber
	,r.CustomerName
	,r.SequenceNumber
	,r.Term 
	,r.Frequency
	,r.CommenceDate
	,r.MaturityDate
	,r.EquipmentCost
	,r.TotalRemainingRents
	,r.TotalRemainingPmts
	,r.PurchOption
	,r.Funded
	,r.FundingSource
	,r.LabellingLessor
	,r.ISO
	,r.FundingSourceNumber
	,r.Symbol
	,r.Alias
	,IIF(r.EntityID IS NOT NULL,'Yes','No') [Equity Source]
	,ISNULL(r.Syndication,'') Syndication
FROM 
	(
	SELECT 
		 cp.AccountNumber
		,cp.CustomerName
		,lp.SequenceNumber
		,CONVERT(INT,lc.Term) Term
		,rf.[Description] Frequency
		---------------------------------------------------
		-- 20220322
		--,convert(Date,ExpectedInceptionDate) CommenceDate
		--,convert(Date,ExpectedMaturityDate) MaturityDate
		,convert(Date,lc.InceptionDate) CommenceDate
		,convert(Date,lc.MaturityDate) MaturityDate
		---------------------------------------------------
		--,convert (varchar,cast(b.OEC as money),1) EquipmentCost
		,b.OEC EquipmentCost
		--,convert (varchar,cast(a.totalpmt as money),1) TotalRemainingRents
		,a.totalpmt TotalRemainingRents
		,a.pmtcount TotalRemainingPmts   --- count only pmts &gt; zero due to irregular  -- example irregular lease ID 6069 Annual 45 months @ 4 annual payments
		,po.[Description] PurchOption
		,iif(c.isactive=1, 'Yes','No') Funded
		,IsNull(fp.Company,'N/A') FundingSource
		,fp2.Company LabellingLessor
		,lp.LeaseID  
	    ,ci.ISO
	    ,csc.Symbol
		,fs.FundingSourceId
        ,fs.FundingSourceNumber
		,fs.Company
		,fs.Alias
		------------------------
		-- 20220322
		,sq.EntityID
		,sq.Syndication
		------------------------
	FROM Lease_Profile lp
	INNER JOIN 
		(
			SELECT 
				 leaseid
				,sum (PaymentAmount) totalpmt
				,count (leaseid) pmtcount
			FROM Lease_PaymentSchedule
 			WHERE PaymentAmount &lt;&gt; 0 and IsActive=1 and DueDate &gt;= @pMaturityDate
			GROUP BY  LeaseID

		) A
		ON lp.leaseid=a.leaseid
	INNER JOIN
		(
			SELECT 
				 LeaseID
				,sum(InventoryTotalAmount) OEC
			FROM Lease_InventoryInLease
			WHERE 
				IsInLease=1
			GROUP BY 
				leaseid
		) B
		ON lp.leaseid=b.leaseid
	LEFT JOIN 
		(
		SELECT
			 dd.EntityID
			,fd.DiscountLoanID
			,FundingSourceID
			,IsRecourseAvailable
			,dd.IsActive

		FROM DiscountLoan_FundingSourceDetail FD
		INNER JOIN DiscountLoan_Deal DD
			ON fd.DiscountLoanID=dd.DiscountLoanID
		WHERE  
			IsRecourseAvailable=0
			and dd.IsActive=1 
			and dd.BookingStatusID=2
			) C
			ON c.entityid=lp.leaseid
	INNER JOIN Lease_PaymentSchedule PS
		ON lp.leaseid=ps.leaseid
		AND ps.IsActive=1
	inner join Customer_Profile CP
		ON lp.customerid=cp.customerid
	INNER JOIN Lease_Investment LI
		ON lp.leaseid=li.leaseid
	INNER JOIN Lease_ContractPurchaseOption_Cnfg PO
		ON li.PurchaseOptionID = po.PurchaseOptionID
		AND li.IsActive=1
	INNER JOIN Lease_Contract LC
		ON lp.leaseid=lc.leaseid
		AND lc.IsActive=1
	LEFT JOIN FundingSource_Profile FP
		ON c.FundingSourceID=FP.FundingSourceId
	LEFT JOIN FundingSource_Profile FP2
		ON lp.LabellingLessorID=FP2.FundingSourceId
	INNER JOIN Lease_RentalFrequency_Cnfg RF
		ON lc.IrregularRentalFrequencyID=rf.RentalFrequencyID
	INNER JOIN dbo.LLC_Profile llc
        ON lp.LLCID = llc.LLCID
	INNER JOIN Currency_Index ci
        ON llc.CurrencyIndexID = ci.CurrencyIndexID
	INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
        ON ci.ISO = csc.ISO  
	LEFT JOIN FundingSource_Profile fs
        ON lp.LabellingLessorID = fs.FundingSourceID
        AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label
-------------------------------------------------
-- 20220322
	LEFT JOIN 
		(
		SELECT 
			sq.EntityID,
			lp.SequenceNumber,
			fp.FundingSourceId,
			fp.FundingSourceNumber,
			fp.Company Syndication,
			fp.alias
		FROM FundingSource_Profile fp
		INNER JOIN Syndication_Quote sq
			ON sq.TypeID = fp.TypeId
			AND fp.TypeID=2
			AND sq.EntityTypeID=5
			AND sq.SyndicationQuoteStatusID=2
			AND fp.FundingSourceId = sq.FundingSourceId
		INNER JOIN Lease_Profile lp
			ON lp.LeaseID = sq.EntityID
		WHERE fp.DeactivationDate IS NULL
		) sq
		ON lp.LeaseID = sq.EntityID
---------------------------------------------
	WHERE 
		lp.statusid in (2,6) -- Commenced and Assumed
		and lp.bookingstatusid=2 -- Completed
		and ExpectedMaturityDate &gt;= @pMaturityDate 
	GROUP BY
		lp.LeaseID
		,cp.AccountNumber
		,cp.CustomerName
		,lp.SequenceNumber
		------------------------
		-- 20220322
		--,ExpectedInceptionDate
		--,ExpectedMaturityDate
		,lc.InceptionDate
		,lc.MaturityDate
		------------------------
		,lp.LabellingLessorID
		,po.[Description]
		,c.isactive
		,lc.Term
		,fp.Company
		,rf.[Description]
		,a.totalpmt 
		,a.pmtcount
		,b.oec
		,fp2.Company 
		,ci.ISO
	    ,csc.Symbol
		,fs.FundingSourceId
		,fs.FundingSourceNumber
		,fs.Company
		,fs.Alias
		----------------
		-- 20220322
		,sq.EntityID
		,sq.Syndication
		----------------
	--ORDER BY 
	--	lp.leaseid
	) r

WHERE
	r.SequenceNumber like IIF(@pSeq = '','%',@pSeq)
	AND  
	r.CustomerName like IIF(@pCustomerName = '','%','%'+@pCustomerName+'%')
	and 
	r.AccountNumber LIKE IIF(@pCustomerNum = '', '%','%'+@pCustomerNum+'%')
	and 
	r.LabellingLessor IN (@pLessor)
	--r.LabellingLessor IN (select DISTINCT Company FROM [FundingSource_Profile] fsp INNER JOIN Lease_Profile lp ON fsp.FundingSourceId = lp.LabellingLessorID)
ORDER BY
	 r.AccountNumber
	,r.SequenceNumber
	</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
