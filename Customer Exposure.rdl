    </DataSet>
    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT
	Company
from [FundingSource_Profile] fsp
	INNER JOIN Lease_Profile lp
	ON fsp.FundingSourceId = lp.LabellingLessorID 
ORDER BY Company</CommandText>
      </Query>
      <Fields>
        <Field Name="Company">
          <DataField>Company</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
