  <DataSources>
    <DataSource Name="LW_MAIN">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>080c003c-e393-40d3-8bd7-5ba5c0010a54</rd:DataSourceID>
    </DataSource>
    <DataSource Name="DataSource1">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>164aecf4-5f92-454c-bf9d-4d04609e17d9</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>/****** Script for SelectTopNRows command from SSMS  ******/ --For Tammy. Active DFLs (not transition) with untied pmts.

SELECT
	   D.AccountNumber	
	,D.CustomerName
	  ,D.SequenceNumber
      --,A.[LoanRepaymentID]
      ,A.[DiscountLoanID]
	  ,D.MaturityDate
	  --,B.ReceivableHeaderID
      ,COUNT([LoanRepaymentNumber]) #ofUntiedLoanPmts
      --,[IsDealPaymentTieUpRequired]
     -- ,A.[DueDate] LoanRepaymentNumber1
	  --,C.[DueDate] DealPaymentNumber1
      ,[LoanRepaymentAmount]
	  ,D.IsTransitionLease
	  ,IIF(D.PractTransitionDays is null, '', D.PractTransitionDays) TransitionDays
     -- ,A.[IsActive]
	 -- ,E.IsRecourseAvailable
	 ,D.ISO
	 ,D.Symbol
	 ,D.FundingSourceId
	 ,D.FundingSourceNumber
	 ,D.Company
	 ,D.Alias
	 
  FROM [DiscountLoan_RepaymentSchedule] A

  --LEFT JOIN [DiscountLoan_DealPaymentDetail] B
  --ON A.LoanRepaymentID=B.LoanRepaymentID
  --AND A.IsActive=1

  --LEFT JOIN [Receivable_LeasePaymentHeader] C
  --ON B.ReceivableHeaderID=C.ReceivableHeaderID
  --AND C.IsActive=1


  INNER JOIN 
  
  (SELECT

   A.EntityID
  ,A.DiscountLoanID
  ,B.SequenceNumber
  ,C.AccountNumber
  ,C.CustomerName
  ,B.StatusId
  ,CONVERT(DATE,D.MaturityDate) MaturityDate
  ,IIF(E.PractIsTransitionLease=1,'Yes','No') IsTransitionLease
  ,E.PractTransitionDays
  ,ci.ISO 
  ,csc.Symbol
  ,fs.FundingSourceId
  ,fs.FundingSourceNumber
  ,fs.Company
  ,fs.Alias

  
  FROM [DiscountLoan_Deal] A

  INNER JOIN [Lease_Profile] B
  ON A.EntityID=B.LeaseID
  AND B.StatusID IN (2,6) --Commenced, Assumed
	  INNER JOIN dbo.LLC_Profile llc
		   ON B.LLCID = llc.LLCID
	INNER JOIN Currency_Index ci
		   ON llc.CurrencyIndexID = ci.CurrencyIndexID
	INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
		   ON ci.ISO = csc.ISO  
	LEFT JOIN FundingSource_Profile fs
		   ON B.LabellingLessorID = fs.FundingSourceID
		   AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label


  INNER JOIN [Customer_Profile] C
  ON B.CustomerID=C.CustomerID

  INNER JOIN [Lease_Contract] D
  ON A.EntityID=D.LeaseID
  AND D.IsActive=1

  INNER JOIN [MaturityManagement_Lease] E
  ON A.EntityID=E.LeaseID
  AND E.IsActive=1
  /*AND E.PractIsTransitionLease = 0*/

  WHERE 
  
  A.DeactivationDate is null -- filter out deactivated DFLs 
  and A.BookingStatusID = 2 --Active. Status of 1 is pending status. 

  ) D

  ON A.DiscountLoanID=D.DiscountLoanID

  INNER JOIN [DiscountLoan_FundingSourceDetail] E
  ON A.DiscountLoanID =E.DiscountLoanID
  AND E.IsRecourseAvailable=0 -- Not a recourse DFL
 


  WHERE 
  
 -- A.DiscountLoanID=5050
  IsDealPaymentTieUpRequired = 0
  And A.Isactive=1
  --A.LoanRepaymentNumber is null


  GROUP BY

       D.AccountNumber	
	   ,D.CustomerName
	  ,D.SequenceNumber
      --,A.[LoanRepaymentID]
      ,A.[DiscountLoanID]
	  ,D.MaturityDate
	  --,B.ReceivableHeaderID
      ,[IsDealPaymentTieUpRequired]
     -- ,A.[DueDate] LoanRepaymentNumber1
	  --,C.[DueDate] DealPaymentNumber1
      ,[LoanRepaymentAmount]
      ,A.[IsActive]
	  ,D.IsTransitionLease
	  ,IIF(D.PractTransitionDays is null, '', D.PractTransitionDays)
	  ,D.ISO
	 ,D.Symbol
	 ,D.FundingSourceId
	 ,D.FundingSourceNumber
	 ,D.Company
	 ,D.Alias

  ORDER BY 
  
    
   AccountNumber
   ,SequenceNumber</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DiscountLoanID">
          <DataField>DiscountLoanID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="MaturityDate">
          <DataField>MaturityDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="ID_ofUntiedLoanPmts">
          <DataField>#ofUntiedLoanPmts</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="LoanRepaymentAmount">
          <DataField>LoanRepaymentAmount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="IsTransitionLease">
          <DataField>IsTransitionLease</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TransitionDays">
          <DataField>TransitionDays</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="ISO">
          <DataField>ISO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Symbol">
          <DataField>Symbol</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FundingSourceId">
          <DataField>FundingSourceId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="FundingSourceNumber">
          <DataField>FundingSourceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Company">
          <DataField>Company</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Alias">
          <DataField>Alias</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
