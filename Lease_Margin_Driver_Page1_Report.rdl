        <CommandText>-- 20220414
---USE [LW_Main]
--GO
--/****** Object:  StoredProcedure [dbo].[IIC_LeaseMarginDriverPage1Report]    Script Date: 9/11/2020 11:36:27 AM ******/
--SET ANSI_NULLS ON
--GO
--SET QUOTED_IDENTIFIER ON
--GO

--ALTER PROCEDURE [dbo].[IIC_LeaseMarginDriverPage1Report]  
--(  
--DECLARE 
--	   @LeaseSequenceNumber NVARCHAR(50) --= '9071-34'
	 --, @CultureID VARCHAR(15)=null
--)  
--WITH ENCRYPTION  
--AS
--BEGIN

--IF @CultureID IS NULL OR LEN(@CultureID) = 0  
--BEGIN  
--	SET @CultureID = 'en-US'  
--END

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;  
SET NOCOUNT ON;

DECLARE @LeaseID INT;
DECLARE @CustomerID INT;
DECLARE @NewPeriod INT;

SELECT
	  @LeaseID = Lease_Profile.LeaseID
	 ,@CustomerID = Lease_Profile.CustomerID
	 ,@NewPeriod = Customer_Profile.NewPeriod
FROM
	Lease_Profile
	
	INNER JOIN Customer_Profile
		ON Customer_Profile.CustomerID = Lease_Profile.CustomerID

WHERE
	Lease_Profile.SequenceNumber = @LeaseSequenceNumber

	

;WITH CTE_MSLTId
AS
(
	SELECT
		  Lease_Profile.LeaseID
		, MSLT_LeaseTransaction_Profile.LeaseTransactionID [MSLTId]
	FROM
		Lease_Profile
		INNER JOIN LeaseTransaction_Profile LSLT_LeaseTransaction_Profile
			ON Lease_Profile.LeaseID = LSLT_LeaseTransaction_Profile.LeaseID
			AND Lease_Profile.LeaseID = @LeaseID
		INNER JOIN LeaseTransaction_Profile MSLT_LeaseTransaction_Profile
			ON LSLT_LeaseTransaction_Profile.RelatedMasterTransactionID = MSLT_LeaseTransaction_Profile.LeaseTransactionID
	WHERE
		MSLT_LeaseTransaction_Profile.AgreementTypeID = 1 -- Master Transaction
)
,CTE_MSLTCreditOptionDetail
AS
(
	SELECT
		  RS1.LeaseID
		, RS1.MSLTId
		, RS1.CreditOptionDetailID
	FROM
		(
			SELECT
				  CTE_MSLTId.LeaseID
				, CTE_MSLTId.MSLTId
				, LeaseTransaction_CreditOptionDetail.CreditOptionDetailID
				, ROW_NUMBER() OVER(PARTITION BY CTE_MSLTId.MSLTId, CTE_MSLTId.LeaseID ORDER BY LeaseTransaction_CreditOptionDetail.OptionNumber DESC) [RowNum]
			FROM
				CTE_MSLTId
				INNER JOIN Lease_Profile
					ON Lease_Profile.LeaseID = CTE_MSLTId.LeaseID
					AND Lease_Profile.LeaseID = @LeaseID
				INNER JOIN LeaseTransaction_Profile 
					ON LeaseTransaction_Profile.LeaseID = Lease_Profile.LeaseID
				INNER JOIN LeaseTransaction_PaymentCalculation
					ON LeaseTransaction_Profile.LeaseTransactionID = LeaseTransaction_PaymentCalculation.LeaseTransactionID
				INNER JOIN LeaseTransaction_CreditOptionHeader
					ON CTE_MSLTId.MSLTId = LeaseTransaction_CreditOptionHeader.LeaseTransactionID
				INNER JOIN LeaseTransaction_CreditOptionDetail
					ON LeaseTransaction_CreditOptionHeader.CreditOptionHeaderID = LeaseTransaction_CreditOptionDetail.CreditOptionHeaderID
				LEFT JOIN Lease_Contract
					ON Lease_Contract.LeaseID = Lease_Profile.LeaseID
					AND Lease_Contract.IsActive = 1 --Active
				LEFT JOIN Lease_Investment
					ON Lease_Investment.LeaseID = Lease_Profile.LeaseID
					AND Lease_Investment.IsActive = 1 -- Active
			WHERE
				(Lease_Contract.Term = LeaseTransaction_CreditOptionDetail.LeaseTerm OR (Lease_Contract.Term IS NULL AND LeaseTransaction_PaymentCalculation.Term = LeaseTransaction_CreditOptionDetail.LeaseTerm))
				AND (Lease_Investment.PurchaseOptionID = LeaseTransaction_CreditOptionDetail.PurchaseOptionID OR (Lease_Investment.PurchaseOptionID IS NULL AND LeaseTransaction_PaymentCalculation.PurchaseOptionStatusTypeID = LeaseTransaction_CreditOptionDetail.PurchaseOptionID))
				AND LeaseTransaction_CreditOptionDetail.RateTypeID = 2 --Approved
		)RS1
	WHERE
		RS1.RowNum = 1
),
CTE_CustomerLevelMiniumCommencementDate
AS
(
	SELECT	
		 Lease_Profile.CustomerID
		,DATEADD(dd, -1, DATEADD(MM,@NewPeriod,MIN(LeaseTransaction_PaymentCalculation.InceptionDate))) AS [MinCommencementDate]
	FROM
		Lease_Profile
		INNER JOIN LeaseTransaction_Profile 
			ON 	LeaseTransaction_Profile.CustomerID = Lease_Profile.CustomerID
			AND Lease_Profile.CustomerID = @CustomerID
		INNER JOIN LeaseTransaction_Version
			ON 	LeaseTransaction_Version.VersionID = LeaseTransaction_Profile.LeaseTransactionID
			AND LeaseTransaction_Version.IsApproved = 1--Exclude LT that are in Dead Step
			AND LeaseTransaction_Version.IsActive = 1
		INNER JOIN LeaseTransaction_PaymentCalculation
			ON LeaseTransaction_PaymentCalculation.LeaseTransactionID = LeaseTransaction_Profile.LeaseTransactionID
	GROUP BY
		Lease_Profile.CustomerID
)
,CTE_LeaseDetails
AS
(
	SELECT 
		  Lease_Profile.LeaseID
		, Customer_Profile.CustomerName AS LesseName
		, MLA_Profile.ClientMLANumber AS MasterLeaseNumber
		, Lease_Profile.SequenceNumber AS LeaseSequenceNumber
		, CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
				THEN Lease_Contract.InceptionDate 
				ELSE LeaseTransaction_PaymentCalculation.InceptionDate
		  END AS LeaseCommencementDate
		, CASE
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
				THEN 
					CASE 
						WHEN Lease_Contract.ContractStructureID = 1 --Regular
							THEN CASE 
								WHEN Lease_Contract.RentalFrequencyID = 1 --Monthly
									THEN 'M'
								WHEN Lease_Contract.RentalFrequencyID = 2 --Quarterly
									THEN 'Q'
								WHEN Lease_Contract.RentalFrequencyID = 3 --Semi-Annually
									THEN 'S'
								WHEN Lease_Contract.RentalFrequencyID = 4 --Annually
									THEN 'A'
							END
						WHEN Lease_Contract.ContractStructureID = 2 --Irregular
							THEN 'NA'
					END
				ELSE 
					CASE 
						WHEN LeaseTransaction_PaymentCalculation.StructureID = 1 --Regular
							THEN CASE 
								WHEN LeaseTransaction_PaymentCalculation.LeaseFrequencyID = 1 --Monthly
									THEN 'M'
								WHEN LeaseTransaction_PaymentCalculation.LeaseFrequencyID = 2 --Quarterly
									THEN 'Q'
								WHEN LeaseTransaction_PaymentCalculation.LeaseFrequencyID = 3 --Semi-Annually
									THEN 'S'
								WHEN LeaseTransaction_PaymentCalculation.LeaseFrequencyID = 4 --Annually
									THEN 'A'
							END
						WHEN LeaseTransaction_PaymentCalculation.StructureID = 2 --Irregular
							THEN 'NA'
					END
		  END AS FirmTermBillingFrequency
		, CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
				THEN Lease_Contract.TotalPaymentNumber 
				ELSE LeaseTransaction_PaymentCalculation.NumberOfPayments
		  END AS TotalNoOfFirmTermPayments
		, CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
				THEN 
					CASE 
						WHEN Lease_Contract.RegularPaymentAmount = 0 --Irregular
							THEN 'Irregular'
						ELSE CONVERT(VARCHAR,Lease_Contract.RegularPaymentAmount)
					END
				ELSE 
					CASE 
						WHEN LeaseTransaction_PaymentCalculation.RegularPaymentAmount = 0 --Irregular
							THEN 'Irregular'
						ELSE CONVERT(VARCHAR,LeaseTransaction_PaymentCalculation.RegularPaymentAmount)
					END
		  END AS PeriodicRentalPaymentAmount
		, CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
				THEN 
					CASE
						WHEN Lease_Contract.InceptionPaymentNumber &gt; 0 --Advance
							THEN 'ADV'
						ELSE 'ARR'
					END
				ELSE 
					CASE
						WHEN LeaseTransaction_PaymentCalculation.NumberOfInceptionPayments &gt; 0 --Advance
							THEN 'ADV'
						ELSE 'ARR'
					END
		  END AS FirmTermBillingCycle
		, CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
				THEN Lease_ContractPurchaseOption_CnfgLocale.PurchaseOption 
				ELSE FELease_ContractPurchaseOption.PurchaseOption
		  END AS EOTOption
		, COALESCE(Customer_Profile.NewUntilDate,CTE_CustomerLevelMiniumCommencementDate.MinCommencementDate) AS CustomerNewThroughDate
		, Customer_Profile.AccountNumber AS CustomerID
		, LeaseTransaction_CreditOptionDetail.DebtRateToUse AS BasePVRate
		, CofA_Profile.AcceptedDate AS FinalAcceptanceDate
		, CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
				THEN Lease_Contract.Term 
				ELSE LeaseTransaction_PaymentCalculation.Term
		  END AS LeaseTerm
		, CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
				THEN CONVERT(DECIMAL(6,1),(Lease_Contract.TotalPaymentNumber/(Lease_Contract.Term/12))) 
				ELSE CONVERT(DECIMAL(6,1),(LeaseTransaction_PaymentCalculation.NumberOfPayments/(LeaseTransaction_PaymentCalculation.Term/12))) 
		  END AS NoOfPaymentsPerYear
		, CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
			THEN MaturityManagement_Lease.PractFMVCapPercent  
			ELSE MaturityManagement_LeaseTransaction.PractFMVCapPercent
		  END AS FMVCapPercent
		, FundingSource_Profile.Company AS LabellingLessor
	FROM 
		Lease_Profile 
		
		INNER JOIN Customer_Profile 
			ON Lease_Profile.CustomerID = Customer_Profile.CustomerID			
			AND Lease_Profile.LeaseID = @LeaseID
		INNER JOIN FundingSource_Profile			
			ON FundingSource_Profile.FundingSourceId = Lease_Profile.LabellingLessorID				
		LEFT JOIN LeaseTransaction_Profile 
			ON Lease_Profile.LeaseID = LeaseTransaction_Profile.LeaseID
		LEFT JOIN Lease_Contract 
			ON Lease_Profile.LeaseID = Lease_Contract.LeaseID
			AND Lease_Contract.IsActive = 1 --Active
		LEFT JOIN Lease_Investment
			ON Lease_Profile.LeaseID = Lease_Investment.LeaseId
			AND Lease_Investment.IsActive = 1 --Active
		LEFT JOIN Lease_ContractPurchaseOption_CnfgLocale
			ON Lease_Investment.PurchaseOptionID = Lease_ContractPurchaseOption_CnfgLocale.PurchaseOptionID
		LEFT JOIN MLA_Profile 
			ON Lease_Profile.MLAID = MLA_Profile.MLAID	
		LEFT JOIN LeaseTransaction_PaymentCalculation
			ON LeaseTransaction_Profile.LeaseTransactionID = LeaseTransaction_PaymentCalculation.LeaseTransactionID
		LEFT JOIN Lease_ContractPurchaseOption_CnfgLocale AS FELease_ContractPurchaseOption
			ON LeaseTransaction_PaymentCalculation.PurchaseOptionStatusTypeID = FELease_ContractPurchaseOption.PurchaseOptionID
		LEFT JOIN CTE_MSLTCreditOptionDetail
			ON Lease_Profile.LeaseID = CTE_MSLTCreditOptionDetail.LeaseID
		LEFT JOIN LeaseTransaction_CreditOptionDetail
			ON CTE_MSLTCreditOptionDetail.CreditOptionDetailID = LeaseTransaction_CreditOptionDetail.CreditOptionDetailID
		LEFT JOIN MaturityManagement_Lease
			ON Lease_Profile.LeaseID = MaturityManagement_Lease.LeaseID
			AND MaturityManagement_Lease.isactive = 1
		LEFT JOIN MaturityManagement_LeaseTransaction
			ON LeaseTransaction_Profile.LeaseTransactionID = MaturityManagement_LeaseTransaction.LeaseTransactionID
			AND MaturityManagement_LeaseTransaction.isactive = 1
		LEFT JOIN CofA_Profile
			ON LeaseTransaction_Profile.LeaseTransactionID = CofA_Profile.VersionID
			AND CofA_Profile.IsFinalCofA = 1 --Final CofA
			AND CofA_Profile.IsActive = 1 --Active
		LEFT JOIN CTE_CustomerLevelMiniumCommencementDate
			ON CTE_CustomerLevelMiniumCommencementDate.CustomerID = Customer_Profile.CustomerID	
)

,CTE_SalesPerson
AS
(
	SELECT 
		  CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
			THEN COALESCE(MAX(LeaseLevel.EmployeeAssignmentID), MAX(CustomerLevel.EmployeeAssignmentID)) 
			ELSE COALESCE(MAX(LeaseTransactionLevel.EmployeeAssignmentID), MAX(CustomerLevel.EmployeeAssignmentID)) 
		  END AS SalesPerson
		, Lease_Profile.LeaseID
	FROM 
		Lease_Profile
		LEFT JOIN LeaseTransaction_Profile 
			ON Lease_Profile.LeaseID = LeaseTransaction_Profile.LeaseID
		LEFT JOIN EmployeeAssignment_Entity LeaseLevel
			ON LeaseLevel.EntityID = Lease_Profile.LeaseID
			AND LeaseLevel.RoleFunctionID = 8  --Sales Rep
			AND LeaseLevel.EntityTypeID = 5 --Lease
			AND LeaseLevel.IsActive = 1 --Active
		LEFT JOIN EmployeeAssignment_Entity LeaseTransactionLevel
			ON LeaseTransactionLevel.EntityID = LeaseTransaction_Profile.LeaseTransactionID
			AND LeaseTransactionLevel.RoleFunctionID = 8  --Sales Rep
			AND LeaseTransactionLevel.EntityTypeID = 7 --Lease Transaction
			AND LeaseTransactionLevel.IsActive = 1 --Active
		LEFT JOIN EmployeeAssignment_Entity as CustomerLevel
			ON CustomerLevel.EntityID = Lease_Profile.CustomerID
			AND  CustomerLevel.RoleFunctionID = 8  --Sales Rep
			AND CustomerLevel.EntityTypeID = 1 --Customer
			AND CustomerLevel.IsActive = 1 --Active
	WHERE
		Lease_Profile.LeaseID = @LeaseID
	GROUP BY 
		  LeaseLevel.RoleFunctionID
		, LeaseTransactionLevel.RoleFunctionID
		, CustomerLevel.RoleFunctionID
		, Lease_Profile.LeaseID
		, Lease_Profile.StatusID
)
,CTE_SalesPersonCode
AS
(
	SELECT 
		  CTE_SalesPerson.LeaseID
		, Security_UserProfile.UserCode AS SalesPerson
	FROM
		CTE_SalesPerson
		LEFT JOIN EmployeeAssignment_Entity
			ON CTE_SalesPerson.SalesPerson = EmployeeAssignment_Entity.EmployeeAssignmentID
		LEFT JOIN Security_UserProfile
			ON EmployeeAssignment_Entity.UserID = Security_UserProfile.UserID
			AND Security_UserProfile.IsActive = 1 --Active
)
,CTE_CommissionUsers
AS
(
	SELECT DISTINCT
		  CASE 
			WHEN Lease_Profile.StatusID IN (2,3,4,6) --Commenced,FullyPaidOff,Suspended,Assumed
			THEN LeaseLevelAssignment.UserID
			ELSE LeaseTransactionLevelAssignment.UserID
		  END AS UserID	
		, Lease_Profile.LeaseID
	FROM
		Lease_Profile
		LEFT JOIN LeaseTransaction_Profile 
			ON Lease_Profile.LeaseID = LeaseTransaction_Profile.LeaseID
		LEFT JOIN EmployeeAssignment_Entity LeaseLevelAssignment
			ON ((LeaseLevelAssignment.EntityID = Lease_Profile.LeaseID AND LeaseLevelAssignment.EntityTypeID = 5) --Lease Level
			OR (LeaseLevelAssignment.EntityID = Lease_Profile.CustomerID AND LeaseLevelAssignment.EntityTypeID = 1)) --Customer Level
			AND LeaseLevelAssignment.RoleFunctionID = 46 --Commissions
			AND LeaseLevelAssignment.IsActive = 1 --Active
		LEFT JOIN EmployeeAssignment_Entity LeaseTransactionLevelAssignment
			ON ((LeaseTransactionLevelAssignment.EntityID = LeaseTransaction_Profile.LeaseTransactionID AND LeaseTransactionLevelAssignment.EntityTypeID = 7) --LeaseTransaction Level
			OR (LeaseTransactionLevelAssignment.EntityID = LeaseTransaction_Profile.CustomerID AND LeaseTransactionLevelAssignment.EntityTypeID = 1)) --Customer Level
			AND LeaseTransactionLevelAssignment.RoleFunctionID = 46 --Commissions
			AND LeaseTransactionLevelAssignment.IsActive = 1 --Active
	WHERE 
		Lease_Profile.LeaseID = @LeaseID
)
,CTE_Commissions
AS
(
	SELECT 
		  @LeaseID AS LeaseID
		, SUBSTRING(
					(
						SELECT 
							', ' + Security_UserProfile.UserCode
						FROM 
							CTE_CommissionUsers
							INNER JOIN Security_UserProfile
								ON CTE_CommissionUsers.UserID = Security_UserProfile.UserID
						FOR XML PATH('')
					),3,20000) AS Commissions
)
,CTE_EquipmentCost
AS
(
	SELECT 
		  SUM(Lease_InventoryInLease.StickerCost) AS EquipmentCost
		, Lease_InventoryInLease.LeaseID
	FROM
		Lease_InventoryInLease
		INNER JOIN Inventory_Profile
			ON Lease_InventoryInLease.InventoryID = Inventory_Profile.InventoryID
			AND Lease_InventoryInLease.IsInLease = 1 --Is In Lease
			AND Lease_InventoryInLease.LeaseID = @LeaseID
		INNER JOIN Inventory_TypeTemplate
			ON Inventory_Profile.InventoryTypeID = Inventory_TypeTemplate.InventoryTypeID
	WHERE
		Inventory_TypeTemplate.InventoryTypeName NOT IN ('MI-1400','MI-1405','MI-1605','NL-MI-1400','NL-MI-1405','NL-MI-1605','NL-MI-1603')
	GROUP BY
		Lease_InventoryInLease.LeaseID
)
,CTE_IICMarkUp
AS
(
	SELECT 
		SUM(Lease_InventoryInLease.MarkUpAmount) AS IICMarkup
		, Lease_InventoryInLease.LeaseID
	FROM
		Lease_InventoryInLease		
	WHERE
		Lease_InventoryInLease.LeaseID = @LeaseID
		AND Lease_InventoryInLease.IsInLease = 1 --Yes
	GROUP BY
		Lease_InventoryInLease.LeaseID
)
,CTE_UpfrontSalesTax
AS
(
	SELECT 
		  SUM(Lease_InventoryInLease.StickerCost) AS UpfrontSalesTax
		, Lease_InventoryInLease.LeaseID
	FROM
		Lease_InventoryInLease
		INNER JOIN Inventory_Profile
			ON Lease_InventoryInLease.InventoryID = Inventory_Profile.InventoryID
			AND Lease_InventoryInLease.IsInLease = 1 --Is In Lease
			AND Lease_InventoryInLease.LeaseID = @LeaseID
		INNER JOIN Inventory_TypeTemplate
			ON Inventory_Profile.InventoryTypeID = Inventory_TypeTemplate.InventoryTypeID
	WHERE
		Inventory_TypeTemplate.InventoryTypeName IN ('MI-1400','NL-MI-1400','NL-MI-1603')
	GROUP BY
		Lease_InventoryInLease.LeaseID
)
,CTE_PropertyTax
AS
(
	SELECT 
		  SUM(Lease_InventoryInLease.StickerCost) AS PropertyTax
		, Lease_InventoryInLease.LeaseID
	FROM
		Lease_InventoryInLease
		INNER JOIN Inventory_Profile
			ON Lease_InventoryInLease.InventoryID = Inventory_Profile.InventoryID
			AND Lease_InventoryInLease.IsInLease = 1 --Is In Lease
			AND Lease_InventoryInLease.LeaseID = @LeaseID
		INNER JOIN Inventory_TypeTemplate
			ON Inventory_Profile.InventoryTypeID = Inventory_TypeTemplate.InventoryTypeID
	WHERE
		Inventory_TypeTemplate.InventoryTypeName IN ('MI-1405','NL-MI-1405')
	GROUP BY
		Lease_InventoryInLease.LeaseID
)
,CTE_EOTFreight
AS
(
	SELECT 
		  SUM(Lease_InventoryInLease.StickerCost) AS EOTFreight
		, Lease_InventoryInLease.LeaseID
	FROM
		Lease_InventoryInLease
		INNER JOIN Inventory_Profile
			ON Lease_InventoryInLease.InventoryID = Inventory_Profile.InventoryID
			AND Lease_InventoryInLease.IsInLease = 1 --Is In Lease
			AND Lease_InventoryInLease.LeaseID = @LeaseID
		INNER JOIN Inventory_TypeTemplate
			ON Inventory_Profile.InventoryTypeID = Inventory_TypeTemplate.InventoryTypeID
	WHERE
		Inventory_TypeTemplate.InventoryTypeName IN ('MI-1605','NL-MI-1605')
	GROUP BY
		Lease_InventoryInLease.LeaseID
)
,CTE_InterimProrataRent
AS
(
	SELECT 
		  SUM(Receivable_OtherPaymentHeader.Amount) AS InterimProrataAmount
		, Receivable_OtherPaymentHeader.LeaseID 
	FROM
		Receivable_OtherPaymentHeader 
	WHERE
		Receivable_OtherPaymentHeader.ReceivableTypeID IN (2,26) --Interim Rent and Prorata Rent
		AND Receivable_OtherPaymentHeader.LeaseID = @LeaseID
		AND Receivable_OtherPaymentHeader.IsActive = 1 --Yes
	GROUP BY
		Receivable_OtherPaymentHeader.LeaseID
)
,CTE_AdminFee
AS
(
	SELECT 
		  SUM(Receivable_Sundry.Amount) AS AdminFee
		, Receivable_Sundry.EntityID AS LeaseID
	FROM
		Receivable_Sundry
	WHERE
		Receivable_Sundry.SundryCodeTemplateID = 10 --Admin Fee
		AND Receivable_Sundry.EntityTypeID = 5 --Lease
		AND Receivable_Sundry.EntityID = @LeaseID
		AND Receivable_Sundry.IsActive = 1 --Yes
	GROUP BY
		Receivable_Sundry.EntityID
)
------------------------------------------------------
-- 20200911
,
--Ticket Item 2
cte_AcceptanceDate
AS
(
--Ticket Item 2
SELECT 
      LeaseID      
	  ,MAX(InstallationDate) as AcceptanceDate
FROM Lease_InventoryInLease
WHERE IsInLease = 1
GROUP BY LeaseID
)
,
--Ticket Item 3
cte_PrimaryAssetType
AS
(
--Ticket Item 3
SELECT LeaseID
       ,ITT.InventoryTypeName as PrimaryAssetType
FROM Lease_InventoryInLease IIL
INNER JOIN Inventory_Profile IP
  ON IIL.InventoryID = IP.InventoryID
  AND IIL.IsInLease = 1
INNER JOIN Inventory_TypeTemplate ITT
  ON IP.InventoryTypeID = ITT.InventoryTypeID
  AND IIL.IsPrimaryInventory = 1
)
SELECT 
	  CTE_LeaseDetails.LesseName
	, CTE_LeaseDetails.MasterLeaseNumber
	, CTE_LeaseDetails.LeaseSequenceNumber
	, CTE_LeaseDetails.LeaseCommencementDate
	, CTE_LeaseDetails.FirmTermBillingFrequency
	, CTE_LeaseDetails.TotalNoOfFirmTermPayments
	, CTE_LeaseDetails.PeriodicRentalPaymentAmount
	, CTE_LeaseDetails.FirmTermBillingCycle
	, CTE_SalesPersonCode.SalesPerson
	, CTE_LeaseDetails.EOTOption
	, CTE_LeaseDetails.CustomerNewThroughDate
	, CTE_EquipmentCost.EquipmentCost
	, CTE_UpfrontSalesTax.UpfrontSalesTax
	, CTE_IICMarkUp.IICMarkup
	, CTE_LeaseDetails.BasePVRate
	, CTE_InterimProrataRent.InterimProrataAmount
	, CTE_LeaseDetails.FinalAcceptanceDate
	, CTE_LeaseDetails.LeaseTerm
	, CTE_LeaseDetails.NoOfPaymentsPerYear
	, CTE_Commissions.Commissions
	, CTE_LeaseDetails.FMVCapPercent
	, CTE_PropertyTax.PropertyTax
	, CTE_EOTFreight.EOTFreight
	, CTE_LeaseDetails.CustomerID
	, CTE_AdminFee.AdminFee
	, CTE_LeaseDetails.LabellingLessor
--------------------------------------
--20200911
	,FORMAT(ad.AcceptanceDate,'MM/dd/yyyy') LastAcceptanceDate
	,pat.PrimaryAssetType
--------------------------------------
FROM 
	CTE_LeaseDetails 
	LEFT JOIN CTE_EquipmentCost 
		ON CTE_LeaseDetails.LeaseID = CTE_EquipmentCost.LeaseID
	LEFT JOIN CTE_IICMarkUp
		ON CTE_IICMarkUp.LeaseID = CTE_LeaseDetails.LeaseID
	LEFT JOIN CTE_Commissions
		ON CTE_LeaseDetails.LeaseID = CTE_Commissions.LeaseID
	LEFT JOIN CTE_UpfrontSalesTax 
		ON CTE_LeaseDetails.LeaseID = CTE_UpfrontSalesTax.LeaseID
	LEFT JOIN CTE_PropertyTax 
		ON CTE_LeaseDetails.LeaseID = CTE_PropertyTax.LeaseID
	LEFT JOIN CTE_EOTFreight 
		ON CTE_LeaseDetails.LeaseID = CTE_EOTFreight.LeaseID
	LEFT JOIN CTE_InterimProrataRent 
		ON CTE_LeaseDetails.LeaseID = CTE_InterimProrataRent.LeaseID
	LEFT JOIN CTE_AdminFee 
		ON CTE_LeaseDetails.LeaseID = CTE_AdminFee.LeaseID
	LEFT JOIN CTE_SalesPersonCode
		ON CTE_LeaseDetails.LeaseID = CTE_SalesPersonCode.LeaseID
-----------------------------------------------------------------
-- 20200911
INNER JOIN cte_AcceptanceDate ad
	ON CTE_LeaseDetails.LeaseID = ad.LeaseID
LEFT JOIN cte_PrimaryAssetType pat 
	ON CTE_LeaseDetails.LeaseID = pat.LeaseID

--END</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
