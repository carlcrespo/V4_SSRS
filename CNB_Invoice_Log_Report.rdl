  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>dde90c5d-1817-4c31-909d-051921fbc40a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromDate">
            <Value>=Parameters!FromDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToDate">
            <Value>=Parameters!ToDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20191008

--Declare @FromDate as Date= '7/1/2021'
--Declare @ToDate as Date= '9/1/2021'

SELECT bos.vendorinvoiceid,
       (SELECT vendorinvoicenumber
        FROM   apinvoice_profile
        WHERE  vendorinvoiceid = bos.vendorinvoiceid)
       VendorInvoiceNumber,
       bos.stateid,
       (SELECT countryid
        FROM   template_state_cnfg
        WHERE  stateid = bos.stateid)
       CountryID,
       Isnull ((SELECT countryname
                FROM   template_country_cnfglocale
                WHERE  countryid = (SELECT countryid
                                    FROM   template_state_cnfg
                                    WHERE  stateid = bos.stateid)), '')
       CountryName,
       Isnull ((SELECT countryshortcode
                FROM   template_country_cnfglocale
                WHERE  countryid = (SELECT countryid
                                    FROM   template_state_cnfg
                                    WHERE  stateid = bos.stateid)), '')
       CountryShortCode,
       Isnull ((SELECT iso
                FROM   currency_index
                WHERE  countryid = (SELECT countryid
                                    FROM   template_state_cnfg
                                    WHERE  stateid = bos.stateid)), '') ISO,
       Isnull ((SELECT currencyname
                FROM   currency_index
                WHERE  countryid = (SELECT countryid
                                    FROM   template_state_cnfg
                                    WHERE  stateid = bos.stateid)), '')
       CurrencyName
	   --,
	   --Isnull ((SELECT Symbol
    --            FROM   Currency_Symbol_CnfgLocale
    --            WHERE  ISO = Currency_Symbol_CnfgLocale.ISO), '')
       --Symbol
INTO   #curr
FROM   apinvoice_billofsale bos

/* Begin #PAYEE*/
SELECT crpi.vendorinvoiceid,
       crpi.paymentid,
       crp.payeeid
INTO   #payee
FROM   checkrequest_paymentinvoice crpi
       INNER JOIN checkrequest_payment crp
               ON crpi.paymentid = crp.paymentid
                  AND crp.isactive = 1
WHERE  crpi.checknumber IS NOT NULL /*-----------------------------------------------------------*/

DECLARE @FilteredCofA TABLE
  (
     cofaid               BIGINT,
     cofanumber           BIGINT,
     versionid            INT,
     isfinalcofa          BIT,
     cnblineplacementdate DATETIME
  )

INSERT INTO @FilteredCofA
SELECT cofaid,
       cofanumber,
       versionid,
       isfinalcofa,
       cnblineplacementdate
FROM   cofa_profile
WHERE  cofa_profile.isactive = 1
       AND Cast(cofa_profile.cnblineplacementdate AS DATE) BETWEEN
           @FromDate AND @ToDate /* 20180212*/
OPTION (optimize FOR unknown)

/*            (*/
SELECT lease_profile.leaseid,
       leasetransaction_profile.leasetransactionid,
       lease_profile.lessordefineduniqueid,
       customer_profile.accountnumber,
       customer_profile.customername,
       leasetransaction_profile.jarkid/* test code*/,
       lease_profile.bookingstatusid,
	   lease_profile.LabellingLessorID,
       (SELECT [description]
        FROM   [dbo].[lease_bookingstatus_cnfg]
        WHERE  bookingstatusid = lease_profile.bookingstatusid) BookingStatus
/*-------------------------------------------------*/
INTO   #cte_leaselist
FROM   lease_profile
       INNER JOIN customer_profile
               ON customer_profile.customerid = lease_profile.customerid
       INNER JOIN leasetransaction_profile
               ON leasetransaction_profile.leaseid = lease_profile.leaseid
       INNER JOIN leasetransaction_adminstrativeinformation
               ON leasetransaction_adminstrativeinformation.leasetransactionid =
                             leasetransaction_profile.leasetransactionid
                  AND
       leasetransaction_adminstrativeinformation.isnoteligibleforwarehouseline =
       0
/*Consider only leases which are for CNB placement*/
WHERE  lease_profile.statusid IN ( 2, 5 ) /* 20180212*/
OPTION (optimize FOR unknown)

/*     (*/
SELECT cofaid,
       cofanumber/*----------------------------------*/,
       versionid,
       cnblineplacementdate
INTO   #cte_finalcofa
FROM   @FilteredCofA

/*     (  */
SELECT Sum(checkrequest_payeeinvoice.amounttopay) [AmountToPay],
       cofa_inventory.cofaid,
       CofA.cofanumber/*----------------------------------------------------*/,
       CofA.versionid,
       apinvoice_profile.vendorid,
       apinvoice_costheader.vendorinvoiceid,
       apinvoice_profile.vendorinvoicenumber,
       apinvoice_profile.isforeigncurrency
                    /*------------------------------------------------------*/,
       currency_symbol_cnfg.symbol
INTO   #cte_checkrequestinvoicedetail_sum
FROM   @FilteredCofA CofA
       INNER JOIN cofa_inventory
               ON cofa_inventory.cofaid = CofA.cofaid
       INNER JOIN apinvoice_costheader
               ON apinvoice_costheader.inventoryid = cofa_inventory.inventoryid
                  AND apinvoice_costheader.isasset = 1 /*YES  */
                  AND apinvoice_costheader.isactive = 1 /*YES*/
       INNER JOIN apinvoice_profile
               ON apinvoice_profile.vendorinvoiceid =
                  apinvoice_costheader.vendorinvoiceid
       INNER JOIN llc_profile
               ON llc_profile.llcid = apinvoice_profile.vendorllcid
       INNER JOIN currency_index
               ON currency_index.currencyindexid = llc_profile.currencyindexid
       INNER JOIN currency_symbol_cnfg
               ON currency_symbol_cnfg.symbolid =
                  currency_index.currencysymbolid
       LEFT OUTER JOIN checkrequest_payeeinvoice
                    ON checkrequest_payeeinvoice.vendorinvoicecostid =
                                       apinvoice_costheader.vendorinvoicecostid
                       AND checkrequest_payeeinvoice.isactive = 1 /*YES  */
                       AND checkrequest_payeeinvoice.amounttopay &lt;&gt; 0
/* Only assets which have positvie or negative AmountToPay */
WHERE  cofa_inventory.isactive = 1
/* Yes */
GROUP  BY CofA.versionid,
          cofa_inventory.cofaid,
          CofA.cofanumber,
          apinvoice_profile.vendorid,
          apinvoice_costheader.vendorinvoiceid,
          apinvoice_profile.vendorinvoicenumber,
          apinvoice_profile.isforeigncurrency,
          currency_symbol_cnfg.symbol

/*     (  */
SELECT Sum(checkrequest_payeeinvoice.amounttopay) [AmountToPay],
       cofa_inventory.cofaid,
       CofA.cofanumber,
       CofA.versionid,
       apinvoice_profile.vendorid,
       apinvoice_profile.vendorinvoiceid,
       apinvoice_profile.vendorinvoicenumber,
       apinvoice_profile.isforeigncurrency,
       currency_symbol_cnfg.symbol
INTO   #cte_checkrequestinvoicedetail_cofa
FROM   @FilteredCofA CofA
       INNER JOIN cofa_inventory
               ON cofa_inventory.cofaid = CofA.cofaid
                  AND cofa_inventory.isactive = 1 /* Yes */
       INNER JOIN apinvoice_costheader
               ON apinvoice_costheader.inventoryid = cofa_inventory.inventoryid
                  AND apinvoice_costheader.isasset = 1 /*YES  */
                  AND apinvoice_costheader.isactive = 1 /*YES*/
       INNER JOIN apinvoice_profile
               ON apinvoice_profile.vendorinvoiceid =
                  apinvoice_costheader.vendorinvoiceid
       INNER JOIN llc_profile
               ON llc_profile.llcid = apinvoice_profile.vendorllcid
       INNER JOIN currency_index
               ON currency_index.currencyindexid = llc_profile.currencyindexid
       INNER JOIN currency_symbol_cnfg
               ON currency_symbol_cnfg.symbolid =
                  currency_index.currencysymbolid
       INNER JOIN checkrequest_payeeinvoice
               ON checkrequest_payeeinvoice.vendorinvoicecostid =
                             apinvoice_costheader.vendorinvoicecostid
                  AND checkrequest_payeeinvoice.isactive = 1 /*YES  */
                  AND checkrequest_payeeinvoice.amounttopay &lt;&gt; 0
/* Only assets which have positvie or negative AmountToPay*/
GROUP  BY CofA.versionid,
          cofa_inventory.cofaid,
          CofA.cofanumber,
          apinvoice_profile.vendorid,
          apinvoice_profile.vendorinvoiceid,
          apinvoice_profile.vendorinvoicenumber,
          apinvoice_profile.isforeigncurrency,
          currency_symbol_cnfg.symbol

/*     (  */
SELECT Sum(checkrequest_payeeinvoice.amounttopay) [AmountToPay],
       cofa_inventory.cofaid,
       CofA.cofanumber,
       CofA.versionid,
       apinvoice_profile.vendorid,
       apinvoice_profile.vendorinvoiceid,
       apinvoice_profile.vendorinvoicenumber,
       apinvoice_profile.isforeigncurrency,
       currency_symbol_cnfg.symbol
INTO   #cte_checkrequestinvoicedetail_no_cofa
FROM   @FilteredCofA CofA
       INNER JOIN cofa_inventory
               ON cofa_inventory.cofaid = CofA.cofaid
                  AND cofa_inventory.isactive = 1 /* Yes */
       INNER JOIN apinvoice_costheader
               ON apinvoice_costheader.inventoryid = cofa_inventory.inventoryid
       INNER JOIN apinvoice_profile
               ON apinvoice_profile.vendorinvoiceid =
                  apinvoice_costheader.vendorinvoiceid
       INNER JOIN llc_profile
               ON llc_profile.llcid = apinvoice_profile.vendorllcid
       INNER JOIN currency_index
               ON currency_index.currencyindexid = llc_profile.currencyindexid
       INNER JOIN currency_symbol_cnfg
               ON currency_symbol_cnfg.symbolid =
                  currency_index.currencysymbolid
       LEFT OUTER JOIN checkrequest_payeeinvoice
                    ON checkrequest_payeeinvoice.vendorinvoicecostid =
                                       apinvoice_costheader.vendorinvoicecostid
                       AND checkrequest_payeeinvoice.isactive = 1 /*YES  */
                       AND checkrequest_payeeinvoice.amounttopay &lt;&gt; 0
/* Only assets which have positvie or negative AmountToPay */
WHERE  apinvoice_costheader.isactive = 1
/*YES*/
GROUP  BY CofA.versionid,
          cofa_inventory.cofaid,
          CofA.cofanumber,
          apinvoice_profile.vendorid,
          apinvoice_profile.vendorinvoiceid,
          apinvoice_profile.vendorinvoicenumber,
          apinvoice_profile.isforeigncurrency,
          currency_symbol_cnfg.symbol

/*
(*/
SELECT Sum(amounttopay) AmountToPay,
       vendorinvoicenumber
INTO   #cte_sum_cofa
FROM   #cte_checkrequestinvoicedetail_no_cofa
GROUP  BY vendorinvoicenumber

/*     (*/
SELECT COALESCE (#cte_sum_cofa.amounttopay, 0) AmountToPay,
       s.cofaid,
       s.cofanumber,
       s.versionid,
       s.vendorid,
       s.vendorinvoiceid,
       s.vendorinvoicenumber,
       s.isforeigncurrency,
       s.symbol
INTO   #cte_checkrequestinvoicedetail
FROM   #cte_checkrequestinvoicedetail_cofa s
       LEFT JOIN #cte_sum_cofa
              ON s.vendorinvoicenumber = #cte_sum_cofa.vendorinvoicenumber

/*
(*/
SELECT DISTINCT employeeassignment_entity.entityid
INTO   #cte_leaseleveladmin
FROM   security_userprofile
       INNER JOIN employeeassignment_entity
               ON employeeassignment_entity.userid = security_userprofile.userid
                  AND employeeassignment_entity.entitytypeid = 5 /*Lease */
                  AND employeeassignment_entity.rolefunctionid = 38
       /*-----------------------------------------------------------------------------------------------*/
                  AND employeeassignment_entity.isactive = 1 /* 20180212*/
OPTION (optimize FOR unknown)

/*     (*/
SELECT #cte_leaselist.accountnumber        [Lessee],
       #cte_leaselist.customername,
	   #cte_leaselist.LabellingLessorID,
       #cte_checkrequestinvoicedetail.cofanumber,
       #cte_checkrequestinvoicedetail.vendorinvoicenumber,
       vendor_profile.vendorid,
       #cte_checkrequestinvoicedetail.isforeigncurrency,
       apinvoice_billofsale.vendorinvoiceid
                  /*----------------------------------*/,
       #cte_leaselist.lessordefineduniqueid[ScheduleNumber],
       #cte_finalcofa.cnblineplacementdate,
       #cte_checkrequestinvoicedetail.amounttopay,
       #cte_checkrequestinvoicedetail.symbol,
       apinvoice_billofsale.invoicedate,
       apinvoice_billofsale.invoiceduedate,
       vendor_profile.vendorcompanyname/* test code*/,
       #cte_finalcofa.versionid,
       #cte_leaselist.leasetransactionid
/*-------------------------------------                    */
INTO   #cte_finalresult
FROM   #cte_leaselist /*FULL*/
       INNER JOIN #cte_finalcofa
               ON #cte_finalcofa.versionid = #cte_leaselist.leasetransactionid
       LEFT OUTER JOIN #cte_checkrequestinvoicedetail
                    ON #cte_checkrequestinvoicedetail.cofaid =
                       #cte_finalcofa.cofaid
                       AND #cte_checkrequestinvoicedetail.versionid =
                           #cte_finalcofa.versionid
       LEFT OUTER JOIN apinvoice_billofsale
                    ON apinvoice_billofsale.vendorinvoiceid =
                       #cte_checkrequestinvoicedetail.vendorinvoiceid
       LEFT OUTER JOIN vendor_profile
                    ON vendor_profile.vendorid =
                       #cte_checkrequestinvoicedetail.vendorid
       LEFT OUTER JOIN #cte_leaseleveladmin
                    ON #cte_leaseleveladmin.entityid = #cte_leaselist.leaseid
       LEFT OUTER JOIN discountloan_deal
                    ON discountloan_deal.entityid = #cte_leaselist.leaseid
       LEFT OUTER JOIN discountloan_fundingsourcedetail
                    ON discountloan_deal.discountloanid =
discountloan_fundingsourcedetail.discountloanid
AND discountloan_fundingsourcedetail.isrecourseavailable = 0
WHERE  ( ( discountloan_deal.isactive IS NULL
            OR ( discountloan_deal.isactive = 0
                 AND discountloan_deal.deactivatedreasonid != 4 ) )
          OR (( discountloan_deal.isactive = 1
                 OR ( discountloan_deal.isactive = 0
                      AND discountloan_deal.deactivatedreasonid = 4 ) )
             /*Consider fully amortized */) )

/* Begin #O*/
SELECT DISTINCT #cte_finalresult.lessee,
                #cte_finalresult.customername,
                #cte_finalresult.cofanumber,
                #cte_finalresult.vendorid,
                #cte_finalresult.isforeigncurrency,
                #cte_finalresult.vendorinvoiceid,
                #cte_finalresult.schedulenumber,
                #cte_finalresult.cnblineplacementdate,
                #cte_finalresult.symbol,
                Isnull(#cte_finalresult.amounttopay, 0) AmountToPay,
                #cte_finalresult.invoicedate,
                #cte_finalresult.invoiceduedate,
                #cte_finalresult.vendorcompanyname,
                #cte_finalresult.vendorinvoicenumber,
                cri.checkrequestid,
                crpi.checknumber,
                crpi.checkdate,
                PAYEE.payeeid,
                CURR.currencyname,
				CURR.ISO,
				#cte_finalresult.LabellingLessorID,
				fs.Company,
				fs.FundingSourceId,
				fs.FundingSourceNumber,
				fs.Alias
INTO   #o
FROM   #cte_finalresult
       LEFT JOIN checkrequest_invoice cri
              ON #cte_finalresult.vendorinvoiceid = cri.vendorinvoiceid
       LEFT JOIN checkrequest_paymentinvoice crpi
              ON #cte_finalresult.vendorinvoiceid = crpi.vendorinvoiceid
                 AND crpi.isactive = 1 /* 20180426*/
       LEFT JOIN #payee PAYEE
              ON #cte_finalresult.vendorinvoiceid = PAYEE.vendorinvoiceid
       /* 20180426*/
       LEFT JOIN #curr CURR
              ON #cte_finalresult.vendorinvoiceid = CURR.vendorinvoiceid
	   LEFT JOIN FundingSource_Profile fs
      		  ON #cte_finalresult.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label

/* Begin #Z*/
SELECT O.lessee                                       [Cust ID],
       O.customername                                 [Lessee Name],
       O.schedulenumber,
       Isnull(CONVERT(VARCHAR(10), O.cofanumber), '') [CofA Number],
       Cast(O.cnblineplacementdate AS DATE)           [CNB Placement Date],
       O.vendorinvoiceid,
       crp.payeeid,
       vp2.vendorcompanyname                          Payee,
       O.invoicedate,
       CASE CONVERT(CHAR(1), o.isforeigncurrency)
         WHEN '0' THEN O.amounttopay
         WHEN '1' THEN crfc.amount
         ELSE 0
       END                                            AmountToPay
                     /* (Yes, else No)*/,
       O.checknumber/* CheckRequest_PaymentInvoice.CheckNumber*/,
       O.checkdate,
	   O.ISO,
	   O.Symbol,
	   o.LabellingLessorID,
	   o.Company,
	   o.FundingSourceId,
	   o.FundingSourceNumber,
	   o.Alias
/* 20180426*/
INTO   #z
FROM   #o O
       LEFT JOIN checkrequest_foreigncurrency crfc
              ON O.checkrequestid = crfc.checkrequestid
                 AND crfc.[description] = 'Invoice Amount'
       LEFT JOIN vendor_profile vp
              ON O.payeeid = vp.vendorid
       LEFT JOIN checkrequest_payment crp
       /* Select * from CheckRequest_Payment*/
              ON O.checkrequestid = crp.checkrequestid
       /*--------------------------------------*/
       LEFT JOIN vendor_profile vp2 /* select * From Vendor_Profile*/
              ON crp.payeeid = vp2.vendorid
WHERE  O.vendorinvoiceid IS NOT NULL
       /* 20180212*/
       AND crp.isactive = 1

/* Begin #ZZ*/
SELECT Z.[lessee name],
       Z.schedulenumber,
       Z.[cnb placement date],
       Z.payee,
       z.payeeid,
       Sum(Z.amounttopay) AmountToPay,
       Z.vendorinvoiceid,
       Z.invoicedate
	   ,
	   Z.ISO,
	   Z.Symbol,
	   Z.LabellingLessorID,
	   Z.Company,
	   Z.FundingSourceId,
	   Z.FundingSourceNumber,
	   Z.Alias
/* 20180426*/
INTO   #zz
FROM   #z Z
GROUP  BY Z.[lessee name],
          Z.schedulenumber,
          Z.[cnb placement date],
          Z.payee,
          z.payeeid,
          Z.vendorinvoiceid,
          Z.invoicedate,
		  z.ISO,
		  z.Symbol,
		  Z.LabellingLessorID,
	      Z.Company,
	      Z.FundingSourceId,
	      Z.FundingSourceNumber,
		  Z.Alias

/* Begin #ZZZ*/
SELECT ZZ.[lessee name],
       ZZ.schedulenumber,
       ZZ.[cnb placement date],
       ZZ.payee,
       zz.payeeid,
       Sum(ZZ.amounttopay)  AmountToPay_old,
       Sum(AMT.amounttopay) AmountToPay_new,
       ZZ.invoicedate/* 20180323 grouping change*/,
       AMT.vendorinvoiceid  AMT_VendorInvoiceID,
       zz.vendorinvoiceid
	   ,
	   ZZ.ISO,
	   ZZ.Symbol,
	   ZZ.LabellingLessorID,
	   ZZ.Company,
	   ZZ.FundingSourceId,
	   ZZ.FundingSourceNumber,
	   ZZ.Alias
/* 20180426*/
INTO   #zzz
FROM   #zz ZZ
       INNER JOIN (SELECT i.vendorinvoiceid,
                          Sum(p.[amounttopay]) [AmountToPay]
                   FROM   [checkrequest_payeeinvoice] p
                          INNER JOIN [checkrequest_invoice] i
                                  ON p.checkrequestinvoiceid =
                                     i.checkrequestinvoiceid
                  /* 20180426*/
                   WHERE  p.isactive = 1
                  /*------------------*/
                   GROUP  BY i.vendorinvoiceid) AMT
               ON ZZ.vendorinvoiceid = AMT.vendorinvoiceid
GROUP  BY ZZ.[lessee name],
          ZZ.schedulenumber,
          ZZ.[cnb placement date],
          ZZ.payee,
          zz.payeeid,
          ZZ.invoicedate/* 20180323 grouping change*/,
          zz.vendorinvoiceid,
          zz.ISO,
		  zz.Symbol,
		  Zz.LabellingLessorID,
	      Zz.Company,
	      Zz.FundingSourceId,
	      Zz.FundingSourceNumber,
		  Zz.Alias,
		  AMT.vendorinvoiceid/* 20180323 grouping change*/;


WITH cte_zzz
     AS (/*==================================================*/ SELECT
        ZZZ.[lessee name],
        ZZZ.schedulenumber,
        Format(ZZZ.[cnb placement date], 'yyyy-MM-dd')  [CNB Placement Date],
        ZZZ.payee,
        zzz.payeeid,
		ZZZ.ISO,
		ZZZ.Symbol,
		ZZZ.LabellingLessorID,
	    ZZZ.Company,
	    ZZZ.FundingSourceId,
	    ZZZ.FundingSourceNumber,
		ZZZ.Alias,
        Sum(ZZZ.amounttopay_old)                        AmountToPay_old,
        Sum(ZZZ.amounttopay_new)                        AmountToPay_new,
        Iif(Format(Min(ZZZ.invoicedate), 'yyyy-MM-dd') =
            Format(Max(ZZZ.invoicedate), 'yyyy-MM-dd'),
        Format(Max(ZZZ.invoicedate), 'yyyy-MM-dd'), (
        Format(Min(ZZZ.invoicedate), 'yyyy-MM-dd')
        + ' to '
        + Format(Max(ZZZ.invoicedate), 'yyyy-MM-dd') )) [InvoiceDate(s)]
           /* 20180323 grouping change*/,
        zzz.amt_vendorinvoiceid,
        zzz.vendorinvoiceid
        /* 20180426*/
         FROM   #zzz ZZZ
         GROUP  BY ZZZ.[lessee name],
                   ZZZ.schedulenumber,
                   ZZZ.[cnb placement date],
                   ZZZ.payee,
                   zzz.payeeid/* 20180323 grouping change*/,
                   zzz.amt_vendorinvoiceid,
                   zzz.vendorinvoiceid
				   ,ZZZ.ISO
				   ,ZZZ.Symbol
				   ,ZZZ.LabellingLessorID
				   ,ZZZ.Company
				   ,ZZZ.FundingSourceId
				   ,ZZZ.FundingSourceNumber
				   ,ZZZ.Alias
				   
     /*=============================================================================*/),
     cte_union
     AS (SELECT lil.sequencenumber,
                ap.[vendorinvoiceid],
                Sum(ap.[assetamount]) AssetAmount
         FROM   [dbo].[apinvoice_costheader] ap
                INNER JOIN (SELECT i.[inventoryid],
                                   (SELECT sequencenumber
                                    FROM   lease_profile
                                    WHERE  [leaseid] = i.leaseid) SequenceNumber
                            FROM   [dbo].[lease_inventoryinlease] i
                            WHERE  inventoryid IN
                                   (SELECT [inventoryid]
                                    FROM   [dbo].[apinvoice_costheader])
                                   AND i.isinlease = 1) lil
                        ON ap.inventoryid = lil.inventoryid
         WHERE  vendorinvoiceid = 54992
         GROUP  BY lil.sequencenumber,
                   ap.[vendorinvoiceid])
/*----------------------------------------------------------------------------*/
,
     cte_zzzz
     AS (SELECT cte_zzz.[lessee name],
                cte_zzz.schedulenumber,
                cte_zzz.[cnb placement date],
                cte_zzz.payee,
                cte_zzz.payeeid,
				cte_zzz.ISO,
				cte_zzz.Symbol,
				cte_zzz.LabellingLessorID,
				cte_zzz.Company,
				cte_zzz.FundingSourceId,
				cte_zzz.FundingSourceNumber,
				cte_zzz.Alias,
                Sum(cte_zzz.amounttopay_old)  AmountToPay_old,
                Sum(cte_zzz.amounttopay_new)  AmountToPay_new,
                Min(cte_zzz.[invoicedate(s)]) minInvoiceDate,
                Max(cte_zzz.[invoicedate(s)]) maxInvoiceDate
         FROM   cte_zzz
/* 20180323 filter out Vendor Invoices that span multiple Lease schedule*/
         WHERE  cte_zzz.vendorinvoiceid IN (SELECT cte_zzz.vendorinvoiceid
                                            FROM   cte_zzz
                                            GROUP  BY cte_zzz.vendorinvoiceid
                                            HAVING
                Count(cte_zzz.vendorinvoiceid) = 1
                                           )
         GROUP  BY cte_zzz.[lessee name],
                   cte_zzz.schedulenumber,
                   cte_zzz.[cnb placement date],
                   cte_zzz.payee,
                   cte_zzz.payeeid
				   ,cte_zzz.ISO
				   ,cte_zzz.Symbol
				   ,cte_zzz.LabellingLessorID,
					cte_zzz.Company,
					cte_zzz.FundingSourceId,
					cte_zzz.FundingSourceNumber,
					cte_zzz.Alias
				),
     cte_zzzzz
     AS (SELECT cte_zzz.[lessee name],
                cte_zzz.schedulenumber,
                cte_zzz.[cnb placement date],
                cte_zzz.payee,
                cte_zzz.payeeid,
				cte_zzz.ISO,
				cte_zzz.Symbol,
				cte_zzz.LabellingLessorID,
				cte_zzz.Company,
				cte_zzz.FundingSourceId,
				cte_zzz.FundingSourceNumber,
				cte_zzz.Alias,
                Sum(cte_zzz.amounttopay_old)  AmountToPay_old,
                u.assetamount                 AmountToPay_new,
                Min(cte_zzz.[invoicedate(s)]) minInvoiceDate,
                Max(cte_zzz.[invoicedate(s)]) maxInvoiceDate
         FROM   cte_zzz
/*-----------------------------------------------------------------------*/
                INNER JOIN cte_union u
                        ON cte_zzz.schedulenumber = u.sequencenumber
/* 20180323 filter out Vendor Invoices that span multiple Lease schedule*/
         WHERE  cte_zzz.vendorinvoiceid IN (SELECT cte_zzz.vendorinvoiceid
                                            FROM   cte_zzz
                                            GROUP  BY cte_zzz.vendorinvoiceid
                                            HAVING
                Count(cte_zzz.vendorinvoiceid) &gt;= 1)
         GROUP  BY cte_zzz.[lessee name],
                   cte_zzz.schedulenumber,
                   cte_zzz.[cnb placement date],
                   cte_zzz.payee,
                   cte_zzz.payeeid,
                   u.assetamount
				   ,cte_zzz.ISO
				   ,cte_zzz.Symbol
				  ,cte_zzz.LabellingLessorID,
				cte_zzz.Company,
				cte_zzz.FundingSourceId,
				cte_zzz.FundingSourceNumber,
				cte_zzz.Alias
				)
/* 20180323 revised output*/ SELECT DISTINCT y.[lessee name],
                y.schedulenumber,
                y.[cnb placement date],
                y.payee,
                y.payeeid,
				y.ISO,
				y.Symbol,
				y.LabellingLessorID,
				y.Company,
				y.FundingSourceId,
				y.FundingSourceNumber,
				y.Alias,
                Sum(y.amounttopay_old) AmountToPay_old,
                Sum(y.amounttopay_new) AmountToPay_new,
                Iif(Min(y.mininvoicedate) = Max(y.maxinvoicedate),
                Max(y.maxinvoicedate),
                Min(y.mininvoicedate) + ' to '
                + Max(
                y.maxinvoicedate))     [InvoiceDate(s)]
FROM   (SELECT zzzz.[lessee name],
               zzzz.schedulenumber,
               zzzz.[cnb placement date],
               zzzz.payee,
               zzzz.payeeid,
			   zzzz.ISO,
			   zzzz.Symbol,
			   zzzz.LabellingLessorID,
			   zzzz.Company,
			   zzzz.FundingSourceId,
			   zzzz.FundingSourceNumber,
			   zzzz.Alias,
               0 AmountToPay_old,
               zzzz.amounttopay_new,
               zzzz.mininvoicedate,
               zzzz.maxinvoicedate
        FROM   cte_zzzz zzzz
        UNION
        SELECT zzzzz.[lessee name],
               zzzzz.schedulenumber,
               zzzzz.[cnb placement date],
               zzzzz.payee,
               zzzzz.payeeid,
			   zzzzz.ISO,
			   zzzzz.Symbol,
			   zzzzz.LabellingLessorID,
			   zzzzz.Company,
			   zzzzz.FundingSourceId,
			   zzzzz.FundingSourceNumber,
			   zzzzz.Alias,
               0 AmountToPay_old,
               zzzzz.amounttopay_new,
               zzzzz.mininvoicedate,
               zzzzz.maxinvoicedate
        FROM   cte_zzzzz zzzzz) y
GROUP  BY y.[lessee name],
          y.schedulenumber,
          y.[cnb placement date],
          y.payee,
          y.payeeid,
				y.ISO,
				y.Symbol,
				y.LabellingLessorID,
				y.Company,
				y.FundingSourceId,
				y.FundingSourceNumber,
				y.Alias
ORDER  BY y.payee,
          y.schedulenumber

/*--------------------------------------------------------------------------*/
DROP TABLE #cte_leaselist

DROP TABLE #cte_finalcofa

DROP TABLE #cte_checkrequestinvoicedetail_sum

DROP TABLE #cte_checkrequestinvoicedetail_cofa

DROP TABLE #cte_checkrequestinvoicedetail_no_cofa

DROP TABLE #cte_sum_cofa

DROP TABLE #cte_checkrequestinvoicedetail

DROP TABLE #cte_leaseleveladmin

DROP TABLE #cte_finalresult

/* 20180426*/
DROP TABLE #curr

DROP TABLE #payee

DROP TABLE #o

DROP TABLE #z

DROP TABLE #zz

DROP TABLE #zzz </CommandText>
      </Query>
