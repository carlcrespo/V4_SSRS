    <DataSet Name="SubTransactionTypeDS">
      <Query>
        <DataSourceName>Insight</DataSourceName>
        <CommandText>SELECT GeneralLedger_SubTransactionType_Cnfg.SubTransactionTypeId, GeneralLedger_SubTransactionType_Cnfg.EnumValue FROM GeneralLedger_SubTransactionType_Cnfg
INNER JOIN GeneralLedger_TransactionType_Cnfg ON GeneralLedger_TransactionType_Cnfg.TransactionTypeID = GeneralLedger_SubTransactionType_Cnfg.TransactionTypeID
AND GeneralLedger_TransactionType_Cnfg.IsActive = 1
ORDER BY GeneralLedger_SubTransactionType_Cnfg.EnumValue</CommandText>
      </Query>
      <Fields>
        <Field Name="SubTransactionTypeId">
          <DataField>SubTransactionTypeId</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="EnumValue">
          <DataField>EnumValue</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EntityTypesDS">
      <Query>
        <DataSourceName>Insight</DataSourceName>
        <CommandText>
SELECT 
	Template_EntityType_CnfgLocale.EntityTypeID, 
	Template_EntityType_CnfgLocale.EntityTypeName 
FROM 
	Template_EntityType_CnfgLocale 
	INNER JOIN
	(
		SELECT 
			DISTINCT EntityTypeID 
		FROM 
			GeneralLedger_JournalEntryEntity) AS GLEntityTypes
		ON Template_EntityType_CnfgLocale.EntityTypeID = GLEntityTypes.EntityTypeID
WHERE Template_EntityType_CnfgLocale.EntityTypeID NOT IN (5,24,20) --Excluding Lease and Vendor Invoice entity types and Clear Unallocated Cash
UNION 
SELECT 0,'NULL'</CommandText>
      </Query>
      <Fields>
        <Field Name="EntityTypeID">
          <DataField>EntityTypeID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="EntityTypeName">
          <DataField>EntityTypeName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="LabellingLessorDS">
      <Query>
        <DataSourceName>Insight</DataSourceName>
        <CommandText>SELECT NULL FundingSourceId,'NULL' FundingSourceNumber
UNION ALL
SELECT 
	FundingSourceId,
	FundingSourceNumber
FROM 
	FundingSource_Profile 
WHERE 
	TypeId IN (1, 7) 
	AND StatusId = 2 --Active</CommandText>
      </Query>
      <Fields>
        <Field Name="FundingSourceId">
          <DataField>FundingSourceId</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="FundingSourceNumber">
          <DataField>FundingSourceNumber</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
