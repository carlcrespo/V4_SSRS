          <QueryParameter Name="@EntityID">
            <Value>=Parameters!EntityID.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EntityTypeID">
            <Value>=IIF(Parameters!EntityTypeID.Value = 0, System.DBNull.Value, Parameters!EntityTypeID.Value)</Value>
          </QueryParameter>
          <QueryParameter Name="@SubTransactionType">
            <Value>=JOIN(Parameters!SubTransactionType.Value,",")</Value>
