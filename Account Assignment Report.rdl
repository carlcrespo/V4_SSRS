With
cte_EOLAdmin
As
(
	SELECT Distinct e.EmployeeAssignmentID,
	 e.EntityTypeID
	,(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
	,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
	,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
	,(SELECT FirstName+SPACE(1)+LastName FROM Security_UserProfile WHERE UserID = e.UserID) Name
	,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
	,CASE WHEN (SELECT UserAlias FROM Security_UserProfile WHERE UserID = e.UserID) = 'End of Lease Administrator' THEN 'EOL_Admin'
		ELSE (SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) 
		END RoleFunctionName
		,e.EntityID
	FROM EmployeeAssignment_Entity e
	Inner Join Security_UserProfile s
	ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator' 

	Where e.EntityTypeID = 1
	And e.EmployeeAssignmentID IN
		(
			SELECT Max(e.EmployeeAssignmentID) 
			FROM EmployeeAssignment_Entity e
			Inner Join Security_UserProfile s
				ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator'  
			Where e.EntityTypeID = 1
			And 
				(
				SELECT UserAlias 
				FROM Security_UserProfile 
				WHERE UserID = e.UserID
				) = 'End of Lease Administrator' 
			Group By  e.EntityTypeID,e.EntityID
		)
)
---------------------------------------------
,
cte_LeaseAdmin
AS
(
		SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID
		,(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
		,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
		,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
		,(SELECT FirstName+SPACE(1)+LastName FROM Security_UserProfile WHERE UserID = e.UserID) Name
		,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
		,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
		,(SELECT RoleFunctionID FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionID
		,e.EntityID
		FROM EmployeeAssignment_Entity e
		WHERE e.EntityTypeID  = 1 
		And 
		 e.EmployeeAssignmentID IN 
			(
			SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
			FROM EmployeeAssignment_Entity 
			WHERE EntityTypeID = 1  /*@EntityTypeID --LeaseAdmin*/
				AND IsActive = 1 /*@IsActive*/
				AND RoleFunctionID = 38  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=38, RoleFunctionName = 'Lease Administrator'
			------------------------------	
				And EmployeeAssignmentID Not IN 
				(
					SELECT distinct e.EmployeeAssignmentID 
					FROM EmployeeAssignment_Entity e
					Inner Join Security_UserProfile s
					ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator'  
					Where e.EntityTypeID = 1
				And (SELECT UserAlias FROM Security_UserProfile WHERE UserID = e.UserID) = 'End of Lease Administrator' 
				)			
			------------------------------	 
			GROUP BY EntityID --,UserID 
			)
)
---------------------------------------------
,
cte_SalesAdmin
AS
(
	SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID,
	(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
	,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
	,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
	,(SELECT FirstName+SPACE(1)+LastName FROM Security_UserProfile WHERE UserID = e.UserID) Name
	,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
	,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
	,e.EntityID
	FROM EmployeeAssignment_Entity e
	WHERE e.EntityTypeID  = 1 And 
	 e.EmployeeAssignmentID IN 
		(
		SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
		FROM EmployeeAssignment_Entity 
		WHERE EntityTypeID = 1  /*@EntityTypeID --SalesAdmin*/
			AND IsActive = 1 
			AND RoleFunctionID = 8  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=8, RoleFunctionName = 'Sales Representative'
		GROUP BY EntityID --,UserID 
		)
)
---------------------------------------------
,
cte_BillingAdmin
AS
(
	SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID,
	(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
	,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
	,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
	,(SELECT FirstName+SPACE(1)+LastName FROM Security_UserProfile WHERE UserID = e.UserID) Name
	,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
	,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
	,e.EntityID
	FROM EmployeeAssignment_Entity e
	WHERE e.EntityTypeID  = 1 And 
	 e.EmployeeAssignmentID IN 
		(
		SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
		FROM EmployeeAssignment_Entity 
		WHERE EntityTypeID = 1  /*@EntityTypeID --BillingAdmin*/
			AND IsActive = 1 
			AND RoleFunctionID = 40  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=40, RoleFunctionName = 'Billing'
		GROUP BY EntityID --,UserID 
		)
)
---------------------------------------------
,
cte_add
AS
(
---------------------------------------------------------------------------------------------------------------
	SELECT 
		 ca.ContactAddressID
		 ,p.ContactAddressID ContactAddressID_person
		,ca.EntityTypeID
		,ca.EntityID CustomerID
		,p.FirstName + SPACE(1) + p.LastName Name 
		,ca.[Address]
		,ca.Address2
		,ca.City
		,((SELECT StateShortName FROM Template_State_CnfgLocale WHERE StateID = ca.StateID)
		) State
		,ca.StateID
		,ca.ZIP
		,CAST((SELECT NewUntilDate FROM Customer_profile WHERE CustomerID = ca.EntityID and CustomerStatusID=1) AS DATE) NewUntilDate
		,p.PhoneNumber1
		,p.FaxNumber
		,p.EmailID
		,p.ContactType
		,p.ContactPersonID
	FROM Contact_Address ca
	Left JOIN 
		(
		Select 
			   ct.ContactType
			  ,ct.[ContactPersonID]
			  ,ct.[ContactAddressID]
			  ,ct.[Prefix]
			  ,ct.[FirstName]
			  ,ct.[MiddleName]
			  ,ct.[LastName]
			  ,ct.[Suffix]
			  ,ct.[Department]
			  ,ct.[Title]
			  ,ct.[PhoneNumber1]
			  ,ct.[ExtensionNumber1]
			  ,ct.[PhoneNumber2]
			  ,ct.[ExtensionNumber2]
			  ,ct.[CellPhoneNumber]
			  ,ct.[FaxNumber]
			  ,ct.[EmailID]
			  ,ct.[Description]
			  ,ct.[IsIncumbentSigner]
			  ,ct.[IncumbentSignerDate]
			  ,ct.[IsCofAIncumbentOnly]
			  ,ct.[IsIncumbencyExpires]
			  ,ct.[IncumbencyExpirationDate]
			  ,ct.[LastModifiedUserID]
			  ,ct.[LastModifiedDate]
		From
			(
			SELECT 
				(
				Select [Description] 
					From Contact_Type_Cnfg 
					Where ContactTypeID = cptype.ContactTypeID
					) 
					As ContactType
				  ,cp.[ContactPersonID]
				  ,cp.[ContactAddressID]
				  ,cp.[Prefix]
				  ,cp.[FirstName]
				  ,cp.[MiddleName]
				  ,cp.[LastName]
				  ,cp.[Suffix]
				  ,cp.[Department]
				  ,cp.[Title]
				  ,cp.[PhoneNumber1]
				  ,cp.[ExtensionNumber1]
				  ,cp.[PhoneNumber2]
				  ,cp.[ExtensionNumber2]
				  ,cp.[CellPhoneNumber]
				  ,cp.[FaxNumber]
				  ,cp.[EmailID]
				  ,cp.[Description]
				  ,cp.[IsIncumbentSigner]
				  ,cp.[IncumbentSignerDate]
				  ,cp.[IsCofAIncumbentOnly]
				  ,cp.[IsIncumbencyExpires]
				  ,cp.[IncumbencyExpirationDate]
				  ,cp.[LastModifiedUserID]
				  ,cp.[LastModifiedDate]
			  FROM Contact_Person cp
			  Left Join Contact_PersonContactTypeSetup cptype
			  On cp.ContactPersonID = cptype.ContactPersonID
			  ) ct
		  Where ct.ContactType = 'Main'
				) p
		ON ca.ContactAddressID = p.ContactAddressID 
Where P.ContactType is not null
And p.ContactPersonID IN
	(

		SELECT 
			MAX(p.ContactPersonID) ContactPersonID
			--,ca.EntityID CustomerID, (Select CustomerName From Customer_Profile Where CustomerID = ca.EntityID) CustomerName
		FROM Contact_Address ca
		Left JOIN 
			(
			Select 
					ct.ContactType
					,ct.[ContactPersonID]
					,ct.[ContactAddressID]
			From
				(
				SELECT 
					(Select [Description] 
						From Contact_Type_Cnfg 
						Where ContactTypeID = cptype.ContactTypeID
						) 
						As ContactType
						,cp.[ContactPersonID]
						,cp.[ContactAddressID]
					FROM Contact_Person cp
					Left Join Contact_PersonContactTypeSetup cptype
					On cp.ContactPersonID = cptype.ContactPersonID
					) ct
				Where ct.ContactType = 'Main'
					) p
			ON ca.ContactAddressID = p.ContactAddressID and EntityTypeID=1
			Where P.ContactType is not null
		Group By ca.EntityID -- CustomerID
	)
---------------------------------------------------------------------------------------------------------------
	--SELECT ca.ContactAddressID
	--	,ca.EntityTypeID
	--	,ca.EntityID CustomerID
	--	,p.FirstName + SPACE(1) + p.LastName Name 
	--	,ca.[Address]
	--	,ca.City
	--	,((SELECT StateShortName FROM Template_State_CnfgLocale WHERE StateID = ca.StateID)
	--	+'-'+
	--	(SELECT StateLongName FROM Template_State_CnfgLocale WHERE StateID = ca.StateID)
	--	) [State]
	--	,ca.ZIP
	--	,CAST((SELECT NewUntilDate FROM Customer_profile WHERE CustomerID = ca.EntityID) AS DATE) NewUntilDate
	--FROM Contact_Address ca
	--INNER JOIN Contact_Person p
	--	ON ca.ContactAddressID = p.ContactAddressID
	--	WHERE ca.EntityTypeID = 1 
	--AND ca.ContactAddressID IN
	--	(
	--			SELECT MAX(ContactAddressID)
	--			  FROM Contact_Address			  
	--			  WHERE EntityTypeID = 1
	--			  GROUP BY EntityID
	--	)
----------------------------------------------------------------------------------------------------------------
)
,
cte_ExpectedInceptionDate
AS
(
	SELECT lp.CustomerID
		,Min(lp.ExpectedInceptionDate) ExpectedInceptionDate
	FROM Lease_Profile lp
	Group By lp.CustomerID 
)
---------------------------------------------
Select 
	 o.CustomerID
	,o.AccountNumber
	,o.MLAID
    ,o.MLA_IsActive	
	,o.CustomerName
	,o.SIC_Desc
	,o.Industry_Desc
	,o.MLAName 
    ,o.ClientMLANumber
    ,o.MLADate
	,o.SalesAdmin
	,o.LeaseAdmin
	,o.BillingAdmin
	,o.EOLAdmin
	,o.[Address]
	,o.City
	,o.[State]
	,o.ZIP
	,o.NewUntilDate
	,o.Commence_Date
	,o.ListValue
From
(
-------------------
		Select Distinct  TOP 100 PERCENT
			 cp.CustomerID
			 ,mla.[MLAID]
			,cp.AccountNumber
			,cp.CustomerName
			,dem.SIC_Desc
			,dem.Industry_Desc
			,IIF(mla.IsActive = 1,'Yes','No') MLA_IsActive	
			,IsNull(mla.MLAName,'') MLAName
			,IsNull(mla.ClientMLANumber,'') ClientMLANumber
			,Cast(mla.MLADate AS Date) MLADate
			,IsNull(la.Name,'') LeaseAdmin
			,IsNull(ba.Name,'') BillingAdmin
			,IsNull(sa.Name,'') SalesAdmin
			,IsNull(ea.Name,'') EOLAdmin
			,IsNull(a.[Address],'') [Address]
			,IsNull(a.City,'') City
			,IsNull(a.[State],'') [State]
			,IsNull(a.ZIP,'') ZIP
			,a.NewUntilDate 
			,Convert(Date,d.ExpectedInceptionDate) Commence_Date,
			ulv.ListValue
		From Customer_Profile cp
		

		left join

			(
				select 
					cp.CustomerID
					,sic.[Description] as SIC_Desc
					,ind.[Description] as Industry_Desc
				from Customer_Profile cp
					join [Template_SICCode_Cnfg] sic
					on cp.SICCodeID = sic.SICCodeID 
					join [Template_IndustryCode_Cnfg] ind
					on sic.IndustryCodeID = ind.IndustryCodeID
			) dem
			on cp.CustomerID = dem.CustomerID 


		Left join cte_LeaseAdmin la
			On cp.AccountNumber = la.AccountNumber

		Left join cte_BillingAdmin ba
			on cp.AccountNumber = ba.AccountNumber

		Left Join cte_SalesAdmin sa 
			on cp.AccountNumber = sa.AccountNumber

		Left Join cte_EOLAdmin ea
			on cp.AccountNumber = ea.AccountNumber

		Left Join cte_add a
			on cp.CustomerID = a.CustomerID

		Left Join MLA_Profile mla
			on cp.CustomerID = mla.CustomerID

		Left Join cte_ExpectedInceptionDate d
			On cp.CustomerID = d.CustomerID 

Left JOIN Customer_UDFList CUL ON CP.CustomerID = CUL.CustomerID

Left JOIN UDF_ListValue ULV ON CUL.SalesVertical = ULV.ListID


		Where cp.CustomerStatusID = 1
		Order by cp.AccountNumber
) o</CommandText>
      </Query>
