  <DataSources>
    <DataSource Name="LW_PROD">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>6dceeb62-0898-41aa-bdc7-f19706eb55a6</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <CommandText>-- 20191009
SELECT a.[InventoryTypeID] AssetTypeId
      ,a.[InventoryTypeName] AssetTypeName
      ,(
		SELECT f.[FactorCategoryName] 
		FROM [dbo].[Inventory_FactorCategoryTemplate] f 
		WHERE  f.[FactorCategoryID] = a.[FactorCategoryID]
		) [FactorCategoryName]
      ,(
		SELECT [InventoryCategoryName]
		FROM [dbo].[Inventory_CategoryTemplate]
		WHERE InventoryCategoryID = a.[InventoryCategoryID]
		) AssetCategoryName 
		,(
		SELECT [InventorySubcategoryName]
		FROM [dbo].[Inventory_SubcategoryTemplate]
		WHERE [InventorySubcategoryID] = a.[InventorySubcategoryID]
		) AssetSubCategoryName
      ,(
		SELECT [InventoryFormName]
		FROM [dbo].[Inventory_FormTemplate]
		WHERE [InventoryFormID] = a.[InventoryFormID]
		) AssetFormName
      ,a.[IsTier1]
      ,a.[IsActive]
  FROM [dbo].[Inventory_TypeTemplate] a
  ORDER BY [InventoryTypeID]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="AssetTypeId">
          <DataField>AssetTypeId</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="AssetTypeName">
          <DataField>AssetTypeName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FactorCategoryName">
          <DataField>FactorCategoryName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AssetCategoryName">
