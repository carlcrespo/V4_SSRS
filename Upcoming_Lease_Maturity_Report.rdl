  <DataSets>
    <DataSet Name="PortfolioList">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <CommandText>SELECT        PortfolioID, PortfolioName
FROM            (/*SELECT        NULL AS PortfolioID, NULL AS PortfolioName
                          UNION ALL*/
                          SELECT        PortfolioID, PortfolioName
                          FROM            Portfolio_Profile
                          WHERE        (IsActive = 1)) AS RS1
ORDER BY PortfolioID</CommandText>
      </Query>
      <Fields>
        <Field Name="PortfolioID">
          <DataField>PortfolioID</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="PortfolioName">
          <DataField>PortfolioName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CustomerName">
            <Value>=Parameters!CustomerName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Portfolio">
            <Value>=Parameters!Portfolio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromMaturityDate">
            <Value>=Parameters!FromMaturityDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToMaturityDate">
            <Value>=Parameters!ToMaturityDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20191021
-- 20190227 SSRS
-- Upcoming Lease Maturity/Upcoming Lease Maturities - Ampil Sales 
-- Work Order #31750/31820
-------------------------------------------------------------------------------------------------
 --test code
--DECLARE 
--	  @FromMaturityDate DATETIME = NULL
--	, @ToMaturityDate DATETIME = '9/8/21'
--	, @Portfolio VARCHAR(MAX) = 5	
--	, @CustomerName NVARCHAR(250) = NULL --'Avanti Hospitals, LLC' ----NULL	
--------------------------------------------------------------------------------------------------
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED 

---------------------------------------------
-- rev 20150623
;
WITH
cte_Invoice_ReceivableDetail
AS
(
SELECT a.[InvoiceReceivableDetailID]
	,a.[InvoiceDealDetailID]
	,(SELECT [InvoiceID] FROM [dbo].[Invoice_DealDetail] WHERE [InvoiceDealDetailID]=a.[InvoiceDealDetailID]) [InvoiceID]
	,(
	SELECT [DueDate] FROM [dbo].[Invoice_Header] WHERE InvoiceID =
	(
	SELECT [InvoiceID] FROM [dbo].[Invoice_DealDetail] WHERE [InvoiceDealDetailID]=a.[InvoiceDealDetailID]
	) 
	) [DueDate]
	,a.[ReceivableTypeID]
	,a.[InventoryID]
	,a.[ReceivableID]
	,a.[Amount]
	,a.[Balance]
	,a.[ReceivableTaxID]
	,a.[RentalExecutoryFeeAmount]
	,a.[NonRentalExecutoryFeeAmount]
	,a.[PaymentNumber]
	,a.[ReceivableTypeDescription]
	,a.[DomicileLocationId]
	,a.[AccountingTreatmentID]
	,a.[TaxAmount]
	,a.[TaxBalance]
	,a.[ReceivableRollupTypeID]
	,a.[InterimInterest]
	,a.[RentalPeriodFromDate]
	,a.[RentalPeriodToDate]
FROM [dbo].[Invoice_ReceivableDetail] a
)
,
cte_FilteredLeases
AS
(
				SELECT 
					 Customer_Profile.CustomerName
					---------------------
					 --20190222
					,Customer_Profile.AccountNumber
					-----------------------------
					,Lease_Profile.SequenceNumber
					,Lease_Profile.LeaseID
					,Lease_Profile.ExpectedMaturityDate
					,Lease_Profile.IsStopBilling
				FROM 
					Lease_Profile

					INNER JOIN Customer_Profile 
						ON Lease_Profile.CustomerID = Customer_Profile.CustomerID
				WHERE 
					Lease_Profile.BookingStatusId = 2 -- Completed
					AND Lease_Profile.StatusId = 2 -- Commenced	
					------------------
					-- 20190220
					--FILTERCONDITIONS
					AND Customer_Profile.CustomerName LIKE IIF(@CustomerName IS NULL,'%',@CustomerName)
----------------------------------
-- production code
					AND Lease_Profile.PortfolioID IN (@Portfolio)
					--------------------------------------------------------------------------------------------------------------------------
					-- test code
					--AND Lease_Profile.PortfolioID IN (SELECT PortfolioID FROM Portfolio_Profile WHERE PortfolioName = @Portfolio)
					--------------------------------------------------------------------------------------------------------------------------
)
,
				--;WITH
				CTE_MaxInvoiceDealDetailID
				AS
				(
					SELECT
						 MAX(Invoice_DealDetail.InvoiceDealDetailID) AS InvoiceDealDetailID
						,Invoice_DealDetail.EntityID AS LeaseID
					FROM
						Invoice_DealDetail

						INNER JOIN Invoice_Header
							ON Invoice_Header.InvoiceID = Invoice_DealDetail.InvoiceID					

						INNER JOIN 
							(
								SELECT 		
									 MAX(Invoice_Header.DueDate) AS MaxDueDate					
									,FilteredLease.LeaseID
								FROM 
									Invoice_DealDetail 

									INNER JOIN cte_FilteredLeases FilteredLease
										ON FilteredLease.LeaseID = Invoice_DealDetail.EntityID
										AND Invoice_DealDetail.EntityTypeID = 5 -- Lease_Profile

									INNER JOIN cte_Invoice_ReceivableDetail
										ON cte_Invoice_ReceivableDetail.InvoiceDealDetailID = Invoice_DealDetail.InvoiceDealDetailID
										AND cte_Invoice_ReceivableDetail.ReceivableTypeID in(1,3)--1 indicates "Lease Rental" and 3 indicates "OTP"

									INNER JOIN Invoice_Header
										ON Invoice_DealDetail.InvoiceID = Invoice_Header.InvoiceID
										AND Invoice_Header.InvoiceStatusID = 1 --Active
												
								GROUP BY 
										FilteredLease.LeaseID				
							)R1

							ON Invoice_Header.DueDate = R1.MaxDueDate			 
							AND Invoice_DealDetail.EntityTypeID = 5 -- Lease_Profile	
							AND Invoice_DealDetail.EntityID = R1.LeaseID

						INNER JOIN cte_Invoice_ReceivableDetail
							ON cte_Invoice_ReceivableDetail.InvoiceDealDetailID = Invoice_DealDetail.InvoiceDealDetailID
							AND cte_Invoice_ReceivableDetail.ReceivableTypeID in(1,3)--1 indicates "Lease Rental" and 3 indicates "OTP"
		
						GROUP BY 
							Invoice_DealDetail.EntityID		
				),
				/*Calculates LastInvoiceAmount*/
				CTE_LastInvoiceAmount
				AS
				(
					SELECT
						 FilteredLease.LeaseID
						,SUM(cte_Invoice_ReceivableDetail.Amount + cte_Invoice_ReceivableDetail.TaxAmount) AS LastInvoiceAmount
--------------------------------
-- rev 20150623
						,DueDate
--------------------------------		
					FROM
						cte_FilteredLeases FilteredLease

						INNER JOIN CTE_MaxInvoiceDealDetailID
							ON FilteredLease.LeaseID = CTE_MaxInvoiceDealDetailID.LeaseID

						INNER JOIN cte_Invoice_ReceivableDetail
							ON cte_Invoice_ReceivableDetail.InvoiceDealDetailID = CTE_MaxInvoiceDealDetailID.InvoiceDealDetailID
							AND cte_Invoice_ReceivableDetail.ReceivableTypeID in(1,3)--1 indicates "Lease Rental" and 3 indicates "OTP"
					
					GROUP BY
						 FilteredLease.LeaseID
						,CTE_MaxInvoiceDealDetailID.InvoiceDealDetailID
--------------------------------
-- rev 20150623
						,DueDate
--------------------------------
							),
				CTE_OTPRent
				AS
				(
					SELECT
						  FilteredLease.LeaseID
						 ,SUM(Lease_InventoryInLease.OverTermPaymentRentalAmount) AS OTPRent
					FROM
						cte_FilteredLeases FilteredLease

						INNER JOIN Lease_InventoryInLease
							ON Lease_InventoryInLease.LeaseID = FilteredLease.LeaseID		
							AND Lease_InventoryInLease.IsInLease = 1	
					GROUP BY
						FilteredLease.LeaseID
				),
				CTE_FinalResult
				AS
				(
					SELECT 
						 FilteredLease.CustomerName
						 ---------------------------
						 -- 20190222
						,FilteredLease.AccountNumber
						----------------------------
						,FilteredLease.SequenceNumber AS LeaseNumber
						 ,ci.ISO 
						 ,csc.Symbol
        				 ,fs.FundingSourceId
        				 ,fs.FundingSourceNumber
						 ,fs.Alias As coAlias
						 ,fs.Company
						,CTE_LastInvoiceAmount.LastInvoiceAmount
------------------------------------------------------
--rev 20160623
						,CTE_LastInvoiceAmount.DueDate
------------------------------------------------------
						,CTE_OTPRent.OTPRent
						,CASE WHEN Lease_Contract.ContractStructureId = 1 THEN ----1 indicates Regular Lease
							RegularLeaseFrequency.Frequency
							ELSE
							IrregularLeaseFrequency.Frequency
							END RentalFrequency
						------------------------------------------------------
						-- 2019022
						--,FilteredLease.ExpectedMaturityDate AS MaturityDate
						,Lease_Contract.MaturityDate
						------------------------------------------------------
						,Lease_ContractPurchaseOption_CnfgLocale.PurchaseOption AS PurchaseOptionType
						,Lease_PurchaseOptionSubType_Cnfg.Description AS PurchaseOptionSubType
						,CASE WHEN FilteredLease.IsStopBilling = 0 THEN
							'N'
						 ELSE
							'Y'
						 END AS StopBilling
						,CASE WHEN MaturityManagement_Lease.PractIsFMVCap = 1 THEN
							'Y'
						 ELSE
							'N'
						 END AS FMVCap
						,CASE WHEN MaturityManagement_Lease.PractOTPAdvancePayment = 0 THEN
							'N'
						 ELSE
							'Y'
						 END AS OTPAdvancedBilling
						,Lease_RentalFrequency_CnfgLocale.RentalFrequencyName AS OTPRentalFrequency
						,CASE WHEN MaturityManagement_Lease.PractIsTransitionLease = 0 THEN  
							'N'
						 ELSE
							'Y'
						 END AS TransitionLease
						,CASE WHEN MaturityManagement_Lease.PractIsTransitionLease = 1 THEN  
							CONVERT(NVARCHAR(3),MaturityManagement_Lease.PractTransitionDays)
						 ELSE
							''
						 END AS TransitionPeriod
						,CASE WHEN MaturityManagement_Lease.PractIsDoubleInArrears = 0 THEN
							'N'
						 ELSE
							'Y'
						 END AS OTPDoubleInArrears
						,CONVERT(NVARCHAR(3),ISNULL(MaturityManagement_Lease.PractEOTPartialGracePeriod,0)) + ',' + CONVERT(NVARCHAR(3),ISNULL(MaturityManagement_Lease.PractEOTABNLTAGracePeriod,0)) + ',' + CONVERT(NVARCHAR(3),ISNULL(MaturityManagement_Lease.PractOTPGracePeriod,0)) AS GracePeriod
						,CASE WHEN MaturityManagement_Lease.PractIsSuspendOTPBilling = 0 THEN
							'N'
						 ELSE
							'Y'
						 END AS OTPSuspend
						,PractDataSecurityReqdID.BoolDisplayText AS DataSecurityRequired
						,Inventory_FreightResponsibility_CnfgLocale.FreightResponsibility AS FreightResponsibility
						,PractPurchase.EOTOption AS OTPPurchaseOptions
						,PractRenew.EOTOption AS OTPRenewalOption
						,PractReturn.EOTOption AS OTPReturnOption
						,Inventory_LKEType_CnfgLocale.LKEType AS LKEAllowed	
						,CASE WHEN MaturityManagement_Lease.PractIsEOTRestriction = 1 AND MaturityManagement_Lease.PractIsSpecialEOTProvision = 1 THEN	
							1
						 ELSE
							0
						 END AS IsEOTProvisionAndRestrictionExists
						,MaturityManagement_Lease.PractRestrictions
						,MaturityManagement_Lease.PractConditions
						,CASE WHEN ((MaturityManagement_Lease.PractFirstReductionPercent IS NOT NULL AND MaturityManagement_Lease.PractFirstReductionPercent &gt; 0.00) OR 
									(MaturityManagement_Lease.PractSecondReductionPercent IS NOT NULL AND MaturityManagement_Lease.PractSecondReductionPercent &gt; 0.00) OR 
									(MaturityManagement_Lease.PractThirdReductionPercent IS NOT NULL AND MaturityManagement_Lease.PractThirdReductionPercent &gt; 0.00)) THEN
							'Y'
						 ELSE
							'N'
						 END AS RentalReduction
						,CASE WHEN MaturityManagement_Lease.PractIsTitleTransfer = 1 THEN
							'Y'
						 ELSE
							'N'
						 END AS TitleTransfer
						,CASE WHEN MaturityManagement_Lease.PractIsTitleTransfer = 1 THEN
							CONVERT(NVARCHAR(3),MaturityManagement_Lease.PractTitleTransferPeriod)
						 ELSE
							''
						 END AS TitleTransferPeriod
						,Inventory_SoftcostOTPTreatment_CnfgLocale.SoftcostOTPTreatment AS OTPSoftcostTreatment	
					FROM
						cte_FilteredLeases FilteredLease						

						INNER JOIN CTE_OTPRent
							ON FilteredLease.LeaseID = CTE_OTPRent.LeaseID  

						INNER JOIN Lease_Contract
							ON FilteredLease.LeaseID = Lease_Contract.LeaseID
							AND Lease_Contract.IsActive = 1
						Inner JOIN Lease_Profile lp
      						   ON FilteredLease.LeaseID = lp.LeaseID
						INNER JOIN dbo.LLC_Profile llc
      						   ON lp.LLCID = llc.LLCID
						INNER JOIN Currency_Index ci
      						   ON llc.CurrencyIndexID = ci.CurrencyIndexID
						INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
      						   ON ci.ISO = csc.ISO  
						LEFT JOIN FundingSource_Profile fs
      						   ON lp.LabellingLessorID = fs.FundingSourceID
      						   AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label

						INNER JOIN Deal_RentalFrequency_CnfgLocale RegularLeaseFrequency
							ON RegularLeaseFrequency.FrequencyID = Lease_Contract.RentalFrequencyID

						INNER JOIN Deal_RentalFrequency_CnfgLocale IrregularLeaseFrequency
							ON IrregularLeaseFrequency.FrequencyID = Lease_Contract.IrregularRentalFrequencyID

						INNER JOIN MaturityManagement_Lease
							ON MaturityManagement_Lease.LeaseID = FilteredLease.LeaseID
							AND MaturityManagement_Lease.IsActive = 1						

						INNER JOIN Lease_Investment
							ON Lease_Investment.LeaseID = FilteredLease.LeaseID
							AND Lease_Investment.IsActive = 1

						left join Lease_PurchaseOptionSubType_Cnfg 
							ON Lease_Investment.PurchaseOptionSubTypeID = Lease_PurchaseOptionSubType_Cnfg.PurchaseOptionSubTypeID
							AND Lease_PurchaseOptionSubType_Cnfg.IsActive = 1

						INNER JOIN Lease_ContractPurchaseOption_CnfgLocale
							ON Lease_ContractPurchaseOption_CnfgLocale.PurchaseOptionID = Lease_Investment.PurchaseOptionID

						INNER JOIN Template_YesNoNA_CnfgLocale PractDataSecurityReqdID
							ON PractDataSecurityReqdID.BoolValueID = MaturityManagement_Lease.PractDataSecurityReqdID 

						INNER JOIN Inventory_FreightResponsibility_CnfgLocale
							ON Inventory_FreightResponsibility_CnfgLocale.FreightResponsibilityID = MaturityManagement_Lease.PractFreightResponsibilityID 

						INNER JOIN Lease_EOTOption_CnfgLocale PractPurchase
							ON PractPurchase.EOTOptionID = MaturityManagement_Lease.PractPurchaseID

						INNER JOIN Lease_EOTOption_CnfgLocale PractRenew
							ON PractRenew.EOTOptionID = MaturityManagement_Lease.PractRenewID

						INNER JOIN Lease_EOTOption_CnfgLocale PractReturn
							ON PractReturn.EOTOptionID = MaturityManagement_Lease.PractReturnID

						INNER JOIN Inventory_LKEType_CnfgLocale
							ON Inventory_LKEType_CnfgLocale.LKEAllowedID = MaturityManagement_Lease.LKEAllowedID

						INNER JOIN Inventory_SoftcostOTPTreatment_CnfgLocale
							ON Inventory_SoftcostOTPTreatment_CnfgLocale.SoftcostOTPTreatmentID = MaturityManagement_Lease.PractSoftcostOTPTreatmentID
							
						LEFT JOIN CTE_LastInvoiceAmount
							ON FilteredLease.LeaseID = CTE_LastInvoiceAmount.LeaseID
							
						LEFT JOIN Lease_RentalFrequency_CnfgLocale 
							ON Lease_RentalFrequency_CnfgLocale.RentalFrequencyID = MaturityManagement_Lease.PractOTPFrequencyID
						-------------------------------
						-- 20190220
						--FILTERCONDITIONS	
						WHERE Lease_Contract.MaturityDate BETWEEN IIF(@FromMaturityDate IS NULL,'1/1/2000',@FromMaturityDate) AND @ToMaturityDate
						-------------------------------	
				)
-------------------------------------------------------
-- 20190222
,
cte_SalesRep
AS
(
		SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID
		,(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
		,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
		,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
		,(SELECT FirstName+SPACE(1)+LastName FROM Security_UserProfile WHERE UserID = e.UserID) Name
		,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
		,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
		,(SELECT RoleFunctionID FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionID
		,e.EntityID
		FROM EmployeeAssignment_Entity e
		WHERE e.EntityTypeID  = 1 -- Customer
		And 
		 e.EmployeeAssignmentID IN 
			(
			SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
			FROM EmployeeAssignment_Entity 
			WHERE EntityTypeID = 1   
				AND IsActive = 1 
				AND RoleFunctionID = 8  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=38, RoleFunctionName = 'Lease Administrator'
			GROUP BY EntityID --,UserID 
			)
)
-------------------------------------------------------
-- 20190226
,
cte_LabelingLessor
AS
(
SELECT lp.LeaseID
      ,lp.CustomerID
      ,lp.SequenceNumber
	  ,fp.FundingSourceNumber 
	  ,fp.Alias as coAlias
	  ,fp.Company AS LabellingLessor
  FROM Lease_Profile lp
  INNER JOIN FundingSource_Profile fp
	ON fp.FundingSourceId = lp.LabellingLessorID
)
-------------------------------------------------------
-- 20190225
,
cte_Basic_Search
AS
(
SELECT
         LeaseTransaction_Profile.LeaseTransactionID
       , Customer_Profile.CustomerID
       , Lease_Profile.LeaseID
	   , Lease_Profile.Alias
       , CASE WHEN Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
              THEN MLA_Profile.MLAID
              ELSE Lease_MLA.MLAID
         END AS MLAID
       , Lease_Profile.SequenceNumber
       , [CoTermLeaseDetails].SequenceNumber [CoTermSequenceNumber]
       , CASE WHEN Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
              THEN LeaseTransaction_Profile.BrokerID
              ELSE Lease_Profile.BrokerID
         END AS BrokerID
       , LeaseTransaction_Profile.DDSNotesdata
       , Customer_Profile.AccountNumber
       , Customer_Profile.CustomerName
       , CASE WHEN Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
              THEN 1
              ELSE 0
         END AS FEFlag
FROM
       Lease_Profile
       INNER JOIN Customer_Profile
              ON Customer_Profile.CustomerID = Lease_Profile.CustomerID
			  AND Lease_Profile.CustomerID = Customer_Profile.CustomerID
            --AND Lease_Profile.Alias = @LeaseScheduleNumber
			--AND Customer_Profile.AccountNumber = @AccountNumber
              AND Lease_Profile.BookingStatusID = 2 --Completed
       LEFT JOIN LeaseTransaction_Profile
              ON Lease_Profile.LeaseID = LeaseTransaction_Profile.LeaseID
              AND LeaseTransaction_Profile.AgreementTypeID = 2 --LeaseTransaction
       LEFT JOIN MLA_Profile
              ON MLA_Profile.MLAID = LeaseTransaction_Profile.MLAID
       LEFT JOIN MLA_Profile Lease_MLA
              ON Lease_MLA.MLAID = Lease_Profile.MLAID
       LEFT JOIN Lease_Profile [CoTermLeaseDetails]
              ON [CoTermLeaseDetails].LeaseID = Lease_Profile.CoTermLeaseID
			  --WHERE Lease_Profile.LeaseID=8758
)
----------------------------------------------------------------------------
--SELECT * FROM cte_Basic_Search WHERE leaseID = 8758
----------------------------------------------------------------------------
-- 20190226
,
CTE_InventoryDetails1
AS
(
SELECT
		 ISNULL(a.cntLPIsSaleLeaseBack,0) SaleLeaseBackCount
		,ISNULL(b.cntVendorSubtypeID,0) VARCount
		,ISNULL(c.cntVendorSubtypeID,0) ISECount
        , cte_Basic_Search.LeaseID
        ,cte_Basic_Search.SequenceNumber
		,cte_Basic_Search.Alias
FROM
        cte_Basic_Search
---------------------------------------------------------------------------------
Left join 
	(
	SELECT 
		COUNT (Inventory_Profile.LPIsSaleLeaseBack) cntLPIsSaleLeaseBack
		,cte_Basic_Search.LeaseID 
	FROM
	cte_Basic_Search
	FULL JOIN Lease_InventoryInLease
			ON Lease_InventoryInLease.LeaseID = cte_Basic_Search.LeaseID  
			AND Lease_InventoryInLease.IsInLease = 1 --Yes
	INNER JOIN Inventory_Profile
			On Inventory_Profile.inventoryID = Lease_InventoryInLease.InventoryID
			AND  Inventory_Profile.LPIsSaleLeaseBack = 1   
	group by cte_Basic_Search.LeaseID 
	) a
	on cte_Basic_Search.LeaseID = a.LeaseID
-------------------------------------------------------------------------------
Left join
	(
	SELECT 
		COUNT (Vendor_Profile.VendorSubtypeID) cntVendorSubtypeID
		,cte_Basic_Search.LeaseID 
	FROM
	cte_Basic_Search
	INNER JOIN Lease_InventoryInLease
			ON Lease_InventoryInLease.LeaseID = cte_Basic_Search.LeaseID  
			AND Lease_InventoryInLease.IsInLease = 1 --Yes
	INNER JOIN APInvoice_CostHeader
			ON APInvoice_CostHeader.inventoryID = Lease_InventoryInLease.InventoryID
			AND APInvoice_CostHeader.IsActive = 1
	INNER JOIN APInvoice_profile
			ON APInvoice_profile.VendorInvoiceID = APInvoice_CostHeader.VendorInvoiceID
	INNER JOIN Vendor_Profile
			ON Vendor_Profile.VendorID = APInvoice_profile.VendorID 
			AND Vendor_Profile.VendorSubtypeID = 2 --VAR
	Group By cte_Basic_Search.LeaseID 
	) b
	on cte_Basic_Search.LeaseID = b.LeaseID
-----------------------------------------------------------------------------
Left join 
	(
	SELECT 
		COUNT (Vendor_Profile.VendorSubtypeID) cntVendorSubtypeID
		,cte_Basic_Search.LeaseID 
	FROM
	cte_Basic_Search
	INNER JOIN Lease_InventoryInLease
			ON Lease_InventoryInLease.LeaseID = cte_Basic_Search.LeaseID  
			AND Lease_InventoryInLease.IsInLease = 1 --Yes
	INNER JOIN APInvoice_CostHeader
			ON APInvoice_CostHeader.inventoryID = Lease_InventoryInLease.InventoryID
			AND APInvoice_CostHeader.IsActive = 1
	INNER JOIN APInvoice_profile
			ON APInvoice_profile.VendorInvoiceID = APInvoice_CostHeader.VendorInvoiceID
	INNER JOIN Vendor_Profile
			ON Vendor_Profile.VendorID = APInvoice_profile.VendorID 
			AND Vendor_Profile.VendorSubtypeID = 3 --ISE
	GROUP BY cte_Basic_Search.LeaseID
        ) c
		on cte_Basic_Search.LeaseID = c.LeaseID
-----------------------------------------------------------------------------
)
------------------------------
---- test code
--SELECT * FROM CTE_InventoryDetails1 --WHERE leaseid=8758

----------------------------
,
CTE_BillInfo1
AS
(
SELECT
        Cofa_profile.AcceptedDate
        , Lease_Contract.InceptionDate
        , Lease_Contract.MaturityDate
        , Lease_Contract.Term
        , Deal_RentalFrequency_Cnfg.Description [Billingfrequency]
        , IrregularPayments = CASE WHEN Lease_Contract.ContractStructureID = 1
                THEN 'No'
                ELSE 'Yes'
                END
        , BillingCycle = CASE WHEN Lease_Contract.InceptionPaymentNumber &gt; 0
                THEN 'Advance'
                ELSE 'Arrears'
                END    
        , Lease_ContractpurchaseOption_Cnfglocale.PurchaseOption [EOTOption]
        , MaturityManagement_Lease.PractFMVCapPercent
        , TransitionLease = CASE WHEN MaturityManagement_Lease.PractIsTransitionLease = 0
                                                THEN 'N'
                                                ELSE 'Y'
                                        END
        , TransitionDays = CASE WHEN MaturityManagement_Lease.PractIsTransitionLease = 1
                                                THEN MaturityManagement_Lease.PractTransitionDays
                                                ELSE NULL
                                        END
        , SaleLeasebackAsset = CASE WHEN CTE_InventoryDetails1.SaleLeaseBackCount &gt; 0
                                                        THEN 'Y'
                                                        ELSE 'N'
                                                END           
        , VARText = CASE WHEN CTE_InventoryDetails1.VARCount &gt; 0
                                    THEN 'Y'
                                    ELSE 'N'
                            END
        , ISE = CASE WHEN CTE_InventoryDetails1.ISECount &gt; 0
                            THEN 'Y'
                            ELSE 'N'
                    END
        , MaturityManagement_Lease.PractFirstReminderNoticeDays [ReminderPeriod]
        , MaturityManagement_Lease.PractFTNoticePeriod [NoticePeriod]
        , cte_Basic_Search.LeaseID
		, cte_Basic_Search.SequenceNumber
		, Lease_Investment.PurchaseOptionSubTypeID
		, [Lease_PurchaseOptionSubType_CnfgLocale].PurchaseOptionSubType
        ,MaturityManagement_Lease.DataSecurityReqdID
		,cte_Basic_Search.Alias                          
FROM
        cte_Basic_Search
        LEFT JOIN Lease_Contract
                ON Lease_Contract.LeaseID = cte_Basic_Search.LeaseID
                AND Lease_Contract.IsActive = 1
        LEFT JOIN Lease_Investment
                ON Lease_Investment.LeaseID = cte_Basic_Search.LeaseID
                AND Lease_Investment.IsActive = 1
        LEFT JOIN Lease_ContractpurchaseOption_Cnfglocale
                ON Lease_ContractpurchaseOption_Cnfglocale.PurchaseOptionID = Lease_Investment.PurchaseOptionID
                --AND Lease_ContractpurchaseOption_Cnfglocale.CultureID = @CultureID
        LEFT JOIN Deal_RentalFrequency_Cnfg
                ON Deal_RentalFrequency_Cnfg.FrequencyID = Lease_Contract.RentalFrequencyID
        LEFT JOIN Lease_ContractStructure_Cnfg
                ON Lease_ContractStructure_Cnfg.ContractStructureID = Lease_Contract.ContractStructureID 
        LEFT JOIN CTE_InventoryDetails1
                ON CTE_InventoryDetails1.LeaseID = cte_Basic_Search.LeaseID
        LEFT JOIN Cofa_profile
                ON Cofa_profile.VersionID = cte_Basic_Search.LeaseTransactionID  
                AND Cofa_profile.IsFinalCofa = 1 --Yes
                AND Cofa_profile.IsActive = 1 --Yes
        LEFT JOIN MaturityManagement_Lease
                ON MaturityManagement_Lease.LeaseID = cte_Basic_Search.LeaseID
		LEFT JOIN [dbo].[Lease_PurchaseOptionSubType_CnfgLocale] 
				ON Lease_Investment.PurchaseOptionSubTypeID = Lease_PurchaseOptionSubType_CnfgLocale.PurchaseOptionSubTypeID
)
-------------------------------------------------------
-- test code
--SELECT * FROM CTE_BillInfo1 WHERE leaseid =8758

-------------------------------------------------------
SELECT
	 CTE_FinalResult.CustomerName
	----------------------------
	-- 20190222
	,CTE_FinalResult.AccountNumber
	, CTE_FinalResult.ISO 
	, CTE_FinalResult.Symbol
    , CTE_FinalResult.FundingSourceId
    , CTE_FinalResult.FundingSourceNumber
	, CTE_FinalResult.coAlias
	, CTE_FinalResult.Company
	----------------------------
	 -- 20190225
	 ,v.Alias
	----------------------------
	,CTE_FinalResult.LeaseNumber	
	,CTE_FinalResult.LastInvoiceAmount
--------------------------------------------
--rev 20150623
	,CTE_FinalResult.DueDate
--------------------------------------------
	,CTE_FinalResult.OTPRent
	,CTE_FinalResult.RentalFrequency
	,CTE_FinalResult.MaturityDate
	,CTE_FinalResult.PurchaseOptionType
	,CTE_FinalResult.PurchaseOptionSubType
			,CTE_FinalResult.StopBilling
	,CTE_FinalResult.FMVCap
			,CTE_FinalResult.OTPAdvancedBilling
	,CTE_FinalResult.OTPRentalFrequency
	,CTE_FinalResult.TransitionLease
	,CTE_FinalResult.TransitionPeriod
			,CTE_FinalResult.OTPDoubleInArrears
			,CTE_FinalResult.GracePeriod
			,CTE_FinalResult.OTPSuspend
			,CTE_FinalResult.DataSecurityRequired
			,CTE_FinalResult.FreightResponsibility
			,CTE_FinalResult.OTPPurchaseOptions
			,CTE_FinalResult.OTPRenewalOption
			,CTE_FinalResult.OTPReturnOption
			,CTE_FinalResult.LKEAllowed	
			,CTE_FinalResult.IsEOTProvisionAndRestrictionExists
			,CTE_FinalResult.PractRestrictions
			,CTE_FinalResult.PractConditions
			,CTE_FinalResult.RentalReduction
			,CTE_FinalResult.TitleTransfer
			,CTE_FinalResult.TitleTransferPeriod
			,CTE_FinalResult.OTPSoftcostTreatment	
	---------------------------------------
	-- 20190225
	,ll.LabellingLessor 
	,v.VARText [Is Red8 Vendor]
	,v.ISE [Is 2ND Gear Vendor] -- Isa ISE Vendor
	,cte_SalesRep.[Name] [Sales Rep]
	
FROM
	CTE_FinalResult
LEFT JOIN cte_SalesRep
	ON CTE_FinalResult.AccountNumber = cte_SalesRep.AccountNumber
INNER JOIN cte_LabelingLessor ll
	ON CTE_FinalResult.LeaseNumber = ll.SequenceNumber
INNER JOIN CTE_BillInfo1 v
	ON CTE_FinalResult.LeaseNumber = v.SequenceNumber
                         
ORDER BY
	CTE_FinalResult.CustomerName ASC</CommandText>
      </Query>
