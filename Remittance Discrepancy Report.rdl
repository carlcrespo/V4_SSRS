  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LW_PRD</DataSourceName>
        <CommandText>-- 20221229

SELECT
FSP.Alias as 'Labelling Lessor'
,FSP.Company as 'Labelling Lessor Company'
,FSP.FundingSourceNumber as 'Labelling Lessor Code'
,IGP.CustomerName as 'Lessee Name'
,IGP.InvoiceGroupName
,RP.RemittanceName
,RP.RemittanceCode
,cp.AccountNumber
FROM InvoiceGroup_Profile IGP

LEFT JOIN Remittance_Profile RP
ON IGP.RemittanceID = RP.RemittanceID
LEFT JOIN MLA_Profile MP
ON IGP.CustomerID = MP.CustomerID
LEFT JOIN FundingSource_Profile FSP
ON MP.LabellingLessorID = FSP.FundingSourceId
LEFT JOIN Customer_Profile cp
	ON igp.CustomerID = cp.CustomerID
WHERE MP.LabellingLessorID in (146,147,148,149,150,151,223)
AND RP.RemittanceCode = 'FTB 1'
-------------------
-- 20221229
AND MP.IsActive = 1
-------------------
ORDER BY IGP.CustomerName</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
