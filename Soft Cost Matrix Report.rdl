  <DataSources>
    <DataSource Name="LW">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>a831b627-4c6e-48d2-8f6e-a40a807b7da0</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LW</DataSourceName>
        <CommandText>-- 20191021
WITH cte_Soft AS (SELECT DISTINCT r.SoftCostOTPTypeID, r.[SoftcostOTPTreatment], r.[SoftcostOTPTreatmentID]
                                        FROM         (SELECT     s.[SoftCostOTPRelationID], s.[SoftcostOTPTreatmentID],
                                                                                          (SELECT     [SoftcostOTPTreatment]
                                                                                            FROM          [dbo].[Inventory_SoftcostOTPTreatment_CnfgLocale]
                                                                                            WHERE      [SoftcostOTPTreatmentID] = s.[SoftcostOTPTreatmentID]) [SoftcostOTPTreatment], s.[SoftCostOTPTypeID], s.[IsActive]
                                                               FROM          [dbo].[Inventory_SoftCostOTPRelation_Cnfg] s) r), cte_type AS
    (SELECT DISTINCT t .[InventoryTypeID], t .[InventoryTypeName] [LW Asset Type],
                                 (SELECT     [Description]
                                   FROM          [dbo].[Inventory_SoftCostOTPType_Cnfg]
                                   WHERE      [SoftCostOTPTypeID] = t .[SoftCostOTPTypeID]) [SoftCostOTPTypeID], t .[Description], ISNULL(cte_soft.SoftcostOTPTreatment, '') 
                             [Insight Softcost OTP Treatment], ISNULL(cte_soft.SoftcostOTPTreatmentID, '') SoftcostOTPTreatmentID, IIF(t .IsActive = '1', 'Active', 'InActive') [LW Code]
      FROM          [dbo].[Inventory_TypeTemplate] t FULL JOIN
                             cte_Soft ON cte_Soft.SoftCostOTPTypeID = t .SoftCostOTPTypeID
      WHERE      t .SoftCostOTPTypeID IS NOT NULL AND t .IsActive = 1/*ORDER BY t.[InventoryTypeName]*/ ), cte_distinct AS
    (SELECT DISTINCT [InventoryTypeID], [LW Asset Type], SoftCostOTPTypeID, [Description], [LW Code]
      FROM          cte_type
	  WHERE [LW Asset Type] != 'ZZ-1000'
), cte_softcost AS
    (SELECT     *
      FROM          cte_type
      WHERE      cte_type.[Insight Softcost OTP Treatment] = ''
      UNION
      SELECT     *
      FROM         cte_type
      WHERE     cte_type.[Insight Softcost OTP Treatment] = 'No Automatic Softcost dropoff'
      UNION
      SELECT     *
      FROM         cte_type
      WHERE     cte_type.[Insight Softcost OTP Treatment] = 'Automatic Softcost dropoff'
      UNION
      SELECT     *
      FROM         cte_type
      WHERE     cte_type.[Insight Softcost OTP Treatment] = 'Automatic Software dropoff')
    SELECT     a.InventoryTypeID, a.[LW Asset Type], a.SoftCostOTPTypeID, a.[Description], a.[LW Code], 
                            CASE WHEN b.[Insight Softcost OTP Treatment] = '' THEN '' WHEN c.[Insight Softcost OTP Treatment] = 'No Automatic Softcost dropoff' THEN 'X' ELSE '' END [No Automatic Soft Cost Drop Off],
                             CASE WHEN b.[Insight Softcost OTP Treatment] = '' THEN '' WHEN d .[Insight Softcost OTP Treatment] = 'Automatic Softcost dropoff' THEN 'X' ELSE '' END [Automatic Softcost Dropoff],
                             CASE WHEN b.[Insight Softcost OTP Treatment] = '' THEN '' WHEN e.[Insight Softcost OTP Treatment] = 'Automatic Software Dropoff' THEN 'X' ELSE '' END [Automatic Software Dropoff]
     FROM         cte_distinct a LEFT JOIN
                            cte_type b ON a.InventoryTypeID = b.InventoryTypeID AND a.SoftCostOTPTypeID = b.SoftCostOTPTypeID AND b.[Insight Softcost OTP Treatment] = '' LEFT JOIN
                            cte_type c ON a.InventoryTypeID = c.InventoryTypeID AND a.SoftCostOTPTypeID = c.SoftCostOTPTypeID AND 
                            c.[Insight Softcost OTP Treatment] = 'No Automatic Softcost dropoff' LEFT JOIN
                            cte_type d ON a.InventoryTypeID = d .InventoryTypeID AND a.SoftCostOTPTypeID = d .SoftCostOTPTypeID AND 
                            d .[Insight Softcost OTP Treatment] = 'Automatic Softcost Dropoff' LEFT JOIN
                            cte_type e ON a.InventoryTypeID = e.InventoryTypeID AND a.SoftCostOTPTypeID = e.SoftCostOTPTypeID AND 
                            e.[Insight Softcost OTP Treatment] = 'Automatic Software Dropoff'
     ORDER BY a.[LW Asset Type]</CommandText>
      </Query>
      <Fields>
        <Field Name="InventoryTypeID">
          <DataField>InventoryTypeID</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="LW_Asset_Type">
          <DataField>LW Asset Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SoftCostOTPTypeID">
          <DataField>SoftCostOTPTypeID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LW_Code">
          <DataField>LW Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="No_Automatic_Soft_Cost_Drop_Off">
          <DataField>No Automatic Soft Cost Drop Off</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Automatic_Softcost_Dropoff">
          <DataField>Automatic Softcost Dropoff</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Automatic_Software_Dropoff">
          <DataField>Automatic Software Dropoff</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
