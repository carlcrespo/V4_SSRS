  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>LW_PRD</DataSourceName>
        <CommandText>-- IMH Report logic 20240409
;
WITH 
cte_BillTo
AS 
	(
	SELECT
		 Contact_ContactTypeRelationAssignment.ContactTypeEntityID InvoiceGroupID
		,Contact_EntityPersonRelation.ContactPersonID
		,cp.ContactAddressID
		,cp.FirstName BillToFirstName
		,cp.LastName BillToLastName
		,ca.[Address] BillToAddress
		,ca.Address2 BillToAddress2
		,ca.City BillToCity
		,st.[Description] BillToState
		,ca.ZIP BillToPostalCode
		,cc.CountryName BillToCountry
	FROM Contact_EntityPersonRelation
	INNER JOIN Contact_ContactTypeRelationAssignment
		ON Contact_ContactTypeRelationAssignment.ContactRelationID = Contact_EntityPersonRelation.ContactRelationID
		AND Contact_ContactTypeRelationAssignment.ContactTypeID = 2 --InvoiceGroup
		AND Contact_ContactTypeRelationAssignment.ContactSubTypeID = 1 --Primary
		AND Contact_ContactTypeRelationAssignment.IsActive = 1 --Yes
	INNER JOIN Contact_Person as CP
		ON Contact_EntityPersonRelation.ContactPersonID=cp.ContactPersonID
	INNER JOIN Contact_Address as CA
		ON cp.ContactAddressID= ca.ContactAddressID
	INNER JOIN Template_State_Cnfg as ST
		ON ca.StateID=st.stateid 
	INNER JOIN Template_Country_CnfgLocale cc
		ON cc.CountryID = st.CountryID
	WHERE
		Contact_EntityPersonRelation.EntityTypeId = 1 -- Customer
		AND Contact_EntityPersonRelation.IsActive = 1 --Yes
	)
SELECT 
	FSP.Company as 'LabellingLessor'
	,CP.CustomerName as 'Lessee'
	,LP.SequenceNumber as 'SequenceNumber'
	,FORMAT(LC.InceptionDate,'MM/dd/yyyy') AS 'CommencementDate'
	,FORMAT(LC.MaturityDate,'MM/dd/yyyy') AS 'MaturityDate'
	,CAST(LC.Term AS INT) AS 'Term'
	,LIL.InventoryID as 'AssetNumber'
	,IP.Alias as 'AspireAssetNumber'
	,IP.DerivedDescription as 'Description'
	,ISNULL(IP.Model,'') AS 'Model'
	,IIF(IMT.InventoryManufacturerName = '-','',IMT.InventoryManufacturerName) AS 'Manufacturer'
	,ISNULL(IP.SerialNumber,'') AS 'SerialNumber'
	,LIL.StickerCost as 'EquipmentCost'
	,LIL.ResidualBookedAmount as 'ResidualBookedAmount'
	,LIL.LeaseRentalAmount as 'FirmTermRental'
	,LIL.OverTermPaymentRentalAmount as 'OverTermRentalAmount'
	,FORMAT(IP.AcquisitionDate,'MM/dd/yyyy') as 'Acquisition Date'
	,FORMAT(IP.InServiceDate,'MM/dd/yyyy') as 'In Service Date'
	,LCPOCL.PurchaseOption as 'Purchase Option'
	,ILT.LocationCode as 'AssetLocationCode'
	,ILT.Address as 'AssetLocationAddress'
	,ILT.City as 'AssetLocationCity'
	,TSCL.StateShortName as 'AssetLocationState'
	,ILT.ZIP as 'AssetLocationPostalCode'
	,LSC.Description as 'IsContractBooked'
	,ITT.InventoryTypeName as 'AssetType'
	,ICT.InventoryCategoryName as 'AssetCategory'
	,ISCT.InventorySubcategoryName as 'AssetSubCategory'
	,ISNULL(LP.PurchaseOrderNumber,'') AS 'LeaseRentalPO'
	,ISNULL(IP.RentalPurchaseOrderNumber,'') AS 'AssetRentalPO'
	,LIL.InvoiceGroupID
	,bt.BillToFirstName
	,bt.BillToLastName
	,bt.BillToAddress
	,bt.BillToAddress2
	,bt.BillToCity
	,bt.BillToState
	,bt.BillToPostalCode
	,bt.BillToCountry
FROM Lease_InventoryInLease LIL
Left Join Lease_Profile LP
	ON LIL.LeaseID = LP.LeaseID
Left Join FundingSource_Profile FSP
	ON LP.LabellingLessorID = FSP.FundingSourceId
Left Join Customer_Profile CP
	ON LP.CustomerID = CP.CustomerID
LEFT JOIN Lease_Contract LC
	ON LP.LeaseID = LC.LeaseID
Left Join Inventory_Profile IP
	ON LIL.InventoryID = IP.InventoryID
Left Join Inventory_ManufacturerTemplate IMT
	ON IP.InventoryManufacturerID = IMT.InventoryManufacturerID
Left Join Lease_Investment LI
	ON LIL.LeaseID = LI.LeaseId
Left Join Lease_ContractPurchaseOption_CnfgLocale LCPOCL
	ON LI.PurchaseOptionID = LCPOCL.PurchaseOptionID
Left Join Inventory_Location IL
	ON LIL.InventoryID = IL.InventoryID
Left Join Inventory_LocationTemplate ILT
	ON IL.LocationTemplateID = ILT.LocationTemplateID
Left Join Template_State_CnfgLocale TSCL
	ON ILT.StateID = TSCL.StateID
Left Join Lease_Status_Cnfg LSC
	ON LP.StatusId = LSC.StatusID
Left Join Inventory_TypeTemplate ITT
	ON IP.InventoryTypeID = ITT.InventoryTypeID
Left Join Inventory_CategoryTemplate ICT
	ON IP.InventoryCategoryID = ICT.InventoryCategoryID
Left Join Inventory_SubcategoryTemplate ISCT
	ON IP.InventorySubCategoryID = ISCT.InventorySubcategoryID
LEFT JOIN cte_BillTo bt
	ON bt.InvoiceGroupID = LIL.InvoiceGroupID
WHERE LIL.IsInLease = 1
	AND FSP.FundingSourceId in (146,147,148,149,150,151,152,207)
	AND LC.IsActive = 1
	AND LI.IsActive = 1</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
