-- 20190118
,
cte_LeaseAdmin
AS
(
		SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID
		,(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
		,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = e.EntityID) CustomerName
		,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = e.EntityID) AccountNumber
		,(SELECT FirstName+SPACE(1)+LastName FROM Security_UserProfile WHERE UserID = e.UserID) Name
		,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
		,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
		,(SELECT RoleFunctionID FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionID
		,e.EntityID
		FROM EmployeeAssignment_Entity e
		WHERE e.EntityTypeID  = 1 
		And 
		 e.EmployeeAssignmentID IN 
			(
			SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
			FROM EmployeeAssignment_Entity 
			WHERE EntityTypeID = 1  /*@EntityTypeID --LeaseAdmin*/
				AND IsActive = 1 /*@IsActive*/
				AND RoleFunctionID = 38  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=38, RoleFunctionName = 'Lease Administrator'
			------------------------------	
				And EmployeeAssignmentID Not IN 
				(
					SELECT distinct e.EmployeeAssignmentID 
					FROM EmployeeAssignment_Entity e
					Inner Join Security_UserProfile s
					ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator'  
					Where e.EntityTypeID = 1
				And (SELECT UserAlias FROM Security_UserProfile WHERE UserID = e.UserID) = 'End of Lease Administrator' 
				)			
			------------------------------	 
			GROUP BY EntityID --,UserID 
			)
)
,
cte_LeaseAdminCustomer
AS
(
SELECT cte_LeaseAdmin.EmployeeAssignmentID,cte_LeaseAdmin.[Name],cte_LeaseAdmin.AccountNumber
FROM cte_LeaseAdmin
Right JOIN Customer_Profile cp
ON cte_LeaseAdmin.AccountNumber = cp.AccountNumber
INNER JOIN Lease_Profile lp
ON cp.CustomerID = lp.CustomerID
WHERE lp.LeaseID IN (SELECT TOP(1) LeaseID FROM  cte_Basic_Search)
)
-----------------------------------------------------------------------------
-- 20181127
SELECT
       o.ARSpecialist
      ,o.SalesRep
	  ------------------------------
	  -- 20190118
      --,o.LeaseSpecialist
	  ,cte_LeaseAdminCustomer.[Name] LeaseSpecialist
	  ------------------------------
      ,o.CommissionsUser
      --,CONVERT(INT,o.MasterLeaseNumber) MasterLeaseNumber
	  ,o.MasterLeaseNumber
      ,o.MLAType
         ------------------------------------------------------------------
         -- 20181127
         ,CASE o.MLAType
              WHEN 'Government (w/EOT)' THEN 'Y'
              WHEN 'Government Municipal' THEN 'Y'
              WHEN 'Medical - Government' THEN 'Y'
              ELSE 'N'
              END [Municipality (Y/N)]
         --------------------------------------------------------------------
         ,CASE 
              WHEN o.MLAType = 'Government (w/EOT)' THEN
              (CASE 
              WHEN (SELECT UCCStateID FROM [dbo].[Customer_UCCDetail] WHERE CustomerID = (SELECT CustomerID FROM Lease_Profile WHERE SequenceNumber = o.SequenceNumber)) = 44 THEN 'Y' 
              WHEN (SELECT UCCStateID FROM [dbo].[Customer_UCCDetail] WHERE CustomerID = (SELECT CustomerID FROM Lease_Profile WHERE SequenceNumber = o.SequenceNumber)) BETWEEN 1 AND 1000  THEN 'N'
              ELSE 'Error'
              END) -- [Texas Municipality (Y/N)]

              WHEN o.MLAType = 'Government Municipal' THEN
         (CASE 
              WHEN (SELECT UCCStateID FROM [dbo].[Customer_UCCDetail] WHERE CustomerID = (SELECT CustomerID FROM Lease_Profile WHERE SequenceNumber = o.SequenceNumber)) = 44 THEN 'Y' 
              WHEN (SELECT UCCStateID FROM [dbo].[Customer_UCCDetail] WHERE CustomerID = (SELECT CustomerID FROM Lease_Profile WHERE SequenceNumber = o.SequenceNumber)) BETWEEN 1 AND 1000  THEN 'N'
              ELSE 'Error'
              END) --[Texas Municipality (Y/N)]

              WHEN o.MLAType = 'Medical - Government' THEN
          (CASE 
              WHEN (SELECT UCCStateID FROM [dbo].[Customer_UCCDetail] WHERE CustomerID = (SELECT CustomerID FROM Lease_Profile WHERE SequenceNumber = o.SequenceNumber)) = 44 THEN 'Y' 
              WHEN (SELECT UCCStateID FROM [dbo].[Customer_UCCDetail] WHERE CustomerID = (SELECT CustomerID FROM Lease_Profile WHERE SequenceNumber = o.SequenceNumber)) BETWEEN 1 AND 1000  THEN 'N'
              ELSE 'Error'
              END) -- [Texas Municipality (Y/N)]

              ELSE 'N'
              END [Texas Municipality (Y/N)]
----------------------------------------------------------------------
-- 20181207
      , IIF(o.DataSecurityReqdID = 1,'Y','N') [Data Wipe Required (Y/N)]
------------------------------------------------------------------------
-- 20181211
         ,v.[Modular (Y/N)]
         ,v.[Titled Vehicle (Y/N)]
         ,v.[Used Equipment]
         ,v.[Decontamination Language (Y/N)]
         ,v.[WI Disclosure Required (Y/N)]
----------------------------------------------------------------------
      ,o.LabellingLessor
      ,o.ColesseCSV
      ,o.SequenceNumber
      ,ISNULL(o.CoTermSequenceNumber,'') CoTermSequenceNumber
      ,o.RentalPoNumber
	 -- -------------------------------------------------------
	  -- 20190118
      --,o.Prorata
	  ,CASE o.Prorata
		WHEN 'S' THEN 'Standard'
		WHEN 'I' THEN 'InterestOnly'
		WHEN 'N' THEN 'None'
		ELSE o.Prorata
		END Prorata
	  -------------------------------------------------------
	  -- 20190118
      --,o.Interim
	  ,CASE o.Interim
		WHEN 'S' THEN 'Standard'
		WHEN 'I' THEN 'InterestOnly'
		WHEN 'F' THEN 'Fixed'
		WHEN 'N' THEN 'None'
		ELSE o.Interim
		END Interim
	 -- -------------------------------------------------------
      ,o.ProrataInterestCarry
      ,o.FixedInterimNoofDays
      ,o.AccountNumber
      ,FORMAT(o.AcceptedDate,'MM/dd/yyyy') AcceptedDate
      ,FORMAT(o.InceptionDate,'MM/dd/yyyy') InceptionDate
      ,FORMAT(o.MaturityDate,'MM/dd/yyyy') MaturityDate
      ,CAST(o.Term AS INT) Term
      ,o.Billingfrequency
      ,o.IrregularPayments
      ,o.BillingCycle
      ,o.EOTOption
      ,o.PractFMVCapPercent
      ,o.TransitionLease
      ,o.TransitionDays
      ,o.SaleLeasebackAsset
      ,o.VARText
      ,o.ISE
      ,o.ReminderPeriod
      ,o.NoticePeriod
      ,ISNULL(o.SequenceNumberCSV,'') SequenceNumberCSV
      ,ISNULL(o.PayableTo, '') PayableTo
      ,o.LeaseTransactionID
      ,o.TotalAssetLevelRental
      ,o.DDSNotesdata
      ,o.ReferralFee
      ,o.FreightRebill
      ,o.AdminFee
      ,o.SoftcostAndSoftwareRebill
      ,o.TotalPassThroughRentals
      ,o.TotalOtherRebill
      ,o.TransactionType
      ,o.PurchaseOptionSubType
      ,o.leases
      ,o.StatusID
---------------------------------------------------------------
         --,v.LeaseID
      ,o.DataSecurityReqdID
      ,o.MLAID
	  ,(SELECT TOP(1) LeaseID FROM  cte_Basic_Search) LeaseID
FROM 
       cte_1_5 o
Left JOIN cte_V v
       --ON CONVERT(INT,o.MasterLeaseNumber) = CONVERT(INT,v.LeaseID)
	   ON (SELECT TOP(1) LeaseID FROM  cte_Basic_Search) = v.LeaseID
INNER JOIN cte_LeaseAdminCustomer
	ON o.AccountNumber = cte_LeaseAdminCustomer.AccountNumber

</CommandText>
