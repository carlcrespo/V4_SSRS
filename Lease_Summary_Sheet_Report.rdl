    <DataSet Name="DataSet4">
      <Query>
        <DataSourceName>Insight</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LeaseScheduleNumber">
            <Value>=Parameters!LeaseScheduleNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AccountNumber">
            <Value>=Parameters!AccountNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20191021
-- Build 20190122 ssrs Dataset4
-- LW - Lease Summary Sheet - Re-Bill items on Renewals or Re-Writes
-- Work Order #20432

--USE [LW_PROD]
--GO
---------------------------------------------------
--Declare
--         @LeaseScheduleNumber VARCHAR(50) 
--       , @AccountNumber NVARCHAR(80)    
--       , @CultureID VARCHAR(15) = NULL
--       , @CustomerID INT 

--SET @LeaseScheduleNumber ='1' -- '27' -- 'Insight-CAP-43' -- '136' -- '6617-FY17-30' --'8005-1-R' -- 6617-FY17-30
--SET @AccountNumber ='HEI010'  -- 'ORE010' -- 'COA010'  -- 'BET020'  --'CAL070' --'CAL19'
------------------------------------------------------

SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
--SET NOCOUNT ON;
--BEGIN

--CREATE TABLE cte_Basic_Search (LeaseTransactionID INT,CustomerID INT,LeaseID INT,MLAID INT,SequenceNumber NVARCHAR(50),CoTermSequenceNumber NVARCHAR(50),BrokerID INT,DDSNotesdata NVARCHAR(MAX),AccountNumber NVARCHAR(80),CustomerName NVARCHAR(250),FEFlag TINYINT)

--INSERT INTO cte_Basic_Search
;
WITH
cte_Basic_Search
AS
(
SELECT
         LeaseTransaction_Profile.LeaseTransactionID
       , Customer_Profile.CustomerID
       , Lease_Profile.LeaseID
       , CASE WHEN Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
              THEN MLA_Profile.MLAID
              ELSE Lease_MLA.MLAID
         END AS MLAID
       , Lease_Profile.SequenceNumber
       , [CoTermLeaseDetails].SequenceNumber [CoTermSequenceNumber]
       , CASE WHEN Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
              THEN LeaseTransaction_Profile.BrokerID
              ELSE Lease_Profile.BrokerID
         END AS BrokerID
       , LeaseTransaction_Profile.DDSNotesdata
       , Customer_Profile.AccountNumber
       , Customer_Profile.CustomerName
       , CASE WHEN Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
              THEN 1
              ELSE 0
         END AS FEFlag
FROM
       Lease_Profile
       INNER JOIN Customer_Profile
              ON Customer_Profile.CustomerID = Lease_Profile.CustomerID
              AND Lease_Profile.Alias = @LeaseScheduleNumber
              AND Customer_Profile.AccountNumber = @AccountNumber
              AND Lease_Profile.BookingStatusID = 2 --Completed
       LEFT JOIN LeaseTransaction_Profile
              ON Lease_Profile.LeaseID = LeaseTransaction_Profile.LeaseID
              AND LeaseTransaction_Profile.AgreementTypeID = 2 --LeaseTransaction
       LEFT JOIN MLA_Profile
              ON MLA_Profile.MLAID = LeaseTransaction_Profile.MLAID
       LEFT JOIN MLA_Profile Lease_MLA
              ON Lease_MLA.MLAID = Lease_Profile.MLAID
       LEFT JOIN Lease_Profile [CoTermLeaseDetails]
              ON [CoTermLeaseDetails].LeaseID = Lease_Profile.CoTermLeaseID
)
,
CTE_CustomerInfo
AS
(
      SELECT
                cte_Basic_Search.LeaseTransactionID
              , MLA_Profile.ClientMLANumber [MasterLeaseNumber]
              , Template_MLATYpe_Cnfg.Description [MLAType]
              , cte_Basic_Search.CustomerID
              , FundingSource_Profile.Company [LabellingLessor]
              , LeaseTransaction_AdminstrativeInformation.PurchaseOrderNumber [RentalPoNumber]
              , Prorata = CASE WHEN LeaseTransaction_AdminstrativeInformation.ProrataRentTypeID = 2 --Standard
                                         THEN 'S'
                                         WHEN LeaseTransaction_AdminstrativeInformation.ProrataRentTypeID = 3 --Interest Carry
                                         THEN 'I'      
                                         WHEN LeaseTransaction_AdminstrativeInformation.ProrataRentTypeID = 1 --None
                                                THEN 'N'
                                         WHEN LeaseTransaction_AdminstrativeInformation.ProrataRentTypeID = 4 --N/A
                                                THEN 'NA'
                                         ELSE ''
                                  END
              , Interim = CASE WHEN LeaseTransaction_AdminstrativeInformation.InterimRentTypeID = 1 --Standard
                                         THEN 'S'
                                  WHEN LeaseTransaction_AdminstrativeInformation.InterimRentTypeID = 2 --Interest Carry
                                         THEN 'I'      
                                  WHEN LeaseTransaction_AdminstrativeInformation.InterimRentTypeID = 3 --Fixed
                                         THEN 'F'
                                  WHEN LeaseTransaction_AdminstrativeInformation.InterimRentTypeID = 4 --None
                                         THEN 'N'
                                  WHEN LeaseTransaction_AdminstrativeInformation.InterimRentTypeID = 5 --N/A
                                         THEN 'NA'
                                  ELSE ''
                                  END
              , ProrataInterestCarry = CASE WHEN LeaseTransaction_AdminstrativeInformation.ProrataRentTypeID = 3 --Interest Carry
                                                              THEN LeaseTransaction_AdminstrativeInformation.ProrataInterestCarry
                                                              ELSE NULL
                                                       END
              , FixedInterimNoofDays = CASE WHEN LeaseTransaction_AdminstrativeInformation.InterimRentTypeID = 3 --Fixed
                                                              THEN LeaseTransaction_AdminstrativeInformation.NoOfDays
                                                              ELSE NULL
                                                       END
              ,[BrokerDetails].Company
              ,Lease_TransactionType_Cnfglocale.LeaseTransactionTypeName
              ,LeaseTransaction_AdminstrativeInformation.AdminFee
       FROM
              cte_Basic_Search
              LEFT JOIN MLA_Profile
                     ON MLA_Profile.MLAID = cte_Basic_Search.MLAID
              LEFT JOIN Template_MLATYpe_Cnfg
                     ON Template_MLATYpe_Cnfg.MLATypeID = MLA_Profile.MLATypeID
              LEFT JOIN LeaseTransaction_AdminstrativeInformation
                     ON LeaseTransaction_AdminstrativeInformation.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              LEFT JOIN Lease_TransactionType_Cnfg
                     ON Lease_TransactionType_Cnfg.LeaseTransactionTypeID = LeaseTransaction_AdminstrativeInformation.LeaseTransactionTypeID
              LEFT JOIN Lease_TransactionType_Cnfglocale
                     ON Lease_TransactionType_Cnfglocale.LeaseTransactionTypeID = Lease_TransactionType_Cnfg.LeaseTransactionTypeID
                    --AND Lease_TransactionType_Cnfglocale.CultureID = @CultureID 
              LEFT JOIN FundingSource_Profile
                     ON FundingSource_Profile.FundingSourceID = LeaseTransaction_AdminstrativeInformation.labellinglessorid
              LEFT JOIN FundingSource_Profile [BrokerDetails]
                     ON [BrokerDetails].FundingSourceID = cte_Basic_Search.BrokerID
              
)
,
CTE_ARSpecialist_Details
AS
(
SELECT 
         COALESCE(MAX(LeaseLevel.EmployeeAssignmentID) ,MAX(CustomerLevel.EmployeeAssignmentID) ,NULL) [ARSpecialist]
       , cte_Basic_Search.LeaseTransactionID
FROM 
       cte_Basic_Search
       LEFT JOIN EmployeeAssignment_Entity LeaseLevel
              ON LeaseLevel.EntityID = cte_Basic_Search.LeaseTransactionID
              AND LeaseLevel.RoleFunctionID = 40 --Billing[A/R Specialist]
              AND LeaseLevel.EntityTypeID = 7 --LeaseTransaction
              AND LeaseLevel.IsActive = 1 --Yes
       LEFT JOIN EmployeeAssignment_Entity as CustomerLevel
              ON CustomerLevel.EntityID = cte_Basic_Search.CustomerID
              AND  CustomerLevel.RoleFunctionID = 40 --Billing[A/R Specialist]
              AND CustomerLevel.EntityTypeID = 1 --Customer
              AND CustomerLevel.IsActive = 1 --Yes
GROUP BY 
              LeaseLevel.RoleFunctionID
       , CustomerLevel.RoleFunctionID
       , cte_Basic_Search.LeaseTransactionID
) 
,

CTE_SalesPerson_Details
AS
(
       SELECT 
                COALESCE(MAX(LeaseLevel.EmployeeAssignmentID) ,MAX(CustomerLevel.EmployeeAssignmentID) ,NULL) [SalesPerson]
              , cte_Basic_Search.LeaseTransactionID
FROM 
       cte_Basic_Search
       LEFT JOIN EmployeeAssignment_Entity LeaseLevel
              ON LeaseLevel.EntityID = cte_Basic_Search.LeaseTransactionID
              AND LeaseLevel.RoleFunctionID = 8  --Sales Representative
              AND LeaseLevel.EntityTypeID = 7 --LeaseTransaction
              AND LeaseLevel.IsActive = 1 --Yes
       LEFT JOIN EmployeeAssignment_Entity as CustomerLevel
              ON CustomerLevel.EntityID = cte_Basic_Search.CustomerID
              AND  CustomerLevel.RoleFunctionID = 8  --Sales Representative
              AND CustomerLevel.EntityTypeID = 1 --Customer
              AND CustomerLevel.IsActive = 1 --Yes
GROUP BY 
              LeaseLevel.RoleFunctionID
       , CustomerLevel.RoleFunctionID
       , cte_Basic_Search.LeaseTransactionID
)
,
CTE_LeaseSpecialist_Details
AS
(
       SELECT 
                COALESCE(MAX(LeaseLevel.EmployeeAssignmentID) ,MAX(CustomerLevel.EmployeeAssignmentID) ,NULL) [LeaseSpecialist]
              , cte_Basic_Search.LeaseTransactionID
       FROM 
              cte_Basic_Search
              LEFT JOIN EmployeeAssignment_Entity LeaseLevel
                     ON LeaseLevel.EntityID = cte_Basic_Search.LeaseTransactionID
                     AND LeaseLevel.RoleFunctionID = 38  --Lease Administrator[Lease Specialist]
                     AND LeaseLevel.EntityTypeID = 7 --LeaseTransaction
                     AND LeaseLevel.IsActive = 1 --Yes
              LEFT JOIN EmployeeAssignment_Entity as CustomerLevel
                     ON CustomerLevel.EntityID = cte_Basic_Search.CustomerID
                     AND  CustomerLevel.RoleFunctionID = 38  --Lease Administrator[Lease Specialist]
                     AND CustomerLevel.EntityTypeID = 1 --Customer
                     AND CustomerLevel.IsActive = 1 --Yes
       GROUP BY 
                     LeaseLevel.RoleFunctionID
              , CustomerLevel.RoleFunctionID
              , cte_Basic_Search.LeaseTransactionID
),

CTE_Commissions_Details
AS
(
       SELECT 
             COALESCE(MAX(LeaseLevel.EmployeeAssignmentID) ,MAX(CustomerLevel.EmployeeAssignmentID) ,NULL)  [Commissions]
              , cte_Basic_Search.LeaseTransactionID
       FROM 
              cte_Basic_Search
              LEFT JOIN EmployeeAssignment_Entity LeaseLevel
                     ON LeaseLevel.EntityID = cte_Basic_Search.LeaseTransactionID
                     AND LeaseLevel.RoleFunctionID = 46  --Commissions
                     AND LeaseLevel.EntityTypeID = 7 --LeaseTransaction
                     AND LeaseLevel.IsActive = 1 --Yes
              LEFT JOIN EmployeeAssignment_Entity as CustomerLevel
                     ON CustomerLevel.EntityID = cte_Basic_Search.CustomerID
                     AND  CustomerLevel.RoleFunctionID = 46  --Commissions
                     AND CustomerLevel.EntityTypeID = 1 --Customer
                     AND CustomerLevel.IsActive = 1 --Yes
       GROUP BY 
                LeaseLevel.RoleFunctionID
              , CustomerLevel.RoleFunctionID
              , cte_Basic_Search.LeaseTransactionID
),
CTE_Colesse_Details
As
(
       SELECT 
                cte_Basic_Search.LeaseTransactionID
              , Customer_Profile.CustomerID
              , Customer_Profile.CustomerName
       FROM         
              cte_Basic_Search
              INNER JOIN ThirdParty_CustomerRelationshipHeader 
                     ON ThirdParty_CustomerRelationshipHeader.CustomerID = cte_Basic_Search.CustomerID 
                     AND cte_Basic_Search.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              INNER JOIN ThirdParty_CustomerRelationshipDetail
                     ON ThirdParty_CustomerRelationshipDetail.ThirdPartyCustomerRelationshipID = ThirdParty_CustomerRelationshipHeader.ThirdPartyCustomerRelationshipID 
                     AND ThirdParty_CustomerRelationshipDetail.IsActive = 1 --Yes
              INNER JOIN Customer_Profile
                     ON Customer_Profile.CustomerID = ThirdParty_CustomerRelationshipDetail.CustomerID
              INNER JOIN ThirdParty_CustomerRelationshipType_CnfgLocale 
                     ON ThirdParty_CustomerRelationshipType_CnfgLocale.ThirdPartyCustomerRelationshipTypeID  = ThirdParty_CustomerRelationshipDetail.ThirdPartyCustomerRelationshipTypeID
                     AND ThirdParty_CustomerRelationshipType_CnfgLocale.ThirdPartyCustomerRelationshipTypeID = 1 --Co-Lessee
                     --AND ThirdParty_CustomerRelationshipType_CnfgLocale.CultureID = @CultureID
              INNER JOIN ThirdParty_DealRelationshipDetail
                     ON ThirdParty_DealRelationshipDetail.ThirdPartyCustomerRelationshipDetailID = ThirdParty_CustomerRelationshipDetail.ThirdPartyCustomerRelationshipDetailID
                     AND ThirdParty_DealRelationshipDetail.EntityTypeID = 7 --LeaseTransaction
                     AND ThirdParty_DealRelationshipDetail.EntityID = cte_Basic_Search.LeaseTransactionID
                     AND ThirdParty_DealRelationshipDetail.IsAssigned = 1   
),

CTE_ColesseCSV
AS
(
       SELECT 
                LeaseTransactionID
              , ColesseCSV = ISNULL(
                     STUFF((SELECT ',' + CustomerName
                                  FROM CTE_Colesse_Details b 
                                  WHERE b.LeaseTransactionID = a.LeaseTransactionID 
                                  FOR XML PATH('')), 1, 1, ''),NULL)
       FROM CTE_Colesse_Details a
       GROUP BY LeaseTransactionID
)
,
CTE_CustomerInformation_Details
AS
(
       SELECT
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
-- 20181016
               --ARSpecialistUserProfile.LastName + SPACE(1)+ ARSpecialistUserProfile.FirstName + SPACE(5) + 'Ext:' + ARSpecialistUserProfile.Extension [ARSpecialist]
                ARSpecialistUserProfile.FirstName + SPACE(1)+ ARSpecialistUserProfile.LastName ARSpecialist
              --, SalesPersonUserProfile.LastName + SPACE(1)+ SalesPersonUserProfile.FirstName + SPACE(5) + 'Ext:' + SalesPersonUserProfile.Extension [SalesRep] 
              , SalesPersonUserProfile.FirstName + SPACE(1)+ SalesPersonUserProfile.LastName SalesRep 
              --, LeaseSpecialistUserProfile.LastName + SPACE(1)+ LeaseSpecialistUserProfile.FirstName + SPACE(5) + 'Ext:' + LeaseSpecialistUserProfile.Extension  [LeaseSpecialist]
              , '' LeaseSpecialist
              --, [CommissionsUserProfile].LastName + SPACE(1)+ [CommissionsUserProfile].FirstName + SPACE(5) + 'Ext:' + [CommissionsUserProfile].Extension  [CommissionsUser]
              , [CommissionsUserProfile].FirstName + SPACE(1)+ [CommissionsUserProfile].LastName CommissionsUser
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
              , CTE_CustomerInfo.LeaseTransactionID
              , CTE_CustomerInfo.[MasterLeaseNumber]
              , CTE_CustomerInfo.[MLAType]
              , CTE_CustomerInfo.CustomerID
              , CTE_CustomerInfo.[LabellingLessor]
              , CTE_ColesseCSV.ColesseCSV
              , cte_Basic_Search.SequenceNumber
              , cte_Basic_Search.[CoTermSequenceNumber]
              , CTE_CustomerInfo.[RentalPoNumber]
              , CTE_CustomerInfo.Prorata
              , CTE_CustomerInfo.Interim
              , CTE_CustomerInfo.ProrataInterestCarry
              , CTE_CustomerInfo.FixedInterimNoofDays
              , CTE_CustomerInfo.Company
              , cte_Basic_Search.AccountNumber
              , CTE_CustomerInfo.LeaseTransactionTypeName
              , CTE_CustomerInfo.AdminFee
       FROM
              cte_Basic_Search
              INNER JOIN CTE_CustomerInfo
                     ON CTE_CustomerInfo.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              LEFT JOIN CTE_ColesseCSV
                     On CTE_ColesseCSV.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              LEFT JOIN CTE_ARSpecialist_Details
                     ON CTE_ARSpecialist_Details.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              LEFT JOIN CTE_SalesPerson_Details
                     ON CTE_SalesPerson_Details.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              LEFT JOIN CTE_LeaseSpecialist_Details
                     ON CTE_LeaseSpecialist_Details.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              LEFT JOIN CTE_Commissions_Details
                     ON CTE_Commissions_Details.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              LEFT JOIN EmployeeAssignment_Entity AS [SalesPersonEmployeeAssignment]
                     --ON SalesPersonEmployeeAssignment.EntityID = CTE_SalesPerson_Details.LeaseTransactionID
                     ON SalesPersonEmployeeAssignment.EmployeeAssignmentID = CTE_SalesPerson_Details.SalesPerson
              LEFT JOIN Security_UserProfile AS [SalesPersonUserProfile]
                     ON SalesPersonUserProfile.UserID = SalesPersonEmployeeAssignment.UserID
                     AND SalesPersonUserProfile.IsActive = 1 --Yes
              LEFT JOIN EmployeeAssignment_Entity AS [ARSpecialistEmployeeAssignment]
                     --ON ARSpecialistEmployeeAssignment.EntityID = CTE_ARSpecialist_Details.LeaseTransactionID
                     ON ARSpecialistEmployeeAssignment.EmployeeAssignmentID = CTE_ARSpecialist_Details.ARSpecialist
              LEFT JOIN Security_UserProfile AS [ARSpecialistUserProfile]
                     ON ARSpecialistUserProfile.UserID = ARSpecialistEmployeeAssignment.UserID
                     AND ARSpecialistUserProfile.IsActive = 1 --Yes
              LEFT JOIN EmployeeAssignment_Entity AS [LeaseSpecialistEmployeeAssignment]
                     --ON LeaseSpecialistEmployeeAssignment.EntityID = CTE_LeaseSpecialist_Details.LeaseTransactionID
                     ON [LeaseSpecialistEmployeeAssignment].EmployeeAssignmentID = CTE_LeaseSpecialist_Details.[LeaseSpecialist]
              LEFT JOIN Security_UserProfile AS [LeaseSpecialistUserProfile]
                     ON LeaseSpecialistUserProfile.UserID = [LeaseSpecialistEmployeeAssignment].UserID
                     AND LeaseSpecialistUserProfile.IsActive = 1 --Yes
              LEFT JOIN EmployeeAssignment_Entity AS [CommissionsEmployeeAssignment]
                     --ON [CommissionsEmployeeAssignment].EntityID = CTE_Commissions_Details.LeaseTransactionID
                     ON [CommissionsEmployeeAssignment].EmployeeAssignmentID = CTE_Commissions_Details.[Commissions]
              LEFT JOIN Security_UserProfile AS [CommissionsUserProfile]
                     ON [CommissionsUserProfile].UserID = [CommissionsEmployeeAssignment].UserID
                     AND [CommissionsUserProfile].IsActive = 1 --Yes
)
,
CTE_InventoryDetails
AS
(
       SELECT
              SaleLeaseBackCount = (SELECT COUNT (Inventory_Profile.LPIsSaleLeaseBack)
                                                       FROM
                                                              cte_Basic_Search
                                                              INNER JOIN LeaseTransaction_inventory
                                                                     ON LeaseTransaction_inventory.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID  
                                                                     AND LeaseTransaction_inventory.IsActive = 1 --Yes
                                                              INNER JOIN Inventory_Profile
                                                                     On Inventory_Profile.inventoryID = LeaseTransaction_inventory.InventoryID
                                                                     AND  Inventory_Profile.LPIsSaleLeaseBack = 1         )

              
              , VARCount = (SELECT COUNT (Vendor_Profile.VendorSubtypeID)
                                         FROM
                                                cte_Basic_Search
                                                INNER JOIN LeaseTransaction_inventory
                                                       ON LeaseTransaction_inventory.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID  
                                                       AND LeaseTransaction_inventory.IsActive = 1 --Yes
                                                INNER JOIN APInvoice_CostHeader
                                                       ON APInvoice_CostHeader.inventoryID = LeaseTransaction_inventory.InventoryID
                                                INNER JOIN APInvoice_profile
                                                       ON APInvoice_profile.VendorInvoiceID = APInvoice_CostHeader.VendorInvoiceID
                                                INNER JOIN Vendor_Profile
                                                       ON Vendor_Profile.VendorID = APInvoice_profile.VendorID 
                                                       AND Vendor_Profile.VendorSubtypeID = 2 --VAR
                                                                            )
              , ISECount = (SELECT COUNT (Vendor_Profile.VendorSubtypeID)
                                                FROM
                                                       cte_Basic_Search
                                                       INNER JOIN LeaseTransaction_inventory
                                                              ON LeaseTransaction_inventory.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID  
                                                              AND LeaseTransaction_inventory.IsActive = 1 --Yes
                                                       INNER JOIN APInvoice_CostHeader
                                                              ON APInvoice_CostHeader.inventoryID = LeaseTransaction_inventory.InventoryID
                                                       INNER JOIN APInvoice_profile
                                                              ON APInvoice_profile.VendorInvoiceID = APInvoice_CostHeader.VendorInvoiceID
                                                       INNER JOIN Vendor_Profile
                                                              ON Vendor_Profile.VendorID = APInvoice_profile.VendorID 
                                                              AND Vendor_Profile.VendorSubtypeID = 3 --ISE
                                                                           )
              , cte_Basic_Search.LeaseTransactionID
              FROM
                     cte_Basic_Search
),
CTE_BillInfo
AS
(
       SELECT
                Cofa_profile.AcceptedDate
              , LeaseTransaction_PaymentCalculation.InceptionDate
              , LeaseTransaction_PaymentCalculation.MaturityDate
              , LeaseTransaction_PaymentCalculation.Term
              , Deal_RentalFrequency_Cnfg.Description [Billingfrequency]
              , IrregularPayments = CASE WHEN LeaseTransaction_PaymentCalculation.StructureID = 1
                     THEN 'No'
                     ELSE 'Yes'
                     END
              , BillingCycle = CASE WHEN LeaseTransaction_PaymentCalculation.NumberOfInceptionPayments &gt; 0
                     THEN 'Advance'
                     ELSE 'Arrears'
                     END    
              , Lease_ContractpurchaseOption_Cnfglocale.PurchaseOption [EOTOption]
              , MaturityManagement_LeaseTransaction.PractFMVCapPercent
              , TransitionLease = CASE WHEN MaturityManagement_LeaseTransaction.PractIsTransitionLease = 0
                                                       THEN 'N'
                                                       ELSE 'Y'
                                                END
              , TransitionDays = CASE WHEN MaturityManagement_LeaseTransaction.PractIsTransitionLease = 1
                                                       THEN MaturityManagement_LeaseTransaction.PractTransitionDays
                                                       ELSE NULL
                                                END
              , SaleLeasebackAsset = CASE WHEN CTE_InventoryDetails.SaleLeaseBackCount &gt; 0
                                                              THEN 'Y'
                                                              ELSE 'N'
                                                       END           
              , VARText = CASE WHEN CTE_InventoryDetails.VARCount &gt; 0
                                         THEN 'Y'
                                         ELSE 'N'
                                  END
              , ISE = CASE WHEN CTE_InventoryDetails.ISECount &gt; 0
                                  THEN 'Y'
                                  ELSE 'N'
                           END
              , MaturityManagement_LeaseTransaction.PractFirstReminderNoticeDays [ReminderPeriod]
              , MaturityManagement_LeaseTransaction.PractFTNoticePeriod [NoticePeriod]
              , cte_Basic_Search.LeaseTransactionID
---------------------------------------------------------------------------------------------------------
-- 20180810 #2
       ,LeaseTransaction_PaymentCalculation.PurchaseOptionStatusTypeID
       ,Lease_PurchaseOptionSubType_CnfgLocale.PurchaseOptionSubType
--------------------------------------------------------------------------------------------------------
-- 20181207
              ,MaturityManagement_LeaseTransaction.DataSecurityReqdID
--------------------------------------------------------------------------------------------------------
       FROM
              cte_Basic_Search
              LEFT JOIN LeaseTransaction_PaymentCalculation
                     ON LeaseTransaction_PaymentCalculation.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              LEFT JOIN Lease_ContractpurchaseOption_Cnfg
                     On Lease_ContractpurchaseOption_Cnfg.PurchaseOptionID = LeaseTransaction_PaymentCalculation.PurchaseOptionStatusTypeID
                     AND Lease_ContractpurchaseOption_Cnfg.IsActive = 1 --Yes
              LEFT JOIN Lease_ContractpurchaseOption_Cnfglocale
                     ON Lease_ContractpurchaseOption_Cnfglocale.PurchaseOptionID = Lease_ContractpurchaseOption_Cnfg.PurchaseOptionID
                     --AND Lease_ContractpurchaseOption_Cnfglocale.CultureID = @CultureID
              LEFT JOIN Deal_RentalFrequency_Cnfg
                     ON Deal_RentalFrequency_Cnfg.FrequencyID = LeaseTransaction_PaymentCalculation.LeaseFrequencyID
              LEFT JOIN Lease_ContractStructure_Cnfg
                     ON Lease_ContractStructure_Cnfg.ContractStructureID = LeaseTransaction_PaymentCalculation.StructureID 
              LEFT JOIN CTE_InventoryDetails
                     ON CTE_InventoryDetails.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
              LEFT JOIN Cofa_profile
                     ON Cofa_profile.VersionID = cte_Basic_Search.LeaseTransactionID  
                     AND Cofa_profile.IsFinalCofa = 1 --Yes
                     AND Cofa_profile.IsActive = 1 --Yes
              LEFT JOIN MaturityManagement_LeaseTransaction
                     ON MaturityManagement_LeaseTransaction.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
                     AND MaturityManagement_LeaseTransaction.IsActive = 1 --Yes
                     
-------------------------------------------------------------------------------------------------------------
-- 20180810 #2
LEFT JOIN [dbo].[Lease_PurchaseOptionSubType_CnfgLocale] 
       ON LeaseTransaction_PaymentCalculation.PurchaseOptionSubTypeID = Lease_PurchaseOptionSubType_CnfgLocale.PurchaseOptionSubTypeID
-------------------------------------------------------------------------------------------------------------                          
),
CTE_PreviousLeaseDetails
AS
(
       SELECT
                DISTINCT Lease_profile.SequenceNumber
              , cte_Basic_Search.LeaseTransactionID
       FROM
              cte_Basic_Search
              INNER JOIN LeaseTransaction_Inventory    
                     ON LeaseTransaction_Inventory.LeaseTransactionID =        cte_Basic_Search.LeaseTransactionID
              INNER JOIN Inventory_Profile
                     ON Inventory_Profile.InventoryID = LeaseTransaction_Inventory.InventoryID
              INNER JOIN Lease_profile
                     ON Lease_profile.LeaseID = Inventory_Profile.PreviousLeaseID
),
CTE_PreviousSequenceNumberCSV
AS
(
       SELECT 
                LeaseTransactionID
              , SequenceNumberCSV = ISNULL(
                     STUFF((SELECT ',' + SequenceNumber
                                  FROM CTE_PreviousLeaseDetails b 
                                  WHERE b.LeaseTransactionID = a.LeaseTransactionID 
                                  FOR XML PATH('')), 1, 1, ''),NULL)
       FROM CTE_PreviousLeaseDetails a
       GROUP BY LeaseTransactionID
),
CTE_SumofAssetLevelRental
AS
(
       SELECT
                SUM(LeaseTransaction_Inventory.LeaseRentalAmount) [TotalAssetLevelRental]
              , cte_Basic_Search.LeaseTransactionID
       FROM
              cte_Basic_Search
              INNER JOIN LeaseTransaction_Inventory
                     ON LeaseTransaction_Inventory.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
                     AND LeaseTransaction_Inventory.IsActive = 1 --Yes
       GROUP BY
                     cte_Basic_Search.LeaseTransactionID  
),
CTE_VendorInvoiceOtherCost
AS
(
       SELECT DISTINCT 
                     LeaseTRansaction_Inventory.LeaseTransactionID
              , APInvoice_CostOther.VendorInvoiceOtherCostCountID
              , CASE WHEN APInvoice_CostOther.Description = 'Freight' THEN 'Freight'  
                           WHEN APInvoice_CostOther.Description = 'Miscellaneous' THEN 'Miscellaneous'
                           WHEN VendorCostDescriptionID IS NOT NULL THEN 'Softcost / Software Rebill amount'
                           ELSE NULL END   as Description
       FROM  
                     cte_Basic_Search  Basic_Search 
                     INNER JOIN LeaseTRansaction_Inventory
                           ON LeaseTRansaction_Inventory.LeaseTransactionID = Basic_Search.LeaseTransactionID
                           AND LeaseTRansaction_Inventory.IsActive = 1 --Yes
                           AND LeaseTRansaction_Inventory.IsVersionWasDeactivated = 0 
                     INNER JOIN APInvoice_CostHeader 
                           ON LeaseTRansaction_Inventory.InventoryID = APInvoice_CostHeader.InventoryID
                           AND APInvoice_CostHeader.IsActive = 1 --Yes
                     INNER JOIN APInvoice_CostOther
                           ON APInvoice_CostHeader.VendorInvoiceID = APInvoice_CostOther.VendorInvoiceID
                           AND APInvoice_CostOther.IsActive = 1
                           AND APInvoice_CostOther.AllocationMethodID = 5 --ChargeBack
                     LEFT JOIN APInvoice_CostDescription_Cnfg
                           ON APInvoice_CostDescription_Cnfg.Description = APInvoice_CostOther.Description
-----------------------------------------------------------------------------------------------
-- 20180813
  INNER JOIN [dbo].Inventory_Profile ip
       ON ip.InventoryID = LeaseTransaction_Inventory.InventoryID
  INNER JOIN [dbo].[Inventory_Status_Cnfg] isi
       ON  ip.InventoryStatusID = isi.InventoryStatusID
    AND isi.InventoryStatusID = 6
  INNER JOIN [dbo].[Inventory_SubStatus_Cnfg]  iss
       ON ip.[InventorySubStatusID] = iss.[InventorySubStatusID]
       AND iss.[InventorySubStatusID] IN (1) --&gt; new lease
-----------------------------------------------------------------------------------------------
),
CTE_VendorInvoiceOtherCostGrouped
AS
(
SELECT * 
FROM (
       SELECT 
                LeaseTransactionID
              , SUM(AMOUNT)  Amount
              , CTE_VendorInvoiceOtherCost.Description 
       FROM
              CTE_VendorInvoiceOtherCost
                     INNER JOIN APInvoice_CostOther
                           ON CTE_VendorInvoiceOtherCost.VendorInvoiceOtherCostCountID = APInvoice_CostOther.VendorInvoiceOtherCostCountID
       GROUP BY 
                LeaseTransactionID
              , CTE_VendorInvoiceOtherCost.Description
       )      AS VI_Detail
       PIVOT
       (
              SUM(Amount) FOR Description IN ([Freight],[Miscellaneous],[Softcost / Software Rebill amount])
       )      AS PivotOthercharge
)
------------------------------------------------------------------------------------------------------
-- 20180809 #1
,
cte_LeaseRole7 -- Lease Roles (LeaseTransactionID)
AS
(
SELECT 
               o.EntityTypeID
              ,o.EntityTypeName          
              ,o.EmployeeAssignmentID
              ,t.CustomerName
              ,@AccountNumber AccountNumber
              ,@LeaseScheduleNumber LeaseScheduleNumber
              ,t.SequenceNumber
              ,o.FirstName
              ,o.LastName
              ,o.UserCode
              ,o.EXT
              ,o.RoleFunctionName
              ,o.RoleFunctionID
              ,o.EntityID LeaseTransactionID
FROM 
       (
-- EOLAdmin
              (
                     SELECT Distinct 
                      e.EntityTypeID
                     ,e.EmployeeAssignmentID
                     ,(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
                     ,(SELECT FirstName FROM Security_UserProfile WHERE UserID = e.UserID) FirstName
                     ,(SELECT LastName FROM Security_UserProfile WHERE UserID = e.UserID) LastName
                     ,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
                     ,(SELECT Extension FROM Security_UserProfile WHERE UserID = e.UserID) EXT
                     ,CASE WHEN (SELECT UserAlias FROM Security_UserProfile WHERE UserID = e.UserID) = 'End of Lease Administrator' THEN 'EOL_Admin'
                           ELSE (SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) 
                           END RoleFunctionName
                     ,(SELECT RoleFunctionID FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionID
                           ,e.EntityID
                     FROM EmployeeAssignment_Entity e
                     Inner Join Security_UserProfile s
                     ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator' 

                     Where e.EntityTypeID = 7
                     And e.EmployeeAssignmentID IN
                           (
                                  SELECT Max(e.EmployeeAssignmentID) 
                                  FROM EmployeeAssignment_Entity e
                                  Inner Join Security_UserProfile s
                                         ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator'  
                                  Where e.EntityTypeID = 7
                                  And 
                                         (
                                         SELECT UserAlias 
                                         FROM Security_UserProfile 
                                         WHERE UserID = e.UserID
                                         ) = 'End of Lease Administrator' 
                                  Group By  e.EntityTypeID,e.EntityID
                           )
              )
              UNION
              -- LeaseAdmin
              (
                           SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID
                           ,(SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
                     ,(SELECT FirstName FROM Security_UserProfile WHERE UserID = e.UserID) FirstName
                     ,(SELECT LastName FROM Security_UserProfile WHERE UserID = e.UserID) LastName
                           ,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
                     ,(SELECT Extension FROM Security_UserProfile WHERE UserID = e.UserID) EXT
                           ,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
                           ,(SELECT RoleFunctionID FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionID
                           ,e.EntityID
                           FROM EmployeeAssignment_Entity e
                           WHERE e.EntityTypeID  = 7 
                           And 
                            e.EmployeeAssignmentID IN 
                                  (
                                  SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
                                  FROM EmployeeAssignment_Entity 
                                  WHERE EntityTypeID = 7  /*@EntityTypeID --LeaseAdmin*/
                                         AND IsActive = 1 /*@IsActive*/
                                         AND RoleFunctionID = 38  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=38, RoleFunctionName = 'Lease Administrator'
                                  ------------------------------    
                                         And EmployeeAssignmentID Not IN 
                                         (
                                                SELECT distinct e.EmployeeAssignmentID 
                                                FROM EmployeeAssignment_Entity e
                                                Inner Join Security_UserProfile s
                                                ON e.userid = e.UserID and s.UserAlias = 'End of Lease Administrator'  
                                                Where e.EntityTypeID = 7
                                         And (SELECT UserAlias FROM Security_UserProfile WHERE UserID = e.UserID) = 'End of Lease Administrator' 
                                         )                    
                                  ------------------------------    
                                  GROUP BY EntityID --,UserID 
                                  )
              )
              UNION 
              -- SalesAdmin
              (
                     SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID,
                     (SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
                     ,(SELECT FirstName FROM Security_UserProfile WHERE UserID = e.UserID) FirstName
                     ,(SELECT LastName FROM Security_UserProfile WHERE UserID = e.UserID) LastName
                     ,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
                   ,(SELECT Extension FROM Security_UserProfile WHERE UserID = e.UserID) EXT
                     ,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
                                  ,(SELECT RoleFunctionID FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionID
                     ,e.EntityID
                     FROM EmployeeAssignment_Entity e
                     WHERE e.EntityTypeID  = 7 And 
                      e.EmployeeAssignmentID IN 
                           (
                           SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
                           FROM EmployeeAssignment_Entity 
                           WHERE EntityTypeID = 7  /*@EntityTypeID --SalesAdmin*/
                                  AND IsActive = 1 
                                  AND RoleFunctionID = 8  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=8, RoleFunctionName = 'Sales Representative'
                           GROUP BY EntityID --,UserID 
                           )
              )
              UNION 
              -- BillingAdmin
              (
                     SELECT Distinct  e.EntityTypeID,e.EmployeeAssignmentID,
                     (SELECT EntityTypeName FROM Template_EntityType_CnfgLocale WHERE EntityTypeID = e.EntityTypeID) EntityTypeName
                     ,(SELECT FirstName FROM Security_UserProfile WHERE UserID = e.UserID) FirstName
                     ,(SELECT LastName FROM Security_UserProfile WHERE UserID = e.UserID) LastName
                     ,(SELECT UserCode FROM Security_UserProfile WHERE UserID = e.UserID) UserCode
                     ,(SELECT Extension FROM Security_UserProfile WHERE UserID = e.UserID) EXT
                     ,(SELECT RoleFunctionName FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionName
                           ,(SELECT RoleFunctionID FROM Security_RoleFunction_CnfgLocale WHERE RoleFunctionID = e.RoleFunctionID) RoleFunctionID
                     ,e.EntityID
                     FROM EmployeeAssignment_Entity e
                     WHERE e.EntityTypeID  = 7 And 
                      e.EmployeeAssignmentID IN 
                           (
                           SELECT /*EntityID,*/MAX(EmployeeAssignmentID) AccountMgrAssignmentID --,UserID
                           FROM EmployeeAssignment_Entity 
                           WHERE EntityTypeID = 7  /*@EntityTypeID --BillingAdmin*/
                                  AND IsActive = 1 
                                  AND RoleFunctionID = 40  -- Table Security_RoleFunction_CnfgLocale -- &gt; RoleFunctionID=40, RoleFunctionName = 'Billing'
                           GROUP BY EntityID --,UserID 
                           )
              )
       ) o
INNER JOIN 
       (
       SELECT  lt.LeaseTransactionID
                     ,lt.CustomerID
                     ,cp.AccountNumber
                     ,cp.CustomerName
                ,lt.LeaseID
                ,lp.SequenceNumber
                ,lt.LeaseAlias
       FROM [dbo].[LeaseTransaction_Profile] lt
       INNER JOIN Customer_Profile cp
              ON lt.CustomerID = cp.CustomerID
       INNER JOIN Lease_Profile lp
              ON lt.LeaseID = lp.LeaseID
       WHERE lt.AgreementTypeID = 2  
       AND cp.AccountNumber = @AccountNumber
       AND lt.LeaseAlias = @LeaseScheduleNumber
       ) t
       ON o.EntityID = t.LeaseTransactionID
)
