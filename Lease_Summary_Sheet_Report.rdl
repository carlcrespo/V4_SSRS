-----------------------------------------------------------------------------------------------
,
CTE_VendorInvoiceOtherCostGrouped1
AS
(
SELECT * 
FROM (
       SELECT 
                CTE_VendorInvoiceOtherCost1.LeaseID
              , SUM(APInvoice_CostOther.AMOUNT)  Amount
              , CTE_VendorInvoiceOtherCost1.Description 
       FROM
              CTE_VendorInvoiceOtherCost1
                     INNER JOIN APInvoice_CostOther
                           ON CTE_VendorInvoiceOtherCost1.VendorInvoiceOtherCostCountID = APInvoice_CostOther.VendorInvoiceOtherCostCountID
       GROUP BY 
                LeaseID
              , CTE_VendorInvoiceOtherCost1.Description
       )      AS VI_Detail
       PIVOT
       (
              SUM(Amount) FOR Description IN ([Freight],[Miscellaneous],[Softcost / Software Rebill amount])
       )      AS PivotOthercharge
)
