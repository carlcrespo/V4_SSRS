,
cte_5
AS
(
SELECT
         CTE_CustomerInformation_Details1.[ARSpecialist]
       , CTE_CustomerInformation_Details1.[SalesRep]
------------------------------------------------------------------------------------------------------
-- 20180809   #1
       --, CTE_CustomerInformation_Details.[LeaseSpecialist]
-------------------------------------------------------------------------------------------------------
-- 20181016
       --,IIF(l.EXT = '', l.LastName+' '+l.FirstName, l.LastName+' '+l.FirstName+' EXT: '+l.EXT) LeaseSpecialist
          ,l.FirstName+' '+l.LastName LeaseSpecialist
------------------------------------------------------------------------------------------------------
       , ISNULL(CTE_CustomerInformation_Details1.CommissionsUser,'') CommissionsUser
       , CTE_CustomerInformation_Details1.[MasterLeaseNumber]
       , CTE_CustomerInformation_Details1.[MLAType]
       , CTE_CustomerInformation_Details1.[LabellingLessor]
       , CASE WHEN CTE_CustomerInformation_Details1.ColesseCSV IS NULL THEN cte_Basic_Search.CustomerName
              ELSE cte_Basic_Search.CustomerName + ',' + CTE_CustomerInformation_Details1.ColesseCSV
              END AS [ColesseCSV]
       , CTE_CustomerInformation_Details1.SequenceNumber
       , CTE_CustomerInformation_Details1.[CoTermSequenceNumber]
       , CTE_CustomerInformation_Details1.[RentalPoNumber]
       , CTE_CustomerInformation_Details1.Prorata
       , CTE_CustomerInformation_Details1.Interim
       , CTE_CustomerInformation_Details1.ProrataInterestCarry
       , CTE_CustomerInformation_Details1.FixedInterimNoofDays
       , CTE_CustomerInformation_Details1.AccountNumber
       , CTE_BillInfo1.AcceptedDate
       , CTE_BillInfo1.InceptionDate
       , CTE_BillInfo1.MaturityDate
       , CTE_BillInfo1.Term
       , CTE_BillInfo1.[Billingfrequency]
       , CTE_BillInfo1.IrregularPayments
       , CTE_BillInfo1.BillingCycle
       , CTE_BillInfo1.[EOTOption]
       , CTE_BillInfo1.PractFMVCapPercent
       , CTE_BillInfo1.TransitionLease
       , CTE_BillInfo1.TransitionDays
---------------------------------------------------------------------------------------------------------------------------
-- 20181016
          --, CTE_BillInfo.SaleLeasebackAsset
       , IIF(CTE_BillInfo1.SaleLeasebackAsset = 'Y','Y - Give to Tax',CTE_BillInfo1.SaleLeasebackAsset) SaleLeasebackAsset
---------------------------------------------------------------------------------------------------------------------------
       , CTE_BillInfo1.VARText
       , CTE_BillInfo1.ISE
       , CTE_BillInfo1.[ReminderPeriod]
       , CTE_BillInfo1.[NoticePeriod]
       , CTE_PreviousSequenceNumberCSV1.SequenceNumberCSV
       , CTE_CustomerInformation_Details1.Company [PayableTo]
       , CTE_BillInfo1.LeaseID AS LeaseTransactionID 
       , COALESCE(CTE_SumofAssetLevelRental1.[TotalAssetLevelRental],0) [TotalAssetLevelRental]
       , cte_Basic_Search.DDSNotesdata
       , COALESCE(CTE_ReferralFee1.Amount,0) [ReferralFee] 
       , COALESCE(CTE_VendorInvoiceOtherCostGrouped1.Freight,0) [FreightRebill]
       , CTE_CustomerInformation_Details1.AdminFee [AdminFee] 
       , COALESCE(CTE_VendorInvoiceOtherCostGrouped1.[Softcost / Software Rebill amount],0) [SoftcostAndSoftwareRebill]
       , COALESCE(CTE_PassThroughRentals1.[TotalPassThroughRentals],0) [TotalPassThroughRentals]  
       , COALESCE(CTE_VendorInvoiceOtherCostGrouped1.[Miscellaneous],0) [TotalOtherRebill]
       , CTE_CustomerInformation_Details1.LeaseTransactionTypeName [TransactionType]
--------------------------------------------------------------------------
-- 20180810 #2
       ,ISNULL(CTE_BillInfo1.PurchaseOptionSubType,'') PurchaseOptionSubType
       ,'commenced' leases
--------------------------------------------------------------------------
-- 20181018
              , 5 StatusID
--------------------------------------------------------------------------
-- 20181207
              ,CTE_BillInfo1.DataSecurityReqdID
-- 20181211
              ,cte_Basic_Search.MLAID
--------------------------------------------------------------------------
--------------------------------------------------------------------------
--INTO cte_5
--------------------------------------------------------------------------
FROM
       cte_Basic_Search 
       INNER JOIN CTE_CustomerInformation_Details1
              ON cte_Basic_Search.LeaseID = CTE_CustomerInformation_Details1.LeaseID
       LEFT JOIN CTE_BillInfo1
              ON cte_Basic_Search.LeaseID = CTE_BillInfo1.LeaseID
       LEFT JOIN CTE_PreviousSequenceNumberCSV1
              ON CTE_PreviousSequenceNumberCSV1.LeaseID = cte_Basic_Search.LeaseID
       LEFT JOIN CTE_InventoryDetails1
              ON CTE_InventoryDetails1.LeaseID = cte_Basic_Search.LeaseID
       LEFT JOIN CTE_ReferralFee1
              ON CTE_ReferralFee1.LeaseID = cte_Basic_Search.LeaseID
       LEFT JOIN CTE_PassThroughRentals1
              ON CTE_PassThroughRentals1.LeaseID = cte_Basic_Search.LeaseID                  
       LEFT JOIN CTE_SumofAssetLevelRental1
              ON CTE_SumofAssetLevelRental1.LeaseID = cte_Basic_Search.LeaseID  
       LEFT JOIN CTE_VendorInvoiceOtherCostGrouped1
              ON CTE_VendorInvoiceOtherCostGrouped1.LeaseID = cte_Basic_Search.LeaseID
----------------------------------------------------------------------------
-- 20180809 #1
LEFT JOIN cte_LeaseRole71 l
       ON CTE_CustomerInformation_Details1.SequenceNumber = l.SequenceNumber 
       AND l.RoleFunctionName = 'Lease Administrator'
----------------------------------------------------------------------------
-- 20181018
WHERE (SELECT TOP 1 FEFlag FROM cte_Basic_Search) = 0
)
