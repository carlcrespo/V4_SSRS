,
cte_1_5
AS
(
-- Lease_Profile.StatusID IN (1,5) --NoAsset,Uncommenced
       SELECT a.*
       FROM cte_1 a  -- StatusID = 1
       UNION SELECT b.*
       FROM cte_5 b  -- StatusID = 5
)
,
cte_V
AS
(
SELECT
       V.LeaseID
       ,V.SequenceNumber
       ,IIF(SUM(V.[Modular (Y/N)]) &gt; 0, 'Y','N') [Modular (Y/N)] 
       ,IIF(SUM(V.[Titled Vehicle (Y/N)]) &gt; 0, 'Y','N') [Titled Vehicle (Y/N)]
       ,IIF(SUM(V.[Used Equipment]) &gt; 0, 'Y','N') [Used Equipment]
       ,IIF(SUM(V.[Decontamination Language (Y/N)]) &gt; 0, 'Y','N') [Decontamination Language (Y/N)]
       ,IIF(SUM(V.[WI Disclosure Required (Y/N)]) &gt; 0, 'Y','N') [WI Disclosure Required (Y/N)]
FROM 
(

       SELECT li.InventoryID
              ,li.LeaseID
              ,lp.SequenceNumber
              ,ip.InventorySubCategoryID
              ,ist.InventorySubcategoryName
              ,ict.InventoryCategoryName
              ,IIF(ict.InventoryCategoryID = 22, 1, 0) [Modular (Y/N)] -- MI - Modular Building = 22
              ,IIF(ip.InventorySubCategoryID IN (50,53), 1,0) [Titled Vehicle (Y/N)] -- Forklifts = 50, Vehicles = 53
              ,IIF(ip.UsageConditionID IN (2, 3), 1,0) [Used Equipment] -- Used = 2, Refurbished = 3
              ,ip.InventoryTypeID
              ,it.InventoryTypeName
       /*
       "ME-2000" : LanguageYes := 1
       "ME-2100" : LanguageYes := 1
       "ME-2200" : LanguageYes := 1
       "ME-2300" : LanguageYes := 1
       "ME-2400" : LanguageYes := 1
       "ME-3000" : LanguageYes := 1
       "ME-3100" : LanguageYes := 1
       "ME-3200" : LanguageYes := 1
       */
              ,CASE it.InventoryTypeName
                     WHEN 'ME-2000' THEN 1
                     WHEN 'ME-2100' THEN 1
                     WHEN 'ME-2200' THEN 1
                     WHEN 'ME-2300' THEN 1
                     WHEN 'ME-2400' THEN 1
                     WHEN 'ME-3000' THEN 1
                     WHEN 'ME-3100' THEN 1
                     WHEN 'ME-3200' THEN 1
                     ELSE 0
                     END [Decontamination Language (Y/N)]
              ,il.LocationTemplateID     
              ,ilt.StateID
              ,IIF(st.Description = 'WI',1,0) [WI Disclosure Required (Y/N)]
       FROM [dbo].[Lease_InventoryInLease] li
       INNER JOIN dbo.Inventory_Profile ip
              ON li.InventoryID = ip.InventoryID
       INNER JOIN Inventory_SubcategoryTemplate ist
              ON ip.InventorySubCategoryID = ist.InventorySubcategoryID
       INNER JOIN [dbo].[Inventory_CategoryTemplate] ict
              ON ist.InventoryCategoryID = ict.InventoryCategoryID
       INNER JOIN dbo.Lease_Profile lp
              ON li.LeaseID = lp.LeaseID
       INNER JOIN Customer_Profile cp
              ON lp.CustomerID = cp.CustomerID 
       INNER JOIN [dbo].[Inventory_TypeTemplate] it
              ON ip.InventoryTypeID = it.InventoryTypeID
       INNER JOIN  dbo.Inventory_Location il
              ON li.InventoryID = il.InventoryID
       INNER JOIN [dbo].[Inventory_LocationTemplate]  ilt
              ON il.LocationTemplateID = ilt.LocationTemplateID
       INNER JOIN [dbo].[Template_State_Cnfg] st
              ON ilt.StateID = st.StateID
       WHERE 
              li.IsInLease = 1
       ) V
GROUP BY 
        V.LeaseID
       ,V.SequenceNumber
--HAVING 
--     V.LeaseID IN (SELECT CONVERT(INT,cte_1_5.MasterLeaseNumber)  FROM cte_1_5)
--     --V.SequenceNumber IN (SELECT cte_1_5.SequenceNumber  FROM cte_1_5)
)
