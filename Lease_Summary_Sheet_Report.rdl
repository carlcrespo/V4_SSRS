------------------------------------------------------------------------------------------------------
,
cte_1
AS
(
SELECT ---***
         CTE_CustomerInformation_Details.[ARSpecialist]
       , CTE_CustomerInformation_Details.[SalesRep]
------------------------------------------------------------------------------------------------------
-- 20180809   #1
       --, CTE_CustomerInformation_Details.[LeaseSpecialist] 
-------------------------------------------------------------------------------------------------------  
-- 20181016     
              --,IIF(l.EXT = '', l.LastName+' '+l.FirstName, l.LastName+' '+l.FirstName+' EXT: '+l.EXT) LeaseSpecialist
       ,l.FirstName+' '+l.LastName LeaseSpecialist
------------------------------------------------------------------------------------------------------
       , CTE_CustomerInformation_Details.[CommissionsUser]
       , CTE_CustomerInformation_Details.[MasterLeaseNumber]
       , CTE_CustomerInformation_Details.[MLAType]
       , CTE_CustomerInformation_Details.[LabellingLessor]
       , CASE WHEN CTE_CustomerInformation_Details.ColesseCSV IS NULL THEN cte_Basic_Search.CustomerName
              ELSE cte_Basic_Search.CustomerName + ',' + CTE_CustomerInformation_Details.ColesseCSV
              END AS [ColesseCSV]
       , CTE_CustomerInformation_Details.SequenceNumber
       , CTE_CustomerInformation_Details.[CoTermSequenceNumber]
       , CTE_CustomerInformation_Details.[RentalPoNumber]
       , CTE_CustomerInformation_Details.Prorata
       , CTE_CustomerInformation_Details.Interim
       , CTE_CustomerInformation_Details.ProrataInterestCarry
       , CTE_CustomerInformation_Details.FixedInterimNoofDays
       , CTE_CustomerInformation_Details.AccountNumber
       , CTE_BillInfo.AcceptedDate
       , CTE_BillInfo.InceptionDate
       , CTE_BillInfo.MaturityDate
       , CTE_BillInfo.Term
       , CTE_BillInfo.[Billingfrequency]
       , CTE_BillInfo.IrregularPayments
       , CTE_BillInfo.BillingCycle
       , CTE_BillInfo.[EOTOption]
       , CTE_BillInfo.PractFMVCapPercent
       , CTE_BillInfo.TransitionLease
       , CTE_BillInfo.TransitionDays
---------------------------------------------------------------------------------------------------------------------------
-- 20181016
          --, CTE_BillInfo.SaleLeasebackAsset
       , IIF(CTE_BillInfo.SaleLeasebackAsset = 'Y','Y - Give to Tax',CTE_BillInfo.SaleLeasebackAsset) SaleLeasebackAsset
---------------------------------------------------------------------------------------------------------------------------
       , CTE_BillInfo.VARText
       , CTE_BillInfo.ISE
       , CTE_BillInfo.[ReminderPeriod]
       , CTE_BillInfo.[NoticePeriod]
       , CTE_PreviousSequenceNumberCSV.SequenceNumberCSV
       , CTE_CustomerInformation_Details.Company [PayableTo]
       , CTE_BillInfo.LeaseTransactionID
       , COALESCE(CTE_SumofAssetLevelRental.[TotalAssetLevelRental],0) [TotalAssetLevelRental]
       , cte_Basic_Search.DDSNotesdata
       , 0 [ReferralFee]  --only for commneced
       , COALESCE(CTE_VendorInvoiceOtherCostGrouped.Freight,0) [FreightRebill]
       , COALESCE(CTE_CustomerInformation_Details.AdminFee,0) [AdminFee] --from LT admin
       , COALESCE(CTE_VendorInvoiceOtherCostGrouped.[Softcost / Software Rebill amount],0) [SoftcostAndSoftwareRebill]
       , 0 [TotalPassThroughRentals]  --only for commenced
       , COALESCE(CTE_VendorInvoiceOtherCostGrouped.[Miscellaneous],0) [TotalOtherRebill]
       , CTE_CustomerInformation_Details.LeaseTransactionTypeName [TransactionType]
--------------------------------------------------------------------------
-- 20180810 #2
       ,ISNULL(CTE_BillInfo.PurchaseOptionSubType,'') PurchaseOptionSubType
       ,'uncommenced' leases
--------------------------------------------------------------------------
-- 20181018
        , 1 StatusID
--------------------------------------------------------------------------
-- 20181207
              ,CTE_BillInfo.DataSecurityReqdID
--------------------------------------------------------------------------
-- 20181211
              ,cte_Basic_Search.MLAID
--------------------------------------------------------------------------
--INTO #1
--------------------------------------------------------------------------
FROM
       cte_Basic_Search 
       INNER JOIN CTE_CustomerInformation_Details
              ON cte_Basic_Search.LeaseTransactionID = CTE_CustomerInformation_Details.LeaseTransactionID
      LEFT JOIN CTE_BillInfo
              ON cte_Basic_Search.LeaseTransactionID = CTE_BillInfo.LeaseTransactionID
      LEFT JOIN CTE_PreviousSequenceNumberCSV
              ON CTE_PreviousSequenceNumberCSV.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
       LEFT JOIN CTE_InventoryDetails
              ON CTE_InventoryDetails.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID
       LEFT JOIN CTE_SumofAssetLevelRental
              ON CTE_SumofAssetLevelRental.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID 
       LEFT JOIN CTE_VendorInvoiceOtherCostGrouped
              ON CTE_VendorInvoiceOtherCostGrouped.LeaseTransactionID = cte_Basic_Search.LeaseTransactionID  
----------------------------------------------------------------------------
-- 20180809 #1
LEFT JOIN cte_LeaseRole7 l
       ON CTE_CustomerInformation_Details.SequenceNumber = l.SequenceNumber 
       AND l.RoleFunctionName = 'Lease Administrator'
----------------------------------------------------------------------------
-- 20181018
WHERE (SELECT TOP 1 FEFlag FROM cte_Basic_Search) = 1
)
