  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>/****** Script for SelectTopNRows command from SSMS  ******/ -- For Liz’s report of maturing leases with transition. No parameters - will run and return all relevant unterminated leases with transition rents on the discount for loan.

SELECT 
	   D.AccountNumber	
	  ,D.CustomerName
	  ,D.SequenceNumber
	  ,D.MaturityDate
	  ,D.LeaseStatus
	  ,D.LeaseFrequency
	  --,D.PurchaseOption
	  --,D.PurchaseOptionSubType
	  ,D.IsTransitionLease
	  ,IIF(D.PractTransitionDays is null, '', D.PractTransitionDays) TransitionDays
      ,A.[DiscountLoanID]
	  ,CONVERT(Date,A.DueDate) DueDate
      --,COUNT([IsDealPaymentTieUpRequired]) #ofUntiedLoanPmts
      ,[LoanRepaymentAmount]
	  ,F.Alias FundingSource
	  ,D.SalesRep
	  ,D.ISO
         ,D.Symbol
         ,D.FundingSourceId
         ,D.FundingSourceNumber
         ,D.Company
		 ,D.Alias

     
  FROM [DiscountLoan_RepaymentSchedule] A


  INNER JOIN 
  
  (SELECT

   A.EntityID
  ,A.DiscountLoanID
  ,B.SequenceNumber
  ,C.AccountNumber
  ,C.CustomerName
  ,B.StatusId
  ,CONVERT(DATE,D.MaturityDate) MaturityDate
  ,IIF(E.PractIsTransitionLease=1,'Yes','No') IsTransitionLease
  ,E.PractTransitionDays
  ,CASE D.IrregularRentalFrequencyID 
							  WHEN 1 THEN 'Monthly'
							  WHEN 2 THEN 'Quarterly'
							  WHEN 3 THEN 'Sem-Annual'
							  WHEN 4 THEN 'Annual'
							  ELSE '' end as [LeaseFrequency]
 ,CASE F.[PurchaseOptionID] 
							  WHEN 1 THEN 'FMV'
							  WHEN 3 THEN 'DBO'
							  ELSE '' end as [PurchaseOption]

 ,CASE F.[PurchaseOptionSubTypeID] 
							  WHEN 1 THEN 'FMV CAP'
							  WHEN 2 THEN 'Transition'
							  WHEN 3 THEN 'Other Structure'
							  WHEN 4 THEN 'IPA'
							  WHEN 5 THEN '$101'
							  WHEN 6 THEN 'PUT'
							  ELSE '' end as [PurchaseOptionSubType]

  ,CASE B.[StatusID]      	  WHEN 2 THEN 'Commenced'
							  WHEN 3 THEN 'FullyPaidOff'
							  WHEN 5 THEN 'Uncommenced'		
							  WHEN 6 THEN 'Commenced'
							  ELSE '' end as [LeaseStatus]

 
  ,IIF(G.SalesRep is null, '', G.SalesRep) SalesRep
  ,ci.ISO 
         ,csc.Symbol
         ,fs.FundingSourceId
         ,fs.FundingSourceNumber
         ,fs.Company
		 ,fs.Alias


  FROM [DiscountLoan_Deal] A

  INNER JOIN [Lease_Profile] B
  ON A.EntityID=B.LeaseID
  AND B.StatusID IN (2,6) --Commenced, Assumed

  INNER JOIN [Customer_Profile] C
  ON B.CustomerID=C.CustomerID

  INNER JOIN [Lease_Contract] D
  ON A.EntityID=D.LeaseID
  AND D.IsActive=1

  INNER JOIN [MaturityManagement_Lease] E
  ON A.EntityID=E.LeaseID
  AND E.IsActive=1
  AND E.PractIsTransitionLease = 1


  inner join [Lease_Investment] F
  on A.EntityID=F.leaseid
  AND F.IsActive=1
  INNER JOIN Lease_Profile lp
       ON A.EntityID = lp.LeaseID
INNER JOIN dbo.LLC_Profile llc
       ON lp.LLCID = llc.LLCID
INNER JOIN Currency_Index ci
       ON llc.CurrencyIndexID = ci.CurrencyIndexID
INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
       ON ci.ISO = csc.ISO  
LEFT JOIN FundingSource_Profile fs
       ON lp.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)   


  LEFT JOIN 
  
  (

  Select 

  CONCAT(B.FirstName, B.LastName) SalesRep
  ,A.EntityID

  FROM [EmployeeAssignment_Entity] A

  INNER JOIN [Security_UserProfile] B
  ON A.UserID=B.UserID
  AND A.EntityTypeID=1
  AND A.IsActive=1
  AND A.RoleFunctionID=8

  ) G

  ON C.CustomerID=G.EntityID


  WHERE 
  
   A.DeactivationDate is null -- filter out deactivated DFLs.
   --AND A.DeactivatedReasonID=4
   AND A.BookingStatusID = 2 --Active. Status of 1 is pending status. 

  ) D

  ON A.DiscountLoanID=D.DiscountLoanID

  INNER JOIN [DiscountLoan_FundingSourceDetail] E
  ON A.DiscountLoanID =E.DiscountLoanID
  AND E.IsRecourseAvailable=0 -- Not a recourse DFL
 
  INNER JOIN [FundingSource_Profile] F
  ON E.FundingSourceID=F.FundingSourceId

  WHERE 
  
   --A.DiscountLoanID=5050
  --D.EntityID=3692
    IsDealPaymentTieUpRequired = 0
   And A.IsActive=1
  --A.LoanRepaymentNumber is null


  GROUP BY

       D.AccountNumber	
	  ,D.CustomerName
	  ,D.SequenceNumber
      --,A.[LoanRepaymentID]
      ,A.[DiscountLoanID]
	  ,D.MaturityDate
	  --,B.ReceivableHeaderID
     -- ,[IsDealPaymentTieUpRequired]
     -- ,A.[DueDate] LoanRepaymentNumber1
	  --,C.[DueDate] DealPaymentNumber1
      ,[LoanRepaymentAmount]
      --,A.[IsActive]
	  ,D.IsTransitionLease
	  ,IIF(D.PractTransitionDays is null, '', D.PractTransitionDays)
	  ,D.LeaseFrequency
	  ,D.PurchaseOption
	  ,D.PurchaseOptionSubType
      ,D.SalesRep
	  ,F.Alias 
	   ,D.LeaseStatus
	   ,CONVERT(Date,A.DueDate)
	   ,D.ISO
	   ,D.Symbol
	   ,D.FundingSourceId
	   ,D.FundingSourceNumber
	   ,D.Company
	   ,D.Alias

  ORDER BY 
  
   MaturityDate
  ,AccountNumber
  ,SequenceNumber</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
