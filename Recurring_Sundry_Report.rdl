  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>bf6316f9-0a34-4164-b485-db0aee1592f6</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StartDate">
            <Value>=Parameters!StartDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@EndDate">
            <Value>=Parameters!EndDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20211005 Recurring Sundry Report

;
WITH
cte_addr
AS
(
SELECT     
	lt.LocationCode,
	RTRIM(lt.LocationName1 + ' ' + lt.LocationName2) [Location],
	lt.[Address],
	lt.City,
	st.[Description] [State],
	ct.CountryShortCode Country,
	lt.County
FROM         
	Template_Country_CnfgLocale ct
	INNER JOIN dbo.Template_State_Cnfg st
		ON ct.CountryID = st.CountryID 
	INNER JOIN Inventory_LocationTemplate lt
		ON st.StateID = lt.StateID
)
SELECT 
	 ReceivableTaxInventoryHeaderID
	,A.ReceivableTaxID
	,B.ReceivableTypeID
	,IIF(B.ReceivableTypeID=1,'Rental','PassThru') ReceivableType
	,CONVERT(DATE,B.DueDate) ReceivableDueDate
	,CONVERT(DATE,B.TaxEffectiveDate) TaxEffDate
	,B.TaxAmount
	,B.TaxBalance
	,A.[InventoryID]
	,A.[Weight]
	,C.LocationCode AssetLocCode
	,D.[Description] AssetLocState
	,A.[RevenueAmount]
	,A.[TaxReceiptTypeID]
	,A.[FairMarketValue]
	,A.[Cost]
	,A.[CombinedTaxRate]
	,addr.LocationCode
	,addr.[Location]
	,addr.[Address]
	,addr.City
	,addr.[State]
	,addr.County  
	,addr.Country
	,C.ZIP
	,lp.SequenceNumber 
	,ci.ISO 
	,csc.Symbol
	,fs.Company
FROM [Receivable_TaxInventoryHeader] A

INNER JOIN [Receivable_Tax] B
  ON A.ReceivableTaxID=B.ReceivableTaxID

INNER JOIN [Inventory_LocationTemplate] C
  ON A.LocationTemplateID=C.LocationTemplateID

INNER JOIN [Template_State_Cnfg] D
  ON C.StateID=D.StateID

INNER JOIN Lease_Profile lp
	ON B.LeaseID = lp.LeaseID

INNER JOIN dbo.LLC_Profile llc
       ON lp.LLCID = llc.LLCID
INNER JOIN Currency_Index ci
       ON llc.CurrencyIndexID = ci.CurrencyIndexID
INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
       ON ci.ISO = csc.ISO  
LEFT JOIN FundingSource_Profile fs
       ON lp.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)

LEFT JOIN cte_addr addr
	ON C.LocationCode = addr.LocationCode
  --Where B.LeaseID=11115
WHERE B.ReceivableTypeID=28
AND CONVERT(DATE,B.DueDate) BETWEEN @StartDate AND @EndDate
ORDER BY 
lp.SequenceNumber,
A.[InventoryID]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
