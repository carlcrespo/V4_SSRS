    <DataSet Name="CountryList">
      <Query>
        <DataSourceName>Insight_DEV</DataSourceName>
        <CommandText>SELECT 
	Description [CountryName]
	, CAST(CountryID  as Nvarchar(5)) CountryID
FROM
	Template_Country_Cnfg	
WHERE
	Template_Country_Cnfg.IsActive = 1</CommandText>
      </Query>
      <Fields>
        <Field Name="CountryName">
          <DataField>CountryName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CountryID">
          <DataField>CountryID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="StateList">
      <Query>
        <DataSourceName>Insight_DEV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Country">
            <Value>=Parameters!Country.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
	Template_State_CnfgLocale.StateShortName
	, Template_State_CnfgLocale.StateID
FROM
	Template_State_CnfgLocale
	INNER JOIN Template_State_Cnfg
		ON Template_State_Cnfg.StateID = 			Template_State_CnfgLocale.StateID
		AND Template_State_Cnfg.IsActive = 1
WHERE 
	Template_State_Cnfg.CountryID IN ( @Country)</CommandText>
      </Query>
      <Fields>
        <Field Name="StateShortName">
          <DataField>StateShortName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="StateID">
          <DataField>StateID</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
