    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>Insight_DEV</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@FromInvoiceDueDate">
            <Value>=Parameters!FromInvoiceDueDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToInvoiceDueDate">
            <Value>=Parameters!ToInvoiceDueDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StateIds">
            <Value>=Join(Parameters!StateIds.Value, ", ")</Value>
