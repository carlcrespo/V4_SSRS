  <DataSets>
    <DataSet Name="PortfolioList">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <CommandText>SELECT        PortfolioID, PortfolioName
FROM            (SELECT        NULL AS PortfolioID, NULL AS PortfolioName
                          UNION ALL
                          SELECT        PortfolioID, PortfolioName
                          FROM            Portfolio_Profile
                          WHERE        (IsActive = 1)) AS RS1
ORDER BY PortfolioID</CommandText>
      </Query>
      <Fields>
        <Field Name="PortfolioID">
          <DataField>PortfolioID</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="PortfolioName">
          <DataField>PortfolioName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@CustomerName">
            <Value>=Parameters!CustomerName.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CustNumber">
            <Value>=Parameters!CustNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Portfolio">
            <Value>=Parameters!Portfolio.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FromMaturityDate">
            <Value>=Parameters!FromMaturityDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ToMaturityDate">
            <Value>=Parameters!ToMaturityDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--------------------------------------------------------------------------------------------------
-- CHANGE LOG:
--	#0001 - 2021-07-15 - Update Currency field
--------------------------------------------------------------------------------------------------     

-- 20200309
---------------------------------------
-- test code
--Declare 
--	  @FromMaturityDate DATETIME = '6/1/2021'
--	, @ToMaturityDate DATETIME = '6/30/2021'
--	, @Portfolio VARCHAR(MAX) = NULL	
--	, @CustomerName NVARCHAR(250) = NULL	
--	, @CustNumber VARCHAR(100) = NULL
----------------------------------------
SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SET NOCOUNT ON;

WITH
cte_FilteredLeasesA
AS
(
	SELECT Customer_Profile.CustomerName
			,Customer_Profile.AccountNumber
			,Customer_Profile.CustomerID
			,Lease_Profile.SequenceNumber
			,Lease_Profile.LeaseID
			,Lease_Profile.ExpectedMaturityDate
			,Lease_Profile.IsStopBilling
			,Lease_Profile.BookingStatusId
			,Lease_Profile.StatusId
			,Lease_Profile.LabellingLessorID
			,Lease_Profile.PortfolioID
			,Currency_Symbol_Cnfg.Symbol															-- #00001
			,Currency_Symbol_Cnfg.ISO																-- #00001
	  FROM Lease_Profile
	 INNER JOIN Customer_Profile 
		ON Lease_Profile.CustomerID = Customer_Profile.CustomerID

	  LEFT JOIN LLC_Profile																			-- #00001
	    ON Lease_Profile.LLCID = LLC_Profile.LLCID 
	  LEFT JOIN Currency_Index																		-- #00001
	    ON Currency_Index.CurrencyIndexID = LLC_Profile.CurrencyIndexID 
	  LEFT JOIN Currency_Symbol_Cnfg																-- #00001
	    ON Currency_Symbol_Cnfg.SymbolId = Currency_Index.CurrencySymbolID 

	 WHERE Lease_Profile.BookingStatusId = 2 -- Completed
	   AND Lease_Profile.StatusId = 2 -- Commenced	
		--FILTERCONDITIONS
)
,
cte_FilteredLeases
AS
(
	SELECT * 
	  FROM cte_FilteredLeasesA
	 WHERE CustomerName LIKE ISNULL(@CustomerName,'%')
	   AND AccountNumber LIKE ISNULL(@CustNumber, '%')
	   AND PortfolioID LIKE ISNULL(@Portfolio,'%')
	   AND (@FromMaturityDate IS NULL OR @ToMaturityDate IS NULL)
	UNION ALL
	SELECT * 
	  FROM cte_FilteredLeasesA
	 WHERE CustomerName like ISNULL(@CustomerName,'%')
	  AND AccountNumber like ISNULL(@CustNumber, '%')
	  AND PortfolioID like ISNULL(@Portfolio,'%')
	  AND ExpectedMaturityDate BETWEEN @FromMaturityDate AND @ToMaturityDate
)

-----------------------------------------------------------------
-- test code
--select * From cte_FilteredLeases
-----------------------------------------------------------------
,
cte_MaxDueDate -- last due date
AS
(
	SELECT	MAX(Invoice_Header.DueDate)AS MaxDueDate					
			,FilteredLease.LeaseID
			,LabellingLessorID
	  FROM Invoice_DealDetail 

	 INNER JOIN cte_FilteredLeases FilteredLease
		ON FilteredLease.LeaseID = Invoice_DealDetail.EntityID
	   AND Invoice_DealDetail.EntityTypeID = 5 -- Lease_Profile

	 INNER JOIN Invoice_ReceivableDetail
		ON Invoice_ReceivableDetail.InvoiceDealDetailID = Invoice_DealDetail.InvoiceDealDetailID
	   AND Invoice_ReceivableDetail.ReceivableTypeID in(1,3)--1 indicates "Lease Rental" and 3 indicates "OTP"

	 INNER JOIN Invoice_Header
		ON Invoice_DealDetail.InvoiceID = Invoice_Header.InvoiceID
	   AND Invoice_Header.InvoiceStatusID = 1 --Active
												
	 GROUP BY 
			FilteredLease.LeaseID	
			,LabellingLessorID
)
--------------------------------------
-- test code
--select * from cte_MaxDueDate
--------------------------------------
,
CTE_MaxInvoiceDealDetailID
AS
(
	SELECT  MAX(Invoice_DealDetail.InvoiceDealDetailID) AS InvoiceDealDetailID -- last InvoiceDealDetailID
			,Invoice_DealDetail.EntityID AS LeaseID
			,c.InvoiceGroupName
			,c.IsEmailWithAttachment
			,c.IsPrintInvoiceNotRequired
			,c.IsRentalInvoiceSplitByDeal
			,a.Company
			,a.FundingSourceID
			,a.FundingSourceNumber
			,a.Alias
	  FROM	Invoice_DealDetail
	 INNER JOIN Invoice_Header
		ON Invoice_Header.InvoiceID = Invoice_DealDetail.InvoiceID					
	 INNER JOIN cte_MaxDueDate R1
		ON invoice_Header.DueDate = R1.MaxDueDate
	   AND Invoice_DealDetail.EntityTypeID = 5 -- Lease_Profile	
	   AND Invoice_DealDetail.EntityID = R1.LeaseID
	 INNER JOIN Invoice_ReceivableDetail
		ON Invoice_ReceivableDetail.InvoiceDealDetailID = Invoice_DealDetail.InvoiceDealDetailID
	   AND Invoice_ReceivableDetail.ReceivableTypeID in(1,3)--1 indicates "Lease Rental" and 3 indicates "OTP"
	 INNER JOIN FundingSource_Profile a
		ON R1.LabellingLessorID = a.FundingSourceId 
	 INNER JOIN [dbo].[InvoiceGroup_Profile] c
		ON Invoice_Header.InvoiceGroupID = c.InvoiceGroupID 
	 GROUP BY	Invoice_DealDetail.EntityID	
				,c.InvoiceGroupName
				,c.IsEmailWithAttachment
				,c.IsPrintInvoiceNotRequired
				,c.IsRentalInvoiceSplitByDeal
				,a.Company
				,a.FundingSourceID
				,a.FundingSourceNumber
				,a.Alias
)
-----------------------------------------------
-- test code
--select * From CTE_MaxInvoiceDealDetailID
-----------------------------------------------
,
/*Calculates LastInvoiceAmount*/
CTE_LastInvoiceAmount
AS
(
	SELECT	FilteredLease.LeaseID
			,SUM(Invoice_ReceivableDetail.Amount + Invoice_ReceivableDetail.TaxAmount) AS LastInvoiceAmount
			--------------------------------
			-- rev 20150626
			,InvoiceGroupName
			--------------------------------
			,IsEmailWithAttachment
			,IsPrintInvoiceNotRequired
			,IsRentalInvoiceSplitByDeal	
			,Company
			,Alias
			,FundingSourceNumber
	  FROM	cte_FilteredLeases FilteredLease
	 INNER JOIN CTE_MaxInvoiceDealDetailID
		ON FilteredLease.LeaseID = CTE_MaxInvoiceDealDetailID.LeaseID

	 INNER JOIN Invoice_ReceivableDetail
		ON Invoice_ReceivableDetail.InvoiceDealDetailID = CTE_MaxInvoiceDealDetailID.InvoiceDealDetailID
	   AND Invoice_ReceivableDetail.ReceivableTypeID in(1,3)--1 indicates "Lease Rental" and 3 indicates "OTP"
					
	 GROUP BY FilteredLease.LeaseID
			 ,CTE_MaxInvoiceDealDetailID.InvoiceDealDetailID
			--------------------------------
			-- rev 20150626
			,InvoiceGroupName
			--------------------------------
			,IsEmailWithAttachment
			,IsPrintInvoiceNotRequired
			,IsRentalInvoiceSplitByDeal
			,Company	
			,Alias
			,FundingSourceNumber
)
---------------------------------------------
-- test code
--select * from CTE_LastInvoiceAmount
---------------------------------------------
,
CTE_OTPRent
AS
(
	SELECT	FilteredLease.LeaseID
			,SUM(Lease_InventoryInLease.OverTermPaymentRentalAmount) AS OTPRent
	  FROM cte_FilteredLeases FilteredLease
	 INNER JOIN Lease_InventoryInLease
		ON Lease_InventoryInLease.LeaseID = FilteredLease.LeaseID		
	   AND Lease_InventoryInLease.IsInLease = 1	
	 GROUP BY
			FilteredLease.LeaseID
)
-----------------------------------------
-- test code
--select * from CTE_OTPRent
------------------------------------------
,
CTE_AR_Rep
AS
(
	SELECT	ee.EntityID AS CustomerID 
			,up.FirstName 
			,up.LastName 
	  FROM [dbo].[EmployeeAssignment_Entity] ee
	  JOIN [dbo].[Security_UserProfile] up
		ON ee.UserID = up.UserID 
	 WHERE ee.EntityTypeID = 1
	   AND ee.RoleFunctionID = 40
	   AND ee.IsActive = 1
)
------------------------------
-- test code
--select * from CTE_AR_Rep
------------------------------
,
CTE_FinalResult
AS
(
	SELECT  FilteredLease.CustomerName
			,FilteredLease.AccountNumber
			,FilteredLease.SequenceNumber AS LeaseNumber	
			,FilteredLease.Symbol																	-- #00001
			,FilteredLease.ISO			
			,CTE_LastInvoiceAmount.Alias
			,CTE_LastInvoiceAmount.FundingSourceNumber															-- #00001
			,CTE_LastInvoiceAmount.LastInvoiceAmount
			,CTE_OTPRent.OTPRent
			,CASE 
				WHEN Lease_Contract.ContractStructureId = 1 THEN ----1 indicates Regular Lease
					RegularLeaseFrequency.Frequency
				ELSE
					IrregularLeaseFrequency.Frequency
			 END RentalFrequency
			,FilteredLease.ExpectedMaturityDate AS MaturityDate
			,Lease_ContractPurchaseOption_CnfgLocale.PurchaseOption AS PurchaseOptionType
			,CASE 
				WHEN FilteredLease.IsStopBilling = 0 THEN
					'N'
				ELSE
					'Y'
			  END AS StopBilling
			,CASE 
				WHEN MaturityManagement_Lease.PractIsFMVCap = 1 THEN
					'Y'
				ELSE
					'N'
			  END AS FMVCap
			,CASE 
				WHEN MaturityManagement_Lease.PractOTPAdvancePayment = 0 THEN
					'N'
				ELSE
					'Y'
			 END AS OTPAdvancedBilling
			,Lease_RentalFrequency_CnfgLocale.RentalFrequencyName AS OTPRentalFrequency
			,CASE 
				WHEN MaturityManagement_Lease.PractIsTransitionLease = 0 THEN  
					'N'
				ELSE
					'Y'
			  END AS TransitionLease
			,CASE 
				WHEN MaturityManagement_Lease.PractIsTransitionLease = 1 THEN  
					CONVERT(NVARCHAR(3),MaturityManagement_Lease.PractTransitionDays)
				ELSE
					''
			 END AS TransitionPeriod
			,CASE 
				WHEN MaturityManagement_Lease.PractIsDoubleInArrears = 0 THEN
					'N'
				ELSE
					'Y'
			 END AS OTPDoubleInArrears
			,CONVERT(NVARCHAR(3),ISNULL(MaturityManagement_Lease.PractEOTPartialGracePeriod,0)) + ',' + CONVERT(NVARCHAR(3),ISNULL(MaturityManagement_Lease.PractEOTABNLTAGracePeriod,0)) + ',' + CONVERT(NVARCHAR(3),ISNULL(MaturityManagement_Lease.PractOTPGracePeriod,0)) AS GracePeriod
			,CASE 
				WHEN MaturityManagement_Lease.PractIsSuspendOTPBilling = 0 THEN
					'N'
				ELSE
					'Y'
			 END AS OTPSuspend
			,PractDataSecurityReqdID.BoolDisplayText AS DataSecurityRequired
			,Inventory_FreightResponsibility_CnfgLocale.FreightResponsibility AS FreightResponsibility
			,PractPurchase.EOTOption AS OTPPurchaseOptions
			,PractRenew.EOTOption AS OTPRenewalOption
			,PractReturn.EOTOption AS OTPReturnOption
			,Inventory_LKEType_CnfgLocale.LKEType AS LKEAllowed	
			,CASE 
				WHEN MaturityManagement_Lease.PractIsEOTRestriction = 1 AND MaturityManagement_Lease.PractIsSpecialEOTProvision = 1 THEN	
					1
				ELSE
					0
			 END AS IsEOTProvisionAndRestrictionExists
			,MaturityManagement_Lease.PractRestrictions
			,MaturityManagement_Lease.PractConditions
			,CASE 
				WHEN ((MaturityManagement_Lease.PractFirstReductionPercent IS NOT NULL AND MaturityManagement_Lease.PractFirstReductionPercent &gt; 0.00) OR 
						(MaturityManagement_Lease.PractSecondReductionPercent IS NOT NULL AND MaturityManagement_Lease.PractSecondReductionPercent &gt; 0.00) OR 
						(MaturityManagement_Lease.PractThirdReductionPercent IS NOT NULL AND MaturityManagement_Lease.PractThirdReductionPercent &gt; 0.00)) THEN
					'Y'
				ELSE
					'N'
			 END AS RentalReduction
			,CASE WHEN MaturityManagement_Lease.PractIsTitleTransfer = 1 THEN
				'Y'
				ELSE
				'N'
				END AS TitleTransfer
			,CASE 
				WHEN MaturityManagement_Lease.PractIsTitleTransfer = 1 THEN
					CONVERT(NVARCHAR(3),MaturityManagement_Lease.PractTitleTransferPeriod)
				ELSE
					''
			 END AS TitleTransferPeriod
			,Inventory_SoftcostOTPTreatment_CnfgLocale.SoftcostOTPTreatment AS OTPSoftcostTreatment	
			------------------------------------------
			-- rev 20150626
			,CTE_LastInvoiceAmount.InvoiceGroupName
			------------------------------------------
			-- rev 20170501
			,CASE 
				WHEN CTE_LastInvoiceAmount.IsEmailWithAttachment = 1 THEN
					'Y'
				ELSE
					'N'
			 END AS EmailPDF
			,CASE 
				WHEN CTE_LastInvoiceAmount.IsPrintInvoiceNotRequired = 1 THEN
					'Y'
				ELSE
					'N'
			 END AS NOPRINT

			,CASE 
				WHEN CTE_LastInvoiceAmount.IsRentalInvoiceSplitByDeal = 1 THEN
					'Y'
				ELSE
					'N'
			 END AS Combine_Bill
			,CTE_LastInvoiceAmount.Company
			,CTE_AR_Rep.FirstName
			,CTE_AR_Rep.LastName
	  FROM cte_FilteredLeases FilteredLease						

	 INNER JOIN CTE_OTPRent
		ON FilteredLease.LeaseID = CTE_OTPRent.LeaseID  

	 INNER JOIN Lease_Contract
		ON FilteredLease.LeaseID = Lease_Contract.LeaseID
	   AND Lease_Contract.IsActive = 1

 	 INNER JOIN Deal_RentalFrequency_CnfgLocale RegularLeaseFrequency
		ON RegularLeaseFrequency.FrequencyID = Lease_Contract.RentalFrequencyID

 	 INNER JOIN Deal_RentalFrequency_CnfgLocale IrregularLeaseFrequency
		ON IrregularLeaseFrequency.FrequencyID = Lease_Contract.IrregularRentalFrequencyID

	 INNER JOIN MaturityManagement_Lease
		ON MaturityManagement_Lease.LeaseID = FilteredLease.LeaseID
	   AND MaturityManagement_Lease.IsActive = 1						

	 INNER JOIN Lease_Investment
		ON Lease_Investment.LeaseID = FilteredLease.LeaseID
	   AND Lease_Investment.IsActive = 1

	 INNER JOIN Lease_ContractPurchaseOption_CnfgLocale
		ON Lease_ContractPurchaseOption_CnfgLocale.PurchaseOptionID = Lease_Investment.PurchaseOptionID

	 INNER JOIN Template_YesNoNA_CnfgLocale PractDataSecurityReqdID
		ON PractDataSecurityReqdID.BoolValueID = MaturityManagement_Lease.PractDataSecurityReqdID 

	 INNER JOIN Inventory_FreightResponsibility_CnfgLocale
		ON Inventory_FreightResponsibility_CnfgLocale.FreightResponsibilityID = MaturityManagement_Lease.PractFreightResponsibilityID 

	 INNER JOIN Lease_EOTOption_CnfgLocale PractPurchase
		ON PractPurchase.EOTOptionID = MaturityManagement_Lease.PractPurchaseID

	 INNER JOIN Lease_EOTOption_CnfgLocale PractRenew
		ON PractRenew.EOTOptionID = MaturityManagement_Lease.PractRenewID

	 INNER JOIN Lease_EOTOption_CnfgLocale PractReturn
		ON PractReturn.EOTOptionID = MaturityManagement_Lease.PractReturnID

	 INNER JOIN Inventory_LKEType_CnfgLocale
		ON Inventory_LKEType_CnfgLocale.LKEAllowedID = MaturityManagement_Lease.LKEAllowedID

	 INNER JOIN Inventory_SoftcostOTPTreatment_CnfgLocale
		ON Inventory_SoftcostOTPTreatment_CnfgLocale.SoftcostOTPTreatmentID = MaturityManagement_Lease.PractSoftcostOTPTreatmentID
							
	  LEFT JOIN CTE_LastInvoiceAmount
		ON FilteredLease.LeaseID = CTE_LastInvoiceAmount.LeaseID
							
	  LEFT JOIN Lease_RentalFrequency_CnfgLocale 
		ON Lease_RentalFrequency_CnfgLocale.RentalFrequencyID = MaturityManagement_Lease.PractOTPFrequencyID
							
	  LEFT JOIN CTE_AR_Rep
		ON FilteredLease.CustomerID = CTE_AR_Rep.CustomerID														
)


---------------------------------
-- test code
--select * from CTE_FinalResult
---------------------------------
SELECT	CTE_FinalResult.CustomerName
		,CTE_FinalResult.AccountNumber
		,CTE_FinalResult.LeaseNumber	
		,CTE_FinalResult.Symbol														-- #00001
		,CTE_FinalResult.ISO														-- #00001
		,CTE_FinalResult.LastInvoiceAmount
		,CTE_FinalResult.OTPRent
		,CTE_FinalResult.RentalFrequency
		,CTE_FinalResult.MaturityDate
		,CTE_FinalResult.PurchaseOptionType
		,CTE_FinalResult.StopBilling
		,CTE_FinalResult.FMVCap
		,CTE_FinalResult.OTPAdvancedBilling
		,CTE_FinalResult.OTPRentalFrequency
		,CTE_FinalResult.TransitionLease
		,CTE_FinalResult.TransitionPeriod
		,CTE_FinalResult.OTPDoubleInArrears
		,CTE_FinalResult.GracePeriod
		,CTE_FinalResult.OTPSuspend
		,CTE_FinalResult.DataSecurityRequired
		,CTE_FinalResult.FreightResponsibility
		,CTE_FinalResult.OTPPurchaseOptions
		,CTE_FinalResult.OTPRenewalOption
		,CTE_FinalResult.OTPReturnOption
		,CTE_FinalResult.LKEAllowed	
		,CTE_FinalResult.IsEOTProvisionAndRestrictionExists
		,CTE_FinalResult.PractRestrictions
		,CTE_FinalResult.PractConditions
		,CTE_FinalResult.RentalReduction
		,CTE_FinalResult.TitleTransfer
		,CTE_FinalResult.TitleTransferPeriod
		,CTE_FinalResult.OTPSoftcostTreatment
		,CTE_FinalResult.InvoiceGroupName
		,CTE_FinalResult.EmailPDF
		,CTE_FinalResult.NOPRINT
		,CTE_FinalResult.Combine_Bill
		,CTE_FinalResult.Company
		,CTE_FinalResult.FirstName
		,CTE_FinalResult.LastName	
		,CTE_FinalResult.Alias
		,CTE_FinalResult.FundingSourceNumber														
  FROM CTE_FinalResult
--Where LeaseNumber='9125-1'
 ORDER BY CTE_FinalResult.CustomerName ASC, ISO ASC

 SET NOCOUNT OFF;</CommandText>
      </Query>
