  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>-- 2019108
--For Brenda’s Debt Tracker. This queries active discount for loans and then maps it back to the MSLT for the LSLT and retrives the lender preshop information, if any. Brenda may need to do a backfill for missing preshops not in LW.
SELECT 
	   S.Company LabellingLessor
	  ,D.AccountNumber
	  ,C.SequenceNumber
	  ,ISNull(T.TransactionAlias,'') IRQS
	  ,D.CustomerName
	  ,R.MLAType
	  ,L.Description Vertical
	  ,M.InternalRating
	  ,IIF (O.Description='FM','FMV','DBO') PurchaseOptionType
	  ,IIF (Q.PractIsTransitionLease =1,'Yes','No') IsTransitionLease
	  ,CONVERT (Date,[CircleDate]) CircleDate
	  ,CONVERT (Date,B.LoanDate) LoanDate
	  ,CONVERT(Date,F.DueDate) FirstRepaymentDueDate
	  ,IsNull (B.LoanNumber, ' ') LoanNumber
	  ,G.Company FundingSource
	  ,P.Term
	  ,H.NoOfFundedPmts
	  ,E.Description RepaymentFrequency
      ,CONVERT(VARCHAR,CAST([FundingCashReceivedAmount] AS MONEY),1) FundingCashReceivedAmount
      ,CONVERT(VARCHAR,CAST([WarehouseLinePayoffAmount] AS MONEY),1) WarehouseLinePayoff
      ,CONVERT(VARCHAR,CAST([VendorPaymentAmount1] AS MONEY),1) VendorPaymentAmount1
      ,CONVERT(VARCHAR,CAST([VendorPaymentAmount2] AS MONEY),1) VendorPaymentAmount2
	  ,IsNull(J.LenderPreShopID,'') LenderPreshopID
	  ,IsNull(J.OptionNumber,'') OptionNumber
	  ,IsNull (CONVERT(DECIMAL(10,2),J.LenderSwap),'0') LenderSwap
	  ,IsNull (CONVERT(DECIMAL(10,2),J.LenderSpread),'0') LenderSpread
	  ,IsNull (CONVERT(DECIMAL(10,2),J.LenderDebtRate),'0') LenderDebtRate
	  ,ci.ISO 
      ,csc.Symbol
      ,fs.FundingSourceId
      ,fs.FundingSourceNumber
      ,fs.Company
	  ,fs.Alias

  FROM [dbo].[DiscountLoan_Deal] A

  INNER JOIN [dbo].[DiscountLoan_FundingSourceDetail] B
  ON A.DiscountLoanID=B.DiscountLoanID
  AND IsRecourseAvailable=0

  INNER JOIN [dbo].[Lease_Profile] C
  ON A.EntityID=C.LeaseID
INNER JOIN dbo.LLC_Profile llc
       ON C.LLCID = llc.LLCID
INNER JOIN Currency_Index ci
       ON llc.CurrencyIndexID = ci.CurrencyIndexID
INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
       ON ci.ISO = csc.ISO  
LEFT JOIN FundingSource_Profile fs
       ON C.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label

  INNER JOIN [dbo].[Customer_Profile] D
  ON C.CustomerID=D.CustomerID

  INNER JOIN [dbo].[Lease_RentalFrequency_Cnfg] E
  ON A.RepaymentFrequencyID=E.RentalFrequencyID

  LEFT JOIN 

  (

  SELECT 
	   [LoanRepaymentID]
      ,[DiscountLoanID]
      ,[LoanRepaymentNumber]
      ,[IsDealPaymentTieUpRequired]
      ,[DueDate]
      ,[StartDate]
      ,[EndDate]
      ,[LoanRepaymentAmount]
      ,[IsActive]
	  ,ROW_NUMBER() OVER (PARTITION BY DiscountLoanID ORDER BY LoanRepaymentNumber ASC) AS RowCounter -- To pull first repayment due date
  FROM [dbo].[DiscountLoan_RepaymentSchedule]

  WHERE IsActive=1
  

  ) F

  ON A.DiscountLoanID=F.DiscountLoanID

  INNER JOIN 

   [dbo].[FundingSource_Profile] G
   ON B.FundingSourceID=G.FundingSourceId

  INNER JOIN 
   (
   SELECT 
	   COUNT([LoanRepaymentID]) NoOfFundedPmts
      ,[DiscountLoanID]
    
	  
  FROM [dbo].[DiscountLoan_RepaymentSchedule]

  WHERE IsActive=1

  Group By 

  DiscountLoanID

  ) H 

  ON A.DiscountLoanID=H.DiscountLoanID

  LEFT JOIN [dbo].[LeaseTransaction_Profile] I
  ON A.EntityID=I.LeaseID
  AND I.AgreementTypeID=2

  LEFT JOIN [dbo].[LeaseTransaction_LenderPreShop] J
  ON I.RelatedMasterTransactionID=J.LeaseTransactionID

  INNER JOIN 
  
  (

  SELECT
       [CustomerCreditLineID]
      ,[CustomerID]
      ,[VerticalID]
      ,ROW_NUMBER() OVER (PARTITION BY CustomerID ORDER BY CustomerCreditLineID DESC) AS RowCounter 

	   FROM [dbo].[Customer_CreditLine]

  ) K

  ON K.CustomerID = C.CustomerID

  INNER JOIN [dbo].[CustomerCredit_Vertical_Cnfg] L
  ON K.VerticalID=L.VerticalID
  

  INNER JOIN 
  
  (
	
	SELECT 
	   [CreditRatingID]
      ,[CustomerID]
      ,[InternalRating]
	  ,IsActive
	  ,ROW_NUMBER() OVER (PARTITION BY CustomerID ORDER BY CreditRatingID DESC) AS RowCounter
    FROM [dbo].[Customer_CreditRating]

  ) M

  ON C.CustomerID=M.CustomerID
  AND M.IsActive=1

  INNER JOIN 

  (
  SELECT 
	   [LeaseInvestmentId]
      ,[LeaseId]
      ,[IsActive]
      ,[PurchaseOptionID]
	  ,ROW_NUMBER() OVER (PARTITION BY LeaseID ORDER BY LeaseInvestmentID DESC) AS RowCounter
  FROM [dbo].[Lease_Investment]

  ) N

  ON EntityID=N.LeaseId

  INNER JOIN  [dbo].[Lease_ContractPurchaseOption_Cnfg] O
  ON N.PurchaseOptionID=O.PurchaseOptionID
  AND O.IsActive=1

  INNER JOIN 

  (
  SELECT
	   [LeaseContractId]
      ,[LeaseID]
      ,[IsActive]
      ,[Term]
	  ,ROW_NUMBER() OVER (PARTITION BY LeaseID ORDER BY LeaseContractID DESC) AS RowCounter
  FROM [dbo].[Lease_Contract]
  ) P
  ON C.LeaseID=P.LeaseID
  INNER JOIN [dbo].[MaturityManagement_Lease] Q
  ON A.EntityID=Q.LeaseID
  AND Q.IsActive=1
 



  INNER JOIN 

  (

  SELECT 

	  
      [CustomerID]
      ,A.[MLATypeID]
      ,A.[IsActive]
	  ,B.Description MLAType

      ,ROW_NUMBER() OVER (PARTITION BY CustomerID ORDER BY MLAID DESC) AS RowCounter


  FROM [dbo].[MLA_Profile] A

  INNER JOIN [dbo].[Template_MLAType_Cnfg] B
  ON A.MLATypeID=B.MLATypeID

  ) R

  ON C.CustomerID=R.CustomerID

  INNER JOIN [dbo].[FundingSource_Profile] S
  ON C.LabellingLessorID=S.FundingSourceId

 
 LEFT JOIN 

  (
  SELECT 
	     [LeaseTransactionID]
        ,[TransactionAlias]
		
   
  FROM [dbo].[LeaseTransaction_Profile]

  WHERE AgreementTypeID=1 -- MSLT
  ) T

  ON I.RelatedMasterTransactionID=T.LeaseTransactionID

  WHERE 

  A.IsActive=1 -- Yes
  AND A.BookingStatusID=2 -- Completed
  AND EntityTypeID=5 -- Lease
  AND IsAutoPaymentAllowed=0  -- No
  AND F.RowCounter=1
  AND K.RowCounter=1
  AND M.RowCounter=1
  AND N.RowCounter=1
  AND P.RowCounter=1
  AND R.RowCounter=1
 


  ORDER BY 
    LoanDate
   ,SequenceNumber
   ,J.OptionNumber</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
