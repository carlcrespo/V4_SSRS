  <DataSets>
    <DataSet Name="LeaseNumber">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MaturityDate">
            <Value>=Parameters!MaturityDate.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- LeaseNumber
SELECT distinct [Lease Numbe] LeaseNumber
  FROM [dbo].[v_IIC_Hershey_Term_Notice_20160603]
  Where @MaturityDate = ''
Union 
SELECT distinct [Lease Numbe] LeaseNumber
  FROM [dbo].[v_IIC_Hershey_Term_Notice_20160603]
  Where @MaturityDate&lt;&gt;'' and MaturityDate Between DateAdd(dd,-1,@MaturityDate) and @MaturityDate</CommandText>
      </Query>
      <Fields>
        <Field Name="LeaseNumber">
          <DataField>LeaseNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TermNotice">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MaturityDate">
            <Value>=Parameters!MaturityDate.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@LeaseNumber">
            <Value>=Parameters!LeaseNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- TermNotice
SELECT distinct [LeaseID]
      ,[CustomerID]
      ,[AssetNum]
      ,[Lease Numbe]
      ,[Cost Center]
      ,[Contact Na]
      ,[Vendor Nam]
      ,[EquipDescrip]
      ,[Serial Number]
      ,[Pomeroy PO Num]
      ,[EquipOrigCost]
      ,[Rent]
	  ,MaturityDate
  FROM [dbo].[v_IIC_Hershey_Term_Notice_20160603]
  Where @MaturityDate = ''
Union
SELECT distinct [LeaseID]
      ,[CustomerID]
      ,[AssetNum]
      ,[Lease Numbe]
      ,[Cost Center]
      ,[Contact Na]
      ,[Vendor Nam]
      ,[EquipDescrip]
      ,[Serial Number]
      ,[Pomeroy PO Num]
      ,[EquipOrigCost]
      ,[Rent]
	  ,MaturityDate
  FROM [dbo].[v_IIC_Hershey_Term_Notice_20160603]
  Where MaturityDate&lt;&gt;'' and MaturityDate Between DateAdd(dd,-1,@MaturityDate) and @MaturityDate
  AND [Lease Numbe] IN (@LeaseNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="LeaseID">
          <DataField>LeaseID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="CustomerID">
          <DataField>CustomerID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
