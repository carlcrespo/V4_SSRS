  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@RebookPostDateFrom">
            <Value>=Parameters!RebookPostDateFrom.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@RebookPostDateTo">
            <Value>=Parameters!RebookPostDateTo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>/****** Script for SelectTopNRows command from SSMS  ******/
--DECLARE @RebookPostDateFrom DATE = '2018-07-01', @RebookPostDateTo DATE = '2018-07-31'
-- 20191021

SELECT 
      -- A.[LeaseID]
	   E.AccountNumber
	  ,E.CustomerName
	  ,B.SequenceNumber
	  ,CONVERT(DATE,D.OriginalBookingPostDate) OriginalBookingPostDate
      ,CONVERT(DATE,A.[PostDate]) RebookPostDate
      ,CONCAT (C.FirstName,C.LastName) ModifiedBy
      ,CONVERT(DATE,A.[LastModifiedDate]) SystemDate
	  ,fs.Company -- Labelling Lessor
,fs.FundingSourceId
,fs.Alias
     
  FROM [dbo].[Lease_Contract] A

  INNER JOIN [dbo].[Lease_Profile] B
  ON A.LeaseID=B.LeaseID

  INNER JOIN dbo.LLC_Profile llc
  ON B.LLCID = llc.LLCID

  LEFT JOIN FundingSource_Profile fs
  ON B.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)

  INNER JOIN [dbo].[Security_UserProfile] C
  ON A.LastModifiedUserID=C.UserID

  INNER JOIN 

  (

  SELECT
	   [LeaseContractId]
      ,[LeaseID]
      ,[IsActive]
      ,[ReasonId]
      ,[PostDate] OriginalBookingPostDate
      ,ROW_NUMBER() OVER (PARTITION BY LeaseID ORDER BY LeaseContractID ASC) AS RowCounter

  FROM [dbo].[Lease_Contract]

  ) D
  
  ON D.LeaseID=A.LeaseID

  INNER JOIN [dbo].[Customer_Profile] E
  ON B.CustomerID=E.CustomerID

  WHERE 
  A.ReasonID=4 --rebook
  and A.IsActive=1
  and A.PostDate between @RebookPostDateFrom and @RebookPostDateTo
  and D.RowCounter=1 -- to pull original booking post date
  

  ORDER BY 
  E.AccountNumber
  ,A.PostDate</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OriginalBookingPostDate">
          <DataField>OriginalBookingPostDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="RebookPostDate">
