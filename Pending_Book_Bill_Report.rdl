        </Field>
        <Field Name="LeaseRentalAmount">
          <DataField>LeaseRentalAmount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ISO">
          <DataField>ISO</DataField>
