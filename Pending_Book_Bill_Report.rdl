  <DataSets>
    <DataSet Name="StepName">
      <Query>
        <DataSourceName>LW_PROD</DataSourceName>
        <CommandText>;
WITH
CTE_LeaseAdminAsigned
AS
		(
			SELECT Emp_LA.UserID LeaseAdminUserID, Emp_LA.EntityID 
			FROM EmployeeAssignment_Entity Emp_LA
				JOIN (  (  SELECT EntityID,MAX(EmployeeAssignmentID) AccountMgrAssignmentID 
							FROM EmployeeAssignment_Entity 
							WHERE EntityTypeID = 7  /*@EntityTypeID --LeaseTransaction*/
								AND IsActive = 1 /*@IsActive*/
								AND RoleFunctionID = 38  --Lease Admin Role 
							GROUP BY EntityID  ) LeaseAdminDetails
							INNER JOIN EmployeeAssignment_Entity Employee_LeaseAdmin 
								ON Employee_LeaseAdmin.EmployeeAssignmentID = LeaseAdminDetails.AccountMgrAssignmentID
							INNER JOIN Security_UserProfile Security_LeaseAdmin ON Security_LeaseAdmin.UserID = Employee_LeaseAdmin.UserID
					)
				ON LeaseAdminDetails.AccountMgrAssignmentID = Emp_LA.EmployeeAssignmentID
		) 
,
CTE_SalesRepAssigned
AS 
		(
			SELECT EmployeeAssignment_Entity.UserID SalesUserID, EmployeeAssignment_Entity.EntityID 
			FROM EmployeeAssignment_Entity 
				INNER JOIN 
				(  
					(  
					SELECT EntityID,MAX(EmployeeAssignmentID) AccountMgrAssignmentID 
								FROM EmployeeAssignment_Entity 
								WHERE EntityTypeID = 7  /*@EntityTypeID --LeaseTransaction*/ 
									AND IsActive = 1 /*@IsActive*/ 
									AND RoleFunctionID = 8 --Sales Rep Role
								GROUP BY EntityID  
					) SalesRepDetails
				INNER JOIN EmployeeAssignment_Entity Employee_salesRep 
					ON Employee_salesRep.EmployeeAssignmentID = SalesRepDetails.AccountMgrAssignmentID
				INNER JOIN Security_UserProfile Security_Sales 
					ON Security_Sales.UserID = Employee_salesRep.UserID
				)
				ON SalesRepDetails.AccountMgrAssignmentID = EmployeeAssignment_Entity.EmployeeAssignmentID
		) 
,
CTE_BillingUser
AS 
		(
			SELECT Emp_LA.UserID BillingUserID, Emp_LA.EntityID 
			FROM EmployeeAssignment_Entity Emp_LA
				JOIN (  
					(  SELECT EntityID,MAX(EmployeeAssignmentID) AccountMgrAssignmentID 
							FROM EmployeeAssignment_Entity 
							WHERE EntityTypeID = 7  /*@EntityTypeID --LeaseTransaction*/ 
								AND IsActive = 1 /*@IsActive*/ 
								AND RoleFunctionID = 40  --Billing Role
							GROUP BY EntityID  
					) LeaseAdminDetails
						INNER JOIN EmployeeAssignment_Entity Employee_LeaseAdmin 
							ON Employee_LeaseAdmin.EmployeeAssignmentID = LeaseAdminDetails.AccountMgrAssignmentID
						INNER JOIN Security_UserProfile Security_LeaseAdmin 
							ON Security_LeaseAdmin.UserID = Employee_LeaseAdmin.UserID
					)
				ON LeaseAdminDetails.AccountMgrAssignmentID = Emp_LA.EmployeeAssignmentID
		)  
,
cte_StickerCost
AS 
(
SELECT 
	LeaseTransactionID,
    SUM(StickerCost) StickerCost
FROM LeaseTransaction_Inventory
GROUP BY LeaseTransactionID
)
,
cte_a
AS
(
SELECT DISTINCT WorkFlow_PathHeader.EntityName [StepName]
FROM LeaseTransaction_Profile
		INNER JOIN Customer_Profile 
			ON LeaseTransaction_Profile.CustomerID = Customer_Profile.CustomerID
		INNER JOIN Jark_Profile 
			ON LeaseTransaction_Profile.JarkID = Jark_Profile.JarkID  AND LeaseTransaction_Profile.PortfolioID = 5
		INNER JOIN LeaseTransaction_Version 
			ON LeaseTransaction_Profile.LeaseTransactionID = LeaseTransaction_Version.VersionID  AND LeaseTransaction_Version.IsActive=1
		INNER JOIN WorkFlow_PathStepDetail 
				ON WorkFlow_PathStepDetail.StepID = Jark_Profile.CurrentStepID
		INNER JOIN WorkFlow_PathHeader 
			ON WorkFlow_PathHeader.PathHeaderID = WorkFlow_PathStepDetail.PathHeaderID 
		INNER JOIN WorkFlow_StatusTemplate 
					ON WorkFlow_PathStepDetail.StepStatusID = WorkFlow_StatusTemplate.WorkFlowStatusID
		INNER JOIN Security_UserProfile 
			ON Security_UserProfile.UserID = Jark_Profile.UserOwnerID
		LEFT JOIN Security_RoleProfile 
			ON Jark_Profile.RoleOwnerID = Security_RoleProfile.SecurityRoleID
		LEFT JOIN CTE_LeaseAdminAsigned
					ON LeaseTransaction_Profile.LeaseTransactionID = CTE_LeaseAdminAsigned.EntityID
		LEFT JOIN Security_UserProfile [LeaseAdminDetails] 
			ON LeaseAdminDetails.UserID = CTE_LeaseAdminAsigned.LeaseAdminUserID
		LEFT JOIN CTE_SalesRepAssigned
			ON LeaseTransaction_Profile.LeaseTransactionID = CTE_SalesRepAssigned.EntityID
		LEFT JOIN Security_UserProfile [SalesRepDetails] 
			ON CTE_SalesRepAssigned.SalesUserID = SalesRepDetails.UserID
		LEFT JOIN CTE_BillingUser
			ON LeaseTransaction_Profile.LeaseTransactionID = CTE_BillingUser.EntityID
		LEFT JOIN Security_UserProfile [BillingDetails] 
			ON CTE_BillingUser.BillingUserID = BillingDetails.UserID
		LEFT JOIN LeaseTransaction_AdminstrativeInformation
			ON LeaseTransaction_AdminstrativeInformation.LeaseTransactionID = LeaseTransaction_Profile.LeaseTransactionID
		LEFT JOIN LeaseTransaction_PaymentCalculation
			ON LeaseTransaction_PaymentCalculation.LeaseTransactionID = LeaseTransaction_Profile.LeaseTransactionID
		LEFT JOIN Lease_ContractPurchaseOption_CnfgLocale
			ON LeaseTransaction_PaymentCalculation.PurchaseOptionStatusTypeID = Lease_ContractPurchaseOption_CnfgLocale.PurchaseOptionID
		LEFT JOIN Lease_Profile
			ON Lease_Profile.LeaseID = LeaseTransaction_Profile.LeaseID
		LEFT JOIN 
		(
			SELECT LeaseTransactionID
					, SUM(StickerCOst + MarkupAmount) CustomerCost
					, SUM(LeaseTransaction_Inventory.LeaseRentalAmount) LeaseRentalAmount 
			FROM LeaseTransaction_Inventory
			WHERE LeaseTransaction_Inventory.IsActive = 1 /*@IsActive*/
			GROUP BY
				LeaseTransactionID
		) CTE_LeaseRental 
			ON CTE_LeaseRental.LeaseTransactionID = LeaseTransaction_Profile.LeaseTransactionID

WHERE LeaseTransaction_Profile.AgreementTypeID  =  2 -- LSLT transactions
)
-----------------------------------------------------
SELECT [StepName]
FROM cte_a
ORDER BY cte_a.StepName</CommandText>
      </Query>
      <Fields>
        <Field Name="StepName">
          <DataField>StepName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="report">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@STEPNAME">
            <Value>=Parameters!STEPNAME.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--------------------------------------------------------------------------------------------------
-- CHANGE LOG:
--	#0001 - 2021-07-15 - Update Currency field
--------------------------------------------------------------------------------------------------     

----------------------------------------------------------
-- TESTING
-- DECLARE @STEPNAME VARCHAR(100) = 's03-Deal Review' -- 'S01-Deal Submission- Existing Customer' -- 'S04-Equipment Acquisition' --'S08-Approved IRQS'
----------------------------------------------------------


SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;  
SET NOCOUNT ON

-- 20200810
;
WITH
CTE_LeaseAdminAsigned
AS
(
	SELECT	Emp_LA.UserID LeaseAdminUserID
			, Emp_LA.EntityID 
	  FROM EmployeeAssignment_Entity Emp_LA
	  JOIN (  
				SELECT	EntityID
						, MAX(EmployeeAssignmentID) AccountMgrAssignmentID 
				  FROM EmployeeAssignment_Entity 
				 WHERE EntityTypeID = 7  /*@EntityTypeID --LeaseTransaction*/
				   AND IsActive = 1 /*@IsActive*/
				   AND RoleFunctionID = 38  --Lease Admin Role 
				 GROUP BY EntityID
			) LeaseAdminDetails
		 ON LeaseAdminDetails.AccountMgrAssignmentID = Emp_LA.EmployeeAssignmentID
	  INNER JOIN EmployeeAssignment_Entity Employee_LeaseAdmin 
		 ON Employee_LeaseAdmin.EmployeeAssignmentID = LeaseAdminDetails.AccountMgrAssignmentID
	  INNER JOIN Security_UserProfile Security_LeaseAdmin 
		 ON Security_LeaseAdmin.UserID = Employee_LeaseAdmin.UserID
) 
,
CTE_SalesRepAssigned
AS 
(
	SELECT	EmployeeAssignment_Entity.UserID SalesUserID
			, EmployeeAssignment_Entity.EntityID 
		FROM EmployeeAssignment_Entity 
		INNER JOIN 
		(  
			SELECT	EntityID
					,MAX(EmployeeAssignmentID) AccountMgrAssignmentID 
			  FROM EmployeeAssignment_Entity 
			 WHERE EntityTypeID = 7  /*@EntityTypeID --LeaseTransaction*/ 
			   AND IsActive = 1 /*@IsActive*/ 
			   AND RoleFunctionID = 8 --Sales Rep Role
			 GROUP BY EntityID  
			) SalesRepDetails
			ON SalesRepDetails.AccountMgrAssignmentID = EmployeeAssignment_Entity.EmployeeAssignmentID
		INNER JOIN EmployeeAssignment_Entity Employee_salesRep 
			ON Employee_salesRep.EmployeeAssignmentID = SalesRepDetails.AccountMgrAssignmentID
		INNER JOIN Security_UserProfile Security_Sales 
			ON Security_Sales.UserID = Employee_salesRep.UserID
) 
,
CTE_BillingUser
AS 
(
	SELECT	Emp_LA.UserID BillingUserID
			, Emp_LA.EntityID 
	  FROM EmployeeAssignment_Entity Emp_LA
	  JOIN (  
				SELECT	EntityID
						,MAX(EmployeeAssignmentID) AccountMgrAssignmentID 
				  FROM EmployeeAssignment_Entity 
				 WHERE EntityTypeID = 7  /*@EntityTypeID --LeaseTransaction*/ 
				   AND IsActive = 1 /*@IsActive*/ 
				   AND RoleFunctionID = 40  --Billing Role
				 GROUP BY EntityID  
			) LeaseAdminDetails
		 ON LeaseAdminDetails.AccountMgrAssignmentID = Emp_LA.EmployeeAssignmentID
	  INNER JOIN EmployeeAssignment_Entity Employee_LeaseAdmin 
		 ON Employee_LeaseAdmin.EmployeeAssignmentID = LeaseAdminDetails.AccountMgrAssignmentID
	  INNER JOIN Security_UserProfile Security_LeaseAdmin 
		 ON Security_LeaseAdmin.UserID = Employee_LeaseAdmin.UserID
)  

SELECT Customer_Profile.AccountNumber
		, jark_profile.JarkID
		, Customer_Profile.CustomerName
		, LeaseTransaction_Profile.LeaseTransactionID
		, LeaseTransaction_Profile.TransactionAlias 
		, LeaseTransaction_Profile.LeaseAlias ScheduleNumber
		, CASE 
				WHEN Lease_Profile.StatusId IN (1,5)  OR Lease_Profile.StatusId IS NULL THEN 'Un-Commenced' 
				WHEN Lease_Profile.StatusId IN (2) THEN 'Commenced'  
				WHEN Lease_Profile.StatusId IN (3) THEN 'FullyPaidoff'  
				WHEN Lease_Profile.StatusId IN (4) THEN 'Suspended'   
		  END [CommencedStatus]
		, WorkFlow_PathHeader.EntityName [StepName]
		--,jark_profile.StepDate StepDateTime
		--,CAST(jark_profile.StepDate AS DATE) StepDateTime_Date
		--,CAST(CONVERT(TIME,jark_profile.StepDate) AS CHAR(8)) StepDateTime_Time
		, (SELECT MAX(PathDate) FROM Jark_FlowHistory GROUP BY JarkID HAVING JarkID = jark_profile.JarkID) StepDateTime
		, CAST((SELECT MAX(PathDate) FROM Jark_FlowHistory GROUP BY JarkID HAVING JarkID = jark_profile.JarkID) AS DATE) StepDate
		, CAST(CONVERT(TIME,(SELECT MAX(PathDate) FROM Jark_FlowHistory GROUP BY JarkID HAVING JarkID = jark_profile.JarkID)) AS CHAR(8)) StepTime
		, WorkFlow_StatusTemplate.WorkFlowStatusName [StepStatus]
		, Security_UserProfile.FirstName + space(1) + Security_UserProfile.LastName [UserOwnerName] 
		, Security_RoleProfile.SecurityRoleName [RoleOwnerName]
		, SalesRepDetails.FirstName + ''+ SalesRepDetails.[LastName] [SalesRep. Name]  
		, LeaseAdminDetails.FirstName + ''+ LeaseAdminDetails.[LastName] [LeaseAdminName] 
		, BillingDetails.FirstName + ''+ BillingDetails.[LastName] [BillingUserName] 
		, LeaseTransaction_AdminstrativeInformation.ExpectedInceptionDate
		, Lease_ContractPurchaseOption_CnfgLocale.PurchaseOption
		, Currency_Symbol_Cnfg.Symbol																	-- #00001
		, Currency_Symbol_Cnfg.ISO							
		,fs.FundingSourceId
         ,fs.FundingSourceNumber
         ,fs.Company
		 ,fs.Alias
											-- #00001
		, ISNULL(CTE_LeaseRental.LeaseRentalAmount,0) LeaseRentalAmount
		, ISNULL(CTE_LeaseRental.CustomerCost,0) CustomerCost
		, ISNULL(CTE_LeaseRental.StickerCost,0) StickerCost
  FROM LeaseTransaction_Profile
 INNER JOIN Customer_Profile 
	ON LeaseTransaction_Profile.CustomerID = Customer_Profile.CustomerID
 INNER JOIN Jark_Profile 
	ON LeaseTransaction_Profile.JarkID = Jark_Profile.JarkID  AND LeaseTransaction_Profile.PortfolioID = 5
 INNER JOIN LeaseTransaction_Version 
	ON LeaseTransaction_Profile.LeaseTransactionID = LeaseTransaction_Version.VersionID  AND LeaseTransaction_Version.IsActive=1
 INNER JOIN WorkFlow_PathStepDetail 
	ON WorkFlow_PathStepDetail.StepID = Jark_Profile.CurrentStepID
 INNER JOIN WorkFlow_PathHeader 
	ON WorkFlow_PathHeader.PathHeaderID = WorkFlow_PathStepDetail.PathHeaderID 
 INNER JOIN WorkFlow_StatusTemplate 
	ON WorkFlow_PathStepDetail.StepStatusID = WorkFlow_StatusTemplate.WorkFlowStatusID
 INNER JOIN Security_UserProfile 
	ON Security_UserProfile.UserID = Jark_Profile.UserOwnerID
  LEFT JOIN Security_RoleProfile 
	ON Jark_Profile.RoleOwnerID = Security_RoleProfile.SecurityRoleID
  LEFT JOIN CTE_LeaseAdminAsigned
	ON LeaseTransaction_Profile.LeaseTransactionID = CTE_LeaseAdminAsigned.EntityID
  LEFT JOIN Security_UserProfile [LeaseAdminDetails] 
	ON LeaseAdminDetails.UserID = CTE_LeaseAdminAsigned.LeaseAdminUserID
  LEFT JOIN CTE_SalesRepAssigned
	ON LeaseTransaction_Profile.LeaseTransactionID = CTE_SalesRepAssigned.EntityID
  LEFT JOIN Security_UserProfile [SalesRepDetails] 
	ON CTE_SalesRepAssigned.SalesUserID = SalesRepDetails.UserID
  LEFT JOIN CTE_BillingUser
	ON LeaseTransaction_Profile.LeaseTransactionID = CTE_BillingUser.EntityID
  LEFT JOIN Security_UserProfile [BillingDetails] 
	ON CTE_BillingUser.BillingUserID = BillingDetails.UserID
  LEFT JOIN LeaseTransaction_AdminstrativeInformation
	ON LeaseTransaction_AdminstrativeInformation.LeaseTransactionID = LeaseTransaction_Profile.LeaseTransactionID
  LEFT JOIN LeaseTransaction_PaymentCalculation
	ON LeaseTransaction_PaymentCalculation.LeaseTransactionID = LeaseTransaction_Profile.LeaseTransactionID
  LEFT JOIN Lease_ContractPurchaseOption_CnfgLocale
	ON LeaseTransaction_PaymentCalculation.PurchaseOptionStatusTypeID = Lease_ContractPurchaseOption_CnfgLocale.PurchaseOptionID

  LEFT JOIN Lease_Profile
	ON Lease_Profile.LeaseID = LeaseTransaction_Profile.LeaseID

  LEFT JOIN 
		(
			SELECT LeaseTransactionID
					,SUM(StickerCost) AS StickerCost
					, SUM(StickerCOst + MarkupAmount) CustomerCost
					, SUM(LeaseTransaction_Inventory.LeaseRentalAmount) LeaseRentalAmount 
			  FROM LeaseTransaction_Inventory
			 WHERE LeaseTransaction_Inventory.IsActive = 1 /*@IsActive*/
			 GROUP BY LeaseTransactionID
		) CTE_LeaseRental 
	ON CTE_LeaseRental.LeaseTransactionID = LeaseTransaction_Profile.LeaseTransactionID

  LEFT JOIN LLC_Profile																		-- #00001
    ON LeaseTransaction_Profile.LLCID = LLC_Profile.LLCID 
  LEFT JOIN Currency_Index																	-- #00001
	ON Currency_Index.CurrencyIndexID = LLC_Profile.CurrencyIndexID
  LEFT JOIN Currency_Symbol_Cnfg															-- #00001
    ON Currency_Symbol_Cnfg.SymbolId = Currency_Index.CurrencySymbolID
	LEFT JOIN FundingSource_Profile fs
       ON Lease_Profile.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label


--LEFT JOIN cte_StickerCost s
--	ON LeaseTransaction_Profile.LeaseTransactionID =s.LeaseTransactionID
 WHERE LeaseTransaction_Profile.AgreementTypeID  =  2 -- LSLT transactions
   AND EntityName IN (@STEPNAME)
ORDER BY Customer_Profile.AccountNumber
	, Customer_Profile.CustomerName
	, LeaseTransaction_Profile.TransactionAlias 
	, LeaseTransaction_Profile.LeaseAlias 
	, CommencedStatus
	, WorkFlow_PathHeader.EntityName

SET NOCOUNT OFF;</CommandText>
      </Query>
      <Fields>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="JarkID">
          <DataField>JarkID</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="CustomerName">
          <DataField>CustomerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LeaseTransactionID">
          <DataField>LeaseTransactionID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TransactionAlias">
          <DataField>TransactionAlias</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ScheduleNumber">
          <DataField>ScheduleNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CommencedStatus">
          <DataField>CommencedStatus</DataField>
