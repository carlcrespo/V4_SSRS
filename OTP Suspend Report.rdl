  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="LW_PROD">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>4e612741-4f81-4a44-bcba-e17ba3c11bf8</rd:DataSourceID>
    </DataSource>
    <DataSource Name="DataSource1">
      <DataSourceReference>LWDW</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>94f26269-1818-43c8-9110-12f07b99973d</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsReportData">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>

SELECT
       DateEntered AS DateEntered
	  ,EnteredBy AS EnteredBy
	  ,Comment AS OTPSupendComment
	  ,AccountNumber AS AccountNumber
      ,CustomerName AS CustomerName
      ,SequenceNumber AS SequenceNumber
	  ,MaturityDate AS MaturityDate
	  ,Company AS Company
	  ,LeaseID AS LeaseID
,Alias AS CoAlias
,FundingSourceID AS FundingSourceID

FROM

	(
		SELECT 
			   CP.AccountNumber
			  ,CP.CustomerName
			  ,LP.SequenceNumber
			  ,LBC.comment
			  ,LBC.LeaseBillingCommentID
			  ,CONVERT (Date,LBC.LastModifiedDate) DateEntered
			  ,CONCAT (UP.FirstName,UP.LastName) EnteredBy
			  ,CONVERT (Date,lp.[ExpectedMaturityDate]) MaturityDate
			  ,LP.LeaseID
			  ,ROW_NUMBER() OVER (PARTITION BY LP.LeaseID ORDER BY LBC.LeaseBillingCommentID DESC) AS RowCounter
			  ,fs.Company
,fs.Alias
,fs.FundingSourceID
	
		  FROM 

			  [dbo].[Lease_Profile] AS LP

			  join [dbo].[Customer_Profile] AS CP 
				on LP.CustomerID = CP.CustomerID

			  join [dbo].[MaturityManagement_Lease] AS MM 
				on lp.leaseid = mm.leaseid 
				
			  join [dbo].[Lease_BillingComment] AS LBC 
				on MM.leaseid = LBC.LeaseID 
				
			  join [dbo].[Security_UserProfile] AS UP 
				on LBC.LastModifiedUserID = UP.UserID
			
			INNER JOIN dbo.LLC_Profile llc
				ON LP.LLCID = llc.LLCID

			LEFT JOIN FundingSource_Profile fs
				ON LP.LabellingLessorID = fs.FundingSourceID
				AND  fs.TypeID IN ( 1, 7)


		  WHERE 
			lp.statusid = 2 --Commenced
			and MM.PractIsSuspendOTPBilling = 1 --Yes
			and LBC.LeaseBillingCommentTypeID = 2 -- OTPSuspendComment

		  GROUP BY

			   cp.AccountNumber
			  ,cp.CustomerName
			  ,lp.SequenceNumber 
			  ,LBC.Comment 
			  ,LBC.LeaseBillingCommentID
			  ,Convert (Date,LBC.LastModifiedDate) 
			  ,CONCAT (UP.FirstName,UP.LastName) 
			  ,Convert (Date,lp.[ExpectedMaturityDate]) 
			  ,lp.LeaseID
			  ,fs.Company
,fs.Alias
,fs.FundingSourceID

     ) AS A

 WHERE 

	RowCounter = 1 

 ORDER BY 

	 DateEntered
	,AccountNumber</CommandText>
      </Query>
      <Fields>
        <Field Name="DateEntered">
          <DataField>DateEntered</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="EnteredBy">
