    <DataSet Name="CustomerVerticalDS">
      <Query>
        <DataSourceName>Insight_DEV</DataSourceName>
        <CommandText>SELECT VerticalID, Vertical FROM
(
SELECT NULL [VerticalID], NULL [Vertical] 
UNION ALL
SELECT VerticalID, Vertical FROM CustomerCredit_Vertical_CnfgLocale WHERE CultureID = 'en-US'
)RS1
ORDER BY Vertical</CommandText>
      </Query>
      <Fields>
        <Field Name="VerticalID">
          <DataField>VerticalID</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
        <Field Name="Vertical">
          <DataField>Vertical</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PortfolioListDS">
      <Query>
        <DataSourceName>Insight_DEV</DataSourceName>
        <CommandText>select PortfolioID  , PortfolioName FROM
(
select NULL PortfolioID  , NULL PortfolioName 
UNION ALL
select PortfolioID  , PortfolioName from portfolio_Profile where isActive = 1 
)RS1
ORDER BY PortfolioID
</CommandText>
      </Query>
      <Fields>
        <Field Name="portfolioName">
          <DataField>PortfolioName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PortfolioID">
          <DataField>PortfolioID</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
