  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@PostDate1">
            <Value>=Parameters!PostDate1.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@PostDate2">
            <Value>=Parameters!PostDate2.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@SequenceNumber">
            <Value>=Parameters!SequenceNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FundingSourceNumber">
            <Value>=Parameters!FundingSourceNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20191231
------------------------------------------
-- test code
--Declare
	-- @PostDate1 DATE ='1/1/2019' 
	--,@PostDate2 DATE = NULL --'11/30/2019' 
	--,@FundingSourceNumber NVARCHAR(50) = NULL 
	--,@SequenceNumber NVARCHAR(50) = NULL  --'JUD010-1'  
-------------------------------------------
;
WITH 
cte_a
AS
(
	SELECT d.[LeaseID]
		  ,d.[CustomerID]
		  ,d.[DiscountLoanID]
		  ,d.[FundingSourceID]
		  ,d.[RentalFrequencyID]
		  ,d.[FundingSourceNumber]
		  ,d.[FundingSourceCompany]
		  ,d.[RentalFrequency]
		  ,d.[CustomerName]
		  ,d.[AccountNumber]
		  ,d.[BookingStatus]
		  ,d.[SequenceNumber]
		  ,d.[Accounting Treatment Type]
		  ,d.[Funding Cash Received Amount]
		  ,d.[Warehouseline Payoff Amount]
		  ,d.[Is Perfect Pay (Y/N)]
		  ,d.[Vendor Payment Amount 1]
		  ,d.[Vendor Payment Amount 2]
		  ,d.[Repayment Frequency]
		  ,d.[Days in Year]
		  ,d.[TransactionType]
		  ,d.[Received Date]
		  ,d.[Post Date]
		  ,d.[Is Financing Gain (Y/N)]
		  ,d.[Funding Source]
		  ,d.[Loan Amount]
		  ,d.[Interest Rate]
		  ,d.[Total Repayment Amount]
		  ,d.[Recourse Amount]
		  ,d.[Balloon Payment Amount]
		  ,d.[Loan Maturity Date]
		  ,d.[GL Template]
		  ,d.[Amortization GL Template]
		  ,d.[Interest Accrual GL Template]
		  ,d.[Due Date of Loan Repayment Number 1]
		  ,d.[Ending Loan Repayment Number]
		  ,d.[IsActive_Lease_Contract]
		  ,d.[IsActive_DiscountLoan_Deal]
		  ,d.[IsActive_Lease_Investment]
		  ,d.[ISActive_DiscountLoan_RepaymentSchedule]
		  ,d.[IsActive_Lease_AccountingTreatmentType]
		  ,d.ISO 
         ,d.Symbol
         ,d.Company
		 ,d.Alias

	From
		(
			SELECT l.LeaseID
				  ,l.CustomerID
				  ,d.DiscountLoanID
				  ,f.FundingSourceID
				  ,c.RentalFrequencyID
				  ,(SELECT FundingSourceNumber FROM FundingSource_Profile Where FundingSourceId=f.FundingSourceID) FundingSourceNumber
				  ,(SELECT Company FROM FundingSource_Profile Where FundingSourceId=f.FundingSourceID) FundingSourceCompany
				  ,(SELECT RentalFrequencyName FROM Lease_RentalFrequency_CnfgLocale Where RentalFrequencyID = c.RentalFrequencyID) RentalFrequency
				  ,(SELECT CustomerName FROM Customer_Profile WHERE CustomerID = l.CustomerID) CustomerName	  
				  ,(SELECT AccountNumber FROM Customer_Profile WHERE CustomerID = l.CustomerID) AccountNumber
				  ,(SELECT [Description] FROM [Deal_BookingStatus_Cnfg] Where BookingStatusID=d.BookingStatusID) BookingStatus
				  ,l.SequenceNumber
				  ,t.AccountingTreatmentTypeName [Accounting Treatment Type]
				  ,d.FundingCashReceivedAmount [Funding Cash Received Amount]
				  ,d.WarehouseLinePayoffAmount [Warehouseline Payoff Amount]
				  ,IIF(l.IsPerfectPay=1,'Y','N') [Is Perfect Pay (Y/N)]
				  ,d.VendorPaymentAmount1 [Vendor Payment Amount 1]
				  ,d.VendorPaymentAmount2 [Vendor Payment Amount 2]
--------------------------------------------------------------------
-- 20191231
--				  ,(SELECT RentalFrequencyName  FROM Lease_RentalFrequency_CnfgLocale WHERE RentalFrequencyID = c.RentalFrequencyID) [Repayment Frequency]
				  ,(SELECT RentalFrequencyName  FROM Lease_RentalFrequency_CnfgLocale WHERE RentalFrequencyID = d.RepaymentFrequencyID) [Repayment Frequency]
---------------------------------------------------------------------
				  ,c.DaysInYear [Days in Year]
				  ,(SELECT LeaseTransactionTypeName FROM Lease_TransactionType_CnfgLocale where LeaseTransactionTypeID = l.TransactionTypeID) TransactionType
				  ,CONVERT(DATE,d.ReceivedDate) [Received Date]
				  ,Convert(DATE,d.PostDate) [Post Date]
				  ,(CASE d.IsFinancingGain WHEN 1 THEN 'Y' WHEN 0 THEN 'N' ELSE '' END) [Is Financing Gain (Y/N)]
				  ,ISNULL((SELECT FundingSourceNumber FROM  FundingSource_Profile WHERE FundingSourceID = f.FundingSourceID),'') [Funding Source]
				  ,f.LoanAmount [Loan Amount] 
				  ,f.InterestRate [Interest Rate]
				  ,r.sumLoanRepaymentAmount + b.BalloonPaymentAmount [Total Repayment Amount]
				  ,f.RecourseAmount [Recourse Amount]
				  ,f.BalloonPaymentAmount [Balloon Payment Amount]
				  ,CONVERT(DATE,f.LoanMaturityDate) [Loan Maturity Date]
				  ,IIF(f.GLTemplateID IS NULL,'',(SELECT Name FROM GeneralLedger_Template WHERE TemplateId = f.GLTemplateID)) [GL Template]
				  ,IIF(f.GLTemplateID IS NULL,'',(SELECT Name FROM GeneralLedger_Template WHERE TemplateId = f.AmortizationGLTemplateID)) [Amortization GL Template]
				  ,IIF(f.GLTemplateID IS NULL,'',(SELECT Name FROM GeneralLedger_Template WHERE TemplateId = f.InterestAccrualGLTemplateID)) [Interest Accrual GL Template]
				  ,Cast(r.minDueDate As Date) [Due Date of Loan Repayment Number 1]
				  ,r.maxLoanRepaymentNumber [Ending Loan Repayment Number]

				  ,IIF(c.IsActive = 1,'Yes','No') IsActive_Lease_Contract
				  ,IIF(d.IsActive = 1,'Yes','No') IsActive_DiscountLoan_Deal
				  ,IIF(i.IsActive = 1 ,'Yes','No') IsActive_Lease_Investment
				  ,'Yes' ISActive_DiscountLoan_RepaymentSchedule
				  ,IIF(t2.IsActive = 1,'Yes','No') IsActive_Lease_AccountingTreatmentType
				  ,ci.ISO 
         ,csc.Symbol
         ,fs.Company
		 ,fs.Alias


			FROM Lease_Profile l
			INNER JOIN Lease_Contract c
				ON l.LeaseID = c.LeaseID AND c.IsActive = 1
			inner JOIN DiscountLoan_Deal d
				ON l.LeaseID = d.EntityID  AND d.IsActive = 1	
			LEFT JOIN DiscountLoan_FundingSourceDetail f
				ON d.DiscountLoanID = f.DiscountLoanID
			INNER JOIN Lease_Investment i
				ON l.LeaseID = i.LeaseID AND i.IsActive = 1
			INNER JOIN Lease_AccountingTreatmentType_CnfgLocale t
				ON i.AccountingTreatmentTypeId = t.AccountingTreatmentTypeID
			INNER JOIN dbo.LLC_Profile llc
				 ON l.LLCID = llc.LLCID
			INNER JOIN Currency_Index ci
				ON llc.CurrencyIndexID = ci.CurrencyIndexID
			INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
				ON ci.ISO = csc.ISO  
			LEFT JOIN FundingSource_Profile fs
				ON l.LabellingLessorID = fs.FundingSourceID
				AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label

			LEFT JOIN 
				(
				SELECT DiscountLoanID
					  ,MAX(LoanRepaymentNumber) maxLoanRepaymentNumber
					  ,MIN(DueDate) minDueDate
					  ,SUM(LoanRepaymentAmount) sumLoanRepaymentAmount
				  FROM DiscountLoan_RepaymentSchedule
				  WHERE IsActive = 1
				  GROUP BY DiscountLoanID 
				) r
				ON d.DiscountLoanID = r.DiscountLoanID
			INNER JOIN Lease_AccountingTreatmentType_Cnfg t2
				ON t.AccountingTreatmentTypeId = t2.AccountingTreatmentTypeID
			Left join DiscountLoan_FundingSourceDetail b
				ON d.DiscountLoanID = b.DiscountLoanID
------------------------------------------------------------------------------
-- 20191231

------------------------------------------------------------------------------
		) d
)
----------------------------------
-- test code
--SELECT * FROM cte_a
----------------------------------
,
cte_b
AS
	(
	SELECT cte_a.*
	FROM cte_a 
	Where cte_a.[Post Date] Between @PostDate1 And @PostDate2 
		AND (@PostDate1 IS NOT NULL OR @PostDate2 IS NOT NULL)
		AND (@PostDate1 != '' OR @PostDate2 != '')
		AND (SequenceNumber = @SequenceNumber OR @SequenceNumber IS NULL OR @SequenceNumber='')
		AND (FundingSourceNumber = @FundingSourceNumber OR @FundingSourceNumber IS NULL OR @FundingSourceNumber='')
	UNION ALL 
	SELECT cte_a.*
	FROM cte_a 
	Where (@PostDate1 IS NULL OR @PostDate1 = '') AND (@PostDate2 IS NULL OR @PostDate2 = '')
		AND (SequenceNumber = @SequenceNumber OR @SequenceNumber IS NULL OR @SequenceNumber='')
		AND (FundingSourceNumber = @FundingSourceNumber OR @FundingSourceNumber IS NULL OR @FundingSourceNumber='')
UNION ALL
	SELECT cte_a.*
	FROM cte_a 
	Where cte_a.[Post Date] &gt;= @PostDate1 
		AND (@PostDate2 IS NULL or @PostDate2 = '')
		AND (SequenceNumber = @SequenceNumber OR @SequenceNumber IS NULL OR @SequenceNumber='')
		AND (FundingSourceNumber = @FundingSourceNumber OR @FundingSourceNumber IS NULL OR @FundingSourceNumber='')
UNION ALL
	SELECT cte_a.*
	FROM cte_a 
	Where cte_a.[Post Date] &lt;= @PostDate2
		AND (@PostDate1 IS NULL or @PostDate1 = '')
		AND (SequenceNumber = @SequenceNumber OR @SequenceNumber IS NULL OR @SequenceNumber='')
		AND (FundingSourceNumber = @FundingSourceNumber OR @FundingSourceNumber IS NULL OR @FundingSourceNumber='')
	)
SELECT d.[LeaseID]
      ,d.[CustomerID]
      ,d.[DiscountLoanID]
      ,d.[FundingSourceID]
      ,d.[RentalFrequencyID]
      ,d.[FundingSourceNumber]
      ,d.[FundingSourceCompany]
      ,d.[RentalFrequency]
      ,d.[CustomerName]
      ,d.[AccountNumber]
      ,d.[BookingStatus]
      ,d.[SequenceNumber]
      ,d.[Accounting Treatment Type]
      ,d.[Funding Cash Received Amount]
      ,d.[Warehouseline Payoff Amount]
      ,d.[Is Perfect Pay (Y/N)]
      ,d.[Vendor Payment Amount 1]
      ,d.[Vendor Payment Amount 2]
      ,d.[Repayment Frequency]
      ,d.[Days in Year]
      ,d.[TransactionType]
      ,d.[Received Date]
      ,d.[Post Date]
	  ,e.LoanRepaymentNumber1
	  ,e.DueDate_of_Deal_Paymt1
      ,d.[Is Financing Gain (Y/N)]
      ,d.[Funding Source]
      ,d.[Loan Amount]
      ,d.[Interest Rate]
      ,d.[Total Repayment Amount]
      ,d.[Recourse Amount]
      ,d.[Balloon Payment Amount]
      ,d.[Loan Maturity Date]
      ,d.[GL Template]
      ,d.[Amortization GL Template]
      ,d.[Interest Accrual GL Template]
      ,d.[Due Date of Loan Repayment Number 1]
      ,d.[Ending Loan Repayment Number]
      ,d.[IsActive_Lease_Contract]
      ,d.[IsActive_DiscountLoan_Deal]
      ,d.[IsActive_Lease_Investment]
      ,d.[ISActive_DiscountLoan_RepaymentSchedule]
      ,d.[IsActive_Lease_AccountingTreatmentType]
	    ,d.ISO 
         ,d.Symbol
         ,d.Company
		 ,d.Alias
FROM cte_b d
INNER JOIN 
	(
	SELECT    	
			r.[DiscountLoanID],
			CAST(MIN(r.LoanRepaymentNumber1) AS DATE) LoanRepaymentNumber1,
			CAST(MIN(r.DueDate) AS DATE) DueDate_of_Deal_Paymt1
	FROM 
		(
		SELECT 
			 A.[DiscountLoanID],c.DueDate
			,A.[DueDate] LoanRepaymentNumber1
		FROM DiscountLoan_RepaymentSchedule A
		INNER JOIN DiscountLoan_DealPaymentDetail B
			ON A.LoanRepaymentID=B.LoanRepaymentID
			AND A.IsActive=1
		INNER JOIN Receivable_LeasePaymentHeader C
			ON B.ReceivableHeaderID=C.ReceivableHeaderID
			AND C.IsActive=1
		) r
	GROUP BY 
		r.DiscountLoanID
	) e
ON d.DiscountLoanID = e.DiscountLoanID</CommandText>
        <Timeout>37</Timeout>
      </Query>
