  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@serialno">
            <Value>=Parameters!serialno.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
	 @serialno SerialNumber
    ,CP.AccountNumber
	,CP.CompanyName
	,LP.SequenceNumber
	,LP.LeaseID
	,fs.Company -- Labelling Lessor
FROM [Inventory_Profile]IP
INNER JOIN [Lease_InventoryInLease]LIL
	ON IP.InventoryID = LIL.InventoryID
INNER JOIN [Lease_Profile]LP
	ON LIL.LeaseID = LP.LeaseID
INNER JOIN [Customer_Profile]CP
	ON IP.CustomerID = CP.CustomerID
LEFT JOIN FundingSource_Profile fs
    ON lp.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)

WHERE LIL.IsInLease = 1
	AND IP.SerialNumber &lt;&gt; '' AND IP.SerialNumber IS NOT NULL 
	AND IP.SerialNumber = @serialno</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="SerialNumber">
          <DataField>SerialNumber</DataField>
          <rd:TypeName>System.Object</rd:TypeName>
        </Field>
        <Field Name="AccountNumber">
          <DataField>AccountNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CompanyName">
          <DataField>CompanyName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SequenceNumber">
          <DataField>SequenceNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LeaseID">
          <DataField>LeaseID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Company">
          <DataField>Company</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
