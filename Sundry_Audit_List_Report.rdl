  <DataSets>
    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LeaseSequenceNumber">
            <Value>=Parameters!LeaseSequenceNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>-- 20210820

	--declare   @LeaseSequenceNumber NVARCHAR(50)  --= '6859-254'
	-- , @CultureID VARCHAR(15)


SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;  
--SET NOCOUNT ON;

SELECT TOP 10
	  Lease_Profile.LeaseID
	, Inventory_LocationTemplate.LocationCode
	, Inventory_LocationTemplate.Address
	, Inventory_LocationTemplate.City
	, Template_State_CnfgLocale.StateShortName AS State
	, Receivable_Sundry.DueDate
	, ROW_NUMBER() OVER(PARTITION BY Inventory_LocationHistory.InventoryID,Receivable_Sundry.DueDate ORDER BY Inventory_LocationHistory.InventoryLocationHistoryID DESC) AS RowNum
INTO #LeaseInventories
FROM
	Lease_Profile
	INNER JOIN Receivable_Sundry
		ON Lease_Profile.LeaseID = Receivable_Sundry.EntityID
		AND Receivable_Sundry.EntityTypeId = 5 --Lease
		AND Receivable_Sundry.InvoiceID IS NULL --Not Invoiced
		AND Receivable_Sundry.IsTaxAssessed = 0 --Not Tax Assessed
		AND Receivable_Sundry.InventoryID IS NULL
	INNER JOIN Lease_InventoryInLease
		ON Lease_Profile.LeaseID = Lease_InventoryInLease.LeaseID
		AND Lease_InventoryInLease.IsInLease = 1 --In Lease
	INNER JOIN Tax_LeaseDetail
		ON Lease_Profile.LeaseID = Tax_LeaseDetail.EntityID
		AND Tax_LeaseDetail.EntityTypeId = 5 --Lease
	INNER JOIN Inventory_Profile
		ON Lease_InventoryInLease.InventoryID = Inventory_Profile.InventoryID
	INNER JOIN Inventory_LocationHistory 
		ON Lease_InventoryInLease.InventoryID = Inventory_LocationHistory.InventoryID
		AND Inventory_LocationHistory.LocationEffectiveFromDate &lt;= Receivable_Sundry.DueDate --Location As of DueDate
	INNER JOIN Inventory_LocationTemplate 
		ON Inventory_LocationHistory.LocationTemplateID = Inventory_LocationTemplate.LocationTemplateID
	INNER JOIN Template_State_CnfgLocale 
		ON Inventory_LocationTemplate.StateID = Template_State_CnfgLocale.StateID
WHERE
	Lease_Profile.SequenceNumber = @LeaseSequenceNumber --LIKE REPLACE(@LeaseSequenceNumber, '*', '%')
	AND ((Tax_LeaseDetail.IsUseRental = 1 AND Lease_InventoryInLease.LeaseRentalAmount &gt; 0) 
		OR (Tax_LeaseDetail.IsUseRental = 0 AND Inventory_Profile.NetValue &gt; 0))

;WITH CTE_InventoryDetails
AS
(
	SELECT
		  TEMP.LeaseID
		, RS.DueDate
		, SUBSTRING
			(
				(
					SELECT 
						', ' + LeaseInventories.LocationCode
					FROM
						(
						SELECT DISTINCT
							#LeaseInventories.LocationCode
						FROM
							#LeaseInventories
						WHERE
							#LeaseInventories.LeaseID = TEMP.LeaseID
							AND #LeaseInventories.DueDate = RS.DueDate
							AND #LeaseInventories.RowNum = 1 --Top records from Location History
						) AS LeaseInventories
					FOR XML PATH('')
				)
			,3,20000) AS LocationCode
		, SUBSTRING
			(
				(
					SELECT 
						', ' + LeaseInventories.Address
					FROM
						(
						SELECT DISTINCT
							#LeaseInventories.Address
						FROM
							#LeaseInventories
						WHERE
							#LeaseInventories.LeaseID = TEMP.LeaseID
							AND #LeaseInventories.DueDate = RS.DueDate
							AND #LeaseInventories.RowNum = 1 --Top records from Location History
						) AS LeaseInventories
					FOR XML PATH(''),TYPE
				).value('.','NVARCHAR(MAX)')
			,3,20000) AS Address
		, SUBSTRING
			(
				(
					SELECT 
						', ' + LeaseInventories.City
					FROM
						(
						SELECT DISTINCT
							#LeaseInventories.City
						FROM
							#LeaseInventories
						WHERE
							#LeaseInventories.LeaseID = TEMP.LeaseID
							AND #LeaseInventories.DueDate = RS.DueDate
							AND #LeaseInventories.RowNum = 1 --Top records from Location History
						) AS LeaseInventories
					FOR XML PATH('')
				)
			,3,20000) AS City
		, SUBSTRING
			(
				(
					SELECT 
						', ' + LeaseInventories.State
					FROM
						(
						SELECT DISTINCT
							#LeaseInventories.State
						FROM
							#LeaseInventories
						WHERE
							#LeaseInventories.LeaseID = TEMP.LeaseID
							AND #LeaseInventories.DueDate = RS.DueDate
							AND #LeaseInventories.RowNum = 1 --Top records from Location History
						) AS LeaseInventories
					FOR XML PATH('')
				)
			,3,20000) AS State
	FROM
		Lease_Profile TEMP
		INNER JOIN Receivable_Sundry AS RS
			ON TEMP.LeaseID = RS.EntityID
			AND RS.EntityTypeId = 5 --Lease
			AND RS.InvoiceID IS NULL --Not Invoiced
			AND RS.IsTaxAssessed = 0 --Not Tax Assessed
			AND RS.IsActive = 1 --Active
			AND RS.InventoryID IS NULL
	WHERE
		TEMP.SequenceNumber = @LeaseSequenceNumber --LIKE REPLACE(@LeaseSequenceNumber, '*', '%')
	GROUP BY 
		  TEMP.LeaseID
		, RS.DueDate
)
,CTE_SundryDetails
AS
(
	SELECT
		  Lease_Profile.SequenceNumber AS EntityUniqueID
		, Receivable_Type_CnfgLocale.ReceivableTypeName
		, Sundry_Code.SundryCodeTemplateName
		, Template_EntityType_CnfgLocale.EntityTypeName AS EntityType
		, CASE WHEN Receivable_Sundry.InventoryID IS NULL --Not Asset Based
			THEN 'N'
			ELSE 'Y'
		  END AS AssetBased
		, Receivable_Sundry.PostDate
		, Receivable_Sundry.DueDate
		, Receivable_Sundry.Amount
		, Receivable_Sundry.PONumber
		, InvoiceGroup_Profile.InvoiceGroupName AS InvoiceGroup
		, Invoice_ReceivableGroupingOption_CnfgLocale.InvoiceReceivableGroupingOptionName AS InvoiceOption
		, CASE WHEN Receivable_Sundry.InventoryID IS NOT NULL --Asset Based
			THEN Inventory_LocationTemplate.LocationCode
			ELSE CTE_InventoryDetails.LocationCode
		  END AS LocationCode
		, CASE WHEN Receivable_Sundry.InventoryID IS NOT NULL --Asset Based
			THEN Inventory_LocationTemplate.Address
			ELSE CTE_InventoryDetails.Address
		  END AS Address
		, CASE WHEN Receivable_Sundry.InventoryID IS NOT NULL --Asset Based
			THEN Inventory_LocationTemplate.City
			ELSE CTE_InventoryDetails.City
		  END AS City
		, CASE WHEN Receivable_Sundry.InventoryID IS NOT NULL --Asset Based
			THEN Template_State_CnfgLocale.StateShortName
			ELSE CTE_InventoryDetails.State
		  END AS State
		, CASE WHEN Receivable_Sundry.InventoryID IS NOT NULL --Asset Based
			THEN ROW_NUMBER() OVER(PARTITION BY Inventory_LocationHistory.InventoryID,Receivable_Sundry.ReceivableID ORDER BY Inventory_LocationHistory.InventoryLocationHistoryID DESC)
			ELSE 1
		  END AS RowNum
	FROM
		Lease_Profile
		INNER JOIN Receivable_Sundry
			ON Lease_Profile.LeaseID = Receivable_Sundry.EntityID
			AND Receivable_Sundry.EntityTypeId = 5 --Lease
			AND Receivable_Sundry.InvoiceID IS NULL --Not Invoiced
			AND Receivable_Sundry.IsTaxAssessed = 0 --Not Tax Assessed
			AND Receivable_Sundry.IsActive = 1 --Active
		INNER JOIN Sundry_Code
			ON Receivable_Sundry.SundryCodeTemplateID = Sundry_Code.SundryCodeTemplateID
		INNER JOIN Receivable_Type_CnfgLocale
			ON Sundry_Code.ReceivableTypeID = Receivable_Type_CnfgLocale.ReceivableTypeID
			--AND Receivable_Type_CnfgLocale.CultureID = @CultureID
		INNER JOIN Template_EntityType_CnfgLocale
			ON Receivable_Sundry.EntityTypeId = Template_EntityType_CnfgLocale.EntityTypeID
		INNER JOIN InvoiceGroup_Profile
			ON Receivable_Sundry.InvoiceGroupID = InvoiceGroup_Profile.InvoiceGroupID
		INNER JOIN Invoice_ReceivableGroupingOption_CnfgLocale
			ON Receivable_Sundry.InvoiceReceivableGroupingOptionID = Invoice_ReceivableGroupingOption_CnfgLocale.InvoiceReceivableGroupingOptionID
		LEFT JOIN CTE_InventoryDetails
			ON Lease_Profile.LeaseID = CTE_InventoryDetails.LeaseID
			AND Receivable_Sundry.DueDate = CTE_InventoryDetails.DueDate
		LEFT JOIN Inventory_LocationHistory 
			ON Receivable_Sundry.InventoryID = Inventory_LocationHistory.InventoryID
			AND Inventory_LocationHistory.LocationEffectiveFromDate &lt;= Receivable_Sundry.DueDate --Location As of DueDate
		LEFT JOIN Inventory_LocationTemplate 
			ON Inventory_LocationHistory.LocationTemplateID = Inventory_LocationTemplate.LocationTemplateID
		LEFT JOIN Template_State_CnfgLocale 
			ON Inventory_LocationTemplate.StateID = Template_State_CnfgLocale.StateID		
	WHERE
		Lease_Profile.SequenceNumber = @LeaseSequenceNumber --LIKE REPLACE(@LeaseSequenceNumber, '*', '%')
)
SELECT
	  CTE_SundryDetails.EntityUniqueID 
	, CTE_SundryDetails.ReceivableTypeName 
	, CTE_SundryDetails.SundryCodeTemplateName [SundryCodeName]
	, CTE_SundryDetails.EntityType 
	, CTE_SundryDetails.AssetBased 
	, CTE_SundryDetails.PostDate
	, CTE_SundryDetails.DueDate
	, CTE_SundryDetails.Amount
	, CTE_SundryDetails.LocationCode
	, CTE_SundryDetails.Address
	, CTE_SundryDetails.City
	, CTE_SundryDetails.State
	, CTE_SundryDetails.PONumber
	, CTE_SundryDetails.InvoiceGroup
	, CTE_SundryDetails.InvoiceOption 
	, ci.ISO -- 20210820
	, csc.Symbol -- 20210820
	, fs.FundingSourceId
    , fs.FundingSourceNumber
	, fs.Company
,fs.Alias
FROM
	CTE_SundryDetails
INNER JOIN Lease_Profile lp
	ON CTE_SundryDetails.EntityUniqueID = lp.SequenceNumber
INNER JOIN dbo.LLC_Profile llc
       ON lp.LLCID = llc.LLCID
INNER JOIN Currency_Index ci
       ON llc.CurrencyIndexID = ci.CurrencyIndexID
INNER JOIN dbo.Currency_Symbol_CnfgLocale csc
       ON ci.ISO = csc.ISO  
LEFT JOIN FundingSource_Profile fs
       ON lp.LabellingLessorID = fs.FundingSourceID
       AND  fs.TypeID IN ( 1, 7)   --Lessor, Private Label
WHERE
	CTE_SundryDetails.RowNum = 1 --Top record from Location History
ORDER BY
	CTE_SundryDetails.EntityUniqueID

--END</CommandText>
      </Query>
